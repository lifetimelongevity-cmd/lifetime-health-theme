    <span class="pdp-trust-pill__label">&gt;99&thinsp;% Reinheit</span>
  </div>

  <div class="pdp-trust-pill" role="listitem">
    <svg class="pdp-trust-pill__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M9 3h6l1 7H8L9 3z"/><path d="M8 10l-3 8a1 1 0 001 1h12a1 1 0 001-1l-3-8"/>
    </svg>
    <span class="pdp-trust-pill__label">Laborgeprüft</span>
  </div>

  <div class="pdp-trust-pill" role="listitem">
    <svg class="pdp-trust-pill__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
    </svg>
    <span class="pdp-trust-pill__label">Hochdosiert</span>
