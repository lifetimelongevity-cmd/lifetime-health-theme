{% comment %}
  NMN PDP: Trust-Pills (pdp-reference.html-Stil).
  Flex-wrap Zeile, jede Pill: border-radius-full, 1px border, SVG-Icon + Label.
  Kein Scroll — rein dekorativ/Trust.
{% endcomment %}
<div class="pdp-trust-pills" role="list" aria-label="Qualität und Prüfung">

  <div class="pdp-trust-pill" role="listitem">
