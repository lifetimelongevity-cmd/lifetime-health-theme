{%- comment -%}
  LIFETIME — Quiz v2 Slider-Frage (Snippet)

  Rail-Pattern: 5 Dots sind absolut auf einer gemeinsamen Rail positioniert
  (`top: 50%; transform: translate(-50%, -50%)`), dadurch mathematisch
  zentriert auf der Track-Mitte. Heading via kanonisches `section-heading-crs`.

  Pflicht-Parameter:
    question_id  → state-Key (sleep|energy|stress|weight)
    headline     → Frage-Headline (h2 via heading-stack)
    label_1..5   → Slider-Stop-Labels (links → rechts)
    hint         → "Warum fragen wir das?"-Text
  Optional:
    step         → State-Step-ID, default = question_id
    kicker       → Thema-Anker (z.B. "Schlaf")
{%- endcomment -%}

{%- assign _step = step | default: question_id -%}

<div
  class="lt-quiz__step lt-quiz__step--slider"
  data-quiz-step="{{ _step }}"
  data-question-id="{{ question_id }}"
  hidden
>
  {%- render 'section-heading-crs',
      heading: headline,
      subheading: sub,
      kicker: kicker,
      align: 'left',
      headline_lg: true,
      extra_class: 'lt-quiz__step-heading'
  -%}

  <div class="lt-quiz-slider" data-quiz-slider>
    <div
      class="lt-quiz-slider__rail"
      role="radiogroup"
      aria-label="{{ headline | escape }}"
    >
      <div class="lt-quiz-slider__rail-fill" aria-hidden="true"></div>
      {%- for i in (1..5) -%}
        <button
          type="button"
          class="lt-quiz-slider__stop"
          role="radio"
          aria-checked="false"
          data-value="{{ i }}"
        >
          <span class="lt-quiz-slider__dot" aria-hidden="true"></span>
        </button>
      {%- endfor -%}
    </div>

    {%- comment -%} Desktop: alle 5 Labels {%- endcomment -%}
    <div class="lt-quiz-slider__labels lt-quiz-slider__labels--full" aria-hidden="true">
      <span>{{ label_1 | escape }}</span>
      <span>{{ label_2 | escape }}</span>
      <span>{{ label_3 | escape }}</span>
      <span>{{ label_4 | escape }}</span>
      <span>{{ label_5 | escape }}</span>
    </div>

    {%- comment -%} Mobile: nur 3 Anker {%- endcomment -%}
    <div class="lt-quiz-slider__labels lt-quiz-slider__labels--anchors" aria-hidden="true">
      <span>{{ label_1 | escape }}</span>
      <span>{{ label_3 | escape }}</span>
      <span>{{ label_5 | escape }}</span>
    </div>
  </div>

  {%- if hint != blank -%}
    <details class="lt-quiz__hint">
      <summary class="lt-quiz__hint-toggle">Warum fragen wir das?</summary>
      <p class="lt-quiz__hint-text">{{ hint | escape }}</p>
    </details>
  {%- endif -%}
</div>
