{% comment %}
  NMN PDP: Benefit Surface — "Wissenschaftliche Vorteile" 2×2 Grid.
  Visuell identisch mit pdp-reference.html .benefit-surface:
  #E6F4F1 Hintergrund, --radius-lg, Teal Checkmark-Kreise, Name + Sub-Zeile.
{% endcomment %}
<div class="pdp-benefit-surface">
  <p class="pdp-benefit-surface__title">Wissenschaftliche Vorteile</p>
  <div class="pdp-benefit-grid">

    <div class="pdp-benefit-item">
      <div class="pdp-benefit-check" aria-hidden="true">
        <svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 6l2.5 2.5L10 3.5"/>
        </svg>
      </div>
      <div class="pdp-benefit-text">
        <span class="pdp-benefit-name">Energie</span>
        <span class="pdp-benefit-sub">Zell-Stoffwechsel</span>
      </div>
    </div>

    <div class="pdp-benefit-item">
      <div class="pdp-benefit-check" aria-hidden="true">
        <svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 6l2.5 2.5L10 3.5"/>
        </svg>
      </div>
      <div class="pdp-benefit-text">
        <span class="pdp-benefit-name">Alterung</span>
        <span class="pdp-benefit-sub">Sirtuin-Aktivierung</span>
      </div>
    </div>

    <div class="pdp-benefit-item">
      <div class="pdp-benefit-check" aria-hidden="true">
        <svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 6l2.5 2.5L10 3.5"/>
        </svg>
      </div>
      <div class="pdp-benefit-text">
        <span class="pdp-benefit-name">Leistung</span>
        <span class="pdp-benefit-sub">Kognitive Ausdauer</span>
      </div>
    </div>

    <div class="pdp-benefit-item">
      <div class="pdp-benefit-check" aria-hidden="true">
        <svg viewBox="0 0 12 12" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M2 6l2.5 2.5L10 3.5"/>
        </svg>
      </div>
      <div class="pdp-benefit-text">
        <span class="pdp-benefit-name">Regeneration</span>
        <span class="pdp-benefit-sub">DNA-Reparatur</span>
      </div>
    </div>

  </div>
</div>
