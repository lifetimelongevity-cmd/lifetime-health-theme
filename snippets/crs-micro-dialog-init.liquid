{%- comment -%}
  Einmalige Event-Delegation für native <dialog> (CRS Feature Grid, Link Cards, Guarantee).
{%- endcomment -%}
<script>
  (function () {
    if (window.__crsMicroDialogBound) return;
    window.__crsMicroDialogBound = true;
    document.addEventListener('click', function (e) {
      var openBtn = e.target.closest('[data-crs-dialog-open]');
      if (openBtn) {
        var id = openBtn.getAttribute('aria-controls');
        var dlg = id && document.getElementById(id);
        if (dlg && typeof dlg.showModal === 'function') {
          e.preventDefault();
          dlg.showModal();
        }
        return;
      }
      var closeBtn = e.target.closest('[data-crs-dialog-close]');
      if (closeBtn) {
        var d = closeBtn.closest('dialog');
        if (d) d.close();
        return;
      }
      if (e.target.classList && e.target.classList.contains('crs-micro-dialog')) {
        e.target.close();
      }
    });
  })();
</script>
