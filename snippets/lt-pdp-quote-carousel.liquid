  {%- liquid
    assign qc_show_seal = false
    if block.settings.show_trust_seal and block.settings.trust_seal_text != blank
      assign qc_show_seal = true
    endif
  -%}
  {%- if qc_show_seal -%}
    <div class="lt-pdp-trust-seal" role="note">
      <div class="lt-pdp-trust-seal__row">
        <span class="lt-pdp-trust-seal__icon" aria-hidden="true">
          {%- if block.settings.trust_seal_image != blank -%}
            {{ block.settings.trust_seal_image | image_url: width: 56 | image_tag: class: 'lt-pdp-trust-seal__icon-img', loading: 'lazy', alt: '' }}
          {%- else -%}
            <svg class="lt-pdp-trust-seal__icon-svg" width="18" height="18" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M2 9.5 12 4l10 5.5L12 15 2 9.5Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"/>
              <path d="M6 11.2V16c0 .8 2.2 2 6 2s6-1.2 6-2v-4.8" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          {%- endif -%}
