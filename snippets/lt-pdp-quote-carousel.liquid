    {%- if block.settings.show_dots and qc_slides > 1 -%}
      {%- assign qc_j = -1 -%}
      <div class="lt-quote-carousel__dots" role="tablist" aria-label="{{ block.settings.dots_aria_label | escape }}">
        {%- if block.settings.slide_1_quote != blank -%}
          {%- assign qc_j = qc_j | plus: 1 -%}
          <button
            type="button"
            class="lt-quote-carousel__dot{% if qc_j == 0 %} is-active{% endif %}"
            data-lt-quote-dot
            data-index="{{ qc_j }}"
            role="tab"
            aria-selected="{% if qc_j == 0 %}true{% else %}false{% endif %}"
            aria-label="{{ block.settings.dot_label | escape }} {{ qc_j | plus: 1 }}"
          ></button>
        {%- endif -%}
        {%- if block.settings.slide_2_quote != blank -%}
          {%- assign qc_j = qc_j | plus: 1 -%}
          <button
            type="button"
            class="lt-quote-carousel__dot{% if qc_j == 0 %} is-active{% endif %}"
            data-lt-quote-dot
            data-index="{{ qc_j }}"
            role="tab"
            aria-selected="{% if qc_j == 0 %}true{% else %}false{% endif %}"
            aria-label="{{ block.settings.dot_label | escape }} {{ qc_j | plus: 1 }}"
