{% comment %}
  NMN PDP: Produkt-Subtitle unterhalb des Titels.
  Quelle: product.metafields.custom.tagline — Fallback auf deutschen Standardtext.
{% endcomment %}
{%- assign pdp_subtitle = product.metafields.custom.tagline | default: 'Dein direkter NAD⁺-Booster für zelluläre Vitalität und langlebige Performance.' -%}
{%- if pdp_subtitle != blank -%}
  <p class="pdp-product-subtitle">{{ pdp_subtitle | escape }}</p>
{%- endif -%}
