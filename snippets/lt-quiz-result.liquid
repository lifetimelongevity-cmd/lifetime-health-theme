  {%- comment -%} Gated-Reveal Unlock (2026-07-22): schaltet die Tiefe frei, sobald die E-Mail
     abgeschickt ist ([data-result-success] wird sichtbar) + Persistenz für Wiederkehrer.
     Rein additiv, kein Eingriff in lt-quiz-v2.js. {%- endcomment -%}
  <script>
    (function () {
      var root = document.querySelector('.lt-quiz-result[data-quiz-result]');
      if (!root) return;
      var gate = root.querySelector('[data-result-gate]');
      var success = root.querySelector('[data-result-success]');
      var form = root.querySelector('[data-result-form]');
      var email = root.querySelector('[data-result-email]');
      var gateCta = root.querySelector('[data-result-gate-cta]');
      var KEY = 'lt_quiz_result_unlocked';
      function reveal() { if (gate) { gate.classList.add('is-unlocked'); } }
      try {
        if (localStorage.getItem(KEY) === '1') {
          reveal();
          if (form) { form.hidden = true; }
          if (success) { success.hidden = false; }
        }
      } catch (e) {}
      if (success && 'MutationObserver' in window) {
        var mo = new MutationObserver(function () {
          if (!success.hasAttribute('hidden')) {
            reveal();
            try { localStorage.setItem(KEY, '1'); } catch (e) {}
            mo.disconnect();
          }
        });
        mo.observe(success, { attributes: true, attributeFilter: ['hidden'] });
      }
      if (gateCta && email) {
        gateCta.addEventListener('click', function () {
          try { email.scrollIntoView({ behavior: 'smooth', block: 'center' }); } catch (e) {}
          setTimeout(function () { try { email.focus(); } catch (e) {} }, 350);
        });
      }
    })();
  </script>

