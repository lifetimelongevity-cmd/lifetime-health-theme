/* Unlock-Card (dunkel — spiegelt die Ask-Card, damit die vorhandenen Form-Styles greifen) */
.lt-quiz-result__unlock {
  background: var(--color-surface-dark);
  color: var(--color-text-on-dark);
  border: 1px solid var(--color-teal);
  border-radius: var(--radius-xl);
  padding: var(--space-6) var(--space-7);
  margin-top: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}
.lt-quiz-result__unlock-kicker {
  margin: 0;
  font-family: var(--font-body);
  font-size: 12px;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--color-teal);
  font-weight: 600;
}
.lt-quiz-result__unlock-title {
  margin: 0;
  font-family: var(--font-heading);
  font-size: 22px;
  line-height: 1.3;
  font-weight: 400;
  letter-spacing: -0.01em;
}
.lt-quiz-result__unlock-sub {
  margin: 0;
  font-size: 14px;
  line-height: 1.55;
  color: rgba(255, 255, 255, 0.72);
  max-width: 560px;
}
.lt-quiz-result__form { display: flex; flex-direction: column; gap: var(--space-3); }
.lt-quiz-result__form[hidden] { display: none; }

/* Gate um die Tiefe (Themen) */
.lt-quiz-result__gate { position: relative; margin-top: var(--space-5); }
.lt-quiz-result__gate-inner {
  transition: filter 450ms ease, opacity 450ms ease, max-height 600ms ease;
}
.lt-quiz-result__gate:not(.is-unlocked) .lt-quiz-result__gate-inner {
  filter: blur(7px);
  opacity: 0.5;
  max-height: 300px;
  overflow: hidden;
  pointer-events: none;
  user-select: none;
  -webkit-mask-image: linear-gradient(#000 26%, transparent 92%);
          mask-image: linear-gradient(#000 26%, transparent 92%);
}
.lt-quiz-result__gate-lock {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: var(--space-5);
}
.lt-quiz-result__gate.is-unlocked .lt-quiz-result__gate-lock { display: none; }
.lt-quiz-result__gate-lock-card {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-2);
  max-width: 360px;
  padding: var(--space-5) var(--space-6);
  background: var(--color-surface-primary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-lg);
  box-shadow: 0 12px 34px rgba(0, 0, 0, 0.12);
}
.lt-quiz-result__gate-lock-icon { font-size: 28px; line-height: 1; color: var(--color-teal); }
.lt-quiz-result__gate-lock-title {
  margin: 0; font-family: var(--font-heading); font-weight: 400; font-size: 18px;
  color: var(--color-text-primary);
}
.lt-quiz-result__gate-lock-sub {
  margin: 0; font-size: 13px; line-height: 1.5; color: var(--color-text-secondary);
}
.lt-quiz-result__gate-lock-cta {
  margin-top: var(--space-2);
  display: inline-flex; align-items: center; justify-content: center;
  min-height: 44px; padding: 10px var(--space-6);
  border: 0; border-radius: var(--radius-full);
  background: var(--color-teal); color: #fff;
  font-family: var(--font-body); font-size: 14px; font-weight: 600; letter-spacing: 0.01em;
  cursor: pointer; transition: filter 160ms ease;
}
.lt-quiz-result__gate-lock-cta:hover { filter: brightness(1.06); }

@media (prefers-reduced-motion: reduce) {
  .lt-quiz-result__gate-inner { transition: none; }
}
@media (max-width: 880px) {
  .lt-quiz-result__unlock { padding: var(--space-6) var(--space-5); }
  .lt-quiz-result__unlock-title { font-size: 19px; }
}
