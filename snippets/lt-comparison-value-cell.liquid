{%- doc -%}
  Renders one comparison table data cell (icon + value).
  Outputs a <div role="cell"> for the div-grid table.
  @param {object} block  - Section block (type column)
  @param {number} row    - Row index 1–6
  @param {string} row_label - Row heading text
  @param {boolean} is_active - true if this is the active/recommended column
{%- enddoc -%}
{%- liquid
  case row
    when 1
      assign cell_value  = block.settings.first_row
      assign icon_type   = block.settings.first_row_icon_type
      assign icon_var    = block.settings.first_row_icon
      assign custom_img  = block.settings.first_row_custom_image
    when 2
      assign cell_value  = block.settings.second_row
      assign icon_type   = block.settings.second_row_icon_type
      assign icon_var    = block.settings.second_row_icon
      assign custom_img  = block.settings.second_row_custom_image
    when 3
      assign cell_value  = block.settings.third_row
      assign icon_type   = block.settings.third_row_icon_type
      assign icon_var    = block.settings.third_row_icon
      assign custom_img  = block.settings.third_row_custom_image
    when 4
      assign cell_value  = block.settings.fourth_row
      assign icon_type   = block.settings.fourth_row_icon_type
      assign icon_var    = block.settings.fourth_row_icon
      assign custom_img  = block.settings.fourth_row_custom_image
    when 5
      assign cell_value  = block.settings.fifth_row
      assign icon_type   = block.settings.fifth_row_icon_type
      assign icon_var    = block.settings.fifth_row_icon
      assign custom_img  = block.settings.fifth_row_custom_image
    when 6
      assign cell_value  = block.settings.sixth_row
      assign icon_type   = block.settings.sixth_row_icon_type
      assign icon_var    = block.settings.sixth_row_icon
      assign custom_img  = block.settings.sixth_row_custom_image
    else
      assign cell_value  = ''
      assign icon_type   = 'none'
      assign icon_var    = 'check'
      assign custom_img  = nil
  endcase
-%}
<div class="lct-cell lct-cell--data lct-cell--{{ icon_var }}{% if is_active %} is-active{% endif %}"
     role="cell"
     data-label="{{ row_label | escape }}">
  {%- if icon_type == 'default' -%}
    <span class="lct-cell-icon" aria-hidden="true">
      {%- if icon_var == 'check' -%}
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="11" cy="11" r="9.5" fill="currentColor" fill-opacity="0.12"/>
          <circle cx="11" cy="11" r="9.5" stroke="currentColor" stroke-width="1.5"/>
          <path d="M6.5 11l3 3 6-6" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
        </svg>
      {%- elsif icon_var == 'cross' -%}
        <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="11" cy="11" r="9.5" stroke="currentColor" stroke-width="1.25" stroke-opacity="0.4"/>
          <path d="M7.5 7.5l7 7M14.5 7.5l-7 7" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-opacity="0.55"/>
        </svg>
      {%- endif -%}
    </span>
  {%- elsif icon_type == 'custom' and custom_img != blank -%}
    <span class="lct-cell-icon" aria-hidden="true">
      {{- custom_img | image_url: width: 80 | image_tag: loading: 'lazy', class: 'lct-icon-img', alt: '' -}}
    </span>
  {%- endif -%}
  {%- if cell_value != blank -%}
    <span class="lct-cell-text">{{ cell_value | escape }}</span>
  {%- endif -%}
</div>
