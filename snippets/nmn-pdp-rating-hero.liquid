{% comment %}
  NMN PDP: Rating-Zeile (pdp-reference.html-Stil).
  Sterne via CSS-Background-Repeat + Score + Bewertungsanzahl — eine saubere Zeile,
  kein Box-Hintergrund. Klick scrollt zur Bewertungssektion.
{% endcomment %}
{%- assign lt_rating = product.metafields.loox.avg_rating | default: 0 | plus: 0 -%}
{%- assign lt_count = product.metafields.loox.num_reviews | default: 0 | plus: 0 -%}

{%- if lt_rating > 0 or lt_count > 0 -%}
  {%- assign rating_text = lt_rating | round: 1 | replace: '.', ',' -%}
  {%- assign decimal = lt_rating | modulo: 1 -%}
  {%- assign star_floor = lt_rating | floor -%}
  {%- if decimal >= 0.3 and decimal <= 0.7 -%}
    {%- assign star_fill = star_floor | plus: 0.5 -%}
  {%- elsif decimal > 0.7 -%}
    {%- assign star_fill = star_floor | plus: 1 -%}
  {%- else -%}
    {%- assign star_fill = star_floor -%}
  {%- endif -%}
  {%- assign pct = star_fill | times: 20 -%}
  {%- assign star_color = '%23F4B740' -%}
  {%- assign bg_color = '%23E5E5E5' -%}

  {%- if lt_count == 0 and product.handle contains 'nmn' -%}
    {%- assign rating_text = '4,7' -%}
    {%- assign lt_count = 102 -%}
    {%- assign pct = 94 -%}
  {%- endif -%}

  <div id="nmn-rating-{{ section.id }}" class="pdp-rating-wrap">
    <button
      type="button"
      class="pdp-rating"
      data-custom-rating-scroll
      aria-label="{{ rating_text }} von 5 Sternen, {{ lt_count }} Bewertungen"
    >
      <span class="pdp-rating__stars custom-stars" aria-hidden="true">
        <span class="custom-stars-active" style="width: {{ pct }}%"></span>
      </span>
      <span class="pdp-rating__score">{{ rating_text }}</span>
      <span class="pdp-rating__count">({{ lt_count }} Bewertungen)</span>
    </button>
  </div>

  <style>
    #nmn-rating-{{ section.id }} .pdp-rating__stars {
      background-image: url("data:image/svg+xml;utf8,<svg width='16' height='15' viewBox='0 0 14 13' xmlns='http://www.w3.org/2000/svg'><path d='m7 0 1.572 4.837h5.085l-4.114 2.99 1.572 4.836L7 9.673l-4.114 2.99 1.571-4.837-4.114-2.99h5.085L7 0Z' fill='{{ bg_color }}'/></svg>");
    }
    #nmn-rating-{{ section.id }} .custom-stars-active::before {
      background-image: url("data:image/svg+xml;utf8,<svg width='16' height='15' viewBox='0 0 14 13' xmlns='http://www.w3.org/2000/svg'><path d='m7 0 1.572 4.837h5.085l-4.114 2.99 1.572 4.836L7 9.673l-4.114 2.99 1.571-4.837-4.114-2.99h5.085L7 0Z' fill='{{ star_color }}'/></svg>");
    }
  </style>

  <script>
    (function () {
      var rootId = 'nmn-rating-{{ section.id }}';
      var scrollOffsetPx = 80;

      function scrollToEl(el) {
        var y = el.getBoundingClientRect().top + window.pageYOffset - scrollOffsetPx;
        window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
      }

      function findReviewsTarget() {
        var byId = document.getElementById('shopify-section-loox-reviews');
        if (byId) return byId;
        var el = document.getElementById('looxReviews');
        var sec;
        if (el) {
          sec = el.closest('[id^="shopify-section-"]');
          return sec || el;
        }
        el = document.querySelector('.loox-dynamic-section, [class*="loox-dynamic-section"], .loox-v2-widget-container');
        if (el) {
          sec = el.closest('[id^="shopify-section-"]');
          return sec || el;
        }
        var sections = document.querySelectorAll('[id^="shopify-section-"]');
        for (var i = 0; i < sections.length; i++) {
          if (/loox/i.test(sections[i].id) && sections[i].querySelector('[class*="loox"], [id*="loox"]')) {
            return sections[i];
          }
        }
        return null;
      }

      function bind() {
        var root = document.getElementById(rootId);
        if (!root) return;
        var btn = root.querySelector('[data-custom-rating-scroll]');
        if (!btn || btn.dataset.bound) return;
        btn.dataset.bound = '1';
        btn.addEventListener('click', function () {
          if (window.Shopify && Shopify.designMode) return;
          var target = findReviewsTarget();
          if (target) scrollToEl(target);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bind, { once: true });
      } else {
        bind();
      }
    })();
  </script>
{%- endif -%}
