{% comment %}
  NMN PDP: Loox rating bar (IAM8-style hierarchy).
  Desktop: eine Zeile — Sterne + Bewertungstext | Social-Proof-Stat(en).
  Mobile: zwei Zeilen — oben primär (Sterne + Score), unten sekundär (Stats, | dazwischen).
  Metafields:
  - custom.reviews_customer_claim (optional) — erste Stat-Zeile, z. B. „760K+ Kundenkäufe“
  - custom.reviews_stat_2 (optional) — zweite Stat, z. B. „23 Mio.+ Portionen“
{% endcomment %}
{% assign rating = product.metafields.loox.avg_rating | default: 0 | plus: 0 %}
{% assign rating_count = product.metafields.loox.num_reviews | default: 0 | plus: 0 %}

{% if rating_count > 0 and rating > 0 %}
  {% assign rating_text = rating | round: 1 | replace: '.', ',' %}
  {% assign decimal = rating | modulo: 1 %}
  {% assign rounded = rating | floor %}
  {% if decimal >= 0.3 and decimal <= 0.7 %}
    {% assign rounded = rounded | plus: 0.5 %}
  {% elsif decimal > 0.7 %}
    {% assign rounded = rounded | plus: 1 %}
  {% endif %}
  {% assign pct = rounded | times: 20 %}
  {% assign star_color = '%23F4B740' %}
  {% assign bg_color = '%23E5E5E5' %}
  {% assign nmn_stat_1 = product.metafields.custom.reviews_customer_claim.value | default: '>1.000 Kund:innen vertrauen LIFETIME' %}
  {% assign nmn_stat_2 = product.metafields.custom.reviews_stat_2.value | default: '' %}
  {% assign nmn_show_secondary = false %}
  {% if nmn_stat_1 != blank or nmn_stat_2 != blank %}
    {% assign nmn_show_secondary = true %}
  {% endif %}

  <div class="custom-rating-nmn nmn-pdp-rating-hero" id="custom-rating-nmn-{{ section.id }}">
    <div class="nmn-pdp-rating-hero__bar">
      <button
        type="button"
        class="nmn-pdp-rating-hero__trigger"
        data-custom-rating-scroll
        aria-label="Zu den Bewertungen scrollen – {{ rating_text }} von {{ rating_count }} Bewertungen{% if nmn_stat_1 != blank %}, {{ nmn_stat_1 | strip_html | escape }}{% endif %}{% if nmn_stat_2 != blank %}, {{ nmn_stat_2 | strip_html | escape }}{% endif %}"
      >
        <span class="nmn-pdp-rating-hero__primary">
          <span class="nmn-pdp-rating-hero__stars custom-stars" aria-hidden="true">
            <span class="custom-stars-active" style="width: {{ pct }}%;"></span>
          </span>
          <span class="nmn-pdp-rating-hero__copy">
            <span class="nmn-pdp-rating-hero__score">{{ rating_text }}</span>
            <span class="nmn-pdp-rating-hero__reviews-label"> von {{ rating_count }} Bewertungen</span>
          </span>
        </span>

        {% if nmn_show_secondary %}
          <span class="nmn-pdp-rating-hero__sep nmn-pdp-rating-hero__sep--between" aria-hidden="true">|</span>
          <span class="nmn-pdp-rating-hero__secondary">
            {% if nmn_stat_1 != blank %}
              <span class="nmn-pdp-rating-hero__stat">{{ nmn_stat_1 | escape }}</span>
            {% endif %}
            {% if nmn_stat_1 != blank and nmn_stat_2 != blank %}
              <span class="nmn-pdp-rating-hero__sep nmn-pdp-rating-hero__sep--inline" aria-hidden="true">|</span>
            {% endif %}
            {% if nmn_stat_2 != blank %}
              <span class="nmn-pdp-rating-hero__stat">{{ nmn_stat_2 | escape }}</span>
            {% endif %}
          </span>
        {% endif %}
      </button>
    </div>
  </div>

  <style>
    #custom-rating-nmn-{{ section.id }} .nmn-pdp-rating-hero__stars {
      background-image: url("data:image/svg+xml;utf8,<svg width='20' height='15' viewBox='0 0 14 13' xmlns='http://www.w3.org/2000/svg'><path d='m7 0 1.572 4.837h5.085l-4.114 2.99 1.572 4.836L7 9.673l-4.114 2.99 1.571-4.837-4.114-2.99h5.085L7 0Z' fill='{{ bg_color }}'/></svg>");
    }
    #custom-rating-nmn-{{ section.id }} .custom-stars-active::before {
      background-image: url("data:image/svg+xml;utf8,<svg width='20' height='15' viewBox='0 0 14 13' xmlns='http://www.w3.org/2000/svg'><path d='m7 0 1.572 4.837h5.085l-4.114 2.99 1.572 4.836L7 9.673l-4.114 2.99 1.571-4.837-4.114-2.99h5.085L7 0Z' fill='{{ star_color }}'/></svg>");
    }
  </style>

  <script>
    (function () {
      var rootId = 'custom-rating-nmn-{{ section.id }}';
      var scrollOffsetPx = 80;

      function scrollToEl(el) {
        var y = el.getBoundingClientRect().top + window.pageYOffset - scrollOffsetPx;
        window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
      }

      function findReviewsTarget() {
        var byId = document.getElementById('shopify-section-loox-reviews');
        if (byId) return byId;

        var el = document.getElementById('looxReviews');
        var sec;
        if (el) {
          sec = el.closest('[id^="shopify-section-"]');
          return sec || el;
        }
        el = document.querySelector('.loox-dynamic-section, [class*="loox-dynamic-section"], .loox-v2-widget-container');
        if (el) {
          sec = el.closest('[id^="shopify-section-"]');
          return sec || el;
        }
        var sections = document.querySelectorAll('[id^="shopify-section-"]');
        var i;
        for (i = 0; i < sections.length; i++) {
          if (
            /loox/i.test(sections[i].id) &&
            sections[i].querySelector('[class*="loox"], [id*="loox"]')
          ) {
            return sections[i];
          }
        }
        return null;
      }

      function bind() {
        var root = document.getElementById(rootId);
        if (!root) return;
        var btn = root.querySelector('[data-custom-rating-scroll]');
        if (!btn || btn.dataset.bound) return;
        btn.dataset.bound = '1';
        btn.addEventListener('click', function onClick() {
          if (window.Shopify && Shopify.designMode) return;
          var target = findReviewsTarget();
          if (target) scrollToEl(target);
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', bind, { once: true });
      } else {
        bind();
      }
    })();
  </script>
{% endif %}
