    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Ernährung, Gesundheit, Vitamine, Bewegung"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterzeile"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Kategorie",
