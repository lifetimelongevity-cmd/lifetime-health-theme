        {
          "type": "url",
          "id": "link_url",
          "label": "Link-URL"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link-Text",
          "default": "Forum besuchen"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Link Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Forum",
            "description": "Erhalte Antworten von unserem Team und der Community.",
