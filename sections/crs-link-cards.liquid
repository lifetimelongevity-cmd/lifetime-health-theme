{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.1 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="lc-section" id="section-{{ section.id }}">
  <div class="lc-container">
    {%- if section.blocks.size > 0 -%}
      <div class="lc-grid">
        {%- for block in section.blocks -%}
          <div class="lc-card" {{ block.shopify_attributes }}>
            <div class="lc-card-body">
              {%- if block.settings.title != blank -%}
                <h2 class="lc-card-title">{{ block.settings.title | escape }}</h2>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="lc-card-desc">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>
            {%- if block.settings.link_url != blank and block.settings.link_label != blank -%}
              <div class="lc-card-footer">
                <a
                  href="{{ block.settings.link_url }}"
                  class="lc-link"
                  {% unless block.settings.link_url contains 'javascript' %}
                    target="_blank" rel="noopener noreferrer"
                  {% endunless %}
                >{{ block.settings.link_label | escape }} ↗</a>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
/* ===================================================
   Link Cards — crs-link-cards.liquid
   =================================================== */

.lc-section {
  background: var(--crs-bg, #f7f7f4);
}

.lc-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Grid */
.lc-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  align-items: stretch;
}

/* Card */
.lc-card {
  background: var(--crs-card-bg, #f2f1ed);
  border-radius: 4px;
  padding: 15px;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.lc-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.lc-card-title {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: 16px !important;
  font-weight: 400 !important;
  line-height: 1.4 !important;
  letter-spacing: 0 !important;
  color: var(--crs-text, #26251e) !important;
  margin: 0 !important;
}

.lc-card-desc {
  font-size: 16px;
  line-height: 1.6;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
  margin: 0;
}

/* Footer link */
.lc-card-footer {
  margin-top: 24px;
}

.lc-link {
  font-size: 14px;
  font-weight: 400;
  color: var(--crs-text, #26251e);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: var(--crs-border, rgba(38,37,30,0.2));
  transition: text-decoration-color 0.15s ease, opacity 0.15s ease;
}

.lc-link:hover {
  text-decoration-color: var(--crs-text, #26251e);
  opacity: .75;
}

/* Tablet — 2 columns */
@media (max-width: 1024px) {
  .lc-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Mobile — 1 column */
@media (max-width: 640px) {
  .lc-grid {
    grid-template-columns: 1fr;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Link Cards",
  "tag": "section",
  "class": "crs-link-cards",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Karte",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Forum"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Beschreibung",
          "default": "Erhalte Antworten von unserem Team und der Community."
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link-URL"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link-Text",
          "default": "Forum besuchen"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Link Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Forum",
            "description": "Erhalte Antworten von unserem Team und der Community.",
            "link_label": "Forum besuchen"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Discord",
            "description": "Lerne andere Nutzer kennen und entdecke, was sie bauen.",
            "link_label": "Discord besuchen"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Reddit",
            "description": "Bleib über die neuesten Updates auf dem Laufenden und sieh, was die Community erschafft.",
            "link_label": "Reddit besuchen"
          }
        }
      ]
    }
  ]
}
{% endschema %}
