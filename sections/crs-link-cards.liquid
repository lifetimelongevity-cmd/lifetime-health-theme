{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_lc_kicker = section.settings.kicker | strip
  assign crs_lc_head = section.settings.heading | strip
  assign crs_lc_sub = section.settings.subheading | strip
  if crs_lc_kicker == '__none__'
    assign crs_lc_kicker = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.05 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="lc-section" id="section-{{ section.id }}">
  <div class="lc-container">
    {%- if crs_lc_kicker != blank or crs_lc_head != blank or crs_lc_sub != blank -%}
      <header class="lc-section-head crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
        {%- if crs_lc_kicker != blank -%}
          <p class="crs-heading-stack__kicker">{{ crs_lc_kicker | escape }}</p>
        {%- endif -%}
        {%- if crs_lc_head != blank or crs_lc_sub != blank -%}
          <div class="crs-heading-stack__pair">
            {%- if crs_lc_head != blank -%}
              <h2 class="crs-heading-stack__title">{{ crs_lc_head | escape | newline_to_br }}</h2>
            {%- endif -%}
            {%- if crs_lc_sub != blank -%}
              <p class="crs-heading-stack__subtitle">{{ crs_lc_sub | escape | newline_to_br }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </header>
    {%- endif -%}
    {%- if section.blocks.size > 0 -%}
      <div class="lc-grid">
        {%- for block in section.blocks -%}
          <div class="lc-card" {{ block.shopify_attributes }}>
            <div class="lc-card-body">
              {%- if block.settings.title != blank -%}
                <h2 class="lc-card-title">{{ block.settings.title | escape }}</h2>
              {%- endif -%}
              {%- if block.settings.description != blank -%}
                <p class="lc-card-desc">{{ block.settings.description | escape }}</p>
              {%- endif -%}
            </div>
            {%- assign lc_popup_plain = block.settings.popup_body | default: '' | strip_html | strip -%}
            {%- if block.settings.link_label != blank and lc_popup_plain != '' -%}
              <div class="lc-card-footer">
                <button
                  type="button"
                  class="crs-popup-link"
                  data-crs-dialog-open
                  aria-haspopup="dialog"
                  aria-controls="crs-lc-dialog-{{ section.id }}-{{ block.id }}"
                >
                  {{ block.settings.link_label | escape }}&nbsp;↗
                </button>
              </div>
              <dialog
                id="crs-lc-dialog-{{ section.id }}-{{ block.id }}"
                class="crs-micro-dialog"
                aria-modal="true"
                aria-labelledby="crs-lc-dlg-title-{{ section.id }}-{{ block.id }}"
              >
                <div class="crs-micro-dialog__inner">
                  <button
                    type="button"
                    class="crs-micro-dialog__close"
                    data-crs-dialog-close
                    aria-label="{{ 'general.accessibility_labels.close' | t }}"
                  >
                    <span aria-hidden="true">×</span>
                  </button>
                  {%- assign lc_dlg_title = block.settings.popup_title | default: block.settings.link_label -%}
                  <h2 id="crs-lc-dlg-title-{{ section.id }}-{{ block.id }}" class="crs-micro-dialog__title">
                    {{ lc_dlg_title | escape }}
                  </h2>
                  <div class="crs-micro-dialog__body rte">
                    {{ block.settings.popup_body }}
                  </div>
                </div>
              </dialog>
            {%- elsif block.settings.link_url != blank and block.settings.link_label != blank -%}
              <div class="lc-card-footer">
                <a
                  href="{{ block.settings.link_url }}"
                  class="lc-link"
                  {% unless block.settings.link_url contains 'javascript' %}
                    target="_blank" rel="noopener noreferrer"
                  {% endunless %}
                >{{ block.settings.link_label | escape }}&nbsp;↗</a>
              </div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</div>

{% render 'crs-micro-dialog-init' %}

{% stylesheet %}
/* ===================================================
   Link Cards — crs-link-cards.liquid
   =================================================== */

.lc-section {
  background: var(--crs-bg, #f7f7f4);
}

.lc-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 var(--space-5);
}

@media (max-width: 749px) {
  .lc-container {
    padding: 0 var(--space-4);
  }
}

.lc-section-head {
  max-width: 42rem;
  margin-bottom: var(--space-7);
}

.lc-section-head.crs-heading-stack--align-center {
  margin-inline: auto;
}

/* Grid */
.lc-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
  align-items: stretch;
}

/* Card */
.lc-card {
  box-sizing: border-box;
  background: var(--crs-card-bg, #f2f1ed);
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  border-radius: 4px;
  padding: 15px;
  display: flex;
  flex-direction: column;
  height: 100%;
}

.lc-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.lc-card-title {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: 16px !important;
  font-weight: 400 !important;
  line-height: 1.4 !important;
  letter-spacing: 0 !important;
  color: var(--crs-text, #26251e) !important;
  margin: 0 !important;
}

.lc-card-desc {
  font-size: 16px;
  line-height: 1.6;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
  margin: 0;
}

/* Footer link */
.lc-card-footer {
  margin-top: 24px;
}

.lc-link {
  font-size: 14px;
  font-weight: 400;
  color: var(--color-teal);
  text-decoration: underline;
  text-underline-offset: 3px;
  text-decoration-color: var(--color-gray-400);
  transition: color 0.15s ease, text-decoration-color 0.15s ease, opacity 0.15s ease;
}

.lc-link:hover {
  color: var(--color-teal-dark);
  text-decoration-color: var(--color-teal-dark);
  opacity: 0.92;
}

/* Tablet — 2 columns */
@media (max-width: 1024px) {
  .lc-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Mobile — 1 column */
@media (max-width: 640px) {
  .lc-grid {
    grid-template-columns: 1fr;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Link Cards",
  "tag": "section",
  "class": "crs-link-cards",
  "settings": [
    {
      "type": "header",
      "content": "Überschrift"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Titel",
      "default": "Link-Karten"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Untertitel",
      "default": "Kurzer erklärender Text über den Karten."
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Ausrichtung (Überschrift)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Überschrift Größe",
      "options": [
        { "value": "section", "label": "Standard (Abschnitt)" },
        { "value": "product_title", "label": "Wie Produkttitel" }
      ],
      "default": "section",
      "info": "Zeilenumbruch: Enter in Titel/Untertitel."
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Karte",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Forum"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Beschreibung",
          "default": "Erhalte Antworten von unserem Team und der Community."
        },
        {
          "type": "header",
          "content": "Popup statt externem Link"
        },
        {
          "type": "richtext",
          "id": "popup_body",
          "label": "Popup-Inhalt",
          "info": "Wenn ausgefüllt: Button öffnet dieses Fenster. Link-URL wird dann ignoriert."
        },
        {
          "type": "text",
          "id": "popup_title",
          "label": "Popup-Titel",
          "info": "Leer = gleich wie Link-Text"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link-URL",
          "info": "Nur wenn Popup-Inhalt leer ist"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link-Text",
          "default": "Forum besuchen"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Link Cards",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "Forum",
            "description": "Erhalte Antworten von unserem Team und der Community.",
            "link_label": "Forum besuchen"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Discord",
            "description": "Lerne andere Nutzer kennen und entdecke, was sie bauen.",
            "link_label": "Discord besuchen"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "Reddit",
            "description": "Bleib über die neuesten Updates auf dem Laufenden und sieh, was die Community erschafft.",
            "link_label": "Reddit besuchen"
          }
        }
      ]
    }
  ]
}
{% endschema %}
