{%- comment -%}
  Stack-Builder MVP
  -----------------
  Customer baut seinen eigenen Longevity-Stack aus stack-eligible Produkten.
  Live-Total mit gestaffelten Bundle-Rabatten. Gestapelte Discount-Logik:
  Code (15-33%) + bestehender 10%-Single-Abo-Selling-Plan ergibt effektiv
  23/28/33/37/40 % vom Vollpreis (Tier 2..6).

  Voraussetzungen:
  - Collection (default `stack-eligible`) mit den Stack-Produkten
  - Discount-Codes LT-STACK2..6 in Shopify Admin
  - Existierende Single-Abo Selling Plans pro Produkt
  - Kein eigener "Stack-Lieferung"-Selling-Plan nötig (Stacking-Modell)

  Konfigurierbar im Theme-Editor:
  - Heading / Subheading / Note
  - Stack-Eligible Collection Handle
{%- endcomment -%}

<section class="lt-stack-builder section-{{ section.id }}-stack">
  <div class="container--large container--vertical-space">

    <header class="lt-stack-header">
      {%- if section.settings.kicker != blank -%}
        <p class="lt-stack-kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      <h1 class="lt-stack-title">{{ section.settings.heading | default: 'Stell dir deinen Stack zusammen' | escape }}</h1>
      {%- if section.settings.subheading != blank -%}
        <p class="lt-stack-sub">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </header>

    <div class="lt-stack-layout">

      <div class="lt-stack-main">
        <div class="lt-stack-tabs" role="tablist">
          <button class="lt-stack-tab is-active" data-stack-tab="hallmarks" role="tab" aria-selected="true" type="button">
            Hallmarks of Aging
          </button>
          <button class="lt-stack-tab" data-stack-tab="products" role="tab" aria-selected="false" type="button">
            Wirkstoffe direkt
          </button>
        </div>

        <div class="lt-stack-pane" id="lt-stack-pane-{{ section.id }}" data-stack-pane>
          <p class="lt-stack-loading">Stack wird geladen…</p>
        </div>
      </div>

      <aside class="lt-stack-sidebar" id="lt-stack-sidebar-{{ section.id }}" data-stack-sidebar></aside>
    </div>

  </div>
</section>

<div class="lt-stack-backdrop" data-stack-backdrop hidden></div>

{%- comment -%}
  Hallmark-Icons als hidden <template>-Tags. JS liest sie über
  data-icon-Attribut und rendert sie in den Goal-Cards.
  Single Source of Truth bleibt snippets/icon-pack.liquid.
{%- endcomment -%}
<template data-stack-icon="genomic-instability">{% render 'icon-pack', icon: 'hallmark-genomic-instability' %}</template>
<template data-stack-icon="telomere-attrition">{% render 'icon-pack', icon: 'hallmark-telomere-attrition' %}</template>
<template data-stack-icon="epigenetic">{% render 'icon-pack', icon: 'hallmark-epigenetic' %}</template>
<template data-stack-icon="proteostasis">{% render 'icon-pack', icon: 'hallmark-proteostasis' %}</template>
<template data-stack-icon="autophagy">{% render 'icon-pack', icon: 'hallmark-autophagy' %}</template>
<template data-stack-icon="nutrient-sensing">{% render 'icon-pack', icon: 'hallmark-nutrient-sensing' %}</template>
<template data-stack-icon="mitochondrial">{% render 'icon-pack', icon: 'hallmark-mitochondrial' %}</template>
<template data-stack-icon="senescence">{% render 'icon-pack', icon: 'hallmark-senescence' %}</template>
<template data-stack-icon="stem-cell">{% render 'icon-pack', icon: 'hallmark-stem-cell' %}</template>
<template data-stack-icon="intercellular">{% render 'icon-pack', icon: 'hallmark-intercellular' %}</template>
<template data-stack-icon="inflammation">{% render 'icon-pack', icon: 'hallmark-inflammation' %}</template>
<template data-stack-icon="dysbiosis">{% render 'icon-pack', icon: 'hallmark-dysbiosis' %}</template>

{%- assign stack_collection_handle = section.settings.product_collection | default: 'stack-eligible' -%}
{%- assign stack_products = collections[stack_collection_handle].products -%}

<script type="application/json" data-stack-products-{{ section.id }}>
[
  {%- for product in stack_products -%}
    {%- assign variant = product.selected_or_first_available_variant -%}
    {%- assign sp = product.selling_plan_groups.first.selling_plans.first -%}
    {%- comment -%}
      Wirkweise: zuerst Metafield-Override, sonst hardcoded per Produkt-Handle.
      Erlaubt dem Merchant, einzelne Texte über Shopify-Admin zu übersteuern,
      ohne dass die anderen Produkte ohne Text dastehen.
    {%- endcomment -%}
    {%- assign wirkweise = product.metafields.custom.product-wirkweise -%}
    {%- if wirkweise == blank -%}
      {%- case product.handle -%}
        {%- when 'spermidin-kapseln' -%}{%- assign wirkweise = 'Aktiviert die zelluläre Autophagie — den körpereigenen Reinigungsprozess.' -%}
        {%- when 'resveratrol-kapseln' -%}{%- assign wirkweise = 'Stimuliert Sirtuine, eine Familie zellschützender Langlebigkeits-Enzyme.' -%}
        {%- when 'fisetin-kapseln' -%}{%- assign wirkweise = 'Wirkt senolytisch — beseitigt alte, geschädigte Zellen aus dem Gewebe.' -%}
        {%- when 'betain-tmg-kapseln' -%}{%- assign wirkweise = 'Unterstützt den Methylierungs-Stoffwechsel und Homocystein-Abbau.' -%}
        {%- when 'caakg-kapseln' -%}{%- assign wirkweise = 'Liefert Energie-Bausteine für Mitochondrien und Zellteilung.' -%}
        {%- when 'nad-booster' -%}{%- assign wirkweise = 'Hebt NAD⁺-Spiegel — den zentralen Co-Faktor für Zellenergie.' -%}
      {%- endcase -%}
    {%- endif -%}
    {
      "id": {{ product.id }},
      "handle": {{ product.handle | json }},
      "title": {{ product.title | json }},
      "image": {{ product.featured_image | image_url: width: 400 | json }},
      "variantId": {{ variant.id }},
      "priceCents": {{ variant.price }},
      "sellingPlanId": {%- if sp -%}{{ sp.id }}{%- else -%}null{%- endif -%},
      "claim": {{ product.metafields.custom.product-benefit | default: '' | json }},
      "wirkweise": {{ wirkweise | default: '' | json }},
      "portion": {{ product.metafields.custom.portion_label | default: '60 Kapseln · 1 Monat' | json }}
    }{%- unless forloop.last -%},{%- endunless -%}
  {%- endfor -%}
]
</script>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var pane = document.querySelector('[data-stack-pane]');
    var sidebar = document.querySelector('[data-stack-sidebar]');
    var tabs = document.querySelectorAll('[data-stack-tab]');
    var dataEl = document.querySelector('[data-stack-products-' + sectionId + ']');
    if (!pane || !sidebar || !dataEl) return;

    var products = [];
    try { products = JSON.parse(dataEl.textContent); } catch (e) {}
    if (!products.length) {
      pane.innerHTML = '<p class="lt-stack-empty">Keine Stack-Produkte konfiguriert. Bitte Collection prüfen.</p>';
      return;
    }

    /* Alle 12 Hallmarks of Aging (López-Otín et al. 2023, Update von 2013).
       Customer-Flow: Klick auf Hallmark-Card → Detail-Panel öffnet
       darunter mit Beschreibung + verfügbaren Wirkstoffen. Wirkstoffe
       können einzeln oder als Bundle zum Stack hinzugefügt werden.

       Categories:
         primary       → Schäden auf molekularer Ebene
         antagonistic  → Antworten der Zelle auf die Schäden
         integrative   → Folgen für Gewebe + Organismus

       Coverage: 9 von 12 Hallmarks haben mindestens 1 Wirkstoff in
       unserem Stack-Sortiment. Telomere, Zell-Kommunikation und
       Mikrobiom haben keinen — Customer sieht das transparent.
    */
    var hallmarks = [
      /* PRIMARY HALLMARKS — Schäden auf molekularer Ebene */
      {
        id: 'genomic-instability',
        title: 'Genomische Instabilität',
        short: 'DNA-Schäden',
        category: 'primary',
        categoryLabel: 'Primärer Hallmark · Schäden',
        description: 'Mit jedem Tag entstehen Tausende DNA-Schäden in deinen Zellen — durch oxidativen Stress, UV-Licht, Replikationsfehler. Mit dem Alter werden die Reparatur-Mechanismen langsamer, Mutationen häufen sich an. NAD⁺ ist zentral für die DNA-Reparatur via PARP-Enzyme.',
        productHandles: ['nad-booster']
      },
      {
        id: 'telomere-attrition',
        title: 'Telomer-Verkürzung',
        short: 'Telomere',
        category: 'primary',
        categoryLabel: 'Primärer Hallmark · Schäden',
        description: 'Telomere sind die Schutzkappen an den Enden deiner Chromosomen. Mit jeder Zellteilung verkürzen sie sich. Sind sie zu kurz, kann die Zelle sich nicht mehr teilen — das sogenannte Hayflick-Limit. Aktuell kein Wirkstoff in unserem Sortiment der direkt hier ansetzt.',
        productHandles: []
      },
      {
        id: 'epigenetic',
        title: 'Epigenetische Veränderungen',
        short: 'Epigenetik',
        category: 'primary',
        categoryLabel: 'Primärer Hallmark · Schäden',
        description: 'Methylierungs-Muster auf deiner DNA bestimmen, welche Gene aktiv sind. Mit dem Alter geraten diese Muster aus der Balance — die „epigenetische Uhr" tickt schneller. NAD⁺ als Sirtuin-Substrat und Methyl-Spender wie TMG stabilisieren sie.',
        productHandles: ['nad-booster', 'betain-tmg-kapseln', 'caakg-kapseln']
      },
      {
        id: 'proteostasis',
        title: 'Verlust der Proteostase',
        short: 'Proteostase',
        category: 'primary',
        categoryLabel: 'Primärer Hallmark · Schäden',
        description: 'Proteine müssen sich richtig falten und am Ende abgebaut werden. Mit dem Alter versagen Falt-Helfer und Abbau-Maschinerie — fehlerhafte Proteine sammeln sich an (siehe Alzheimer, Parkinson). Spermidin aktiviert die Autophagie als Hauptabbau-Weg für defekte Proteine.',
        productHandles: ['spermidin-kapseln']
      },
      {
        id: 'autophagy',
        title: 'Gestörte Autophagie',
        short: 'Autophagie',
        category: 'primary',
        categoryLabel: 'Primärer Hallmark · Schäden',
        description: 'Der zelluläre Müllabbau verlangsamt sich mit dem Alter. Geschädigte Mitochondrien, fehlerhafte Proteine, alte Organellen werden nicht mehr ausreichend recycelt. Spermidin und Resveratrol sind die zwei am besten erforschten Autophagie-Induktoren.',
        productHandles: ['spermidin-kapseln', 'resveratrol-kapseln']
      },
      {
        id: 'nutrient-sensing',
        title: 'Dysregulierte Nährstoff-Sensoren',
        short: 'Nährstoff-Sensoren',
        category: 'primary',
        categoryLabel: 'Primärer Hallmark · Schäden',
        description: 'mTOR, IGF-1 und Insulin-Signalwege geben deinen Zellen das Signal „Wachstum" oder „Reparatur". Mit dem Alter geraten sie aus der Balance, oft Richtung chronisches Wachstumssignal. Spermidin und Resveratrol modulieren diese Sensoren in Richtung Reparatur-Modus.',
        productHandles: ['spermidin-kapseln', 'resveratrol-kapseln']
      },

      /* ANTAGONISTIC HALLMARKS — Antworten der Zelle */
      {
        id: 'mitochondrial',
        title: 'Mitochondrien-Dysfunktion',
        short: 'Mitochondrien',
        category: 'antagonistic',
        categoryLabel: 'Antagonistischer Hallmark · Antwort',
        description: 'Mitochondrien sind die Energiekraftwerke deiner Zellen. Mit dem Alter werden sie ineffizienter, produzieren weniger ATP und mehr oxidativen Stress. NAD⁺, CaAKG und Resveratrol zielen direkt auf Mitochondrien-Funktion und -Biogenese.',
        productHandles: ['nad-booster', 'caakg-kapseln', 'resveratrol-kapseln']
      },
      {
        id: 'senescence',
        title: 'Zellseneszenz',
        short: 'Zombie-Zellen',
        category: 'antagonistic',
        categoryLabel: 'Antagonistischer Hallmark · Antwort',
        description: 'Manche Zellen werden alt und teilen sich nicht mehr — sterben aber auch nicht ab. Diese „Zombie-Zellen" sondern entzündungsfördernde Stoffe ab und schaden umliegendem Gewebe. Fisetin ist eines der am besten erforschten Senolytika.',
        productHandles: ['fisetin-kapseln']
      },
      {
        id: 'stem-cell',
        title: 'Stammzell-Erschöpfung',
        short: 'Stammzellen',
        category: 'antagonistic',
        categoryLabel: 'Antagonistischer Hallmark · Antwort',
        description: 'Deine Stammzellen erneuern Gewebe — Haut, Blut, Darm. Mit dem Alter nimmt ihre Anzahl und Aktivität ab. CaAKG zeigt in jüngerer Forschung Effekte auf Stammzell-Erhalt und Gewebe-Regeneration.',
        productHandles: ['caakg-kapseln']
      },

      /* INTEGRATIVE HALLMARKS — Folgen für den Organismus */
      {
        id: 'intercellular',
        title: 'Gestörte Zell-Kommunikation',
        short: 'Zell-Kommunikation',
        category: 'integrative',
        categoryLabel: 'Integrativer Hallmark · Folge',
        description: 'Hormone, Zytokine, neuronale Signale — alle Kommunikation zwischen Zellen wird mit dem Alter ungenauer. Aktuell kein Wirkstoff in unserem Sortiment der hier direkt ansetzt; Anti-Inflammation und Sirtuin-Aktivierung haben Sekundäreffekte.',
        productHandles: []
      },
      {
        id: 'inflammation',
        title: 'Chronische Entzündungen',
        short: 'Inflammaging',
        category: 'integrative',
        categoryLabel: 'Integrativer Hallmark · Folge',
        description: 'Niedriggradige systemische Entzündungen — Inflammaging — sind ein zentraler Treiber des Alterungsprozesses und vieler altersbedingter Erkrankungen. Fisetin und Resveratrol haben starke entzündungshemmende Effekte.',
        productHandles: ['fisetin-kapseln', 'resveratrol-kapseln']
      },
      {
        id: 'dysbiosis',
        title: 'Mikrobiom-Dysbalance',
        short: 'Mikrobiom',
        category: 'integrative',
        categoryLabel: 'Integrativer Hallmark · Folge',
        description: 'Deine Darmflora wird mit dem Alter weniger divers, die Anzahl pathogener Bakterien steigt. Aktuell kein Wirkstoff in unserem Sortiment der hier direkt ansetzt — Probiotika sind hier der primäre Hebel.',
        productHandles: []
      }
    ];

    var activeHallmarkId = null;
    var activeTab = 'hallmarks';

    /* Tier-Set: codePercent ist der reine Code-Wert in Shopify Admin.
       Effektive Rabattrate ergibt sich aus Stacking mit dem 10%-Single-Abo-
       Selling-Plan (≈ codePercent + 10pp − codePercent×10pp). */
    var tiers = [
      { min: 2, code: 'LT-STACK2', codePercent: 0.15, effectivePct: 23 },
      { min: 3, code: 'LT-STACK3', codePercent: 0.20, effectivePct: 28 },
      { min: 4, code: 'LT-STACK4', codePercent: 0.25, effectivePct: 33 },
      { min: 5, code: 'LT-STACK5', codePercent: 0.30, effectivePct: 37 },
      { min: 6, code: 'LT-STACK6', codePercent: 0.33, effectivePct: 40 }
    ];

    var selected = new Set();

    /* Initial-State aus URL: ?stack=handle1,handle2,... */
    (function readUrl() {
      var params = new URLSearchParams(window.location.search);
      var raw = params.get('stack');
      if (!raw) return;
      raw.split(',').forEach(function(handle) {
        var p = products.find(function(x) { return x.handle === handle.trim(); });
        if (p) selected.add(p.id);
      });
    })();

    function findTier(count) {
      var match = null;
      for (var i = 0; i < tiers.length; i++) if (count >= tiers[i].min) match = tiers[i];
      return match;
    }
    function findNextTier(count) {
      for (var i = 0; i < tiers.length; i++) if (count < tiers[i].min) return tiers[i];
      return null;
    }
    function fmt(cents) {
      return (cents / 100).toLocaleString('de-DE', { minimumFractionDigits: 2, maximumFractionDigits: 2 }) + ' €';
    }
    function escape(s) {
      var d = document.createElement('div');
      d.textContent = s == null ? '' : String(s);
      return d.innerHTML;
    }

    function calc() {
      var items = [];
      selected.forEach(function(id) {
        var p = products.find(function(x) { return x.id === id; });
        if (p) items.push(p);
      });
      var subtotalAbo = items.reduce(function(s, p) { return s + p.priceCents; }, 0);
      var tier = findTier(items.length);
      var nextTier = findNextTier(items.length);
      var stackDiscount = tier ? Math.round(subtotalAbo * tier.codePercent) : 0;
      var total = subtotalAbo - stackDiscount;
      return { items: items, subtotalAbo: subtotalAbo, tier: tier, nextTier: nextTier, stackDiscount: stackDiscount, total: total };
    }

    function syncUrl() {
      var handles = [];
      selected.forEach(function(id) {
        var p = products.find(function(x) { return x.id === id; });
        if (p) handles.push(p.handle);
      });
      var url = new URL(window.location.href);
      if (handles.length) url.searchParams.set('stack', handles.join(','));
      else url.searchParams.delete('stack');
      window.history.replaceState({}, '', url);
    }

    function renderProducts() {
      pane.innerHTML = '<div class="lt-stack-grid">' + products.map(function(p) {
        var isSel = selected.has(p.id);
        return ''
          + '<button class="lt-stack-card' + (isSel ? ' is-selected' : '') + '" data-id="' + p.id + '" type="button" aria-pressed="' + (isSel ? 'true' : 'false') + '">'
          +   '<span class="lt-stack-card__check" aria-hidden="true">' + (isSel ? '✓' : '+') + '</span>'
          +   '<div class="lt-stack-card__media"><img src="' + p.image + '" alt="' + escape(p.title) + '" loading="lazy"></div>'
          +   '<div class="lt-stack-card__body">'
          +     '<h3>' + escape(p.title) + '</h3>'
          +     (p.claim ? '<p class="lt-stack-card__claim">' + escape(p.claim) + '</p>' : '')
          +     (p.wirkweise ? '<p class="lt-stack-card__wirkweise">' + escape(p.wirkweise) + '</p>' : '')
          +     '<p class="lt-stack-card__portion">' + escape(p.portion) + '</p>'
          +     '<p class="lt-stack-card__price">' + fmt(p.priceCents) + '<small> /Monat im Abo</small></p>'
          +   '</div>'
          +   '<span class="lt-stack-card__cta">' + (isSel ? '✓ Im Stack' : 'Hinzufügen') + '</span>'
          + '</button>';
      }).join('') + '</div>';
    }

    /* Icon-Markup aus den hidden <template>-Tags ziehen.
       Cached, damit wir nicht bei jedem Re-Render querySelectors machen. */
    var iconCache = {};
    function getHallmarkIcon(id) {
      if (iconCache[id] !== undefined) return iconCache[id];
      var tpl = document.querySelector('template[data-stack-icon="' + id + '"]');
      iconCache[id] = tpl ? tpl.innerHTML.trim() : '';
      return iconCache[id];
    }

    /* Welche Hallmark-Produkte sind schon im Stack? */
    function hallmarkCoverageState(h) {
      if (!h.productHandles.length) return 'none-available';
      var inStack = h.productHandles.filter(function(handle) {
        var p = products.find(function(x) { return x.handle === handle; });
        return p && selected.has(p.id);
      }).length;
      if (inStack === 0) return 'available';
      if (inStack === h.productHandles.length) return 'fully-added';
      return 'partial';
    }

    function renderHallmarks() {
      var html = '<div class="lt-stack-hallmarks-grid">';

      hallmarks.forEach(function(h) {
        var state = hallmarkCoverageState(h);
        var iconSvg = getHallmarkIcon(h.id);
        var isActive = h.id === activeHallmarkId;

        html += '<button'
          + ' class="lt-stack-hallmark-card'
          +   ' lt-stack-hallmark-card--' + h.category
          +   ' lt-stack-hallmark-card--state-' + state
          +   (isActive ? ' is-active' : '')
          + '"'
          + ' data-hallmark="' + h.id + '"'
          + ' type="button"'
          + ' aria-expanded="' + (isActive ? 'true' : 'false') + '">'
          +   (iconSvg ? '<span class="lt-stack-hallmark-card__icon" aria-hidden="true">' + iconSvg + '</span>' : '')
          +   '<span class="lt-stack-hallmark-card__name">' + escape(h.short) + '</span>'
          +   (state === 'fully-added' ? '<span class="lt-stack-hallmark-card__check" aria-label="Voll im Stack">✓</span>' : '')
          +   (state === 'partial' ? '<span class="lt-stack-hallmark-card__dot" aria-label="Teilweise im Stack"></span>' : '')
          + '</button>';
      });

      html += '</div>';

      /* Detail-Panel unter dem Grid */
      html += '<div class="lt-stack-hallmark-detail" data-hallmark-detail>';
      if (activeHallmarkId) {
        var h = hallmarks.find(function(x) { return x.id === activeHallmarkId; });
        if (h) html += renderHallmarkDetail(h);
      } else {
        html += ''
          + '<div class="lt-stack-hallmark-detail__empty">'
          +   '<p>Klick auf einen der 12 Hallmarks oben, um zu erfahren wie er den Alterungsprozess beeinflusst und welche Wirkstoffe ihn adressieren.</p>'
          + '</div>';
      }
      html += '</div>';

      pane.innerHTML = html;
    }

    function renderHallmarkDetail(h) {
      var state = hallmarkCoverageState(h);
      var hallmarkProducts = h.productHandles.map(function(handle) {
        return products.find(function(x) { return x.handle === handle; });
      }).filter(Boolean);

      var html = '<div class="lt-stack-hallmark-detail__inner">';

      /* Header */
      html += '<div class="lt-stack-hallmark-detail__header">';
      html += '<span class="lt-stack-hallmark-detail__category lt-stack-hallmark-detail__category--' + h.category + '">' + escape(h.categoryLabel) + '</span>';
      html += '<h3 class="lt-stack-hallmark-detail__title">' + escape(h.title) + '</h3>';
      html += '</div>';

      /* Description */
      html += '<p class="lt-stack-hallmark-detail__desc">' + escape(h.description) + '</p>';

      /* Wirkstoffe */
      html += '<div class="lt-stack-hallmark-detail__products">';
      if (state === 'none-available') {
        html += '<p class="lt-stack-hallmark-detail__no-products">'
             +   '<strong>Aktuell kein Wirkstoff in unserem Sortiment</strong> der diesen Hallmark direkt adressiert. '
             +   'Wir arbeiten daran, das Sortiment hier zu erweitern.'
             + '</p>';
      } else {
        html += '<p class="lt-stack-hallmark-detail__label">'
             +   'Wirkstoffe, die diesen Hallmark adressieren'
             + ' <span>(' + hallmarkProducts.length + ')</span>'
             + '</p>';

        html += '<ul class="lt-stack-hallmark-detail__product-list">';
        hallmarkProducts.forEach(function(p) {
          var inStack = selected.has(p.id);
          html += '<li>'
                + '<button class="lt-stack-hallmark-product' + (inStack ? ' is-in-stack' : '') + '"'
                +   ' data-product-toggle="' + p.id + '" type="button">'
                +   '<span class="lt-stack-hallmark-product__icon" aria-hidden="true">' + (inStack ? '✓' : '+') + '</span>'
                +   '<span class="lt-stack-hallmark-product__title">' + escape(p.title) + '</span>'
                +   '<span class="lt-stack-hallmark-product__price">' + fmt(p.priceCents) + '/Mo</span>'
                + '</button>'
                + '</li>';
        });
        html += '</ul>';

        if (hallmarkProducts.length > 1 && state !== 'fully-added') {
          html += '<button class="lt-stack-hallmark-bulk" data-hallmark-bulk="' + h.id + '" type="button">'
               +   '+ Alle ' + hallmarkProducts.length + ' Wirkstoffe in den Stack'
               + '</button>';
        }
      }
      html += '</div>';

      html += '</div>';
      return html;
    }

    function renderPane() {
      if (activeTab === 'hallmarks') renderHallmarks();
      else renderProducts();
    }

    function setTab(tab) {
      if (tab === activeTab) return;
      activeTab = tab;
      tabs.forEach(function(t) {
        var isActive = t.getAttribute('data-stack-tab') === tab;
        t.classList.toggle('is-active', isActive);
        t.setAttribute('aria-selected', isActive ? 'true' : 'false');
      });
      renderPane();
    }

    function setActiveHallmark(id) {
      /* Toggle: Klick auf bereits aktiven Hallmark schließt das Detail */
      activeHallmarkId = (activeHallmarkId === id) ? null : id;
      renderHallmarks();
      /* Nach Auswahl ins Detail scrollen — auf Mobile wichtig damit
         Customer die Erklärung sofort sieht */
      if (activeHallmarkId) {
        var detail = pane.querySelector('[data-hallmark-detail]');
        if (detail && detail.scrollIntoView) {
          detail.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }
      }
    }

    function addAllFromHallmark(hallmarkId) {
      var h = hallmarks.find(function(x) { return x.id === hallmarkId; });
      if (!h) return;
      h.productHandles.forEach(function(handle) {
        var p = products.find(function(x) { return x.handle === handle; });
        if (p) selected.add(p.id);
      });
      rerender();
    }

    function toggleProductFromHallmark(productId) {
      var id = parseInt(productId, 10);
      if (selected.has(id)) selected.delete(id);
      else selected.add(id);
      rerender();
    }

    function renderSidebar() {
      var c = calc();
      var wasExpanded = sidebar.classList.contains('is-expanded');

      var html = '';

      /* Mobile-only: Sheet-Header (Toggle) — auf Desktop via CSS hidden */
      var summaryCount = c.items.length === 0
        ? 'Noch leer'
        : c.items.length + ' Produkt' + (c.items.length > 1 ? 'e' : '');
      html += '<button class="lt-stack-sheet-toggle" data-stack-toggle type="button" aria-expanded="' + (wasExpanded ? 'true' : 'false') + '" aria-controls="lt-stack-bar-' + sectionId + '">';
      html +=   '<span class="lt-stack-sheet-toggle__handle" aria-hidden="true"></span>';
      html +=   '<span class="lt-stack-sheet-toggle__summary">';
      html +=     '<span class="lt-stack-sheet-toggle__count">' + escape(summaryCount) + '</span>';
      if (c.items.length > 0) {
        html +=   '<span class="lt-stack-sheet-toggle__total">' + fmt(c.total) + '/Mo</span>';
      }
      html +=   '</span>';
      html +=   '<span class="lt-stack-sheet-toggle__chevron" aria-hidden="true">›</span>';
      html += '</button>';

      html += '<div class="lt-stack-bar" id="lt-stack-bar-' + sectionId + '">';

      /* Tier-Progress (immer sichtbar, auch im Collapsed-State) */
      html += '<div class="lt-stack-progress">';
      if (c.items.length === 0) {
        html += '<p class="lt-stack-progress__hint">Wähle 2 + Produkte für deinen Stack-Bonus</p>';
      } else if (c.nextTier) {
        var pct = (c.items.length / c.nextTier.min) * 100;
        html += '<div class="lt-stack-progress__bar"><span style="width:' + Math.min(pct, 100).toFixed(0) + '%"></span></div>';
        var remaining = c.nextTier.min - c.items.length;
        html += '<p class="lt-stack-progress__hint">'
             + 'Noch ' + remaining + ' Produkt' + (remaining > 1 ? 'e' : '')
             + ' für <strong>' + c.nextTier.effectivePct + ' % Stack-Bonus</strong>'
             + '</p>';
      } else if (c.tier) {
        html += '<div class="lt-stack-progress__bar"><span style="width:100%"></span></div>';
        html += '<p class="lt-stack-progress__hint">'
             + 'Top-Tier erreicht — <strong>' + c.tier.effectivePct + ' % Stack-Bonus</strong> aktiv'
             + '</p>';
      }
      html += '</div>';

      /* Details-Wrapper (auf Mobile kollabierbar via .is-expanded) */
      html += '<div class="lt-stack-bar__details">';

      /* Items-Liste */
      html += '<div class="lt-stack-list">';
      html += '<h3 class="lt-stack-list__heading">Dein Stack <span>(' + c.items.length + ')</span></h3>';
      if (c.items.length === 0) {
        html += '<p class="lt-stack-list__empty">Noch leer. Wähle deine Wirkstoffe oben.</p>';
      } else {
        html += '<ul>';
        c.items.forEach(function(p) {
          html += '<li>'
                + '<span class="lt-stack-list__title">' + escape(p.title) + '</span>'
                + '<span class="lt-stack-list__price">' + fmt(p.priceCents) + '/Mo</span>'
                + '<button class="lt-stack-list__remove" data-remove="' + p.id + '" aria-label="' + escape(p.title) + ' entfernen" type="button">×</button>'
                + '</li>';
        });
        html += '</ul>';
      }
      html += '</div>';

      /* Totals */
      if (c.items.length > 0) {
        html += '<div class="lt-stack-totals">';
        html += '<div class="lt-stack-totals__row"><span>Zwischensumme (Abo)</span><span>' + fmt(c.subtotalAbo) + '</span></div>';
        if (c.tier) {
          html += '<div class="lt-stack-totals__row lt-stack-totals__discount"><span>Stack-Bonus (' + c.tier.code + ')</span><span>−' + fmt(c.stackDiscount) + '</span></div>';
        }
        html += '<div class="lt-stack-totals__row lt-stack-totals__total"><span>Monatlich</span><strong>' + fmt(c.total) + '</strong></div>';
        html += '</div>';
      }

      html += '</div>'; /* /.lt-stack-bar__details */

      /* CTA (immer sichtbar, auch collapsed) */
      html += '<button class="lt-stack-cta" data-stack-submit type="button"' + (c.items.length < 2 ? ' disabled' : '') + '>';
      if (c.items.length === 0)      html += 'Mindestens 2 Produkte wählen';
      else if (c.items.length === 1) html += 'Noch 1 Produkt für Stack-Bonus';
      else                            html += 'Stack abonnieren →';
      html += '</button>';

      html += '<p class="lt-stack-flex">Jederzeit pausierbar oder kündbar. Kostenloser Versand inklusive.</p>';

      html += '</div>'; /* /.lt-stack-bar */

      sidebar.innerHTML = html;
    }

    function rerender() {
      renderPane();
      renderSidebar();
      syncUrl();
    }

    /* Tab-Navigation: Klick auf "Nach Ziel" oder "Wirkstoffe wählen" */
    tabs.forEach(function(t) {
      t.addEventListener('click', function() {
        setTab(t.getAttribute('data-stack-tab'));
      });
    });

    /* Pane: Klicks auf Produkt-Cards, Hallmark-Cards, Bulk-Buttons + Produkt-Toggles */
    pane.addEventListener('click', function(e) {
      /* Produkt-Card im Wirkstoffe-Tab → Toggle Selection */
      var card = e.target.closest('[data-id]');
      if (card) {
        e.preventDefault();
        var id = parseInt(card.getAttribute('data-id'), 10);
        if (selected.has(id)) selected.delete(id);
        else selected.add(id);
        rerender();
        return;
      }
      /* Hallmark-Card → aktivieren, Detail-Panel öffnen */
      var hallmarkCard = e.target.closest('[data-hallmark]');
      if (hallmarkCard) {
        e.preventDefault();
        setActiveHallmark(hallmarkCard.getAttribute('data-hallmark'));
        return;
      }
      /* Bulk-Button im Detail-Panel → alle Hallmark-Produkte auf einmal */
      var bulkBtn = e.target.closest('[data-hallmark-bulk]');
      if (bulkBtn) {
        e.preventDefault();
        addAllFromHallmark(bulkBtn.getAttribute('data-hallmark-bulk'));
        return;
      }
      /* Einzel-Produkt-Toggle im Detail-Panel */
      var productToggle = e.target.closest('[data-product-toggle]');
      if (productToggle) {
        e.preventDefault();
        toggleProductFromHallmark(productToggle.getAttribute('data-product-toggle'));
        return;
      }
    });

    sidebar.addEventListener('click', function(e) {
      var rem = e.target.closest('[data-remove]');
      if (rem) {
        var id = parseInt(rem.getAttribute('data-remove'), 10);
        selected.delete(id);
        rerender();
        return;
      }
      var toggle = e.target.closest('[data-stack-toggle]');
      if (toggle) {
        toggleSheet();
        return;
      }
      var cta = e.target.closest('[data-stack-submit]');
      if (cta && !cta.disabled) submitStack();
    });

    /* Mobile-Bottom-Sheet: expand / collapse */
    function toggleSheet() {
      var expanded = sidebar.classList.toggle('is-expanded');
      var backdrop = document.querySelector('[data-stack-backdrop]');
      var toggle = sidebar.querySelector('[data-stack-toggle]');
      if (toggle) toggle.setAttribute('aria-expanded', expanded ? 'true' : 'false');
      if (backdrop) backdrop.hidden = !expanded;
      /* Body-Scroll lock im Expanded-State */
      document.body.style.overflow = expanded ? 'hidden' : '';
    }
    function collapseSheet() {
      if (!sidebar.classList.contains('is-expanded')) return;
      sidebar.classList.remove('is-expanded');
      var backdrop = document.querySelector('[data-stack-backdrop]');
      if (backdrop) backdrop.hidden = true;
      var toggle = sidebar.querySelector('[data-stack-toggle]');
      if (toggle) toggle.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }
    var backdropEl = document.querySelector('[data-stack-backdrop]');
    if (backdropEl) backdropEl.addEventListener('click', collapseSheet);
    /* Escape-Taste schließt das Sheet */
    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') collapseSheet();
    });

    async function submitStack() {
      var c = calc();
      if (c.items.length < 2 || !c.tier) return;
      var cta = sidebar.querySelector('[data-stack-submit]');
      cta.disabled = true;
      cta.textContent = 'Wird vorbereitet…';

      try {
        await fetch('/cart/clear.js', { method: 'POST' });
        var items = c.items.map(function(p) {
          var item = { id: p.variantId, quantity: 1 };
          if (p.sellingPlanId) item.selling_plan = p.sellingPlanId;
          return item;
        });
        var res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
          body: JSON.stringify({ items: items })
        });
        if (!res.ok) {
          var body = await res.text();
          throw new Error('cart/add ' + res.status + ': ' + body);
        }
        window.location.href = '/discount/' + c.tier.code + '?redirect=/checkout';
      } catch (err) {
        cta.disabled = false;
        cta.textContent = 'Erneut versuchen →';
        console.error('[lt-stack-builder]', err);
      }
    }

    rerender();
  })();
</script>

