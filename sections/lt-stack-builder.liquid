  .section-{{ section.id }}-stack .lt-stack-hallmark-detail__category {
    align-self: flex-start;
    background: var(--color-light-warm, #F6F4F1);
    color: var(--color-text-secondary, #525252);
    font-size: var(--text-micro, 12px);
    font-weight: var(--weight-semibold, 600);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 4px 10px;
    border-radius: var(--radius-full, 999px);
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-detail__category--primary { color: var(--color-promo, #E85D5D); }
  .section-{{ section.id }}-stack .lt-stack-hallmark-detail__category--antagonistic { color: var(--color-teal-dark, #4A8C85); }
  .section-{{ section.id }}-stack .lt-stack-hallmark-detail__category--integrative { color: var(--color-sand, #C7A39B); }
  .section-{{ section.id }}-stack .lt-stack-hallmark-detail__title {
    font-family: var(--font-heading, Helvetica);
    font-size: var(--text-h2, 28px);
    font-weight: var(--weight-bold, 700);
    line-height: var(--leading-heading, 1.15);
    margin: 0;
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-detail__desc {
    font-size: var(--text-body, 16px);
    color: var(--color-text-secondary, #525252);
    line-height: var(--leading-body, 1.4);
    margin: 0;
  }

  /* Wirkstoffe-Liste im Detail */
  .section-{{ section.id }}-stack .lt-stack-hallmark-detail__products {
    border-top: 1px solid var(--color-border-default, #E5E5E5);
    padding-top: var(--space-4, 16px);
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-detail__label {
    font-size: var(--text-body-sm, 14px);
    font-weight: var(--weight-semibold, 600);
    color: var(--color-text-secondary, #525252);
    margin: 0 0 var(--space-3, 12px);
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-detail__label span {
    color: var(--color-text-muted, #A3A3A3);
    font-weight: var(--weight-regular, 400);
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-detail__no-products {
    font-size: var(--text-body-sm, 14px);
    color: var(--color-text-muted, #A3A3A3);
    line-height: 1.5;
    margin: 0;
    padding: var(--space-3, 12px);
    background: var(--color-light-warm, #F6F4F1);
    border-radius: var(--radius-sm, 8px);
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-detail__product-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-3, 12px);
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 8px);
  }

  .section-{{ section.id }}-stack .lt-stack-hallmark-product {
    display: grid;
    grid-template-columns: 28px 1fr auto;
    align-items: center;
    gap: var(--space-3, 12px);
    width: 100%;
    padding: 10px var(--space-3, 12px);
    background: #fff;
    border: 1px solid var(--color-border-default, #E5E5E5);
    border-radius: var(--radius-sm, 8px);
    cursor: pointer;
    text-align: left;
    transition: border-color var(--ease-default, 0.2s ease), background var(--ease-default, 0.2s ease);
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-product:hover {
    border-color: var(--color-dark, #364F56);
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-product.is-in-stack {
    border-color: var(--color-success, #22C55E);
    background: rgba(34, 197, 94, 0.06);
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-product__icon {
    width: 24px;
    height: 24px;
    border-radius: var(--radius-full, 999px);
    background: var(--color-light-warm, #F6F4F1);
    color: var(--color-text-secondary, #525252);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    font-weight: var(--weight-bold, 700);
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-product.is-in-stack .lt-stack-hallmark-product__icon {
    background: var(--color-success, #22C55E);
    color: #fff;
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-product__title {
    font-size: var(--text-body-sm, 14px);
    font-weight: var(--weight-semibold, 600);
    color: var(--color-text-primary, #000);
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-product__price {
    font-size: var(--text-body-sm, 14px);
    color: var(--color-text-muted, #A3A3A3);
    white-space: nowrap;
  }

  .section-{{ section.id }}-stack .lt-stack-hallmark-bulk {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 44px;
    padding: 0 var(--space-5, 24px);
    border: 1px solid var(--color-dark, #364F56);
    background: transparent;
    color: var(--color-dark, #364F56);
    border-radius: var(--radius-full, 999px);
    font-family: var(--font-body, 'Lato');
    font-size: var(--text-body-sm, 14px);
    font-weight: var(--weight-semibold, 600);
    cursor: pointer;
    transition: background var(--ease-default, 0.2s ease), color var(--ease-default, 0.2s ease);
  }
  .section-{{ section.id }}-stack .lt-stack-hallmark-bulk:hover {
    background: var(--color-dark, #364F56);
    color: #fff;
  }

  /* Produktgrid */
  .section-{{ section.id }}-stack .lt-stack-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-4, 16px);
  }
  @media (max-width: 1023px) {
    .section-{{ section.id }}-stack .lt-stack-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .section-{{ section.id }}-stack .lt-stack-grid { grid-template-columns: 1fr; }
  }
  .section-{{ section.id }}-stack .lt-stack-loading {
    grid-column: 1 / -1;
    text-align: center;
    color: var(--color-text-muted, #A3A3A3);
    padding: var(--space-7, 48px) 0;
  }

  /* Card */
  .section-{{ section.id }}-stack .lt-stack-card {
    position: relative;
    display: flex;
    flex-direction: column;
    text-align: left;
    background: #fff;
    border: 1px solid var(--color-border-default, #E5E5E5);
    border-radius: var(--radius-md, 12px);
    padding: var(--space-4, 16px);
    cursor: pointer;
    transition: border-color var(--ease-default, 0.2s ease), transform var(--ease-default, 0.2s ease), box-shadow var(--ease-default, 0.2s ease);
  }
  .section-{{ section.id }}-stack .lt-stack-card:hover {
    border-color: var(--color-dark, #364F56);
    box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,0.05));
  }
  .section-{{ section.id }}-stack .lt-stack-card.is-selected {
    border-color: var(--color-dark, #364F56);
    box-shadow: 0 0 0 2px var(--color-dark, #364F56);
  }
  .section-{{ section.id }}-stack .lt-stack-card__check {
    position: absolute;
    top: var(--space-3, 12px);
    right: var(--space-3, 12px);
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full, 999px);
    border: 1px solid var(--color-border-default, #E5E5E5);
    background: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    font-weight: var(--weight-bold, 700);
    color: var(--color-text-muted, #A3A3A3);
    transition: all var(--ease-default, 0.2s ease);
  }
  .section-{{ section.id }}-stack .lt-stack-card.is-selected .lt-stack-card__check {
    background: var(--color-dark, #364F56);
    color: #fff;
    border-color: var(--color-dark, #364F56);
  }
  .section-{{ section.id }}-stack .lt-stack-card__media {
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-4, 16px);
  }
  .section-{{ section.id }}-stack .lt-stack-card__media img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .section-{{ section.id }}-stack .lt-stack-card__body { flex: 1; }
  .section-{{ section.id }}-stack .lt-stack-card h3 {
    font-family: var(--font-heading, Helvetica);
    font-size: var(--text-h3, 24px);
    font-weight: var(--weight-bold, 700);
    margin: 0 0 var(--space-2, 8px);
    line-height: 1.2;
  }
  .section-{{ section.id }}-stack .lt-stack-card__claim {
    font-size: var(--text-body-sm, 14px);
    font-weight: var(--weight-semibold, 600);
    color: var(--color-text-primary, #000);
    margin: 0 0 var(--space-2, 8px);
    line-height: 1.4;
  }
  .section-{{ section.id }}-stack .lt-stack-card__wirkweise {
    font-size: var(--text-body-sm, 14px);
    color: var(--color-text-secondary, #525252);
    margin: 0 0 var(--space-3, 12px);
    line-height: var(--leading-body, 1.4);
  }
  .section-{{ section.id }}-stack .lt-stack-card__portion {
    font-size: var(--text-micro, 12px);
    color: var(--color-text-muted, #A3A3A3);
    margin: 0 0 var(--space-3, 12px);
  }
  .section-{{ section.id }}-stack .lt-stack-card__price {
    font-size: var(--text-body-lg, 18px);
    font-weight: var(--weight-semibold, 600);
    margin: 0 0 var(--space-4, 16px);
  }
  .section-{{ section.id }}-stack .lt-stack-card__price small {
    font-weight: var(--weight-regular, 400);
    color: var(--color-text-muted, #A3A3A3);
    font-size: var(--text-body-sm, 14px);
  }
  .section-{{ section.id }}-stack .lt-stack-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 44px;
    border-radius: var(--radius-full, 999px);
    border: 1px solid var(--color-dark, #364F56);
    color: var(--color-dark, #364F56);
    font-family: var(--font-body, 'Lato');
    font-size: var(--text-body-sm, 14px);
    font-weight: var(--weight-semibold, 600);
    background: transparent;
    transition: all var(--ease-default, 0.2s ease);
  }
  .section-{{ section.id }}-stack .lt-stack-card.is-selected .lt-stack-card__cta {
    background: var(--color-dark, #364F56);
    color: #fff;
  }

  /* ---- Mobile-Card-Anpassungen ---- */

  /* Tablet / mittlere Mobile-Breiten (481-1023): Bild kleiner, kein 1:1 mehr */
  @media (max-width: 1023px) and (min-width: 481px) {
    .section-{{ section.id }}-stack .lt-stack-card__media {
      aspect-ratio: 4 / 3;
      max-height: 140px;
    }
    .section-{{ section.id }}-stack .lt-stack-card h3 {
      font-size: var(--text-section, 20px);
    }
  }

  /* Kleine Mobile (≤480, 1-Spalten-Grid): Card horizontal mit kompaktem Bild */
  @media (max-width: 480px) {
    .section-{{ section.id }}-stack .lt-stack-card {
      display: grid;
      grid-template-columns: 96px 1fr;
      grid-template-rows: auto auto;
      gap: var(--space-3, 12px);
      padding: var(--space-4, 16px);
    }
    .section-{{ section.id }}-stack .lt-stack-card__check {
      top: var(--space-2, 8px);
      right: var(--space-2, 8px);
      width: 24px;
      height: 24px;
      font-size: 14px;
    }
    .section-{{ section.id }}-stack .lt-stack-card__media {
      grid-column: 1;
      grid-row: 1;
      aspect-ratio: 1 / 1;
      width: 96px;
      height: 96px;
      margin-bottom: 0;
    }
    .section-{{ section.id }}-stack .lt-stack-card__body {
      grid-column: 2;
      grid-row: 1;
      padding-right: 32px; /* Platz für Check-Badge oben rechts */
    }
    .section-{{ section.id }}-stack .lt-stack-card h3 {
      font-size: var(--text-body-lg, 18px);
      margin-bottom: 4px;
    }
    .section-{{ section.id }}-stack .lt-stack-card__claim {
      margin-bottom: 4px;
    }
    .section-{{ section.id }}-stack .lt-stack-card__wirkweise {
      margin-bottom: 6px;
      font-size: var(--text-body-sm, 14px);
    }
    .section-{{ section.id }}-stack .lt-stack-card__portion {
      margin-bottom: 6px;
    }
    .section-{{ section.id }}-stack .lt-stack-card__price {
      margin-bottom: 0;
      font-size: var(--text-body, 16px);
    }
    .section-{{ section.id }}-stack .lt-stack-card__cta {
      grid-column: 1 / -1;
      grid-row: 2;
    }
  }

  /* ============================================================
     Sidebar / Bottom-Sheet
     ------------------------------------------------------------
     Desktop (≥1024px): klassische sticky Sidebar rechts.
     Mobile (<1024px): fixed-bottom Sheet, kollabiert per Default,
     expandiert via .is-expanded Klasse mit Backdrop.
     ============================================================ */

  /* Desktop-Default */
  .section-{{ section.id }}-stack .lt-stack-sidebar {
    position: sticky;
    top: var(--space-7, 48px);
  }
  .section-{{ section.id }}-stack .lt-stack-bar {
    background: #fff;
    border: 1px solid var(--color-border-default, #E5E5E5);
    border-radius: var(--radius-md, 12px);
    padding: var(--space-5, 24px);
    box-shadow: var(--shadow-md, 0 4px 12px rgba(0,0,0,0.08));
  }

  /* Toggle-Header: Desktop hidden */
  .section-{{ section.id }}-stack .lt-stack-sheet-toggle { display: none; }

  /* Backdrop: immer hidden, sofern nicht vom JS via Attribut entfernt */
  .lt-stack-backdrop { display: none; }
  .lt-stack-backdrop[hidden] { display: none !important; }

  /* ---- Mobile: Bottom-Sheet-Pattern ---- */
  @media (max-width: 1023px) {
    .section-{{ section.id }}-stack .lt-stack-sidebar {
      position: fixed;
      left: 0;
      right: 0;
      bottom: 0;
      top: auto;
      z-index: 50;
      background: #fff;
      border-radius: var(--radius-lg, 16px) var(--radius-lg, 16px) 0 0;
      box-shadow: 0 -8px 24px rgba(0, 0, 0, 0.12);
      padding: 0;
      max-height: 80vh;
      display: flex;
      flex-direction: column;
      transition: transform var(--ease-smooth, 0.4s ease);
    }
    /* Toggle = Sheet-Header */
    .section-{{ section.id }}-stack .lt-stack-sheet-toggle {
      display: grid;
      grid-template-columns: 1fr auto;
      align-items: center;
      gap: var(--space-3, 12px);
      width: 100%;
      padding: 22px var(--space-5, 24px) var(--space-3, 12px);
      border: none;
      background: transparent;
      text-align: left;
      cursor: pointer;
      position: relative;
      flex-shrink: 0;
    }
    /* Drag-Handle visuell */
    .section-{{ section.id }}-stack .lt-stack-sheet-toggle__handle {
      position: absolute;
      top: 8px;
      left: 50%;
      transform: translateX(-50%);
      width: 36px;
      height: 4px;
      border-radius: 2px;
      background: var(--color-gray-200, #E5E5E5);
    }
    .section-{{ section.id }}-stack .lt-stack-sheet-toggle__summary {
      display: flex;
      flex-direction: column;
      gap: 2px;
      min-width: 0;
    }
    .section-{{ section.id }}-stack .lt-stack-sheet-toggle__count {
      font-family: var(--font-body, 'Lato');
      font-size: var(--text-micro, 12px);
      font-weight: var(--weight-medium, 500);
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--color-text-muted, #A3A3A3);
    }
    .section-{{ section.id }}-stack .lt-stack-sheet-toggle__total {
      font-family: var(--font-body, 'Lato');
      font-size: var(--text-body-lg, 18px);
      font-weight: var(--weight-bold, 700);
      color: var(--color-text-primary, #000);
    }
    .section-{{ section.id }}-stack .lt-stack-sheet-toggle__chevron {
      width: 32px;
      height: 32px;
      border-radius: var(--radius-full, 999px);
      background: var(--color-light-warm, #F6F4F1);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 18px;
      color: var(--color-text-secondary, #525252);
      transform: rotate(-90deg); /* zeigt nach oben — "expand" */
      transition: transform var(--ease-default, 0.2s ease);
    }
    .section-{{ section.id }}-stack .lt-stack-sidebar.is-expanded .lt-stack-sheet-toggle__chevron {
      transform: rotate(90deg); /* zeigt nach unten — "collapse" */
    }

    /* Bar-Wrapper: kein Border mehr (Sheet hat schon Radius/Shadow am Sidebar) */
    .section-{{ section.id }}-stack .lt-stack-bar {
      border: none;
      border-radius: 0;
      box-shadow: none;
      padding: 0 var(--space-5, 24px) max(var(--space-5, 24px), env(safe-area-inset-bottom, 0px));
      flex: 1;
      overflow-y: auto;
      -webkit-overflow-scrolling: touch;
    }

    /* Details (Items + Totals): collapsed = hidden, expanded = sichtbar */
    .section-{{ section.id }}-stack .lt-stack-sidebar:not(.is-expanded) .lt-stack-bar__details {
      display: none;
    }

    /* Backdrop nur sichtbar, wenn JS [hidden] entfernt hat (d.h. expanded) */
    .lt-stack-backdrop:not([hidden]) {
      display: block;
      position: fixed;
      inset: 0;
      background: rgba(0, 0, 0, 0.4);
      z-index: 49;
      animation: lt-stack-backdrop-in 0.25s ease;
    }
    @keyframes lt-stack-backdrop-in {
      from { opacity: 0; }
      to   { opacity: 1; }
    }

    /* Collapsed-Sheet ist ~180px hoch — Layout braucht Padding-Bottom,
       damit das letzte Produkt nicht unter dem Sheet liegt */
    .section-{{ section.id }}-stack .lt-stack-layout {
      padding-bottom: 200px;
    }
  }

  .section-{{ section.id }}-stack .lt-stack-progress { margin-bottom: var(--space-5, 24px); }
  .section-{{ section.id }}-stack .lt-stack-progress__bar {
    height: 6px;
    background: var(--color-gray-200, #E5E5E5);
    border-radius: var(--radius-full, 999px);
    overflow: hidden;
    margin-bottom: var(--space-2, 8px);
  }
  .section-{{ section.id }}-stack .lt-stack-progress__bar span {
    display: block;
    height: 100%;
    background: var(--color-dark, #364F56);
    transition: width var(--ease-smooth, 0.4s ease);
  }
  .section-{{ section.id }}-stack .lt-stack-progress__hint {
    font-size: var(--text-body-sm, 14px);
    margin: 0;
    color: var(--color-text-secondary, #525252);
  }
  .section-{{ section.id }}-stack .lt-stack-progress__hint strong {
    color: var(--color-text-primary, #000);
    font-weight: var(--weight-semibold, 600);
  }

  .section-{{ section.id }}-stack .lt-stack-list { margin-bottom: var(--space-5, 24px); }
  .section-{{ section.id }}-stack .lt-stack-list__heading {
    font-family: var(--font-heading, Helvetica);
    font-size: var(--text-section, 20px);
    font-weight: var(--weight-bold, 700);
    margin: 0 0 var(--space-3, 12px);
  }
  .section-{{ section.id }}-stack .lt-stack-list__heading span {
    color: var(--color-text-muted, #A3A3A3);
    font-weight: var(--weight-regular, 400);
  }
  .section-{{ section.id }}-stack .lt-stack-list__empty {
    font-size: var(--text-body-sm, 14px);
    color: var(--color-text-muted, #A3A3A3);
    margin: 0;
  }
  .section-{{ section.id }}-stack .lt-stack-list ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 8px);
  }
  .section-{{ section.id }}-stack .lt-stack-list li {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: var(--space-3, 12px);
    font-size: var(--text-body-sm, 14px);
  }
  .section-{{ section.id }}-stack .lt-stack-list__title { color: var(--color-text-primary, #000); }
  .section-{{ section.id }}-stack .lt-stack-list__price { color: var(--color-text-muted, #A3A3A3); white-space: nowrap; }
  .section-{{ section.id }}-stack .lt-stack-list__remove {
    width: 22px; height: 22px; min-width: 22px;
    border-radius: var(--radius-full, 999px);
    border: none;
    background: var(--color-gray-200, #E5E5E5);
    color: var(--color-text-secondary, #525252);
    cursor: pointer;
    font-size: 16px;
    line-height: 1;
    padding: 0;
  }
  .section-{{ section.id }}-stack .lt-stack-list__remove:hover { background: var(--color-text-secondary, #525252); color: #fff; }

  .section-{{ section.id }}-stack .lt-stack-totals {
    border-top: 1px solid var(--color-border-default, #E5E5E5);
    padding-top: var(--space-4, 16px);
    margin-bottom: var(--space-4, 16px);
    font-size: var(--text-body-sm, 14px);
    display: flex;
    flex-direction: column;
    gap: var(--space-2, 8px);
  }
  .section-{{ section.id }}-stack .lt-stack-totals__row {
    display: flex;
    justify-content: space-between;
  }
  .section-{{ section.id }}-stack .lt-stack-totals__discount { color: var(--color-success, #22C55E); }
  .section-{{ section.id }}-stack .lt-stack-totals__total {
    border-top: 1px solid var(--color-border-default, #E5E5E5);
    padding-top: var(--space-3, 12px);
    margin-top: var(--space-2, 8px);
    font-size: var(--text-body-lg, 18px);
  }
  .section-{{ section.id }}-stack .lt-stack-totals__total strong {
    font-weight: var(--weight-bold, 700);
  }

  .section-{{ section.id }}-stack .lt-stack-cta {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    border-radius: var(--radius-full, 999px);
    border: none;
    background: var(--color-dark, #364F56);
    color: #fff;
    font-family: var(--font-body, 'Lato');
    font-size: var(--text-body-sm, 14px);
    font-weight: var(--weight-semibold, 600);
    cursor: pointer;
    transition: opacity var(--ease-default, 0.2s ease);
  }
  .section-{{ section.id }}-stack .lt-stack-cta:hover:not([disabled]) { opacity: 0.92; }
  .section-{{ section.id }}-stack .lt-stack-cta[disabled] {
    background: var(--color-gray-200, #E5E5E5);
