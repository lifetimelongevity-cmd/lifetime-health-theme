{% comment %}
  lt-hp-cta-close
  Surface: dark close
  Dominant element: conviction headline followed by the buy row
  CTA: primary product CTA
  Quality move: the CTA sits in the same horizontal decision row as the final price, so the section reads like a calm buy box instead of a promo banner
{% endcomment %}

{%- liquid
  assign hp_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign hp_headline_lg = true
  endif

  assign has_setting_trust = false
  if section.settings.trust_1 != blank or section.settings.trust_2 != blank or section.settings.trust_3 != blank or section.settings.trust_4 != blank
    assign has_setting_trust = true
  endif

  assign has_block_trust = false
  if section.blocks.size > 0
    assign has_block_trust = true
  endif
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    --ctac-bg: {{ section.settings.color_bg | default: '#26251e' }};
    --ctac-text: {{ section.settings.color_text | default: '#f7f7f4' }};
    --ctac-text-muted: {{ section.settings.color_text | default: '#f7f7f4' | color_modify: 'alpha', 0.68 }};
    --ctac-border: {{ section.settings.color_text | default: '#f7f7f4' | color_modify: 'alpha', 0.12 }};
    --ctac-accent: {{ section.settings.color_accent | default: '#2a6b5c' }};
    background: var(--ctac-bg);
    color: var(--ctac-text);
    padding-top: {{ section.settings.padding_top | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
  }
{% endstyle %}

<section id="lt-hp-cta-close-{{ section.id }}" class="ctac">
  <div class="ctac__container">
    <div class="ctac__header crs-heading-stack crs-heading-stack--align-center{% if hp_headline_lg %} crs-heading-stack--headline-lg{% endif %} crs-heading-stack--on-dark crs-heading-stack--homepage-truth">
      {%- if section.settings.kicker != blank and section.settings.kicker != '__none__' -%}
        <p class="crs-heading-stack__kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      <div class="crs-heading-stack__pair">
        {%- if section.settings.headline != blank -%}
          <h2 class="crs-heading-stack__title">{{ section.settings.headline | escape | newline_to_br }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank and section.settings.subheading != '__none__' -%}
          <p class="crs-heading-stack__subtitle">{{ section.settings.subheading | escape | newline_to_br }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.price_display != blank or section.settings.cta_label != blank or section.settings.price_fallback != blank -%}
      <div class="ctac__buybox">
        {%- if section.settings.price_display != blank or section.settings.cta_label != blank -%}
          <div class="ctac__buybox-row">
            <div class="ctac__price-group">
              {%- if section.settings.price_display != blank -%}
                <p class="ctac__price-display">{{ section.settings.price_display | escape }}</p>
              {%- elsif section.settings.price_fallback != blank -%}
                <p class="ctac__price-display">{{ section.settings.price_fallback | escape }}</p>
              {%- endif -%}

              {%- if section.settings.price_subline != blank -%}
                <p class="ctac__price-subline ctac__price-subline--mobile">{{ section.settings.price_subline | escape }}</p>
              {%- endif -%}
            </div>

            {%- if section.settings.cta_label != blank -%}
              <a href="{{ section.settings.cta_url | default: '/products/lifetime-age-dna' }}" class="ctac__cta-primary">
                {{ section.settings.cta_label | escape }}
              </a>
            {%- endif -%}
          </div>

          {%- if section.settings.price_subline != blank -%}
            <p class="ctac__price-subline ctac__price-subline--desktop">{{ section.settings.price_subline | escape }}</p>
          {%- endif -%}
        {%- elsif section.settings.price_fallback != blank -%}
          <p class="ctac__price-fallback">{{ section.settings.price_fallback | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.badge_text != blank -%}
      <p class="ctac__badge">{{ section.settings.badge_text | escape }}</p>
    {%- endif -%}

    {%- if section.settings.cta_secondary_label != blank and section.settings.cta_secondary_url != blank -%}
      <a href="{{ section.settings.cta_secondary_url }}" class="ctac__cta-secondary">
        {{ section.settings.cta_secondary_label | escape }}
      </a>
    {%- endif -%}

    {%- if section.settings.show_trust_row -%}
      {%- if has_setting_trust -%}
        <ul class="ctac__trust-row" aria-label="Vertrauens-Merkmale">
          {%- if section.settings.trust_1 != blank -%}<li>{{ section.settings.trust_1 | escape }}</li>{%- endif -%}
          {%- if section.settings.trust_2 != blank -%}<li>{{ section.settings.trust_2 | escape }}</li>{%- endif -%}
          {%- if section.settings.trust_3 != blank -%}<li>{{ section.settings.trust_3 | escape }}</li>{%- endif -%}
          {%- if section.settings.trust_4 != blank -%}<li>{{ section.settings.trust_4 | escape }}</li>{%- endif -%}
        </ul>
      {%- elsif has_block_trust -%}
        <ul class="ctac__trust-row" aria-label="Vertrauens-Merkmale">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_line' and block.settings.text != blank -%}
              <li {{ block.shopify_attributes }}>{{ block.settings.text | escape }}</li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
.ctac {
  background: var(--ctac-bg);
  color: var(--ctac-text);
}

.ctac__container {
  max-width: 52rem;
  margin: 0 auto;
  padding-inline-start: var(--gutter-container);
  padding-inline-end: var(--gutter-container);
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
  text-align: center;
}

@supports (padding: max(0px)) {
  .ctac__container {
    padding-inline-start: max(var(--gutter-container), env(safe-area-inset-left));
    padding-inline-end: max(var(--gutter-container), env(safe-area-inset-right));
  }
}

.ctac__buybox {
  display: grid;
  gap: var(--space-3);
  padding-block: var(--space-5);
  border-top: 1px solid var(--ctac-border);
  border-bottom: 1px solid var(--ctac-border);
}

.ctac__buybox-row {
  display: grid;
  gap: var(--space-4);
  align-items: center;
}

.ctac__price-group {
  min-width: 0;
}

.ctac__price-display,
.ctac__price-fallback,
.ctac__price-subline,
.ctac__badge {
  margin: 0;
}

.ctac__price-display {
  font-family: var(--font-heading);
  font-size: clamp(var(--text-h2), 5vw, var(--text-display));
  font-weight: var(--weight-bold);
  line-height: var(--leading-heading);
  color: var(--ctac-text);
}

.ctac__price-fallback {
  font-family: var(--font-body);
  font-size: var(--text-body-lg);
  font-weight: var(--weight-medium);
  line-height: var(--leading-body);
  color: var(--ctac-text);
}

.ctac__price-subline {
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  line-height: var(--leading-body);
  color: var(--ctac-text-muted);
}

.ctac__price-subline--mobile {
  margin-top: var(--space-2);
}

.ctac__price-subline--desktop {
  display: none;
}

.ctac__cta-primary,
.ctac__cta-secondary {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48px;
  padding: 0.875rem var(--space-7);
  border-radius: var(--radius-full);
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-body);
  text-decoration: none;
  transition: opacity var(--ease-default), border-color var(--ease-default), color var(--ease-default);
}

.ctac__cta-primary {
  width: 100%;
  background: var(--ctac-accent);
  border: 1px solid var(--ctac-accent);
  color: var(--color-white);
}

.ctac__cta-primary:hover,
.ctac__cta-primary:focus-visible {
  opacity: 0.9;
}

.ctac__cta-secondary {
  align-self: center;
  border: 1px solid var(--ctac-border);
  color: var(--ctac-text);
}

.ctac__cta-secondary:hover,
.ctac__cta-secondary:focus-visible {
  border-color: var(--ctac-text);
}

.ctac__badge {
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  line-height: var(--leading-body);
  color: var(--ctac-text-muted);
}

.ctac__trust-row {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: var(--space-3);
  margin: 0;
  padding: 0;
  list-style: none;
  font-family: var(--font-body);
  font-size: var(--text-micro);
  line-height: var(--leading-body);
  color: var(--ctac-text-muted);
}

.ctac__trust-row li {
  position: relative;
  padding-inline-end: var(--space-3);
}

.ctac__trust-row li:not(:last-child)::after {
  content: "·";
  position: absolute;
  inset-inline-end: calc(var(--space-1) * -0.5);
}

@media screen and (min-width: 750px) {
  .ctac__buybox-row {
    grid-template-columns: minmax(0, 1fr) auto;
    text-align: start;
  }

  .ctac__cta-primary {
    width: auto;
    min-width: 14rem;
  }

  .ctac__price-subline--mobile {
    display: none;
  }

  .ctac__price-subline--desktop {
    display: block;
    text-align: start;
  }
}
{% endstylesheet %}

{% schema %}
{
