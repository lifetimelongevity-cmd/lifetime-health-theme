      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 200,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Hintergrundfarbe",
      "default": "#26251e"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund"
    },
    {
