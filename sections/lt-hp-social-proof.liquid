{% comment %} lt-hp-social-proof — Stub. Liquid pending. {% endcomment %}

{% schema %}
{
  "name": "HP Social Proof",
  "settings": [
    { "type": "color", "id": "color_bg", "label": "Hintergrundfarbe" },
    { "type": "color", "id": "color_text", "label": "Textfarbe" },
    { "type": "range", "id": "padding_top", "label": "Abstand oben", "min": 0, "max": 200, "step": 8, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Abstand unten", "min": 0, "max": 200, "step": 8, "default": 80, "unit": "px" },
    { "type": "text", "id": "kicker", "label": "Kicker" },
    { "type": "text", "id": "headline", "label": "Headline" },
    { "type": "text", "id": "aggregate_stat_number", "label": "Aggregat-Stat Zahl" },
    { "type": "textarea", "id": "aggregate_stat_label", "label": "Aggregat-Stat Label" },
    { "type": "checkbox", "id": "show_press_logos", "label": "Presse-Logos anzeigen", "default": true }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        { "type": "textarea", "id": "quote", "label": "Zitat" },
        { "type": "text", "id": "name", "label": "Name" },
        { "type": "text", "id": "age", "label": "Alter" },
        { "type": "text", "id": "result_metric", "label": "Ergebnis-Metrik" },
        { "type": "checkbox", "id": "verified", "label": "Verifiziert", "default": true }
      ]
    },
    {
      "type": "press_logo",
      "name": "Presse-Logo",
      "settings": [
        { "type": "text", "id": "logo_image_url", "label": "Logo URL" },
        { "type": "text", "id": "logo_alt", "label": "Alt-Text" },
        { "type": "url", "id": "logo_link_url", "label": "Link" }
      ]
    }
  ],
  "presets": [{ "name": "HP Social Proof" }]
}
{% endschema %}
