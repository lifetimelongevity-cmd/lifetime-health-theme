{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_lct_kicker = section.settings.kicker | strip
  assign crs_lct_head = section.settings.headline | strip
  assign crs_lct_sub = section.settings.subheading | strip
  if crs_lct_kicker == '__none__'
    assign crs_lct_kicker = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.05 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="tl-section lct-section" id="section-{{ section.id }}">
  <div class="tl-container lct-container">
    {%- if crs_lct_kicker != blank or crs_lct_head != blank or crs_lct_sub != blank -%}
      <div class="tl-header lct-header crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
        {%- if crs_lct_kicker != blank -%}
          <p class="crs-heading-stack__kicker">{{ crs_lct_kicker | escape }}</p>
        {%- endif -%}
        {%- if crs_lct_head != blank or crs_lct_sub != blank -%}
          <div class="crs-heading-stack__pair">
            {%- if crs_lct_head != blank -%}
              <h2 class="crs-heading-stack__title">{{ crs_lct_head | escape | newline_to_br }}</h2>
            {%- endif -%}
            {%- if crs_lct_sub != blank -%}
              <p class="crs-heading-stack__subtitle">{{ crs_lct_sub | escape | newline_to_br }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="lct-scroll">
      <div
        class="lct-table"
        role="region"
        aria-label="{{ section.settings.headline | default: 'Produktvergleich' | escape }}"
      >
        {%- liquid
          assign rh1 = section.settings.first_row_heading
          assign rh2 = section.settings.second_row_heading
          assign rh3 = section.settings.third_row_heading
          assign rh4 = section.settings.fourth_row_heading
          assign rh5 = section.settings.fifth_row_heading
          assign rh6 = section.settings.sixth_row_heading
        -%}

        <div class="lct-col lct-col--labels active">
          <div class="lct-row lct-row--head"></div>
          {%- if rh1 != blank -%}
            <div class="lct-row lct-row--label"><p class="lct-row-heading">{{ rh1 | escape }}</p></div>
          {%- endif -%}
          {%- if rh2 != blank -%}
            <div class="lct-row lct-row--label"><p class="lct-row-heading">{{ rh2 | escape }}</p></div>
          {%- endif -%}
          {%- if rh3 != blank -%}
            <div class="lct-row lct-row--label"><p class="lct-row-heading">{{ rh3 | escape }}</p></div>
          {%- endif -%}
          {%- if rh4 != blank -%}
            <div class="lct-row lct-row--label"><p class="lct-row-heading">{{ rh4 | escape }}</p></div>
          {%- endif -%}
          {%- if rh5 != blank -%}
            <div class="lct-row lct-row--label"><p class="lct-row-heading">{{ rh5 | escape }}</p></div>
          {%- endif -%}
          {%- if rh6 != blank -%}
            <div class="lct-row lct-row--label"><p class="lct-row-heading">{{ rh6 | escape }}</p></div>
          {%- endif -%}
        </div>

        {%- assign first_data_col = true -%}
        {%- for block in section.blocks -%}
          {%- if block.type == 'column' -%}
            <div
              class="lct-col{% if first_data_col %} active{% endif %}"
              {{ block.shopify_attributes }}
            >
              {%- assign first_data_col = false -%}
              <div class="lct-row lct-row--head lct-row--col-head">
                {%- if block.settings.column_heading_image != blank -%}
                  {%- assign lct_ch_alt = block.settings.column_heading_image.alt | default: '' | escape -%}
                  <div class="lct-col-head-img">
                    {{
                      block.settings.column_heading_image
                      | image_url: width: 240
                      | image_tag: loading: 'lazy', class: 'lct-col-head-img__el', alt: lct_ch_alt
                    }}
                  </div>
                {%- endif -%}
                {%- if block.settings.column_heading != blank -%}
                  <p class="lct-col-heading">{{ block.settings.column_heading | escape }}</p>
                {%- endif -%}
              </div>
              {%- if rh1 != blank -%}{% render 'lt-comparison-value-cell', block: block, row: 1 %}{% endif -%}
              {%- if rh2 != blank -%}{% render 'lt-comparison-value-cell', block: block, row: 2 %}{% endif -%}
              {%- if rh3 != blank -%}{% render 'lt-comparison-value-cell', block: block, row: 3 %}{% endif -%}
              {%- if rh4 != blank -%}{% render 'lt-comparison-value-cell', block: block, row: 4 %}{% endif -%}
              {%- if rh5 != blank -%}{% render 'lt-comparison-value-cell', block: block, row: 5 %}{% endif -%}
              {%- if rh6 != blank -%}{% render 'lt-comparison-value-cell', block: block, row: 6 %}{% endif -%}
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% stylesheet %}
/* LT Comparison Table — aligns with crs-timeline header + crs color tokens */

.lct-section.tl-section {
  background: var(--crs-bg, #f7f7f4);
}

.lct-container.tl-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 var(--space-5);
}

.lct-header.tl-header {
  margin-bottom: var(--space-7);
  max-width: 48rem;
}

.lct-scroll {
  overflow-x: auto;
  scrollbar-width: none;
  margin-left: calc(-1 * var(--space-5));
  margin-right: calc(-1 * var(--space-5));
  padding-left: var(--space-5);
  padding-right: var(--space-5);
  -webkit-overflow-scrolling: touch;
}

.lct-scroll::-webkit-scrollbar {
  display: none;
}

.lct-table {
  display: flex;
  flex-wrap: nowrap;
  width: max-content;
  min-width: 100%;
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.06));
  border-radius: var(--radius-md);
  overflow: hidden;
  background: var(--crs-bg, #f7f7f4);
}

.lct-col {
  flex: 1 0 min(28vw, 200px);
  min-width: 132px;
  display: flex;
  flex-direction: column;
  border-left: 1px solid var(--crs-border, rgba(38, 37, 30, 0.06));
}

.lct-col:first-child {
  border-left: none;
}

.lct-col--labels {
  flex: 0 0 min(32vw, 220px);
  min-width: 112px;
  background: var(--crs-card-bg, #f2f1ed);
}

.lct-col.active {
  background: var(--crs-card-bg, #f2f1ed);
}

.lct-row {
  display: flex;
  align-items: center;
  gap: var(--space-3);
  min-height: 3.5rem;
  padding: var(--space-3) var(--space-4);
  border-top: 1px solid var(--crs-border, rgba(38, 37, 30, 0.06));
}

.lct-row--head {
  border-top: none;
  min-height: 4.5rem;
  align-items: center;
  justify-content: center;
  text-align: center;
}

.lct-col--labels .lct-row--head {
  min-height: 4.5rem;
}

.lct-row--col-head {
  flex-direction: column;
  gap: var(--space-2);
}

.lct-col-head-img {
  max-height: 40px;
  width: auto;
}

.lct-col-head-img__el {
  display: block;
  max-height: 40px;
  width: auto;
  object-fit: contain;
}

.lct-col-heading {
  margin: 0;
  font-family: var(--font-heading);
  font-size: var(--text-body);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-tight);
  color: var(--crs-text, #26251e);
}

.lct-col.active .lct-col-heading {
  font-size: var(--text-section);
}

.lct-row-heading {
  margin: 0;
  font-size: var(--text-body-sm);
  font-weight: var(--weight-medium);
  line-height: var(--leading-body);
  color: var(--crs-text, #26251e);
}

.lct-row--body {
  justify-content: flex-start;
}

.lct-value-icon {
  flex-shrink: 0;
  color: var(--crs-text, #26251e);
  display: flex;
  align-items: center;
  justify-content: center;
}

.lct-value-icon--img .lct-value-icon__img {
  width: 20px;
  height: 20px;
  object-fit: contain;
}

.lct-value-text {
  margin: 0;
  font-size: var(--text-body-sm);
  line-height: var(--leading-body);
  color: var(--crs-text-sec, rgba(38, 37, 30, 0.6));
}

.lct-col.active .lct-value-text {
  color: var(--crs-text, #26251e);
}

@media (min-width: 1024px) {
  .lct-scroll {
    overflow-x: visible;
    margin-left: 0;
    margin-right: 0;
    padding-left: 0;
    padding-right: 0;
  }

  .lct-table {
    width: 100%;
    min-width: 0;
  }

  .lct-col--labels {
    flex: 0 0 30%;
    max-width: 320px;
  }

  .lct-col:not(.lct-col--labels) {
    flex: 1 1 0;
    min-width: 0;
  }
}
{% endstylesheet %}

{% schema %}
