      "type": "text",
      "id": "first_row_heading",
      "label": "Zeile 1",
      "default": "Reinheit"
    },
    {
      "type": "text",
      "id": "second_row_heading",
      "label": "Zeile 2",
      "default": "Rohstoff"
    },
    {
      "type": "text",
      "id": "third_row_heading",
      "label": "Zeile 3",
      "default": "Laborprüfung (COA)"
