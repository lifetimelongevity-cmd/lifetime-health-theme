{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_lct_kicker = section.settings.kicker | strip
  assign crs_lct_head   = section.settings.headline | strip
  assign crs_lct_sub    = section.settings.subheading | strip
  if crs_lct_kicker == '__none__'
    assign crs_lct_kicker = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif

  assign active_col_idx = section.settings.active_column_index | plus: 0
  if active_col_idx < 1
    assign active_col_idx = 1
  endif

  assign group_1_label    = section.settings.group_1_label | strip
  assign group_2_label    = section.settings.group_2_label | strip
  assign group_split_after = section.settings.group_split_after | plus: 0

  assign badge_text = section.settings.recommended_badge_text | default: 'Empfohlen'

  assign rh1 = section.settings.first_row_heading
  assign rh2 = section.settings.second_row_heading
  assign rh3 = section.settings.third_row_heading
  assign rh4 = section.settings.fourth_row_heading
  assign rh5 = section.settings.fifth_row_heading
  assign rh6 = section.settings.sixth_row_heading

  assign data_blocks = section.blocks | where: 'type', 'column'
  assign col_count   = data_blocks.size
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.62 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.42 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.08 }};
    --crs-accent:   {{ section.settings.color_accent | default: '#65c0b6' }};
    --lct-pt:       {{ section.settings.padding_top }}px;
    --lct-pb:       {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="tl-section lct-section" id="section-{{ section.id }}">
  <div class="tl-container lct-container">

    {%- if crs_lct_kicker != blank or crs_lct_head != blank or crs_lct_sub != blank -%}
      <div class="tl-header lct-header crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
        {%- if crs_lct_kicker != blank -%}
          <p class="crs-heading-stack__kicker">{{ crs_lct_kicker | escape }}</p>
        {%- endif -%}
        {%- if crs_lct_head != blank or crs_lct_sub != blank -%}
          <div class="crs-heading-stack__pair">
            {%- if crs_lct_head != blank -%}
              <h2 class="crs-heading-stack__title">{{ crs_lct_head | escape | newline_to_br }}</h2>
            {%- endif -%}
            {%- if crs_lct_sub != blank -%}
              <p class="crs-heading-stack__subtitle">{{ crs_lct_sub | escape | newline_to_br }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- comment -%} Build ordered row list from section headings {%- endcomment -%}
    {%- assign row_data = '' -%}
    {%- if rh1 != blank -%}{%- assign row_data = row_data | append: '1|' | append: rh1 | append: ';' -%}{%- endif -%}
    {%- if rh2 != blank -%}{%- assign row_data = row_data | append: '2|' | append: rh2 | append: ';' -%}{%- endif -%}
    {%- if rh3 != blank -%}{%- assign row_data = row_data | append: '3|' | append: rh3 | append: ';' -%}{%- endif -%}
    {%- if rh4 != blank -%}{%- assign row_data = row_data | append: '4|' | append: rh4 | append: ';' -%}{%- endif -%}
    {%- if rh5 != blank -%}{%- assign row_data = row_data | append: '5|' | append: rh5 | append: ';' -%}{%- endif -%}
    {%- if rh6 != blank -%}{%- assign row_data = row_data | append: '6|' | append: rh6 | append: ';' -%}{%- endif -%}
    {%- assign row_list = row_data | split: ';' -%}

    <div class="lct-outer-wrap">
      <div class="lct-scroll-wrap">
        <div
          class="lct-grid"
          role="table"
          aria-label="{{ section.settings.headline | default: 'Produktvergleich' | escape }}"
          data-cols="{{ col_count }}"
        >

          {%- comment -%}── Column headers ──{%- endcomment -%}
          <div class="lct-row lct-row--head" role="row">
            <div class="lct-cell lct-cell--corner" role="columnheader" aria-hidden="true"></div>
            {%- for block in data_blocks -%}
              {%- assign is_active = false -%}
              {%- if forloop.index == active_col_idx -%}{%- assign is_active = true -%}{%- endif -%}
              <div
                class="lct-cell lct-cell--head{% if is_active %} is-active{% endif %}"
                role="columnheader"
                {{ block.shopify_attributes }}
              >
                {%- if is_active and badge_text != blank -%}
                  <span class="lct-badge">{{ badge_text | escape }}</span>
                {%- endif -%}
                {%- if block.settings.column_heading_image != blank -%}
                  <span class="lct-head-img">
                    {{- block.settings.column_heading_image
                        | image_url: width: 240
                        | image_tag: loading: 'lazy', class: 'lct-head-img-el',
                            alt: block.settings.column_heading_image.alt | default: block.settings.column_heading -}}
                  </span>
                {%- endif -%}
                {%- if block.settings.column_heading != blank -%}
                  <span class="lct-head-name">{{ block.settings.column_heading | escape }}</span>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>

          {%- comment -%}── Group 1 label (optional) ──{%- endcomment -%}
          {%- if group_1_label != blank -%}
            <div class="lct-row lct-row--group" role="row">
              <div class="lct-cell lct-cell--group-label" role="cell">{{ group_1_label | escape }}</div>
              {%- for block in data_blocks -%}
                {%- assign is_active = false -%}
                {%- if forloop.index == active_col_idx -%}{%- assign is_active = true -%}{%- endif -%}
                <div
                  class="lct-cell lct-cell--group-filler{% if is_active %} is-active{% endif %}"
                  role="cell"
                  aria-hidden="true"
                ></div>
              {%- endfor -%}
            </div>
          {%- endif -%}

          {%- comment -%}── Data rows ──{%- endcomment -%}
          {%- assign group_split_target = group_split_after | plus: 1 -%}
          {%- for entry in row_list -%}
            {%- assign entry_parts = entry | split: '|' -%}
            {%- assign row_idx    = entry_parts[0] | plus: 0 -%}
            {%- assign row_label  = entry_parts[1] -%}
            {%- assign visible_idx = forloop.index -%}

            {%- comment -%} Inject group 2 label before the correct row {%- endcomment -%}
            {%- if group_2_label != blank and group_split_after > 0 and visible_idx == group_split_target -%}
              <div class="lct-row lct-row--group" role="row">
                <div class="lct-cell lct-cell--group-label" role="cell">{{ group_2_label | escape }}</div>
                {%- for block in data_blocks -%}
                  {%- assign is_active = false -%}
                  {%- if forloop.index == active_col_idx -%}{%- assign is_active = true -%}{%- endif -%}
                  <div
                    class="lct-cell lct-cell--group-filler{% if is_active %} is-active{% endif %}"
                    role="cell"
                    aria-hidden="true"
                  ></div>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <div class="lct-row lct-row--data" role="row">
              <div class="lct-cell lct-cell--label" role="rowheader">
                <span class="lct-label-text">{{ row_label | escape }}</span>
              </div>
              {%- for block in data_blocks -%}
                {%- assign is_active = false -%}
                {%- if forloop.index == active_col_idx -%}{%- assign is_active = true -%}{%- endif -%}
                {%- render 'lt-comparison-value-cell',
                    block: block,
                    row: row_idx,
                    row_label: row_label,
                    is_active: is_active
                -%}
              {%- endfor -%}
            </div>
          {%- endfor -%}

        </div>
      </div>
    </div>

  </div>
</div>

{% stylesheet %}
/* ============================================================
   LT Comparison Table — v2
   Div-based CSS Grid. No <table> element conflicts.
   Badge sits inside header cell (no negative top, no clip).
   Group rows use per-column filler cells so the accent column
   border is never interrupted by a spanning divider row.
   Mobile: label + active column only (no horizontal scroll).
   Tablet/Desktop (≥640px): full grid inside scroll wrapper.
   ============================================================ */

/* ── Section ── */
.lct-section.tl-section {
  background: var(--crs-bg, #f7f7f4);
  padding-top: var(--lct-pt, 80px);
  padding-bottom: var(--lct-pb, 80px);
}

.lct-container.tl-container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 var(--space-5, 16px);
}

.lct-header.tl-header {
  margin-bottom: 32px;
  max-width: 48rem;
}

/* ── Outer wrap: single element that clips background colours at the radius.
      Badge is inside the header cell (positive top offset) so nothing is clipped. ── */
.lct-outer-wrap {
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
  border-radius: 14px;
  overflow: hidden;
}

/* ── Scroll wrap ── */
.lct-scroll-wrap {
  overflow-x: auto;
  -webkit-overflow-scrolling: touch;
  scrollbar-width: none;
}
.lct-scroll-wrap::-webkit-scrollbar { display: none; }

/* ── Grid (mobile: label col + active col only) ── */
.lct-grid {
  display: grid;
  grid-template-columns: minmax(120px, 1.4fr) 1fr;
  width: 100%;
  background: var(--crs-bg, #f7f7f4);
}

/* ── All row wrappers collapsed out of flow ── */
.lct-row { display: contents; }

/* ── Base cell ── */
.lct-cell {
  display: flex;
  align-items: center;
  padding: 12px 14px;
  border-top: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
  min-height: 58px;
  position: relative;
  background: transparent;
}

/* ── Label-column cells ── */
.lct-cell--corner,
.lct-cell--label,
.lct-cell--group-label {
  background: var(--crs-card-bg, #f2f1ed);
}

.lct-cell--corner { border-top: none; }

/* ── Column header cells ── */
.lct-cell--head {
  background: var(--crs-card-bg, #f2f1ed);
  border-top: none;
  border-left: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
  flex-direction: column;
  align-items: center;
  justify-content: flex-end;
  text-align: center;
  padding: 14px 10px 14px;
  min-height: 76px;
  gap: 4px;
}

/* Active header: white bg + accent top/side borders + room for badge */
.lct-cell--head.is-active {
  background: #fff;
  padding-top: 40px;
  box-shadow:
    inset  2px 0 0 var(--crs-accent, #65c0b6),
    inset -2px 0 0 var(--crs-accent, #65c0b6),
    inset  0  2px 0 var(--crs-accent, #65c0b6);
}

.lct-head-img { display: flex; max-height: 28px; }
.lct-head-img-el { max-height: 28px; width: auto; object-fit: contain; }

.lct-head-name {
  font-size: 12px;
  font-weight: 700;
  line-height: 1.25;
  color: var(--crs-text, #26251e);
}
.lct-cell--head.is-active .lct-head-name { font-size: 13px; }

/* ── Badge — positive top value, lives inside header padding, never clipped ── */
.lct-badge {
  position: absolute;
  top: 10px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--crs-accent, #65c0b6);
  color: #fff;
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  padding: 3px 9px;
  border-radius: 999px;
  white-space: nowrap;
  line-height: 1.4;
}

/* ── Group divider label ── */
.lct-cell--group-label {
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.07em;
  text-transform: uppercase;
  color: var(--crs-text-ter, rgba(38, 37, 30, 0.42));
  padding: 16px 14px 8px;
  min-height: auto;
}

/* No border between header row and first group label */
.lct-row--head + .lct-row--group .lct-cell--group-label {
  border-top: none;
  padding-top: 20px;
}

/* ── Group filler cells — one per data column, keeps accent column unbroken ── */
.lct-cell--group-filler {
  border-left: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
  min-height: 0;
  padding: 0;
  background: transparent;
}

.lct-row--head + .lct-row--group .lct-cell--group-filler {
  border-top: none;
}

/* Active filler cell: continues the white background + side borders */
.lct-cell--group-filler.is-active {
  background: #fff;
  box-shadow:
    inset  2px 0 0 var(--crs-accent, #65c0b6),
    inset -2px 0 0 var(--crs-accent, #65c0b6);
}

/* ── Row label ── */
.lct-label-text {
  font-size: 13px;
  font-weight: 500;
  color: var(--crs-text, #26251e);
}

/* ── Data cells ── */
.lct-cell--data {
  border-left: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
  gap: 8px;
  background: var(--crs-bg, #f7f7f4);
}

.lct-cell--data.is-active {
  background: #fff;
  box-shadow:
    inset  2px 0 0 var(--crs-accent, #65c0b6),
    inset -2px 0 0 var(--crs-accent, #65c0b6);
}

/* Close accent column at the bottom */
.lct-row--data:last-of-type .lct-cell--data.is-active {
  box-shadow:
    inset  2px 0 0 var(--crs-accent, #65c0b6),
    inset -2px 0 0 var(--crs-accent, #65c0b6),
    inset  0 -2px 0 var(--crs-accent, #65c0b6);
}

.lct-cell--cross:not(.is-active) { background: var(--crs-bg, #f7f7f4); }

/* ── Icons ── */
.lct-cell-icon {
  flex-shrink: 0;
  display: inline-flex;
  color: var(--crs-text-ter, rgba(38, 37, 30, 0.4));
}
.lct-cell--data.is-active .lct-cell-icon { color: var(--crs-accent, #65c0b6); }
.lct-icon-img { width: 20px; height: 20px; object-fit: contain; }

/* ── Cell text ── */
.lct-cell-text {
  font-size: 12px;
  font-weight: 500;
  line-height: 1.3;
  color: var(--crs-text, #26251e);
  word-break: break-word;
}
.lct-cell--data.is-active .lct-cell-text { font-weight: 600; }
.lct-cell--cross:not(.is-active) .lct-cell-text {
  color: var(--crs-text-ter, rgba(38, 37, 30, 0.42));
  font-weight: 400;
}

/* ── MOBILE: hide non-active data/header columns ── */
.lct-cell--head:not(.is-active),
.lct-cell--data:not(.is-active),
.lct-cell--group-filler:not(.is-active) {
  display: none;
}

/* ══════════════════════════════════════════════════════════════
   TABLET / DESKTOP  ≥ 640px
   Full grid, all columns, horizontal scroll wrapper kicks in
   only when viewport is narrower than the min-width below.
   ══════════════════════════════════════════════════════════════ */
@media (min-width: 640px) {
  .lct-grid[data-cols="2"] {
    grid-template-columns: minmax(160px, 1.4fr) repeat(2, 1fr);
    min-width: 480px;
  }
  .lct-grid[data-cols="3"] {
    grid-template-columns: minmax(160px, 1.4fr) repeat(3, 1fr);
    min-width: 580px;
  }
  .lct-grid[data-cols="4"] {
    grid-template-columns: minmax(160px, 1.4fr) repeat(4, 1fr);
    min-width: 700px;
  }

  /* Restore all hidden columns — must match mobile specificity to win */
  .lct-cell--head:not(.is-active),
  .lct-cell--data:not(.is-active),
  .lct-cell--group-filler:not(.is-active) { display: flex; }

  .lct-cell { padding: 14px 18px; min-height: 62px; }

  .lct-cell--head {
    padding: 18px 14px;
    min-height: 92px;
    gap: 6px;
  }
  .lct-cell--head.is-active { padding-top: 46px; }

  .lct-head-name { font-size: 14px; }
  .lct-cell--head.is-active .lct-head-name { font-size: 15px; }

  .lct-badge { font-size: 10px; padding: 3px 10px; top: 12px; }

  .lct-cell--group-label { padding: 18px 18px 8px; }

  .lct-label-text { font-size: 14px; }
  .lct-cell-text  { font-size: 13px; }

  .lct-cell-icon svg { width: 20px; height: 20px; }
}

@media (min-width: 1024px) {
  .lct-cell { padding: 16px 24px; min-height: 66px; }

  .lct-cell--head {
    padding: 22px 18px 20px;
    min-height: 104px;
  }
  .lct-cell--head.is-active { padding-top: 50px; }

  .lct-head-name { font-size: 15px; }
  .lct-cell--head.is-active .lct-head-name { font-size: 16px; }

  .lct-badge { top: 14px; }

  .lct-cell--group-label { padding: 20px 24px 10px; }

  .lct-label-text { font-size: 15px; }
  .lct-cell-text  { font-size: 14px; }
}

@media (prefers-reduced-motion: reduce) {
  .lct-cell, .lct-cell--head { transition: none; }
}
{% endstylesheet %}

{% schema %}
{
  "name": "LT - Comparison Table",
  "tag": "section",
  "class": "lt-comparison-table",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Sekundäre Spalte / Label-Bereich",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "color",
      "id": "color_accent",
      "label": "Akzentfarbe (Empfohlen-Spalte)",
      "default": "#65c0b6"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Ausrichtung (Überschrift)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Überschrift Größe",
      "options": [
        { "value": "section", "label": "Standard (Abschnitt)" },
        { "value": "product_title", "label": "Wie Produkttitel" }
      ],
      "default": "section"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Überschrift",
      "default": "Was du bei LIFETIME bekommst — und was nicht"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Unterüberschrift",
      "default": "Direkter Vergleich. Keine Marketing-Floskeln."
    },
    {
      "type": "header",
      "content": "Empfohlen-Spalte"
    },
    {
      "type": "range",
      "id": "active_column_index",
      "label": "Welche Spalte ist die Empfohlene?",
      "info": "1 = erste Spalte, 2 = zweite Spalte usw.",
      "min": 1,
      "max": 4,
      "step": 1,
      "default": 1
    },
    {
      "type": "text",
      "id": "recommended_badge_text",
      "label": "Empfohlen-Badge Text",
      "default": "Empfohlen",
      "info": "Leer lassen, um Badge auszublenden."
    },
    {
      "type": "header",
      "content": "Reihen-Gruppen (optional)"
    },
    {
      "type": "text",
      "id": "group_1_label",
      "label": "Gruppe 1 — Überschrift",
      "info": "Optional. Leer lassen, um keine Gruppen-Überschriften anzuzeigen."
    },
    {
      "type": "text",
      "id": "group_2_label",
      "label": "Gruppe 2 — Überschrift",
      "info": "Optional."
    },
    {
      "type": "range",
      "id": "group_split_after",
      "label": "Gruppe 2 startet nach Reihe",
      "info": "0 = keine zweite Gruppe.",
      "min": 0,
      "max": 5,
      "step": 1,
      "default": 0
    },
    {
      "type": "header",
      "content": "Zeilenbeschriftungen (links)"
    },
    {
      "type": "text",
      "id": "first_row_heading",
      "label": "Zeile 1",
      "default": "Reinheit"
    },
    {
      "type": "text",
      "id": "second_row_heading",
      "label": "Zeile 2",
      "default": "Rohstoff"
    },
    {
      "type": "text",
      "id": "third_row_heading",
      "label": "Zeile 3",
      "default": "Prüfbericht"
    },
    {
      "type": "text",
      "id": "fourth_row_heading",
      "label": "Zeile 4",
      "default": "Formulierung"
    },
    {
      "type": "text",
      "id": "fifth_row_heading",
      "label": "Zeile 5",
      "default": "Garantie"
    },
