{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_lct_kicker = section.settings.kicker | strip
  assign crs_lct_head = section.settings.headline | strip
  assign crs_lct_sub = section.settings.subheading | strip
  if crs_lct_kicker == '__none__'
    assign crs_lct_kicker = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif

  assign active_col_idx = section.settings.active_column_index | plus: 0
  if active_col_idx < 1
    assign active_col_idx = 1
  endif

  assign group_1_label = section.settings.group_1_label | strip
  assign group_2_label = section.settings.group_2_label | strip
  assign group_split_after = section.settings.group_split_after | plus: 0

  assign badge_text = section.settings.recommended_badge_text | default: 'Empfohlen'

  assign rh1 = section.settings.first_row_heading
  assign rh2 = section.settings.second_row_heading
  assign rh3 = section.settings.third_row_heading
  assign rh4 = section.settings.fourth_row_heading
  assign rh5 = section.settings.fifth_row_heading
  assign rh6 = section.settings.sixth_row_heading

  assign data_blocks = section.blocks | where: 'type', 'column'
  assign col_count = data_blocks.size
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:        {{ section.settings.color_bg }};
    --crs-card-bg:   {{ section.settings.color_card_bg }};
    --crs-text:      {{ section.settings.color_text }};
    --crs-text-sec:  {{ section.settings.color_text | color_modify: 'alpha', 0.62 }};
    --crs-text-ter:  {{ section.settings.color_text | color_modify: 'alpha', 0.42 }};
    --crs-border:    {{ section.settings.color_text | color_modify: 'alpha', 0.08 }};
    --crs-accent:    {{ section.settings.color_accent | default: '#65c0b6' }};
    padding-top:     {{ section.settings.padding_top }}px;
    padding-bottom:  {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="tl-section lct-section" id="section-{{ section.id }}">
  <div class="tl-container lct-container">
    {%- if crs_lct_kicker != blank or crs_lct_head != blank or crs_lct_sub != blank -%}
      <div class="tl-header lct-header crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
        {%- if crs_lct_kicker != blank -%}
          <p class="crs-heading-stack__kicker">{{ crs_lct_kicker | escape }}</p>
        {%- endif -%}
        {%- if crs_lct_head != blank or crs_lct_sub != blank -%}
          <div class="crs-heading-stack__pair">
            {%- if crs_lct_head != blank -%}
              <h2 class="crs-heading-stack__title">{{ crs_lct_head | escape | newline_to_br }}</h2>
            {%- endif -%}
            {%- if crs_lct_sub != blank -%}
              <p class="crs-heading-stack__subtitle">{{ crs_lct_sub | escape | newline_to_br }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="lct-wrap">
      <table
        class="lct-table"
        data-cols="{{ col_count }}"
        aria-label="{{ section.settings.headline | default: 'Produktvergleich' | escape }}"
      >
        <thead class="lct-thead">
          <tr class="lct-row lct-row--head">
            <th scope="col" class="lct-th lct-th--label" aria-hidden="true"></th>
            {%- for block in data_blocks -%}
              {%- assign col_index = forloop.index -%}
              {%- assign is_active = false -%}
              {%- if col_index == active_col_idx -%}{%- assign is_active = true -%}{%- endif -%}
              <th
                scope="col"
                class="lct-th lct-th--col{% if is_active %} lct-th--active{% endif %}"
                {{ block.shopify_attributes }}
              >
                <div class="lct-th__inner">
                  {%- if is_active and badge_text != blank -%}
                    <span class="lct-badge">{{ badge_text | escape }}</span>
                  {%- endif -%}
                  {%- if block.settings.column_heading_image != blank -%}
                    {%- assign lct_ch_alt = block.settings.column_heading_image.alt | default: block.settings.column_heading | escape -%}
                    <span class="lct-th__img">
                      {{
                        block.settings.column_heading_image
                        | image_url: width: 240
                        | image_tag: loading: 'lazy', class: 'lct-th__img-el', alt: lct_ch_alt
                      }}
                    </span>
                  {%- endif -%}
                  {%- if block.settings.column_heading != blank -%}
                    <span class="lct-th__heading">{{ block.settings.column_heading | escape }}</span>
                  {%- endif -%}
                </div>
              </th>
            {%- endfor -%}
          </tr>
        </thead>
        <tbody class="lct-tbody">
          {%- comment -%} Define the row sequence so we can inject group dividers cleanly. {%- endcomment -%}
          {%- assign row_data = '' -%}
          {%- if rh1 != blank -%}{%- assign row_data = row_data | append: '1|' | append: rh1 | append: ';' -%}{%- endif -%}
          {%- if rh2 != blank -%}{%- assign row_data = row_data | append: '2|' | append: rh2 | append: ';' -%}{%- endif -%}
          {%- if rh3 != blank -%}{%- assign row_data = row_data | append: '3|' | append: rh3 | append: ';' -%}{%- endif -%}
          {%- if rh4 != blank -%}{%- assign row_data = row_data | append: '4|' | append: rh4 | append: ';' -%}{%- endif -%}
          {%- if rh5 != blank -%}{%- assign row_data = row_data | append: '5|' | append: rh5 | append: ';' -%}{%- endif -%}
          {%- if rh6 != blank -%}{%- assign row_data = row_data | append: '6|' | append: rh6 | append: ';' -%}{%- endif -%}
          {%- assign row_list = row_data | split: ';' -%}

          {%- if group_1_label != blank -%}
            <tr class="lct-row lct-row--group">
              <th colspan="{{ col_count | plus: 1 }}" class="lct-group-head" scope="colgroup">{{ group_1_label | escape }}</th>
            </tr>
          {%- endif -%}

          {%- for entry in row_list -%}
            {%- assign entry_parts = entry | split: '|' -%}
            {%- assign row_idx = entry_parts[0] | plus: 0 -%}
            {%- assign row_label = entry_parts[1] -%}
            {%- assign visible_idx = forloop.index -%}

            {%- if group_2_label != blank and group_split_after > 0 and visible_idx == group_split_after | plus: 1 -%}
              <tr class="lct-row lct-row--group">
                <th colspan="{{ col_count | plus: 1 }}" class="lct-group-head" scope="colgroup">{{ group_2_label | escape }}</th>
              </tr>
            {%- endif -%}

            <tr class="lct-row lct-row--data">
              <th scope="row" class="lct-th lct-th--row">
                <span class="lct-row-label">{{ row_label | escape }}</span>
              </th>
              {%- for block in data_blocks -%}
                {%- assign col_index = forloop.index -%}
                {%- assign is_active = false -%}
                {%- if col_index == active_col_idx -%}{%- assign is_active = true -%}{%- endif -%}
                {%- render 'lt-comparison-value-cell',
                    block: block,
                    row: row_idx,
                    row_label: row_label,
                    is_active: is_active
                -%}
              {%- endfor -%}
            </tr>
          {%- endfor -%}
        </tbody>
      </table>
    </div>
  </div>
</div>

{% stylesheet %}
/* ========================================================================
   LT Comparison Table — Mobile-First
   • Semantic <table> markup, switches to card-per-row on mobile
   • CSS Grid for desktop ensures equal row heights regardless of content
   • Active column highlighted with accent border + badge
   ======================================================================== */

.lct-section.tl-section {
  background: var(--crs-bg, #f7f7f4);
}

.lct-container.tl-container {
  max-width: 1100px;
  margin: 0 auto;
  padding: 0 var(--space-5, 16px);
}

.lct-header.tl-header {
  margin-bottom: var(--space-7, 32px);
  max-width: 48rem;
}

.lct-wrap {
  position: relative;
}

/* ------------------------------------------------------------------------
   Base table reset (works as foundation for both desktop and mobile)
   ------------------------------------------------------------------------ */
.lct-table {
  width: 100%;
  border-collapse: separate;
  border-spacing: 0;
  table-layout: fixed;
  background: transparent;
}

.lct-table th,
.lct-table td {
  vertical-align: middle;
  text-align: left;
  font-weight: inherit;
}

/* ========================================================================
   MOBILE LAYOUT (default — under 768px)
   Each <tr.lct-row--data> becomes a card with:
     • Row label on top (small, secondary)
     • Two value cells side-by-side (active + other)
   No horizontal scroll, fits 375px viewport.
   ======================================================================== */

.lct-table[data-cols] {
  display: block;
}

.lct-thead,
.lct-tbody {
  display: block;
}

/* Header row on mobile: compact, shows only column titles */
.lct-row--head {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  padding: 0 0 16px 0;
  border-bottom: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
  margin-bottom: 8px;
}

/* 3-column variant: header gets 3 equal slim cards on mobile */
.lct-table[data-cols="3"] .lct-row--head {
  grid-template-columns: 1fr 1fr 1fr;
  gap: 6px;
}

.lct-th--label {
  display: none;
}

.lct-th--col {
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 12px 8px;
  border-radius: 10px;
  background: var(--crs-card-bg, #f2f1ed);
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
  position: relative;
  min-height: 56px;
}

.lct-th--active {
  background: #fff;
  border: 2px solid var(--crs-accent, #65c0b6);
  box-shadow: 0 4px 12px rgba(38, 37, 30, 0.06);
}

.lct-th__inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
}

.lct-badge {
  position: absolute;
  top: -10px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--crs-accent, #65c0b6);
  color: #fff;
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.04em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 999px;
  white-space: nowrap;
  line-height: 1.2;
}

.lct-th__img {
  display: flex;
  max-height: 32px;
}

.lct-th__img-el {
  display: block;
  max-height: 32px;
  width: auto;
  object-fit: contain;
}

.lct-th__heading {
  font-family: var(--font-heading, inherit);
  font-size: 13px;
  font-weight: 600;
  line-height: 1.25;
  color: var(--crs-text, #26251e);
}

.lct-th--active .lct-th__heading {
  font-size: 14px;
}

/* Group dividers on mobile */
.lct-row--group {
  display: block;
  padding: 16px 0 6px 0;
}

.lct-group-head {
  display: block;
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--crs-text-ter, rgba(38, 37, 30, 0.42));
  padding: 0;
  text-align: left;
}

/* Data row → card on mobile */
.lct-row--data {
  display: grid;
  grid-template-columns: 1fr 1fr;
  grid-template-areas:
    "label label"
    "active other";
  gap: 8px 12px;
  padding: 10px 0 14px 0;
  border-top: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
}

/* 3-column variant: 3 equal value cards in a row */
.lct-table[data-cols="3"] .lct-row--data {
  grid-template-columns: 1fr 1fr 1fr;
  grid-template-areas:
    "label label label"
    "c1 c2 c3";
  gap: 8px 6px;
}

.lct-row--data:first-of-type,
.lct-row--group + .lct-row--data {
  border-top: none;
}

.lct-th--row {
  grid-area: label;
  padding: 0 2px;
}

/* In 3-col mode, cells map to c1/c2/c3 by DOM order */
.lct-table[data-cols="3"] .lct-cell:nth-child(2) { grid-area: c1; }
.lct-table[data-cols="3"] .lct-cell:nth-child(3) { grid-area: c2; }
.lct-table[data-cols="3"] .lct-cell:nth-child(4) { grid-area: c3; }

.lct-row-label {
  font-size: 13px;
  font-weight: 500;
  color: var(--crs-text-sec, rgba(38, 37, 30, 0.62));
  letter-spacing: 0;
}

.lct-cell {
  background: var(--crs-card-bg, #f2f1ed);
  border-radius: 10px;
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
  padding: 0;
  min-height: 64px;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.lct-cell:nth-child(2) { grid-area: active; }
.lct-cell:nth-child(3) { grid-area: other; }

.lct-cell--active {
  background: #fff;
  border: 2px solid var(--crs-accent, #65c0b6);
}

.lct-cell--cross:not(.lct-cell--active) {
  background: var(--crs-bg, #f7f7f4);
  color: var(--crs-text-ter, rgba(38, 37, 30, 0.42));
}

.lct-cell__inner {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 12px;
  width: 100%;
}

/* 3-col mode: tighter cells, vertical icon+text stacking, smaller text */
.lct-table[data-cols="3"] .lct-cell__inner {
  flex-direction: column;
  gap: 4px;
  padding: 10px 6px;
  text-align: center;
  align-items: center;
  justify-content: center;
}

.lct-table[data-cols="3"] .lct-cell {
  min-height: 72px;
}

.lct-table[data-cols="3"] .lct-cell__text {
  font-size: 12px;
  line-height: 1.25;
}

.lct-table[data-cols="3"] .lct-icon-wrap svg {
  width: 18px;
  height: 18px;
}

.lct-table[data-cols="3"] .lct-th--col {
  padding: 10px 4px;
  min-height: 64px;
}

.lct-table[data-cols="3"] .lct-th__heading {
  font-size: 11px;
  line-height: 1.2;
}

.lct-table[data-cols="3"] .lct-th--active .lct-th__heading {
  font-size: 12px;
}

.lct-table[data-cols="3"] .lct-badge {
  font-size: 9px;
  padding: 2px 7px;
  top: -8px;
}

.lct-icon-wrap {
  flex-shrink: 0;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.lct-cell--active .lct-icon-wrap {
  color: var(--crs-accent, #65c0b6);
}

.lct-cell--cross:not(.lct-cell--active) .lct-icon-wrap {
  color: var(--crs-text-ter, rgba(38, 37, 30, 0.42));
}

.lct-icon__img {
  width: 22px;
  height: 22px;
  object-fit: contain;
}

.lct-cell__text {
  font-size: 13px;
  font-weight: 500;
  line-height: 1.3;
  color: var(--crs-text, #26251e);
  word-break: break-word;
}

.lct-cell--active .lct-cell__text {
  font-weight: 600;
}

.lct-cell--cross:not(.lct-cell--active) .lct-cell__text {
  color: var(--crs-text-sec, rgba(38, 37, 30, 0.62));
  font-weight: 400;
}

/* ========================================================================
   DESKTOP LAYOUT (≥768px)
   Real 3-column grid table. CSS Grid on <table> ensures equal row heights.
   ======================================================================== */

@media (min-width: 768px) {
  .lct-table[data-cols="2"] {
    display: grid;
    grid-template-columns: minmax(180px, 1.2fr) minmax(0, 1fr) minmax(0, 1fr);
    gap: 0;
    border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
    border-radius: 14px;
    overflow: hidden;
    background: var(--crs-bg, #f7f7f4);
  }

  .lct-table[data-cols="3"] {
    display: grid;
    grid-template-columns: minmax(180px, 1.2fr) minmax(0, 1fr) minmax(0, 1fr) minmax(0, 1fr);
    gap: 0;
    border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
    border-radius: 14px;
    overflow: hidden;
    background: var(--crs-bg, #f7f7f4);
  }

  .lct-thead {
    display: contents;
  }

  .lct-tbody {
    display: contents;
  }

  .lct-row {
    display: contents;
  }

  /* Header row */
  .lct-th--label {
    display: block;
    background: var(--crs-bg, #f7f7f4);
  }

  .lct-th--col {
    background: var(--crs-card-bg, #f2f1ed);
    border: none;
    border-radius: 0;
    padding: 24px 16px 20px 16px;
    min-height: 110px;
    text-align: center;
    position: relative;
    box-shadow: none;
  }

  .lct-th--col:not(:last-child) {
    border-right: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
  }

  .lct-th--active {
    background: #fff;
    border: none;
    border-bottom: 2px solid var(--crs-accent, #65c0b6);
    box-shadow: inset 0 0 0 2px var(--crs-accent, #65c0b6);
    z-index: 2;
  }

  .lct-th__inner {
    gap: 6px;
  }

  .lct-th__heading {
    font-size: 16px;
    font-weight: 600;
  }

  .lct-th--active .lct-th__heading {
    font-size: 17px;
  }

  .lct-badge {
    top: 12px;
    font-size: 10px;
    padding: 4px 10px;
  }

  /* Group divider row */
  .lct-row--group {
    display: contents;
    padding: 0;
  }

  .lct-group-head {
    grid-column: 1 / -1;
    background: var(--crs-bg, #f7f7f4);
    padding: 18px 20px 8px 20px;
    font-size: 11px;
    border-top: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
  }

  /* First group head: no top-border so it abuts cleanly under header */
  .lct-thead + .lct-tbody .lct-row--group:first-child .lct-group-head {
    border-top: none;
    padding-top: 22px;
  }

  /* Data rows */
  .lct-row--data {
    display: contents;
  }

  .lct-th--row {
    grid-area: auto;
    background: var(--crs-card-bg, #f2f1ed);
    padding: 16px 20px;
    border-top: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
    min-height: 64px;
    display: flex;
    align-items: center;
  }

  .lct-row-label {
    font-size: 14px;
    font-weight: 500;
    color: var(--crs-text, #26251e);
  }

  .lct-cell {
    grid-area: auto !important;
    background: var(--crs-bg, #f7f7f4);
    border: none;
    border-top: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
    border-radius: 0;
    padding: 0;
    min-height: 64px;
  }

  .lct-cell:not(:last-child) {
    border-right: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
  }

  .lct-cell--active {
    background: #fff;
    border: none;
    border-top: 1px solid var(--crs-border, rgba(38, 37, 30, 0.08));
    box-shadow: inset 2px 0 0 var(--crs-accent, #65c0b6), inset -2px 0 0 var(--crs-accent, #65c0b6);
  }

  .lct-cell--cross:not(.lct-cell--active) {
    background: var(--crs-bg, #f7f7f4);
  }

  .lct-cell__inner {
    padding: 16px 20px;
    gap: 10px;
  }

  .lct-cell__text {
    font-size: 14px;
  }

  .lct-cell--active .lct-cell__text {
    font-weight: 600;
  }

  .lct-icon {
    width: 22px;
    height: 22px;
  }

  /* Bottom edge of active column gets accent rounding feel */
  .lct-tbody .lct-row--data:last-of-type .lct-cell--active {
    box-shadow: inset 2px 0 0 var(--crs-accent, #65c0b6), inset -2px 0 0 var(--crs-accent, #65c0b6), inset 0 -2px 0 var(--crs-accent, #65c0b6);
  }
}

/* ========================================================================
   LARGER DESKTOP — slightly more breathing room
   ======================================================================== */
@media (min-width: 1024px) {
  .lct-th--col {
    padding: 28px 20px 22px 20px;
  }

  .lct-th--row,
  .lct-cell__inner {
    padding-left: 28px;
    padding-right: 28px;
  }

  .lct-cell__text,
  .lct-row-label {
    font-size: 15px;
  }
}

/* ========================================================================
   Reduced motion / a11y polish
   ======================================================================== */
@media (prefers-reduced-motion: reduce) {
  .lct-cell,
  .lct-th--col {
    transition: none;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "LT - Comparison Table",
  "tag": "section",
  "class": "lt-comparison-table",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Sekundäre Spalte / Label-Bereich",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "color",
      "id": "color_accent",
      "label": "Akzentfarbe (Empfohlen-Spalte)",
      "default": "#65c0b6"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
