{%- comment -%}
  LIFETIME — Ärzte-Quiz (B2B Partnerprogramm)
  ──────────────────────────────────────────────
  Spec: docs/lifetime-doctor-quiz-spec.md (status: living)

  Folgt visuell konsequent dem Live AGE-Quiz (lt-pdp-quiz-v2). Reused:
    - section-lt-pdp-quiz-v2.css für Intro, Fragen-Cards, Result-Header,
      Themes, Scope, CTA-Card.
    - Snippets: lt-quiz-question-cards, lt-quiz-question-multi,
      section-heading-crs, lt-quiz-loading (Loading-Screen).
  Eigenes nur für Matrix + Perspektiv-Wechsler + Trust-Footer.

  Source of Truth für alle Reports: produktdetails-age-dna-test.md
{%- endcomment -%}

{{ 'section-lt-pdp-quiz-v2.css' | asset_url | stylesheet_tag }}
{{ 'section-lt-doctor-quiz.css' | asset_url | stylesheet_tag }}
<noscript>
  <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/thin/style.css">
</noscript>
<link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/thin/style.css">

<a id="quiz" aria-hidden="true" tabindex="-1" style="display:block;scroll-margin-top:100px;"></a>

<section
  class="lt-quiz lt-doctor-quiz"
  data-lt-doctor-quiz
  data-section-id="{{ section.id }}"
  data-calendly-url="{{ section.settings.calendly_url | default: 'https://calendly.com/lifetime365/longevity-coaching' }}"
  data-secondary-cta-url="{{ section.settings.secondary_cta_url | default: '/products/lifetime-age-dna' }}"
>
  {%- comment -%} Progress-Rail (edge-to-edge, blendet sich via Modifier-Klassen ein) {%- endcomment -%}
  <div class="lt-quiz__rail" aria-hidden="true">
    <div class="lt-quiz__rail-fill" data-quiz-progress-bar></div>
  </div>

  <div class="lt-quiz__container">

    {%- comment -%} Chrome-Row {%- endcomment -%}
    <div class="lt-quiz__topbar">
      <div class="lt-quiz__chrome-row">
        <button type="button" class="lt-quiz__back" data-quiz-back hidden aria-label="Zurück">←</button>
        <div class="lt-quiz__progress-label" data-quiz-progress-label aria-live="polite"></div>
        <button type="button" class="lt-quiz__close" data-quiz-close aria-label="Quiz beenden">×</button>
      </div>
    </div>

    {%- comment -%} ── Intro (2-Spalten wie Live-Quiz) ──────────────── {%- endcomment -%}
    <div class="lt-quiz__step lt-quiz__step--intro" data-quiz-step="intro">
      <div class="lt-quiz__intro-grid">
        <div class="lt-quiz__intro-content">
          {%- render 'section-heading-crs',
              heading: section.settings.intro_headline,
              subheading: section.settings.intro_sub,
              kicker: section.settings.intro_kicker,
              align: 'left',
              headline_lg: true,
              extra_class: 'lt-quiz__intro-heading'
          -%}
          <p class="lt-quiz__intro-body">{{ section.settings.intro_body }}</p>
          <div class="lt-quiz__intro-ctas">
            <button type="button" class="lt-quiz__cta" data-quiz-start>
              {{ section.settings.intro_cta | escape }}
            </button>
          </div>
          {%- if section.settings.intro_trust != blank -%}
            <p class="lt-quiz__intro-trust">{{ section.settings.intro_trust | escape }}</p>
          {%- endif -%}
        </div>

        {%- assign _intro_image = section.settings.intro_image | default: 'https://cdn.shopify.com/s/files/1/0621/2173/8340/files/lifetime-app-hand-test.png?v=1778667349' -%}
        <aside class="lt-quiz__intro-visual" aria-hidden="true">
          <img
            class="lt-quiz__intro-visual-img"
            src="{{ _intro_image }}"
            alt=""
            loading="eager"
            decoding="async"
            fetchpriority="high"
          >
        </aside>
      </div>
    </div>

    {%- comment -%} ── Fragen ────────────────────────────────────────── {%- endcomment -%}
    <div class="lt-quiz__questions" data-quiz-grid hidden>

      {%- assign q1_options = 'kardio|Kardiologie|heartbeat,ortho|Orthopädie|bone,allgemein|Allgemeinmedizin|stethoscope,innere|Innere Medizin|microscope,neuro|Neurologie / Psychiatrie|brain,sport|Sportmedizin|barbell,andere|Andere Fachrichtung|dots-three-circle' | split: ',' -%}
      {%- render 'lt-quiz-question-cards',
          step: 'q1',
          question_id: 'specialty',
          kicker: 'Fachrichtung',
          headline: 'Was ist Ihr',
          sub: 'fachlicher Schwerpunkt?',
          options: q1_options,
          hint: 'Unser Test liefert 187 Reports in 16 DNA-Kategorien plus 6 Epigenetik-Bereiche. Welche dieser Reports klinisch im Vordergrund stehen, hängt von Ihrer Fachrichtung ab — das Produkt selbst ändert sich nicht.'
      -%}

      {%- assign q2_options = 'praevention|Prävention & Healthspan|heart,veranlagung|Familiäre Veranlagung|tree-structure,sensitivitaet|Verträglichkeiten & Nährstoffe|leaf,lifestyle|Lifestyle-Beratung|barbell' | split: ',' -%}
      {%- render 'lt-quiz-question-multi',
          step: 'q2',
          question_id: 'focus',
          kicker: 'Patientenfokus',
          headline: 'Wo liegt der Schwerpunkt',
          sub: 'Ihrer Patient:innen-Arbeit?',
          options: q2_options,
          max_select: 2,
          hint: 'Die Kombination aus Fachrichtung und Fokus bestimmt, welche der 187 Reports wir in Ihrem Vorschau-Ergebnis nach vorn stellen. Das ausgelieferte Test-Set ist für alle Praxen identisch.'
      -%}

    </div>

    {%- comment -%} ── Loading ───────────────────────────────────────── {%- endcomment -%}
    <div class="lt-quiz__step lt-quiz__step--loading" data-quiz-step="loading" hidden>
      <div class="lt-doctor-quiz__loading">
        <div class="lt-doctor-quiz__loading-ring" aria-hidden="true">
          <svg viewBox="0 0 100 100" class="lt-doctor-quiz__loading-svg">
            <circle cx="50" cy="50" r="46" class="lt-doctor-quiz__loading-track"></circle>
            <circle cx="50" cy="50" r="46" class="lt-doctor-quiz__loading-fill" data-loading-fill></circle>
          </svg>
        </div>
        <h2 class="lt-doctor-quiz__loading-headline">Wir bereiten Ihr Ergebnis vor…</h2>
        <p class="lt-doctor-quiz__loading-sub" data-loading-sub>Abgleich mit 16 DNA-Kategorien</p>
        <p class="lt-doctor-quiz__loading-trust">Wissenschaftlich begleitet von Prof. Dr. med. Volker Limmroth</p>
      </div>
    </div>

    {%- comment -%} ── Result (Live-Klassenstruktur .lt-quiz-result) ───── {%- endcomment -%}
    <div class="lt-quiz__step lt-quiz__step--result" data-quiz-step="result" hidden>
      <div class="lt-quiz-result">

        {%- comment -%} 1 — Header {%- endcomment -%}
        <section class="lt-quiz-result__header">
          <p class="lt-quiz-result__kicker">Ihr Ergebnis</p>
          <h2 class="lt-quiz-result__h1" data-result-headline></h2>
          <p class="lt-quiz-result__sub" data-result-sub></p>
          <p class="lt-doctor-quiz__result-trust">Wissenschaftlich begleitet von Prof. Dr. med. Volker Limmroth · Laboranalyse durch Eurofins Genomics</p>
        </section>

        {%- comment -%} 2 — Top-Reports (als Themes) {%- endcomment -%}
        <section class="lt-quiz-result__themes-section">
          <p class="lt-quiz-result__themes-lead">Im Befund besonders relevant für Sie</p>
          <h3 class="lt-quiz-result__h2">Die Reports, die in Ihrer Praxis im Vordergrund stehen.</h3>
          <div class="lt-quiz-result__themes" data-result-reports></div>
          <p class="lt-doctor-quiz__science-note" data-result-genes></p>
        </section>

        {%- comment -%} 3 — Epigenetik {%- endcomment -%}
        <section class="lt-quiz-result__themes-section">
          <p class="lt-quiz-result__themes-lead">Aktueller Status (epigenetisch)</p>
          <h3 class="lt-quiz-result__h2">Zusätzlich zur DNA-Veranlagung — Methylierungs-Status.</h3>
          <p class="lt-quiz-result__sub" style="font-size: var(--text-body); margin-bottom: var(--space-4);">Modifizierbar durch Lebensstil und sinnvoll als Verlaufsparameter.</p>
          <div class="lt-quiz-result__themes" data-result-epi></div>
        </section>

        {%- comment -%} 4 — Scope (Pills, wie Live-Quiz) + Perspektiv-Wechsler {%- endcomment -%}
        <section class="lt-quiz-result__scope">
          <p class="lt-quiz-result__themes-lead">Ein Test, 22 Bereiche</p>
          <h3 class="lt-quiz-result__h2">Jede Fachrichtung wertet andere Schwerpunkte aus.</h3>
          <p class="lt-quiz-result__scope-sub">
            <strong>187 Reports</strong> zu 16 DNA-Kategorien plus 6 epigenetischen Bereichen. Markiert sind die für Ihre Fachrichtung im Vordergrund. Wechseln Sie die Perspektive, um zu sehen, was Kolleg:innen aus einer anderen Fachrichtung sähen.
          </p>

          <div class="lt-doctor-quiz__perspective" role="tablist" aria-label="Fachrichtungs-Perspektive wechseln" data-result-perspective></div>

          <ul class="lt-quiz-result__pills" data-result-scope-pills></ul>

          <p class="lt-quiz-result__scope-epi" data-result-scope-epi></p>
        </section>

        {%- comment -%} 5 — CTA (Live-Klassen) {%- endcomment -%}
        <section class="lt-quiz-result__cta-section">
          <div class="lt-quiz-result__cta-card lt-doctor-quiz__cta-card">
            <div class="lt-quiz-result__cta-content">
              <p class="lt-quiz-result__cta-kicker">Empfehlungsprogramm</p>
              <h3 class="lt-quiz-result__cta-text">Gespräch zum Partnerprogramm.</h3>
              <p class="lt-quiz-result__cta-sub">
                LIFETIME arbeitet mit Ärzt:innen zusammen, die unseren Test in passende Präventions- und Lebensstil-Gespräche integrieren. Im persönlichen Gespräch zeigen wir Ihnen die LIFETIME App und besprechen die Konditionen einer Zusammenarbeit.
              </p>
              <a class="lt-quiz-result__cta-primary" data-cta-booking target="_blank" rel="noopener">
                Gespräch vereinbaren →
              </a>

              <div class="lt-quiz-result__cta-divider" role="separator" aria-label="Oder">
                <span class="lt-quiz-result__cta-divider-label">Oder</span>
              </div>

              <p class="lt-quiz-result__cta-kicker lt-quiz-result__cta-kicker--small">Lieber erst informieren?</p>
              <p class="lt-quiz-result__cta-sub lt-quiz-result__cta-sub--small">
                Sehen Sie sich die Produktseite an und informieren Sie sich in Ruhe über den Test.
              </p>
              <a class="lt-quiz-result__cta-secondary" data-cta-secondary>
                Mehr zum Test erfahren →
              </a>
            </div>
          </div>
        </section>

        {%- comment -%} 6 — Trust-Footer {%- endcomment -%}
        <section class="lt-doctor-quiz__trust-footer">
          <div class="lt-doctor-quiz__trust-col">
            <p class="lt-doctor-quiz__trust-label">Wissenschaftliche Begleitung</p>
            <p class="lt-doctor-quiz__trust-value">Prof. Dr. med. Volker Limmroth</p>
          </div>
          <div class="lt-doctor-quiz__trust-col">
            <p class="lt-doctor-quiz__trust-label">Laboranalyse</p>
            <p class="lt-doctor-quiz__trust-value">Eurofins Genomics<br>ISO 9001 · ISO 17025 · ISO 13485</p>
          </div>
          <div class="lt-doctor-quiz__trust-col">
            <p class="lt-doctor-quiz__trust-label">Ablauf</p>
            <p class="lt-doctor-quiz__trust-value">Speichelprobe von zuhause<br>Ergebnisse in 6–8 Wochen in der LIFETIME App</p>
          </div>
        </section>

      </div>
    </div>

  </div>
</section>

<script src="{{ 'lt-doctor-quiz.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "LT Ärzte-Quiz",
  "tag": "section",
  "class": "section lt-doctor-quiz-section",
  "settings": [
    {
      "type": "header",
      "content": "Intro"
    },
    {
      "type": "text",
      "id": "intro_kicker",
      "label": "Intro Kicker",
      "default": "Für Ärzt:innen"
    },
    {
      "type": "text",
      "id": "intro_headline",
      "label": "Intro Headline",
      "default": "Ein Test, alle Bereiche"
    },
    {
      "type": "textarea",
      "id": "intro_sub",
      "label": "Intro Sub-Headline (gleiche Größe, mit Opacity)",
      "default": "— jede Praxis wertet andere Schwerpunkte aus."
    },
    {
      "type": "textarea",
      "id": "intro_body",
      "label": "Intro Body",
      "default": "In 2 Klicks zeigen wir Ihnen, welche der 187 Reports aus unserem AGE & DNA-Test für Ihre Fachrichtung im Vordergrund stehen — und welche Ihre Kolleg:innen aus anderen Fachrichtungen anders gewichten würden."
    },
    {
      "type": "text",
      "id": "intro_cta",
      "label": "Intro CTA",
      "default": "Quiz starten →"
    },
    {
      "type": "text",
      "id": "intro_trust",
      "label": "Intro Trust-Zeile (optional)",
      "default": "Wissenschaftlich begleitet von Prof. Dr. med. Volker Limmroth"
    },
    {
      "type": "text",
      "id": "intro_image",
      "label": "Intro-Bild (URL)",
      "info": "Default: LIFETIME App in Hand (gleich wie Live-Quiz)",
      "default": "https://cdn.shopify.com/s/files/1/0621/2173/8340/files/lifetime-app-hand-test.png?v=1778667349"
    },
    {
      "type": "header",
      "content": "CTAs"
    },
    {
      "type": "text",
      "id": "calendly_url",
      "label": "Buchungs-Link (Calendly)",
      "default": "https://calendly.com/lifetime365/longevity-coaching",
      "info": "Gleicher Kalender wie auf /pages/longevity-coach. Wird mit UTM-Parametern aus dem Quiz-Kontext angereichert."
    },
    {
      "type": "text",
      "id": "secondary_cta_url",
      "label": "Sekundär-CTA-Link",
      "default": "/products/lifetime-age-dna"
    }
  ],
  "presets": [
    {
      "name": "LT Ärzte-Quiz"
    }
  ]
}
{% endschema %}
