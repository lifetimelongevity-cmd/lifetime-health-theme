{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_fg_kicker = section.settings.kicker | strip
  assign crs_fg_head = section.settings.heading | strip
  assign crs_fg_sub = section.settings.subheading | strip
  if crs_fg_kicker == '__none__'
    assign crs_fg_kicker = ''
  endif
  if crs_fg_head == '__none__'
    assign crs_fg_head = ''
  endif
  if crs_fg_sub == '__none__'
    assign crs_fg_sub = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif
  assign fg_single_frame_media = section.settings.single_frame_media
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.05 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="fg-section" id="section-{{ section.id }}">
  <div class="fg-container">
    <div class="fg-layout{% if section.settings.image != blank or section.settings.image_url != blank %} fg-layout--has-media fg-layout--media-{{ section.settings.media_position }}{% endif %}{% if fg_single_frame_media %} fg-layout--single-frame{% endif %}">
      {%- if section.settings.image != blank or section.settings.image_url != blank -%}
        <div class="fg-media">
          <div class="fg-media__frame">
            {%- if section.settings.image != blank -%}
              {{
                section.settings.image
                | image_url: width: 900
                | image_tag:
                  loading: 'lazy',
                  class: 'fg-media__image',
                  alt: section.settings.image_alt | default: crs_fg_head
              }}
            {%- elsif section.settings.image_url != blank -%}
              <img
                src="{{ section.settings.image_url | escape }}"
                alt="{{ section.settings.image_alt | default: crs_fg_head | escape }}"
                loading="lazy"
                class="fg-media__image"
                width="420"
              >
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      <div class="fg-content">
        {%- if crs_fg_kicker != blank or crs_fg_head != blank or crs_fg_sub != blank -%}
          <div class="fg-header crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
            {%- if crs_fg_kicker != blank -%}
              <p class="crs-heading-stack__kicker">{{ crs_fg_kicker | escape }}</p>
            {%- endif -%}
            {%- if crs_fg_head != blank or crs_fg_sub != blank -%}
              <div class="crs-heading-stack__pair">
                {%- if crs_fg_head != blank -%}
                  <h2 class="crs-heading-stack__title">{{ crs_fg_head | escape | newline_to_br }}</h2>
                {%- endif -%}
                {%- if crs_fg_sub != blank -%}
                  <p class="crs-heading-stack__subtitle">{{ crs_fg_sub | escape | newline_to_br }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.settings.cta_label != blank and section.settings.cta_url != blank -%}
          <div class="fg-actions">
            <a href="{{ section.settings.cta_url }}" class="fg-cta">
              {{ section.settings.cta_label | escape }}
            </a>
          </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="fg-grid fg-grid--cols-{{ section.settings.columns }}{% if section.settings.image != blank or section.settings.image_url != blank %} fg-grid--with-media{% endif %}">
            {%- for block in section.blocks -%}
              {%- assign fg_popup_plain = block.settings.popup_body | default: '' | strip_html | strip -%}
              <div class="fg-card" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h3 class="fg-card-title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <div class="fg-card-desc">{{ block.settings.description | escape }}</div>
                {%- endif -%}
                {%- if block.settings.link_label != blank and fg_popup_plain != '' -%}
                  <div class="fg-card-footer">
                    <button
                      type="button"
                      class="crs-popup-link"
                      data-crs-dialog-open
                      aria-haspopup="dialog"
                      aria-controls="crs-fg-dialog-{{ section.id }}-{{ block.id }}"
                    >
                      {{ block.settings.link_label | escape }}&nbsp;↗
                    </button>
                  </div>
                  <dialog
                    id="crs-fg-dialog-{{ section.id }}-{{ block.id }}"
                    class="crs-micro-dialog"
                    aria-modal="true"
                    aria-labelledby="crs-fg-dlg-title-{{ section.id }}-{{ block.id }}"
                  >
                    <div class="crs-micro-dialog__inner">
                      <button
                        type="button"
                        class="crs-micro-dialog__close"
                        data-crs-dialog-close
                        aria-label="{{ 'general.accessibility_labels.close' | t }}"
                      >
                        <span aria-hidden="true">×</span>
                      </button>
                      {%- assign fg_dlg_title = block.settings.popup_title | default: block.settings.link_label -%}
                      <h2 id="crs-fg-dlg-title-{{ section.id }}-{{ block.id }}" class="crs-micro-dialog__title">
                        {{ fg_dlg_title | escape }}
                      </h2>
                      <div class="crs-micro-dialog__body rte">
                        {{ block.settings.popup_body }}
                      </div>
                    </div>
                  </dialog>
                {%- endif -%}
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

{% render 'crs-micro-dialog-init' %}

{% stylesheet %}
/* ===================================================
   Feature Grid — crs-feature-grid.liquid
   =================================================== */

.fg-section {
  background: var(--crs-bg, #f7f7f4);
}

.fg-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

.fg-layout {
  display: block;
}

.fg-layout--has-media {
  display: grid;
  gap: var(--space-7);
  align-items: center;
}

@media (min-width: 980px) {
  .fg-layout--has-media {
    grid-template-columns: minmax(280px, 360px) minmax(0, 1fr);
  }

  .fg-layout--media-right {
    grid-template-columns: minmax(0, 1fr) minmax(280px, 360px);
  }

  .fg-layout--media-right .fg-media {
    order: 2;
  }
}

.fg-content {
  min-width: 0;
}

.fg-media {
  min-width: 0;
}

.fg-media__frame {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: clamp(1rem, 3vw, 1.5rem);
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.42), rgba(247, 247, 244, 0.88));
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  border-radius: 20px;
  box-shadow: 0 22px 36px rgba(38, 37, 30, 0.08);
}

.fg-media__image {
  display: block;
  width: 100%;
  max-width: 280px;
  height: auto;
  border-radius: 18px;
  box-shadow: 0 12px 24px rgba(38, 37, 30, 0.12);
}

.fg-layout--single-frame .fg-media__image {
  border-radius: 0;
  box-shadow: none;
}

/* Header */
.fg-header {
  margin-bottom: var(--space-7);
}

.fg-actions {
  margin: calc(var(--space-7) * -1 + var(--space-4)) 0 var(--space-6);
}

.fg-cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 44px;
  padding: 0.75rem 1.25rem;
  border-radius: 999px;
  background: var(--color-dark);
  border: 1px solid var(--color-dark);
  color: var(--color-text-on-dark);
  font-family: var(--font-body);
  font-size: 14px;
  font-weight: 500;
  line-height: 1.2;
  text-decoration: none;
  transition: opacity var(--ease-default, 0.2s ease);
}

.fg-cta:hover,
.fg-cta:focus-visible {
  opacity: 0.86;
}

/* Grid */
.fg-grid {
  display: grid;
  gap: 10px;
  align-items: stretch;
}

.fg-grid--cols-3 {
  grid-template-columns: repeat(3, 1fr);
}

.fg-grid--cols-2 {
  grid-template-columns: repeat(2, 1fr);
}

/* Card */
.fg-card {
  box-sizing: border-box;
  background: var(--crs-card-bg, #f2f1ed);
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  border-radius: 4px;
  padding: 13.4px 15px 15px;
  min-height: 102.4px;
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.fg-card-title {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: 16px !important;
  font-weight: 400 !important;
  line-height: 1.4 !important;
  letter-spacing: 0 !important;
  color: var(--crs-text, #26251e) !important;
  margin: 0 !important;
}

.fg-card-desc {
  font-size: 16px;
  font-weight: 400;
  line-height: 1.5;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
}

.fg-card-footer {
  margin-top: var(--space-5);
}

/* Tablet — 2 columns for 3-col grid */
@media (max-width: 1280px) {
  .fg-grid--cols-3 {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (min-width: 980px) {
  .fg-grid--with-media.fg-grid--cols-3 {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Mobile — 1 column */
@media (max-width: 640px) {
  .fg-grid--cols-3,
  .fg-grid--cols-2 {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 979px) {
  .fg-layout--has-media {
    gap: var(--space-6);
  }

  .fg-media__image {
    max-width: 220px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Feature Grid",
  "tag": "section",
  "class": "crs-feature-grid",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Ausrichtung (Überschrift)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Überschrift Größe",
      "options": [
        { "value": "section", "label": "Standard (Abschnitt)" },
        { "value": "product_title", "label": "Wie Produkttitel" }
      ],
      "default": "section",
      "info": "Zeilenumbruch: Enter in Überschrift/Unterüberschrift."
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Überschrift (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Unterüberschrift (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Link"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Spalten",
      "options": [
        { "value": "2", "label": "2 Spalten" },
        { "value": "3", "label": "3 Spalten" }
      ],
      "default": "3"
    },
    {
      "type": "header",
      "content": "App-Screenshot (optional)"
    },
    {
      "type": "select",
      "id": "media_position",
      "label": "Bildposition",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild"
    },
    {
      "type": "url",
      "id": "image_url",
      "label": "Bild-URL (Fallback)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Bild Alt-Text"
    },
    {
      "type": "checkbox",
      "id": "single_frame_media",
      "label": "Nur ein Bildrahmen",
      "default": false
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Dedicated guidance"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Beschreibung",
          "default": "Deploy AI at scale with professional expertise."
        },
        {
          "type": "header",
          "content": "Popup-Link (optional)"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link-Text mit Pfeil ↗",
          "info": "Nur sichtbar, wenn Popup-Inhalt gesetzt ist. Öffnet ein kleines Fenster statt neuer Seite."
        },
        {
          "type": "text",
          "id": "popup_title",
          "label": "Popup-Titel",
          "info": "Leer = gleich wie Link-Text"
        },
        {
          "type": "richtext",
          "id": "popup_body",
          "label": "Popup-Inhalt"
        }
      ]
    }
  ],
  "max_blocks": 9,
  "presets": [
    {
      "name": "Feature Grid",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "title": ">99,9% Reinheit",
            "description": "Unabhängig bestätigt durch Drittlabor in Deutschland."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Uthever® Rohstoff",
            "description": "Patentierter Markenrohstoff, klinisch untersucht."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "GMP & HACCP",
            "description": "Hergestellt nach höchsten Produktionsstandards."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "100% vegan",
            "description": "Ohne Füllstoffe, glutenfrei, kein Magnesiumstearat."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "Frei von Schwermetallen",
            "description": "Jede Charge einzeln getestet und zertifiziert."
          }
        },
        {
          "type": "feature",
          "settings": {
            "title": "COA öffentlich",
            "description": "Prüfbericht jeder Charge online einsehbar."
          }
        }
      ]
    }
  ]
}
{% endschema %}
