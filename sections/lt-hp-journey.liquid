{% comment %} lt-hp-journey — Stub. Liquid pending. {% endcomment %}

{% schema %}
{
  "name": "HP Journey",
  "settings": [
    { "type": "color", "id": "color_bg", "label": "Hintergrundfarbe" },
    { "type": "color", "id": "color_card_bg", "label": "Karten-Hintergrund" },
    { "type": "color", "id": "color_text", "label": "Textfarbe" },
    { "type": "range", "id": "padding_top", "label": "Abstand oben", "min": 0, "max": 200, "step": 8, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Abstand unten", "min": 0, "max": 200, "step": 8, "default": 80, "unit": "px" },
    { "type": "text", "id": "kicker", "label": "Kicker" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" },
    { "type": "text", "id": "cta_label", "label": "CTA Text" },
    { "type": "url", "id": "cta_url", "label": "CTA Link" }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Schritt",
      "settings": [
        { "type": "text", "id": "step_number", "label": "Nummer" },
        { "type": "text", "id": "step_title", "label": "Titel" },
        { "type": "textarea", "id": "step_body", "label": "Beschreibung" },
        { "type": "text", "id": "step_timeframe", "label": "Zeitangabe" },
        { "type": "checkbox", "id": "show_callout", "label": "Callout anzeigen", "default": false },
        { "type": "textarea", "id": "callout_text", "label": "Callout Text" }
      ]
    },
    {
      "type": "faq",
      "name": "FAQ",
      "settings": [
        { "type": "text", "id": "question", "label": "Frage" },
        { "type": "textarea", "id": "answer", "label": "Antwort" }
      ]
    }
  ],
  "presets": [{ "name": "HP Journey" }]
}
{% endschema %}
