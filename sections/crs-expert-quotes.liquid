{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_eq_kicker = section.settings.kicker | strip
  assign crs_eq_head = section.settings.heading | strip
  assign crs_eq_sub = section.settings.subheading | strip
  if crs_eq_kicker == '__none__'
    assign crs_eq_kicker = ''
  endif
  if crs_eq_head == '__none__'
    assign crs_eq_head = ''
  endif
  if crs_eq_sub == '__none__'
    assign crs_eq_sub = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.1 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="eq-section" id="section-{{ section.id }}">
  <div class="eq-container">

    {%- if crs_eq_kicker != blank or crs_eq_head != blank or crs_eq_sub != blank -%}
      <div class="eq-section-head crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
        {%- if crs_eq_kicker != blank -%}
          <p class="crs-heading-stack__kicker">{{ crs_eq_kicker | escape }}</p>
        {%- endif -%}
        {%- if crs_eq_head != blank or crs_eq_sub != blank -%}
          <div class="crs-heading-stack__pair">
            {%- if crs_eq_head != blank -%}
              <h2 class="crs-heading-stack__title">{{ crs_eq_head | escape | newline_to_br }}</h2>
            {%- endif -%}
            {%- if crs_eq_sub != blank -%}
              <p class="crs-heading-stack__subtitle">{{ crs_eq_sub | escape | newline_to_br }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="eq-grid">
        {%- for block in section.blocks -%}
          <div class="eq-card" {{ block.shopify_attributes }}>

            <blockquote class="eq-blockquote">
              <p class="eq-quote-text">{{ block.settings.quote | escape }}</p>
            </blockquote>

            <div class="eq-author">
              {%- if block.settings.photo != blank -%}
                <div class="eq-photo">
                  {{
                    block.settings.photo
                    | image_url: width: 160
                    | image_tag:
                      loading: 'lazy',
                      class: 'eq-photo-img',
                      alt: block.settings.name | escape
                  }}
                </div>
              {%- else -%}
                <div class="eq-initials" aria-hidden="true">
                  {{ block.settings.name | slice: 0, 2 | upcase }}
                </div>
              {%- endif -%}
              <div class="eq-author-info">
                <span class="eq-name">{{ block.settings.name | escape }}</span>
                <span class="eq-title">{{ block.settings.title | escape }}</span>
                <span class="eq-source">{{ block.settings.source | escape }}</span>
              </div>
            </div>

          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
.eq-section {
  background: var(--crs-bg, #f7f7f4);
}

.eq-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 var(--space-5);
}

.eq-section-head {
  margin-bottom: var(--space-7);
}

.eq-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-3);
}

.eq-card {
  background: var(--crs-card-bg, #f2f1ed);
  border-radius: var(--radius-sm);
  padding: var(--space-5);
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
}

.eq-blockquote {
  flex: 1;
  margin: 0;
}

.eq-quote-text {
  font-size: 0.9375rem;
  line-height: 1.7;
  color: var(--crs-text, #26251e);
  margin: 0;
}

.eq-author {
  display: flex;
  align-items: flex-start;
  gap: 12px;
}

.eq-initials {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  background: var(--crs-border, rgba(38,37,30,0.1));
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--crs-text, #26251e);
  flex-shrink: 0;
}

.eq-photo {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 1.5px solid var(--crs-border, rgba(38, 37, 30, 0.1));
  box-sizing: border-box;
}

.eq-photo-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

.eq-author-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.eq-name {
  font-size: 0.875rem;
  font-weight: 500;
  color: var(--crs-text, #26251e);
  line-height: 1.3;
}

.eq-title {
  font-size: 0.8125rem;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
  line-height: 1.4;
}

.eq-source {
  font-size: 0.75rem;
  color: var(--crs-text-ter, rgba(38,37,30,0.4));
  line-height: 1.4;
  margin-top: 2px;
}

@media (max-width: 1024px) {
  .eq-grid {
    grid-template-columns: 1fr;
    gap: 8px;
  }
}

@media (max-width: 640px) {
  .eq-container {
    padding: 0 var(--space-4);
  }

  .eq-card {
    padding: var(--space-5);
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Expert Quotes",
  "tag": "section",
  "class": "crs-expert-quotes",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "default": 80,
      "unit": "px"
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Ausrichtung (Überschrift)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Überschrift Größe",
      "options": [
        { "value": "section", "label": "Standard (Abschnitt)" },
        { "value": "product_title", "label": "Wie Produkttitel" }
      ],
      "default": "section",
      "info": "Zeilenumbruch: Enter in Überschrift/Unterüberschrift."
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Überschrift (optional)",
      "default": "Was führende Forscher sagen",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Unterüberschrift (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    }
  ],
  "blocks": [
    {
      "type": "expert",
      "name": "Experten-Zitat",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Zitat (Original-Sprache)",
          "default": "Zitat hier einfügen."
        },
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Autorenfoto (optional)"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Prof. Vorname Nachname"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel & Institution",
          "default": "Harvard Medical School · Genetik & Aging"
        },
        {
          "type": "text",
          "id": "source",
          "label": "Quelle (Buch, Podcast, Interview)",
          "default": "Lifespan (2019), S. 304"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Expert Quotes",
      "blocks": [
        {
          "type": "expert",
          "settings": {
            "quote": "I take 1 gram of NMN every morning. NAD is critical to energy production in all cells. Levels of NAD tend to go down as we age — it's an absolute requirement for cellular health and life.",
            "name": "Prof. David Sinclair, Ph.D.",
            "title": "Harvard Medical School · Genetik & Aging-Forschung",
            "source": "Lifespan (2019), S. 304"
          }
        },
        {
          "type": "expert",
          "settings": {
            "quote": "I take NMN sublingually every morning. I notice significantly more sustained mental and physical energy throughout the day. When I stop taking it, I notice a clear decrement in energy.",
            "name": "Prof. Andrew Huberman, Ph.D.",
            "title": "Stanford University · Neurobiologie & Ophthalmologie",
            "source": "Huberman Lab AMA #12, Oktober 2023"
          }
        },
        {
          "type": "expert",
          "settings": {
            "quote": "Ab Mitte 30 sinken unsere NAD⁺-Werte signifikant – das beeinflusst Energieproduktion, DNA-Reparatur und Zellalterung. NMN ist der Baustein, den der Körper braucht, um gegenzusteuern.",
            "name": "Dr. Volker Limmroth",
            "title": "Chefarzt Neurologie · In-House Neurologe",
            "source": "LIFETIME Longevity & Health, Berlin"
          }
        }
      ]
    }
  ]
}
{% endschema %}
