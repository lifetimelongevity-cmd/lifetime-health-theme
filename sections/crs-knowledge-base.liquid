{% javascript %}
  (function () {
    function bindHotspots(graph) {
      if (!graph || graph.dataset.hotspotsBound === 'true') return;

      var hotspots = graph.querySelectorAll('[data-nad-hotspot]');

      function closeAll(except) {
        hotspots.forEach(function (hotspot) {
          var expanded = except && hotspot === except;
          hotspot.setAttribute('aria-expanded', expanded ? 'true' : 'false');
        });
      }

      hotspots.forEach(function (hotspot) {
        hotspot.addEventListener('click', function (event) {
          event.stopPropagation();
          var isOpen = hotspot.getAttribute('aria-expanded') === 'true';
          closeAll(isOpen ? null : hotspot);
        });
      });

      graph.addEventListener('click', function () {
        closeAll(null);
      });

      graph.addEventListener('keydown', function (event) {
        if (event.key !== 'Escape') return;
        closeAll(null);
      });

      graph.dataset.hotspotsBound = 'true';
    }

    function setupGraph(graph) {
      if (!graph || graph.dataset.graphReady === 'true') return;

      var line = graph.querySelector('.ckb-nad__line');
      if (line) {
        var length = line.getTotalLength();
        line.style.strokeDasharray = length;
        line.style.strokeDashoffset = length;
        graph.style.setProperty('--ckb-nad-path-length', length);
      }

      graph.dataset.graphReady = 'true';
    }

    function observeGraph(graph) {
      if (!graph || graph.dataset.graphObserved === 'true') return;
      graph.dataset.graphObserved = 'true';

      function play() {
        if (graph.dataset.graphPlayed === 'true') return;
        graph.dataset.graphPlayed = 'true';
        graph.classList.add('is-visible');

        window.setTimeout(function () {
          graph.classList.add('is-complete');
        }, 2600);
      }

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        play();
        graph.classList.remove('is-complete');
        return;
      }

      if (!('IntersectionObserver' in window)) {
        play();
        return;
      }

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          play();
          observer.unobserve(entry.target);
        });
      }, {
        threshold: 0.18,
        rootMargin: '0px 0px -8% 0px'
      });

      observer.observe(graph);
    }

    function init(root) {
      var scope = root || document;
      var graphs = scope.querySelectorAll('[data-ckb-nad-graph]');

      graphs.forEach(function (graph) {
        setupGraph(graph);
        bindHotspots(graph);
        observeGraph(graph);
      });
    }

    document.addEventListener('shopify:section:load', function (event) {
      init(event.target);
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        init(document);
      });
    } else {
      init(document);
    }
  })();
{% endjavascript %}

{% style %}
  @keyframes ckb-nad-line-draw {
    from {
      stroke-dashoffset: var(--ckb-nad-path-length, 1);
    }
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes ckb-nad-marker-in {
    from {
      opacity: 0;
      transform: scale(0);
    }
    72% {
      opacity: 1;
      transform: scale(1.1);
    }
    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @keyframes ckb-nad-ripple {
    0% {
      opacity: 0.42;
      transform: scale(1);
    }
    100% {
      opacity: 0;
      transform: scale(3.2);
    }
  }

  @keyframes ckb-nad-axis-fade {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes ckb-nad-breathe {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.94;
    }
  }

  @keyframes ckb-nad-point-idle {
    0%,
    100% {
      transform: scale(1);
    }
    50% {
      transform: scale(1.06);
    }
  }
{% endstyle %}

