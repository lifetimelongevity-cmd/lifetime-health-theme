{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_ckb_kicker = section.settings.kicker | strip
  assign crs_ckb_head = section.settings.heading | strip
  assign crs_ckb_sub = section.settings.subheading | strip
  assign crs_ckb_visual_type = section.settings.visual_type | default: 'image'
  assign crs_ckb_graph_kicker = section.settings.graph_kicker | strip
  assign crs_ckb_graph_badge = section.settings.graph_badge | strip
  assign crs_ckb_graph_note = section.settings.graph_note | strip
  if crs_ckb_kicker == '__none__'
    assign crs_ckb_kicker = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.05 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="ckb-section" id="section-{{ section.id }}">
  <div class="ckb-container">
    <div class="ckb-card{% if section.settings.image_position == 'left' %} ckb-card--image-left{% endif %}">

      {%- comment -%} LEFT — text + testimonial {%- endcomment -%}
      <div class="ckb-content">
        <div class="ckb-text-block crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
          {%- if crs_ckb_kicker != blank -%}
            <p class="crs-heading-stack__kicker">{{ crs_ckb_kicker | escape }}</p>
          {%- endif -%}
          {%- if crs_ckb_head != blank or crs_ckb_sub != blank -%}
            <div class="crs-heading-stack__pair">
              {%- if crs_ckb_head != blank -%}
                <h2 class="crs-heading-stack__title">{{ crs_ckb_head | escape | newline_to_br }}</h2>
              {%- endif -%}
              {%- if crs_ckb_sub != blank -%}
                <p class="crs-heading-stack__subtitle">{{ crs_ckb_sub | escape | newline_to_br }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.quote_text != blank -%}
          <figure class="ckb-quote">
            <blockquote>
              <p class="ckb-quote-body">{{ section.settings.quote_text | escape }}</p>
            </blockquote>
            <figcaption class="ckb-author">
              {%- if section.settings.author_image != blank -%}
                <div class="ckb-avatar">
                  {{
                    section.settings.author_image
                    | image_url: width: 84
                    | image_tag:
                      width: 42,
                      height: 42,
                      loading: 'lazy',
                      alt: section.settings.author_name | escape
                  }}
                </div>
              {%- endif -%}
              <div class="ckb-author-info">
                <span class="ckb-author-name">{{ section.settings.author_name | escape }}</span>
                <span class="ckb-author-role">{{ section.settings.author_role | escape }}</span>
              </div>
            </figcaption>
          </figure>
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT — image {%- endcomment -%}
      <div class="ckb-visual{% if crs_ckb_visual_type == 'nad_graph' %} ckb-visual--graph{% endif %}">
        {%- if crs_ckb_visual_type == 'nad_graph' -%}
          <div class="ckb-nad" data-ckb-nad-graph>
            <div class="ckb-nad__frame">
              <div class="ckb-nad__topline">
                {%- if crs_ckb_graph_kicker != blank -%}
                  <p class="ckb-nad__eyebrow">{{ crs_ckb_graph_kicker | escape }}</p>
                {%- endif -%}
                {%- if crs_ckb_graph_badge != blank -%}
                  <span class="ckb-nad__badge">{{ crs_ckb_graph_badge | escape }}</span>
                {%- endif -%}
              </div>

              <div
                class="ckb-nad__chart"
                role="img"
                aria-labelledby="ckb-nad-title-{{ section.id }}"
                aria-describedby="ckb-nad-desc-{{ section.id }}"
              >
                <span class="visually-hidden" id="ckb-nad-title-{{ section.id }}">
                  Animierte Visualisierung eines altersbedingten NAD+ Rueckgangs
                </span>
                <span class="visually-hidden" id="ckb-nad-desc-{{ section.id }}">
                  Schematische Kurve mit hoehren NAD+ Werten in juengeren Jahren und niedrigeren Werten im hoeheren Alter.
                </span>

                <div class="ckb-nad__scan" aria-hidden="true"></div>
                <div class="ckb-nad__pill ckb-nad__pill--start" aria-hidden="true">hoeher</div>
                <div class="ckb-nad__pill ckb-nad__pill--end" aria-hidden="true">niedriger</div>

                <svg
                  class="ckb-nad__svg"
                  viewBox="0 0 720 520"
                  preserveAspectRatio="none"
                  aria-hidden="true"
                >
                  <defs>
                    <linearGradient id="ckb-nad-line-{{ section.id }}" x1="0%" x2="100%" y1="0%" y2="0%">
                      <stop offset="0%" stop-color="#c37b56"></stop>
                      <stop offset="55%" stop-color="#a78559"></stop>
                      <stop offset="100%" stop-color="#7a9156"></stop>
                    </linearGradient>
                    <linearGradient id="ckb-nad-fill-{{ section.id }}" x1="0%" x2="0%" y1="0%" y2="100%">
                      <stop offset="0%" stop-color="#7a9156" stop-opacity="0.22"></stop>
                      <stop offset="100%" stop-color="#7a9156" stop-opacity="0"></stop>
                    </linearGradient>
                    <filter id="ckb-nad-shadow-{{ section.id }}" x="-20%" y="-20%" width="140%" height="140%">
                      <feDropShadow dx="0" dy="16" stdDeviation="16" flood-color="#26251e" flood-opacity="0.14"></feDropShadow>
                    </filter>
                  </defs>

                  <g class="ckb-nad__grid">
                    <line x1="82" y1="76" x2="660" y2="76"></line>
                    <line x1="82" y1="164" x2="660" y2="164"></line>
                    <line x1="82" y1="252" x2="660" y2="252"></line>
                    <line x1="82" y1="340" x2="660" y2="340"></line>
                    <line x1="82" y1="428" x2="660" y2="428"></line>
                    <line x1="82" y1="428" x2="82" y2="76"></line>
                  </g>

                  <path
                    class="ckb-nad__area"
                    d="M 82 428 L 82 118 C 128 126, 164 136, 202 150 C 246 167, 286 190, 324 222 C 364 256, 408 290, 458 326 C 514 364, 570 388, 660 404 L 660 428 Z"
                  ></path>
                  <path
                    class="ckb-nad__line"
                    d="M 82 118 C 128 126, 164 136, 202 150 C 246 167, 286 190, 324 222 C 364 256, 408 290, 458 326 C 514 364, 570 388, 660 404"
                  ></path>

                  <g class="ckb-nad__markers" filter="url(#ckb-nad-shadow-{{ section.id }})">
                    <g class="ckb-nad__marker" style="--delay: 0.35s;">
                      <circle class="ckb-nad__marker-glow" cx="158" cy="138" r="22"></circle>
                      <circle class="ckb-nad__marker-ring" cx="158" cy="138" r="10"></circle>
                      <circle class="ckb-nad__marker-core" cx="158" cy="138" r="4"></circle>
                    </g>
                    <g class="ckb-nad__marker" style="--delay: 0.55s;">
                      <circle class="ckb-nad__marker-glow" cx="336" cy="232" r="18"></circle>
                      <circle class="ckb-nad__marker-ring" cx="336" cy="232" r="9"></circle>
                      <circle class="ckb-nad__marker-core" cx="336" cy="232" r="4"></circle>
                    </g>
                    <g class="ckb-nad__marker" style="--delay: 0.78s;">
                      <circle class="ckb-nad__marker-glow" cx="610" cy="390" r="22"></circle>
                      <circle class="ckb-nad__marker-ring" cx="610" cy="390" r="10"></circle>
                      <circle class="ckb-nad__marker-core" cx="610" cy="390" r="4"></circle>
                    </g>
                  </g>
                </svg>

                <div class="ckb-nad__axis ckb-nad__axis--x">{{ section.settings.graph_axis_x | escape }}</div>
                <div class="ckb-nad__axis ckb-nad__axis--y">{{ section.settings.graph_axis_y | escape }}</div>
              </div>

              {%- if crs_ckb_graph_note != blank -%}
                <p class="ckb-nad__note">{{ crs_ckb_graph_note | escape }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- elsif section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag:
              loading: 'lazy',
              class: 'ckb-visual-img',
              alt: section.settings.image.alt | escape
          }}
        {%- else -%}
          <div class="ckb-visual-placeholder">
            {{ 'image' | placeholder_svg_tag: 'ckb-placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
/* ===================================================
   Knowledge Base — crs-knowledge-base.liquid
   =================================================== */

.ckb-section {
  background: var(--crs-bg, #f7f7f4);
}

.ckb-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Card — Text 1fr, Bild 2fr (Bild rechts: Text | Bild) */
.ckb-card {
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 1fr 2fr;
  min-height: 560px;
  border-radius: 4px;
  overflow: hidden;
  background: var(--crs-card-bg, #f2f1ed);
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
}

/* Bild links: gleiche Proportionen, Spalten getauscht */
.ckb-card--image-left {
  grid-template-columns: 2fr 1fr;
}

.ckb-card--image-left .ckb-visual {
  grid-column: 1;
}

.ckb-card--image-left .ckb-content {
  grid-column: 2;
}

/* Left column */
.ckb-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 52px 44px;
  gap: 28px;
}

.ckb-text-block {
  display: flex;
  flex-direction: column;
}

/* Testimonial quote */
.ckb-quote {
  margin: 0;
  border-left: 2px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  padding-left: 20px;
}

.ckb-quote-body {
  font-size: .9375rem;
  line-height: 1.6;
  color: var(--crs-text, #26251e);
  margin: 0 0 16px;
}

/* Author */
.ckb-author {
  display: flex;
  align-items: center;
  gap: 12px;
}

.ckb-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 1.5px solid var(--crs-border, rgba(38, 37, 30, 0.05));
}

.ckb-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.ckb-author-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.ckb-author-name {
  font-size: .875rem;
  font-weight: 600;
  color: var(--crs-text, #26251e);
}

.ckb-author-role {
  font-size: .8125rem;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
}

/* Right column — image */
.ckb-visual {
  position: relative;
  overflow: hidden;
}

.ckb-visual--graph {
  display: flex;
  align-items: stretch;
  padding: 20px;
  background:
    radial-gradient(circle at top right, rgba(122, 145, 86, 0.14), transparent 36%),
    linear-gradient(180deg, rgba(255, 255, 255, 0.22), transparent 45%),
    var(--crs-card-bg, #f2f1ed);
}

.ckb-visual-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.ckb-nad {
  position: relative;
  display: flex;
  width: 100%;
  min-height: 100%;
}

.ckb-nad__frame {
  position: relative;
  display: grid;
  grid-template-rows: auto 1fr auto;
  gap: 16px;
  width: 100%;
  padding: 24px;
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  border-radius: 20px;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.8), rgba(255, 255, 255, 0.54)),
    rgba(246, 243, 236, 0.92);
  box-shadow: 0 18px 36px rgba(38, 37, 30, 0.08);
  overflow: hidden;
}

.ckb-nad__frame::before {
  content: '';
  position: absolute;
  inset: 0;
  background:
    linear-gradient(rgba(122, 145, 86, 0.07) 1px, transparent 1px),
    linear-gradient(90deg, rgba(122, 145, 86, 0.07) 1px, transparent 1px);
  background-size: 32px 32px;
  mask-image: linear-gradient(180deg, rgba(0, 0, 0, 0.28), transparent 75%);
  pointer-events: none;
}

.ckb-nad__topline {
  position: relative;
  z-index: 1;
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  align-items: center;
  gap: 12px;
}

.ckb-nad__eyebrow {
  margin: 0;
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: var(--crs-text-ter, rgba(38, 37, 30, 0.4));
}

.ckb-nad__badge {
  display: inline-flex;
  align-items: center;
  min-height: 2rem;
  padding: 0.35rem 0.75rem;
  border: 1px solid rgba(122, 145, 86, 0.16);
  border-radius: 999px;
  background: rgba(122, 145, 86, 0.08);
  font-size: 0.76rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #6a7c45;
}

.ckb-nad__chart {
  position: relative;
  min-height: 420px;
}

.ckb-nad__svg {
  position: relative;
  z-index: 1;
  display: block;
  width: 100%;
  height: 100%;
}

.ckb-nad__grid line {
  stroke: rgba(38, 37, 30, 0.08);
  stroke-width: 1;
  vector-effect: non-scaling-stroke;
}

.ckb-nad__area {
  fill: url(#ckb-nad-fill-{{ section.id }});
  opacity: 0;
  transform: translateY(14px);
}

.ckb-nad__line {
  fill: none;
  stroke: url(#ckb-nad-line-{{ section.id }});
  stroke-width: 5;
  stroke-linecap: round;
  stroke-linejoin: round;
  opacity: 0;
}

.ckb-nad.is-visible .ckb-nad__area {
  opacity: 1;
  transform: translateY(0);
  transition:
    opacity 0.8s ease 0.35s,
    transform 0.8s ease 0.35s;
}

.ckb-nad.is-visible .ckb-nad__line {
  opacity: 1;
  animation: ckb-nad-line-draw 1.8s cubic-bezier(0.2, 0.72, 0.26, 1) forwards;
}

.ckb-nad__marker {
  opacity: 0;
  transform-origin: center;
}

.ckb-nad.is-visible .ckb-nad__marker {
  animation: ckb-nad-marker-in 0.7s cubic-bezier(0.2, 0.72, 0.26, 1) forwards;
  animation-delay: var(--delay, 0s);
}

.ckb-nad__marker-glow {
  fill: rgba(195, 123, 86, 0.18);
}

.ckb-nad__marker-ring {
  fill: rgba(255, 255, 255, 0.92);
  stroke: #c37b56;
  stroke-width: 4;
}

.ckb-nad__marker-core {
  fill: #c37b56;
}

.ckb-nad__scan {
  position: absolute;
  z-index: 0;
  inset-block: 9% 18%;
  inset-inline-start: -16%;
  width: 26%;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0), rgba(255, 255, 255, 0.46), rgba(255, 255, 255, 0));
  filter: blur(6px);
  opacity: 0;
  transform: translateX(0) skewX(-18deg);
  pointer-events: none;
}

.ckb-nad.is-visible .ckb-nad__scan {
  opacity: 0.85;
  animation: ckb-nad-scan 1.6s ease 0.2s forwards;
}

.ckb-nad__pill {
  position: absolute;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  min-height: 2rem;
  padding: 0.35rem 0.7rem;
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.74);
  backdrop-filter: blur(6px);
  font-size: 0.78rem;
  font-weight: 600;
  color: var(--crs-text, #26251e);
}

.ckb-nad__pill--start {
  inset-block-start: 40px;
  inset-inline-start: 24px;
}

.ckb-nad__pill--end {
  inset-block-end: 44px;
  inset-inline-end: 26px;
}

.ckb-nad__axis {
  position: absolute;
  z-index: 2;
  font-size: 0.78rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--crs-text-ter, rgba(38, 37, 30, 0.4));
}

.ckb-nad__axis--x {
  inset-inline-end: 10px;
  inset-block-end: 0;
}

.ckb-nad__axis--y {
  inset-inline-start: -30px;
  inset-block-start: 50%;
  transform: translateY(-50%) rotate(-90deg);
  transform-origin: left top;
}

.ckb-nad__note {
  position: relative;
  z-index: 1;
  margin: 0;
  max-width: 36ch;
  font-size: 0.875rem;
  line-height: 1.55;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
}

.ckb-visual-placeholder {
  width: 100%;
  height: 100%;
  min-height: 400px;
  background: var(--crs-card-bg, #f2f1ed);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ckb-placeholder-svg {
  width: 60px;
  height: 60px;
  opacity: .3;
}

/* Responsive — tablet */
@media (max-width: 1024px) {
  .ckb-card {
    grid-template-columns: 1fr;
    grid-template-rows: auto 360px;
  }

  .ckb-card--image-left .ckb-visual,
  .ckb-card--image-left .ckb-content {
    grid-column: auto;
  }

  .ckb-visual {
    order: -1;
  }

  .ckb-visual--graph {
    min-height: 420px;
    padding: 16px;
  }

  .ckb-content {
    padding: 40px 32px;
  }
}

/* Responsive — mobile */
@media (max-width: 640px) {
  .ckb-content {
    padding: 32px 20px;
    gap: 20px;
  }

  .ckb-visual {
    min-height: 280px;
  }

  .ckb-visual--graph {
    min-height: 360px;
    padding: 12px;
  }

  .ckb-nad__frame {
    padding: 18px;
    border-radius: 16px;
  }

  .ckb-nad__chart {
    min-height: 300px;
  }

  .ckb-nad__pill {
    font-size: 0.72rem;
  }

  .ckb-nad__axis--y {
    display: none;
  }
}
{% endstylesheet %}

{% javascript %}
  (function () {
    function setupGraph(graph) {
      if (!graph || graph.dataset.graphReady === 'true') return;

      var line = graph.querySelector('.ckb-nad__line');
      if (line) {
        var length = line.getTotalLength();
        line.style.strokeDasharray = length;
        line.style.strokeDashoffset = length;
        graph.style.setProperty('--ckb-nad-path-length', length);
      }

      graph.dataset.graphReady = 'true';
    }

    function observeGraph(graph) {
      if (!graph || graph.dataset.graphObserved === 'true') return;
      graph.dataset.graphObserved = 'true';

      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
        graph.classList.add('is-visible');
        return;
      }

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          observer.unobserve(entry.target);
        });
      }, {
        threshold: 0.35
      });

      observer.observe(graph);
    }

    function init(root) {
      var scope = root || document;
      var graphs = scope.querySelectorAll('[data-ckb-nad-graph]');

      graphs.forEach(function (graph) {
        setupGraph(graph);
        observeGraph(graph);
      });
    }

    document.addEventListener('shopify:section:load', function (event) {
      init(event.target);
    });

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function () {
        init(document);
      });
    } else {
      init(document);
    }
  })();
{% endjavascript %}

{% style %}
  @keyframes ckb-nad-line-draw {
    from {
      stroke-dashoffset: var(--ckb-nad-path-length, 1);
    }
    to {
      stroke-dashoffset: 0;
    }
  }

  @keyframes ckb-nad-marker-in {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.92);
    }
    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes ckb-nad-scan {
    from {
      transform: translateX(0) skewX(-18deg);
    }
    to {
      transform: translateX(360%) skewX(-18deg);
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Cursor Knowledge Base",
  "tag": "section",
  "class": "crs-knowledge-base",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Linke Spalte — Text"
    },
    {
      "type": "select",
      "id": "content_align",
