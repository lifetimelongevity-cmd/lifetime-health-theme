{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_ckb_kicker = section.settings.kicker | strip
  assign crs_ckb_head = section.settings.heading | strip
  assign crs_ckb_sub = section.settings.subheading | strip
  if crs_ckb_kicker == '__none__'
    assign crs_ckb_kicker = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.05 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="ckb-section" id="section-{{ section.id }}">
  <div class="ckb-container">
    <div class="ckb-card{% if section.settings.image_position == 'left' %} ckb-card--image-left{% endif %}">

      {%- comment -%} LEFT — text + testimonial {%- endcomment -%}
      <div class="ckb-content">
        <div class="ckb-text-block crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
          {%- if crs_ckb_kicker != blank -%}
            <p class="crs-heading-stack__kicker">{{ crs_ckb_kicker | escape }}</p>
          {%- endif -%}
          {%- if crs_ckb_head != blank or crs_ckb_sub != blank -%}
            <div class="crs-heading-stack__pair">
              {%- if crs_ckb_head != blank -%}
                <h2 class="crs-heading-stack__title">{{ crs_ckb_head | escape | newline_to_br }}</h2>
              {%- endif -%}
              {%- if crs_ckb_sub != blank -%}
                <p class="crs-heading-stack__subtitle">{{ crs_ckb_sub | escape | newline_to_br }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>

        {%- if section.settings.quote_text != blank -%}
          <figure class="ckb-quote">
            <blockquote>
              <p class="ckb-quote-body">{{ section.settings.quote_text | escape }}</p>
            </blockquote>
            <figcaption class="ckb-author">
              {%- if section.settings.author_image != blank -%}
                <div class="ckb-avatar">
                  {{
                    section.settings.author_image
                    | image_url: width: 84
                    | image_tag:
                      width: 42,
                      height: 42,
                      loading: 'lazy',
                      alt: section.settings.author_name | escape
                  }}
                </div>
              {%- endif -%}
              <div class="ckb-author-info">
                <span class="ckb-author-name">{{ section.settings.author_name | escape }}</span>
                <span class="ckb-author-role">{{ section.settings.author_role | escape }}</span>
              </div>
            </figcaption>
          </figure>
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT — image {%- endcomment -%}
      <div class="ckb-visual">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag:
              loading: 'lazy',
              class: 'ckb-visual-img',
              alt: section.settings.image.alt | escape
          }}
        {%- else -%}
          <div class="ckb-visual-placeholder">
            {{ 'image' | placeholder_svg_tag: 'ckb-placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
/* ===================================================
   Knowledge Base — crs-knowledge-base.liquid
   =================================================== */

.ckb-section {
  background: var(--crs-bg, #f7f7f4);
}

.ckb-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Card — Text 1fr, Bild 2fr (Bild rechts: Text | Bild) */
.ckb-card {
  box-sizing: border-box;
  display: grid;
  grid-template-columns: 1fr 2fr;
  min-height: 560px;
  border-radius: 4px;
  overflow: hidden;
  background: var(--crs-card-bg, #f2f1ed);
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
}

/* Bild links: gleiche Proportionen, Spalten getauscht */
.ckb-card--image-left {
  grid-template-columns: 2fr 1fr;
}

.ckb-card--image-left .ckb-visual {
  grid-column: 1;
}

.ckb-card--image-left .ckb-content {
  grid-column: 2;
}

/* Left column */
.ckb-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 52px 44px;
  gap: 28px;
}

.ckb-text-block {
  display: flex;
  flex-direction: column;
}

/* Testimonial quote */
.ckb-quote {
  margin: 0;
  border-left: 2px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  padding-left: 20px;
}

.ckb-quote-body {
  font-size: .9375rem;
  line-height: 1.6;
  color: var(--crs-text, #26251e);
  margin: 0 0 16px;
}

/* Author */
.ckb-author {
  display: flex;
  align-items: center;
  gap: 12px;
}

.ckb-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 1.5px solid var(--crs-border, rgba(38, 37, 30, 0.05));
}

.ckb-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.ckb-author-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.ckb-author-name {
  font-size: .875rem;
  font-weight: 600;
  color: var(--crs-text, #26251e);
}

.ckb-author-role {
  font-size: .8125rem;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
}

/* Right column — image */
.ckb-visual {
  position: relative;
  overflow: hidden;
}

.ckb-visual-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.ckb-visual-placeholder {
  width: 100%;
  height: 100%;
  min-height: 400px;
  background: var(--crs-card-bg, #f2f1ed);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ckb-placeholder-svg {
  width: 60px;
  height: 60px;
  opacity: .3;
}

/* Responsive — tablet */
@media (max-width: 1024px) {
  .ckb-card {
    grid-template-columns: 1fr;
    grid-template-rows: auto 360px;
  }

  .ckb-card--image-left .ckb-visual,
  .ckb-card--image-left .ckb-content {
    grid-column: auto;
  }

  .ckb-visual {
    order: -1;
  }

  .ckb-content {
    padding: 40px 32px;
  }
}

/* Responsive — mobile */
@media (max-width: 640px) {
  .ckb-content {
    padding: 32px 20px;
    gap: 20px;
  }

  .ckb-visual {
    min-height: 280px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Cursor Knowledge Base",
  "tag": "section",
  "class": "crs-knowledge-base",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Linke Spalte — Text"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Ausrichtung (Überschrift)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Überschrift Größe",
      "options": [
        { "value": "section", "label": "Standard (Abschnitt)" },
        { "value": "product_title", "label": "Wie Produkttitel" }
      ],
      "default": "section",
      "info": "Zeilenumbruch: Enter in Überschrift/Unterüberschrift."
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Überschrift",
      "default": "Deine Wissensdatenbank fürs Engineering"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Unterüberschrift",
      "default": "Ausgelegt für komplexe Codebasen, an denen Tausende von Entwicklern arbeiten."
    },
    {
      "type": "header",
      "content": "Testimonial"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Zitat",
      "default": "Über alle Rollen und Erfahrungsstufen hinweg sehen wir einen Anstieg des PR-Volumens um über 25 % und der durchschnittlichen PR-Größe um über 100 %."
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "Autorenfoto"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Name",
      "default": "Anton Andreev"
    },
    {
      "type": "text",
      "id": "author_role",
      "label": "Position",
      "default": "Principal Software Engineer, Upwork"
    },
    {
      "type": "header",
      "content": "Bild"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Bildposition (Desktop)",
      "options": [
        { "value": "right", "label": "Rechts" },
        { "value": "left", "label": "Links" }
      ],
      "default": "right"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Cursor Knowledge Base"
    }
  ]
}
{% endschema %}
