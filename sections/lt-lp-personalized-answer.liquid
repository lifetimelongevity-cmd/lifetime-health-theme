{% comment %}
  lt-lp-personalized-answer
  Surface: warm editorial answer block
  Dominant element: the personalized headline and dense checklist
  CTA: none
  Quality move: relevant items stay compact and textual, so the section reads like an answer not a feature grid
{% endcomment %}

{% style %}
  #lt-lp-personalized-answer-{{ section.id }} {
    --lt-lp-pa-bg: {{ section.settings.color_bg }};
    --lt-lp-pa-surface: {{ section.settings.color_surface }};
    --lt-lp-pa-text: {{ section.settings.color_text }};
    --lt-lp-pa-muted: {{ section.settings.color_text | color_modify: 'alpha', 0.64 }};
    --lt-lp-pa-border: {{ section.settings.color_text | color_modify: 'alpha', 0.12 }};
    --lt-lp-pa-accent: {{ section.settings.color_accent }};
    --lt-lp-pa-padding-top: {{ section.settings.padding_top }}px;
    --lt-lp-pa-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<section id="lt-lp-personalized-answer-{{ section.id }}" class="lt-lp-pa" data-active-goal="">
  <div class="lt-lp-pa__inner page-width">
    <div class="lt-lp-pa__placeholder" data-pa-placeholder>
      <p class="lt-lp-pa__eyebrow">{{ section.settings.placeholder_eyebrow | escape }}</p>
      <h2 class="lt-lp-pa__headline">{{ section.settings.placeholder_headline | escape }}</h2>
      <p class="lt-lp-pa__body">{{ section.settings.placeholder_body | escape }}</p>
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'goal_answer' -%}
        <article
          class="lt-lp-pa__state"
          data-goal-id="{{ block.settings.goal_id | escape }}"
          data-highlighted-categories="{{ block.settings.highlighted_categories | escape }}"
          data-micro-texts="{{ block.settings.micro_texts_json | escape }}"
          hidden
          {{ block.shopify_attributes }}
        >
          <p class="lt-lp-pa__eyebrow">Dein Fokus</p>
          <h2 class="lt-lp-pa__headline">{{ block.settings.result_headline | escape }}</h2>
          {%- if block.settings.result_subheadline != blank -%}
            <p class="lt-lp-pa__subheadline">{{ block.settings.result_subheadline | escape }}</p>
          {%- endif -%}

          <div class="lt-lp-pa__checklist" data-pa-checklist></div>

          <div class="lt-lp-pa__rest">
            <p class="lt-lp-pa__rest-label">{{ section.settings.rest_categories_label | escape }}</p>
            <p class="lt-lp-pa__rest-list" data-pa-rest></p>
          </div>

          {%- if section.settings.transition_cta_text != blank -%}
            <p class="lt-lp-pa__transition">{{ section.settings.transition_cta_text | escape }}</p>
          {%- endif -%}
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div hidden data-all-categories="{{ section.settings.all_categories_list | escape }}"></div>
</section>

<script>
  (function() {
    var sectionId = '{{ section.id }}';

    function initPersonalizedAnswerSection() {
      var section = document.getElementById('lt-lp-personalized-answer-' + sectionId);
      if (!section || section.dataset.initialized === 'true') return;

      var placeholder = section.querySelector('[data-pa-placeholder]');
      var states = Array.prototype.slice.call(section.querySelectorAll('[data-goal-id]'));
      var allCategoriesEl = section.querySelector('[data-all-categories]');
      var allCategories = (allCategoriesEl && allCategoriesEl.dataset ? allCategoriesEl.dataset.allCategories : '')
        .split(',')
        .map(function(item) { return item.trim(); })
        .filter(Boolean);

      function normalize(value) {
        return String(value || '').trim().toLowerCase();
      }

      function escapeHtml(value) {
        var div = document.createElement('div');
        div.textContent = value;
        return div.innerHTML;
      }

      function setGoal(goalId, shouldScroll) {
        var normalizedGoalId = normalize(goalId);
        var activeState = null;

        states.forEach(function(state) {
          var isActive = normalize(state.dataset.goalId) === normalizedGoalId;
          state.hidden = !isActive;
          if (isActive) activeState = state;
        });

        if (placeholder) {
          placeholder.hidden = Boolean(activeState);
        }

        if (activeState) {
          var highlighted = (activeState.dataset.highlightedCategories || '')
            .split(',')
            .map(function(item) { return item.trim(); })
            .filter(Boolean);

          var microTexts = {};
          try {
            microTexts = JSON.parse(activeState.dataset.microTexts || '{}');
          } catch (error) {
            microTexts = {};
          }

          var checklistEl = activeState.querySelector('[data-pa-checklist]');
          if (checklistEl) {
            checklistEl.innerHTML = highlighted.map(function(title) {
              var micro = microTexts[title] || '';

              return '<div class="lt-lp-pa__check-row">' +
                '<span class="lt-lp-pa__check-icon" aria-hidden="true">' +
                  '<svg viewBox="0 0 24 24" fill="none">' +
                    '<path d="M5 12l5 5 9-11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>' +
                  '</svg>' +
                '</span>' +
                '<span class="lt-lp-pa__check-title">' + escapeHtml(title) + '</span>' +
                '<span class="lt-lp-pa__check-micro">' + escapeHtml(micro) + '</span>' +
              '</div>';
            }).join('');
          }

          var restEl = activeState.querySelector('[data-pa-rest]');
          if (restEl) {
            var highlightedLower = highlighted.map(normalize);
            var restList = allCategories.filter(function(category) {
              return highlightedLower.indexOf(normalize(category)) === -1;
            });
            restEl.textContent = restList.join(' · ');
          }
        }

        section.dataset.activeGoal = activeState ? normalizedGoalId : '';

        if (activeState && shouldScroll) {
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }

      window.addEventListener('quiz-goal-selected', function(event) {
        if (!event.detail || !event.detail.goalId) return;
        setGoal(event.detail.goalId, Boolean(event.detail.shouldScroll));
      });

      setGoal('', false);
      section.dataset.initialized = 'true';
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPersonalizedAnswerSection, { once: true });
    } else {
      initPersonalizedAnswerSection();
    }

    document.addEventListener('shopify:section:load', function(event) {
      if (event.target && event.target.id === 'shopify-section-' + sectionId) {
        initPersonalizedAnswerSection();
      }
    });
  })();
</script>

{% stylesheet %}
.lt-lp-pa {
  background: var(--lt-lp-pa-bg);
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__inner {
  padding-top: var(--lt-lp-pa-padding-top);
  padding-bottom: var(--lt-lp-pa-padding-bottom);
}

.lt-lp-pa__placeholder,
.lt-lp-pa__state {
  max-width: 64rem;
  margin-inline: auto;
  padding: var(--space-7);
  background: var(--lt-lp-pa-surface);
  border: 1px solid var(--lt-lp-pa-border);
  border-radius: var(--radius-lg);
}

.lt-lp-pa__placeholder[hidden],
.lt-lp-pa__state[hidden] {
  display: none;
}

.lt-lp-pa__eyebrow {
  margin: 0;
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-tight);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--lt-lp-pa-muted);
}

.lt-lp-pa__headline {
  margin: var(--space-3) 0 0;
  font-family: var(--font-heading);
  font-size: clamp(var(--text-h2), 4vw, var(--text-display));
  font-weight: var(--weight-bold);
  line-height: var(--leading-heading);
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__body,
.lt-lp-pa__subheadline {
  margin: var(--space-3) 0 0;
  font-family: var(--font-body);
  font-size: var(--text-body-lg);
  line-height: var(--leading-relaxed);
  color: var(--lt-lp-pa-muted);
}

.lt-lp-pa__checklist {
  display: grid;
  gap: var(--space-2);
  margin-top: var(--space-6);
  padding-block: var(--space-5);
  border-top: 1px solid var(--lt-lp-pa-border);
  border-bottom: 1px solid var(--lt-lp-pa-border);
}

.lt-lp-pa__check-row {
  display: grid;
  grid-template-columns: calc(var(--space-6) - var(--space-2)) minmax(11rem, 24%) 1fr;
  align-items: baseline;
  gap: var(--space-4);
  padding-block: var(--space-2);
  font-size: var(--text-body);
  line-height: var(--leading-relaxed);
}

.lt-lp-pa__check-icon {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: calc(var(--space-6) - var(--space-2));
  height: calc(var(--space-6) - var(--space-2));
  color: var(--lt-lp-pa-accent);
}

.lt-lp-pa__check-icon svg {
  width: 100%;
  height: 100%;
}

.lt-lp-pa__check-title {
  font-family: var(--font-body);
  font-size: var(--text-body);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-body);
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__check-micro {
  font-family: var(--font-body);
  font-size: var(--text-body);
  line-height: var(--leading-relaxed);
  color: var(--lt-lp-pa-muted);
}

.lt-lp-pa__rest {
  margin-top: var(--space-5);
}

.lt-lp-pa__rest-label {
  margin: 0 0 var(--space-2);
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-body);
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__rest-list {
  margin: 0;
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  line-height: var(--leading-relaxed);
  color: var(--lt-lp-pa-muted);
}

.lt-lp-pa__transition {
  margin: var(--space-7) 0 0;
  text-align: center;
  font-family: var(--font-body);
  font-size: var(--text-body);
  line-height: var(--leading-body);
  color: var(--lt-lp-pa-muted);
}

@media screen and (max-width: 749px) {
  .lt-lp-pa__placeholder,
  .lt-lp-pa__state {
    padding: var(--space-5);
  }

  .lt-lp-pa__body,
  .lt-lp-pa__subheadline {
    font-size: var(--text-body);
  }

  .lt-lp-pa__check-row {
    grid-template-columns: calc(var(--space-5) - var(--space-1)) 1fr;
    grid-template-areas:
      "icon title"
      ". micro";
    gap: var(--space-1) var(--space-3);
  }

  .lt-lp-pa__check-icon {
    grid-area: icon;
    width: calc(var(--space-5) - var(--space-1));
    height: calc(var(--space-5) - var(--space-1));
    align-self: start;
    margin-top: 2px; /* intentional: optical alignment with the first text baseline */
  }

  .lt-lp-pa__check-title {
    grid-area: title;
  }

  .lt-lp-pa__check-micro {
    grid-area: micro;
    font-size: var(--text-body-sm);
  }
}
{% endstylesheet %}

