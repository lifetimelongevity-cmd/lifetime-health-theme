<script>
  (function() {
    const section = document.getElementById('lt-pdp-hero-{{ section.id }}');
    if (!section) return;

    const reviewButton = section.querySelector('[data-lt-reviews-scroll]');
    if (reviewButton) {
      reviewButton.addEventListener('click', function() {
        const target = document.getElementById('lt-reviews');
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    const plansData = section.querySelector('#lt-selling-plans-data');
    const ltPlans = plansData ? JSON.parse(plansData.textContent).plans : [];

    const planInput = section.querySelector('#lt-selling-plan-input');
    const quantityInput = section.querySelector('[data-lt-quantity-input]');
    const toggleOnce = section.querySelector('#lt-toggle-once');
    const toggleSub = section.querySelector('#lt-toggle-sub');
    const subBanner = section.querySelector('.lt-sub-banner');
    const pills = section.querySelectorAll('.lt-quantity-pill');
    const mainPrice = section.querySelector('.lt-price-main');
    const priceCompare = section.querySelector('[data-js-product-price-compare]');
    const priceSaving = section.querySelector('[data-js-product-price-saving]');
    const stackProductPrice = section.querySelector('[data-lt-stack-product-price]');
    const stackTotalPrice = section.querySelector('[data-lt-stack-total-price]');
    const stackTotalDay = section.querySelector('[data-lt-stack-total-day]');
    const stackTotalWas = section.querySelector('[data-lt-stack-total-was]');
    const guideWasBase = {{ section.settings.stack_guide_value_cents | default: 2990 }};
    const bonusWasBase = {{ section.settings.stack_bonus_value_cents | default: 0 }};
    const baseComparePrice = {{ lt_compare_price | default: 0 }};

    let mode = 'once';

    function formatPrice(cents) {
      return (cents / 100).toFixed(2).replace('.', ',') + ' €';
    }

    function updatePillDisplay() {
      pills.forEach(pill => {
        const priceEl = pill.querySelector('.lt-pill-price');
        const discountEl = pill.querySelector('.lt-pill-discount');
        const cents = parseInt(mode === 'sub' ? pill.dataset.subPrice : pill.dataset.oncePrice, 10);

        if (priceEl) {
          const qty = Math.max(1, parseInt(pill.dataset.quantity, 10) || 1);
          const perMonth = cents / qty;
          priceEl.textContent = qty === 1 ? formatPrice(cents) : formatPrice(perMonth) + '/Mo.';
        }

        if (discountEl) {
          discountEl.style.display = mode === 'sub' ? 'block' : 'none';
        }
      });
    }

    function setMode(newMode) {
      mode = newMode;

      if (toggleOnce) toggleOnce.classList.toggle('lt-toggle--active', mode === 'once');
      if (toggleSub) toggleSub.classList.toggle('lt-toggle--active', mode === 'sub');

      if (subBanner) {
        subBanner.style.display = mode === 'sub' ? 'flex' : 'none';
      }

      if (planInput) {
        planInput.value = mode === 'sub' && ltPlans.length ? ltPlans[0].id : '';
      }

      updatePillDisplay();

      const activePill = section.querySelector('.lt-quantity-pill--active');
      if (activePill && mainPrice) {
        const cents = parseInt(mode === 'sub' ? activePill.dataset.subPrice : activePill.dataset.oncePrice, 10);
        mainPrice.textContent = formatPrice(cents);
      }

      updateStackPricing();
      updatePriceMeta();
    }

    function updateStackPricing() {
      const activePill = section.querySelector('.lt-quantity-pill--active');
      if (!activePill) return;

      const qty = Math.max(1, parseInt(activePill.dataset.quantity, 10) || 1);
      const onceCents = parseInt(activePill.dataset.oncePrice, 10);
      const currentCents = parseInt(mode === 'sub' ? activePill.dataset.subPrice : activePill.dataset.oncePrice, 10);
      const perDay = (currentCents / 100) / (qty * 30);

      if (stackProductPrice) stackProductPrice.textContent = formatPrice(onceCents);
      if (stackTotalPrice) stackTotalPrice.textContent = formatPrice(currentCents);
      if (stackTotalWas) stackTotalWas.textContent = formatPrice(onceCents + guideWasBase + bonusWasBase);
      if (stackTotalDay) stackTotalDay.textContent = 'nur ' + perDay.toFixed(2).replace('.', ',') + ' € pro Tag';
    }

    function updatePriceMeta() {
      const activePill = section.querySelector('.lt-quantity-pill--active');
      if (!activePill) return;

      const qty = Math.max(1, parseInt(activePill.dataset.quantity, 10) || 1);
      const onceCents = parseInt(activePill.dataset.oncePrice, 10);
      const currentCents = parseInt(mode === 'sub' ? activePill.dataset.subPrice : activePill.dataset.oncePrice, 10);
      const compareCents = mode === 'sub' ? onceCents : (baseComparePrice > 0 ? baseComparePrice * qty : 0);
      const savingCents = compareCents > currentCents ? compareCents - currentCents : 0;

      if (priceCompare) {
        priceCompare.textContent = compareCents > currentCents ? formatPrice(compareCents) : '';
      }
      if (priceSaving) {
        priceSaving.textContent = savingCents > 0 ? 'Du sparst ' + formatPrice(savingCents) : '';
      }
    }

    pills.forEach(pill => {
      pill.addEventListener('click', function() {
        pills.forEach(p => p.classList.remove('lt-quantity-pill--active'));
        this.classList.add('lt-quantity-pill--active');
        if (quantityInput) quantityInput.value = String(Math.max(1, parseInt(this.dataset.quantity, 10) || 1));

        if (mainPrice) {
          const cents = parseInt(mode === 'sub' ? this.dataset.subPrice : this.dataset.oncePrice, 10);
          mainPrice.textContent = formatPrice(cents);
        }
        updateStackPricing();
        updatePriceMeta();
      });
    });

    if (toggleOnce) {
      toggleOnce.addEventListener('click', () => setMode('once'));
    }
    if (toggleSub) {
      toggleSub.addEventListener('click', () => setMode('sub'));
    }

    console.log('LT Selling Plans:', ltPlans);
    const initialPill = section.querySelector('.lt-quantity-pill--active');
    if (quantityInput && initialPill) {
      quantityInput.value = String(Math.max(1, parseInt(initialPill.dataset.quantity, 10) || 1));
    }
    setMode('once');
  })();
</script>

