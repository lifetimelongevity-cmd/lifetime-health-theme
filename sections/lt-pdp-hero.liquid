                <span class="lt-bb-card__body">
                  <span class="lt-bb-card__head lt-bb-card__head--once">
                    <span class="lt-bb-card__radio" aria-hidden="true"></span>
                    <span class="lt-bb-card__row lt-bb-card__row--once">
                      <span class="lt-bb-card__meta">
                        <span class="lt-bb-card__title-row">
                          <span class="lt-bb-card__title">{{ bb_once_title | escape }}</span>
                        </span>
                        <span class="lt-bb-card__sub">{{ bb_once_sub | escape }}</span>
                      </span>
                      <span class="lt-bb-card__prices">
                        <del class="lt-bb-card__compare" data-lt-bb-compare></del>
                        <span class="lt-bb-card__current" data-lt-bb-current></span>
                        <span class="lt-bb-card__unit" data-lt-bb-unit></span>
                      </span>
                    </span>
                  </span>
                </span>
              </label>
            </div>
            {%- else -%}
            <div class="lt-price-direct">
              <span class="lt-price-direct__amount">{{ lt_pill_1_once | money }}</span>
              {%- if lt_compare_price > lt_pill_1_once -%}
                <del class="lt-price-direct__compare">{{ lt_compare_price | money }}</del>
              {%- endif -%}
              <span class="lt-price-direct__note">{{ section.settings.bb_once_subline | default: '' | escape }}</span>
            </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if lt_show_sub -%}
          <div
            id="lt-appstle-widget"
            data-product-id="{{ product.id }}"
            data-variant-id="{{ lt_variant_1.id }}"
            style="display:none"
          >
            <div class="appstle_subscription_widget" data-product-id="{{ product.id }}"></div>
          </div>
        {%- endif -%}

        {%- unless lt_show_sub -%}
          {{ lt_value_stack_block }}
        {%- endunless -%}

        {%- assign product_form_id = 'product-form-' | append: section.id -%}
        <product-form
          id="add-to-cart-{{ section.id }}"
          class="product-form"
          {% if settings.cart_action == 'overlay' %}
            data-ajax-cart
            data-js-product-form
          {% endif %}
        >
          {%- form 'product',
            product,
            id: product_form_id,
            class: 'form',
            novalidate: 'novalidate',
            data-type: 'add-to-cart-form'
          -%}
            <input type="hidden" name="id" value="{{ lt_variant_1.id }}" data-lt-variant-input>
            <input type="hidden" name="quantity" value="1" data-lt-quantity-input>
            <input type="hidden" id="lt-selling-plan-input" name="selling_plan" value="">
            <div class="product__cart-functions">
              <div class="flex-buttons">
                <button
                  id="lt-hero-atc"
                  type="submit"
                  name="add"
                  class="add-to-cart button button--solid button--product button--loader button--move lt-pdp-hero__atc {% unless current_variant.available %}disabled{% endunless %}"
                  data-js-product-add-to-cart
                  data-main-product-add-to-cart
                >
                  <span class="button__text" data-js-product-add-to-cart-text>
                    Jetzt kaufen →
                  </span>
                  <span class="button__preloader">
                    <svg class="button__preloader-element" viewBox="25 25 50 50">
                      <circle cx="50" cy="50" r="20" fill="none" stroke-width="4"></circle>
                    </svg>
                  </span>
                </button>
              </div>
            </div>
          {%- endform -%}
        </product-form>

        {%- unless lt_show_sub -%}
          {{ lt_trust_block }}
          {{ lt_doctor_block }}
        {%- endunless -%}

        {%- if shop.enabled_payment_types.size > 0 -%}
          <div class="lt-payment-icons" aria-label="Zahlungsmethoden">
            {%- for type in shop.enabled_payment_types -%}
              {{ type | payment_type_svg_tag: class: 'lt-payment-icon' }}
            {%- endfor -%}
          </div>
        {%- endif -%}

        <script>
          window.ltPricing = {
            basePrice: {{ lt_base_price }},
            comparePrice: {{ lt_compare_price | default: 0 }},
            subDiscount: {{ section.settings.sub_discount_percent | default: 15 }} * 0.01
          };
        </script>

        {%- if section.settings.show_guarantee_badge -%}
          {%- assign lt_guarantee_line = section.settings.guarantee_text | default: 'Das 90-Tage-Zell-Versprechen — kein Formular, kein Aufwand' -%}
          {%- assign lt_guarantee_popup_plain = section.settings.guarantee_popup_body | default: '' | strip_html | strip -%}
          <div class="lt-pdp-hero__guarantee">
            {%- if section.settings.guarantee_badge_icon != blank -%}
              {{
                section.settings.guarantee_badge_icon
                | image_url: width: 48
                | image_tag: loading: 'lazy', class: 'lt-pdp-hero__guarantee-icon-img', alt: ''
              }}
            {%- else -%}
              <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
                <path d="M6 1L2 3v3c0 2.5 1.8 4.5 4 5 2.2-.5 4-2.5 4-5V3L6 1Z" stroke="currentColor" stroke-width="0.8" fill="none"></path>
                <path d="M4 6l1.5 1.5 2.5-2.5" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            {%- endif -%}
            {%- if lt_guarantee_popup_plain != '' -%}
              <button
                type="button"
                class="lt-pdp-hero__guarantee-btn"
                data-crs-dialog-open
                aria-haspopup="dialog"
                aria-controls="crs-lt-hero-guarantee-{{ section.id }}"
              >
                {{ lt_guarantee_line | escape }}
              </button>
              <dialog
                id="crs-lt-hero-guarantee-{{ section.id }}"
                class="crs-micro-dialog"
                aria-modal="true"
                aria-labelledby="crs-lt-hero-guarantee-title-{{ section.id }}"
              >
                <div class="crs-micro-dialog__inner">
                  <button
                    type="button"
                    class="crs-micro-dialog__close"
                    data-crs-dialog-close
                    aria-label="{{ 'general.accessibility_labels.close' | t }}"
                  >
                    <span aria-hidden="true">×</span>
                  </button>
                  {%- assign lt_gdlg_title = section.settings.guarantee_popup_title | strip -%}
                  {%- if lt_gdlg_title == '' -%}
                    {%- assign lt_gdlg_title = lt_guarantee_line -%}
                  {%- endif -%}
                  <h2 id="crs-lt-hero-guarantee-title-{{ section.id }}" class="crs-micro-dialog__title">
                    {{ lt_gdlg_title | escape }}
                  </h2>
                  <div class="crs-micro-dialog__body rte">{{ section.settings.guarantee_popup_body }}</div>
                </div>
              </dialog>
            {%- else -%}
              <span class="lt-pdp-hero__guarantee-text">{{ lt_guarantee_line | escape }}</span>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if lt_show_sub -%}
          {{ lt_trust_block }}
          {{ lt_doctor_block }}
          {{ lt_value_stack_block }}
        {%- endif -%}

      </div>

      {%- if section.settings.show_sticky_atc and product.available -%}
        <div style="display:none!important" data-update-block="price-sticky-main">
          <span class="show-block-if-variant-selected">
            <span class="sticky-add-to-cart__price-original text-weight--bold">
              {{ current_variant.price | money | append: iso_code }}
            </span>
            {%- if lt_sticky_show_compare_price and current_variant.compare_at_price > current_variant.price -%}
              <del class="sticky-add-to-cart__price-compare">
                {{ current_variant.compare_at_price | money | append: iso_code }}
              </del>
            {%- endif -%}
          </span>
        </div>
      {%- endif -%}
    </product-page>
    {%- if section.settings.show_benefits_icons -%}
      <div class="lt-benefits-icons lt-benefits-icons--mobile" aria-label="Produktvorteile">
        <div class="lt-benefit-item">
          <span class="lt-benefit-icon" aria-hidden="true">
            {%- if section.settings.benefit_1_icon != blank -%}
              {{
                section.settings.benefit_1_icon
                | image_url: width: 96
                | image_tag: loading: 'lazy', class: 'lt-benefit-icon__img', alt: ''
              }}
            {%- else -%}
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.2" opacity="0.35"></circle>
                <path d="M6.5 9.2l1.8 1.8 3.3-3.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            {%- endif -%}
          </span>
          <p>{{ section.settings.benefit_1_text }}</p>
        </div>
        <div class="lt-benefit-item">
          <span class="lt-benefit-icon" aria-hidden="true">
            {%- if section.settings.benefit_2_icon != blank -%}
              {{
                section.settings.benefit_2_icon
                | image_url: width: 96
                | image_tag: loading: 'lazy', class: 'lt-benefit-icon__img', alt: ''
              }}
            {%- else -%}
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.2" opacity="0.35"></circle>
                <path d="M6.5 9.2l1.8 1.8 3.3-3.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            {%- endif -%}
          </span>
          <p>{{ section.settings.benefit_2_text }}</p>
        </div>
        <div class="lt-benefit-item">
          <span class="lt-benefit-icon" aria-hidden="true">
            {%- if section.settings.benefit_3_icon != blank -%}
              {{
                section.settings.benefit_3_icon
                | image_url: width: 96
                | image_tag: loading: 'lazy', class: 'lt-benefit-icon__img', alt: ''
              }}
            {%- else -%}
              <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.2" opacity="0.35"></circle>
                <path d="M6.5 9.2l1.8 1.8 3.3-3.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
              </svg>
            {%- endif -%}
          </span>
          <p>{{ section.settings.benefit_3_text }}</p>
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{%- if section.settings.show_sticky_atc and product.available -%}
  {%- comment -%}
    Kein data-single-with-options: Theme-Komponente würde Preis aus price-sticky-main spiegeln (AJAX-Varianten).
    LT Hero hat kein product-variants — Kaufoptionen laufen über die Buy-Box; Preis kommt ausschließlich aus JS (syncFromCard).
  {%- endcomment -%}
  <sticky-add-to-cart
    id="lt-sticky-atc"
    data-single
    data-lt-pdp-hero-sticky
    data-id="product-{{ section.id }}"
    class="sticky-add-to-cart lt-sticky-atc sticky-add-to-cart--default-to-first-variant-{{ default_to_first_variant }}"
  >
    <div class="lt-sticky-atc__inner">
      <div class="lt-sticky-atc__left">
        {%- if product.featured_media != blank -%}
          <img
            src="{{ product.featured_media | image_url: width: 80, height: 80, crop: 'center' }}"
            alt="{{ product.featured_media.alt | default: product.title | escape }}"
            loading="lazy"
            width="40"
            height="40"
            class="lt-sticky-atc__image"
          >
        {%- endif -%}
        <div class="lt-sticky-atc__meta">
          <span class="lt-sticky-atc__title">{{ product.title | escape }}</span>
          {%- if section.settings.sticky_atc_subline != blank -%}
            <span class="lt-sticky-atc__subline" data-lt-sticky-atc-subline>{{ section.settings.sticky_atc_subline | escape }}</span>
          {%- endif -%}
          <div class="lt-sticky-atc__price" data-js-atc-price>
            <span class="sticky-add-to-cart__price-original text-weight--bold">
              {{ current_variant.price | money | append: iso_code }}
            </span>
            {%- if lt_sticky_show_compare_price and current_variant.compare_at_price > current_variant.price -%}
              <del class="sticky-add-to-cart__price-compare">
                {{ current_variant.compare_at_price | money | append: iso_code }}
              </del>
            {%- endif -%}
          </div>
        </div>
      </div>
      <div class="lt-sticky-atc__right">
        <button data-js-atc class="button button--solid button--move button--product button--loader lt-sticky-btn">
          <span class="button__text">In den Warenkorb</span>
          <span class="button__preloader">
            <svg class="button__preloader-element" viewBox="25 25 50 50">
              <circle cx="50" cy="50" r="20" fill="none" stroke-width="4"></circle>
            </svg>
          </span>
        </button>
      </div>
    </div>
  </sticky-add-to-cart>
{%- endif -%}

{% render 'crs-micro-dialog-init' %}

<script src="{{ 'section-main-product.js' | asset_url }}" defer></script>
{%- if video_script -%}
  <script>
    KrownAssetLoader.loadScript('{{ "component-video.js" | asset_url }}');
  </script>
{%- endif -%}
<script>
  (function() {
    const section = document.getElementById('lt-pdp-hero-{{ section.id }}');
    if (!section) return;

    const ltStickyShowCompare = section.dataset.ltStickyShowCompare !== '0';

    const reviewButton = section.querySelector('[data-lt-reviews-scroll]');

    function markLooxSection() {
      const looxRoot = document.querySelector(
        '#looxReviews, .loox-dynamic-section, [class*="loox-dynamic-section"], .loox-v2-widget-container'
      );
      if (!looxRoot) return false;

      const looxSection = looxRoot.closest('[id^="shopify-section-"]') || looxRoot.closest('.shopify-section') || looxRoot;
      looxSection.classList.add('lt-loox-section');

      if (!document.getElementById('lt-reviews') && !looxRoot.id) {
        looxRoot.id = 'lt-reviews';
      }

      return true;
    }

    if (!markLooxSection()) {
      const looxObserver = new MutationObserver(function() {
        if (markLooxSection()) looxObserver.disconnect();
      });
      looxObserver.observe(document.body, { childList: true, subtree: true });
      window.setTimeout(function() {
        looxObserver.disconnect();
      }, 12000);
    }

    if (reviewButton) {
      reviewButton.addEventListener('click', function() {
        const target = document.getElementById('lt-reviews')
          || document.querySelector('.lt-loox-section');
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    const buyBox = section.querySelector('[data-lt-buy-box]');
    const plansData = section.querySelector('#lt-selling-plans-data');
    const ltPlans = plansData ? JSON.parse(plansData.textContent).plans : [];

    const planInput = section.querySelector('#lt-selling-plan-input');
    const quantityInput = section.querySelector('[data-lt-quantity-input]');
    const mainPrice = section.querySelector('.lt-price-main');
    const priceCompare = section.querySelector('[data-js-product-price-compare]');
    const priceSaving = section.querySelector('[data-js-product-price-saving]');
    const baseComparePrice = {{ lt_compare_price | default: 0 }};

    if (!buyBox) return;

    const supplyDays = Math.max(1, parseFloat(buyBox.dataset.supplyDays) || 30);
    const badgeDiscountPct = Math.max(0, parseInt(buyBox.dataset.discountPct, 10) || 0);
    const productPageId = 'product-{{ section.id }}';

    function formatPrice(cents) {
      return (cents / 100).toFixed(2).replace('.', ',') + ' €';
    }

    function formatPerDay(cents, qty) {
      const totalDays = Math.max(1, supplyDays * Math.max(1, qty || 1));
      const perDay = (cents / 100) / totalDays;
      return perDay.toFixed(2).replace('.', ',') + ' €/Tag';
    }

    function escapeLtHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    /** Vergleichspreis für Sticky (wie Buy-Box / updatePriceMeta) */
    function stickyCompareCents(isSub, qty, onceCents, subCents, currentCents) {
      if (isSub) {
        return onceCents > subCents ? onceCents : 0;
      }
      var shopCompare = baseComparePrice > 0 ? baseComparePrice * qty : 0;
      return shopCompare > onceCents ? shopCompare : 0;
    }

    function buildStickyPriceInner(currentCents, compareCents) {
      var main = formatPrice(currentCents);
      var h =
        '<span class="sticky-add-to-cart__price-original text-weight--bold">' +
        escapeLtHtml(main) +
        '</span>';
      if (ltStickyShowCompare && compareCents > currentCents) {
        h +=
          '<del class="sticky-add-to-cart__price-compare">' +
          escapeLtHtml(formatPrice(compareCents)) +
          '</del>';
      }
      return h;
    }

    function syncStickyAtcPrice(isSub, qty, onceCents, subCents, currentCents) {
      var cmp = stickyCompareCents(isSub, qty, onceCents, subCents, currentCents);
      var inner = buildStickyPriceInner(currentCents, cmp);
      var wrapped =
        '<span class="show-block-if-variant-selected">' + inner + '</span>';

      var stickyRoot = document.querySelector('#lt-sticky-atc [data-js-atc-price]');
      if (stickyRoot) stickyRoot.innerHTML = inner;

      var hidden = document.querySelector('#' + productPageId + ' [data-update-block="price-sticky-main"]');
      if (hidden) hidden.innerHTML = wrapped;
    }

    function savingsPct(onceC, subC) {
      if (!onceC || onceC <= subC) return 0;
      return Math.round((1 - subC / onceC) * 100);
    }

    function getRadio(card) {
      return card.querySelector('.lt-bb-card__input');
    }

    function updatePriceMeta(isSub, qty, onceCents, currentCents) {
      const compareCents = isSub ? onceCents : (baseComparePrice > 0 ? baseComparePrice * qty : 0);
      const savingCents = compareCents > currentCents ? compareCents - currentCents : 0;

      if (priceCompare) {
        priceCompare.textContent = compareCents > currentCents ? formatPrice(compareCents) : '';
      }
      if (priceSaving) {
        priceSaving.textContent = savingCents > 0 ? 'Du sparst ' + formatPrice(savingCents) : '';
      }
    }

    function updateCardFacades() {
      const cards = section.querySelectorAll('[data-lt-bb-card]');
      const subCards = [];

      cards.forEach(card => {
        const input = getRadio(card);
        if (!input) return;

        const kind = card.dataset.bbKind;
        const qty = Math.max(1, parseInt(input.dataset.quantity, 10) || 1);
        const onceC = parseInt(input.dataset.oncePrice, 10) || 0;
        const subC = parseInt(input.dataset.subPrice, 10) || 0;
        const compareEl = card.querySelector('[data-lt-bb-compare]');
        const currentEl = card.querySelector('[data-lt-bb-current]');
        const unitEl = card.querySelector('[data-lt-bb-unit]');
        const badgeEl = card.querySelector('[data-lt-bb-badge]');

        if (kind === 'sub') {
          const pct = badgeDiscountPct > 0 ? badgeDiscountPct : savingsPct(onceC, subC);
          subCards.push({ card, badgeEl, pct });

          if (badgeEl) {
            if (pct > 0) {
              badgeEl.textContent = 'SPARE ' + pct + '%';
              badgeEl.hidden = false;
            } else {
              badgeEl.textContent = '';
              badgeEl.hidden = true;
            }
          }
          if (compareEl) {
            if (onceC > subC) {
              compareEl.textContent = formatPrice(onceC);
              compareEl.hidden = false;
            } else {
              compareEl.textContent = '';
              compareEl.hidden = true;
            }
          }
          if (currentEl) currentEl.textContent = formatPrice(subC);
          if (unitEl) {
            unitEl.textContent = formatPerDay(subC, qty);
          }
        } else {
          const shopCompare = baseComparePrice > 0 ? baseComparePrice * qty : 0;
          if (compareEl) {
            if (shopCompare > onceC) {
              compareEl.textContent = formatPrice(shopCompare);
              compareEl.hidden = false;
            } else {
              compareEl.textContent = '';
              compareEl.hidden = true;
            }
          }
          if (currentEl) currentEl.textContent = formatPrice(onceC);
          if (unitEl) {
            unitEl.textContent = formatPerDay(onceC, qty);
          }
        }
      });

      if (subCards.length === 2) {
        const a = subCards[0].pct;
        const b = subCards[1].pct;
        const firstStrong = a >= b;
        [subCards[0], subCards[1]].forEach((entry, i) => {
          const el = entry.badgeEl;
          if (!el || el.hidden) return;
          const strong = i === 0 ? firstStrong : !firstStrong;
          el.classList.toggle('lt-bb-card__badge--strong', strong);
          el.classList.toggle('lt-bb-card__badge--muted', !strong);
        });
      }
    }

    function syncFromCard(card) {
      const input = getRadio(card);
      if (!input) return;

      const kind = card.dataset.bbKind;
      const qty = Math.max(1, parseInt(input.dataset.quantity, 10) || 1);
      const onceCents = parseInt(input.dataset.oncePrice, 10) || 0;
      const subCents = parseInt(input.dataset.subPrice, 10) || 0;
      const isSub = kind === 'sub';
      const currentCents = isSub ? subCents : onceCents;

      if (quantityInput) quantityInput.value = String(qty);
      if (planInput) {
        planInput.value = isSub && ltPlans.length ? String(ltPlans[0].id) : '';
      }
      if (mainPrice) mainPrice.textContent = formatPrice(currentCents);

      updateCardFacades();
      updatePriceMeta(isSub, qty, onceCents, currentCents);

      syncStickyAtcPrice(isSub, qty, onceCents, subCents, currentCents);

      var atcTextEl = section.querySelector('[data-js-product-add-to-cart-text]');
      var atcLabel =
        (isSub ? 'Abo' : 'Einmalig') + ': ' + formatPrice(currentCents) + ' — Jetzt kaufen →';
      if (atcTextEl) {
        atcTextEl.textContent = atcLabel;
      }
      var atcBtn = section.querySelector('#lt-hero-atc');
      if (atcBtn) {
        atcBtn.setAttribute('aria-label', atcLabel.replace(' →', ''));
      }
    }

    function selectCard(card) {
      if (!card) return;
      section.querySelectorAll('[data-lt-bb-card]').forEach(c => {
        c.classList.toggle('is-selected', c === card);
        const inp = getRadio(c);
        if (inp) inp.checked = c === card;
      });
      syncFromCard(card);
    }

    section.querySelectorAll('[data-lt-bb-card]').forEach(card => {
      const input = getRadio(card);
      if (!input) return;
      input.addEventListener('change', function() {
        if (this.checked) selectCard(card);
      });
    });

    // No selling plans → hide subscription card and or-divider, pre-select once card
    if (ltPlans.length === 0) {
      const noSubCard = section.querySelector('.lt-bb-card--sub');
      const noOrDiv  = section.querySelector('.lt-bb__or');
      if (noSubCard) {
        noSubCard.hidden = true;
        const noSubRadio = noSubCard.querySelector('.lt-bb-card__input');
        if (noSubRadio) noSubRadio.checked = false;
      }
      if (noOrDiv) noOrDiv.hidden = true;
      const noOnceCard = section.querySelector('.lt-bb-card--once');
      if (noOnceCard) {
        noOnceCard.classList.add('is-selected');
        const noOnceRadio = noOnceCard.querySelector('.lt-bb-card__input');
        if (noOnceRadio) noOnceRadio.checked = true;
      }
    }

    const initialCard = section.querySelector('.lt-bb-card__input:checked')?.closest('[data-lt-bb-card]');
    if (initialCard) {
      selectCard(initialCard);
    } else {
      updateCardFacades();
    }

    /* Nach deferred section-main-product.js: StickyAddToCart kann Initial-HTML setzen — Buy-Box erneut anwenden */
    if (typeof customElements !== 'undefined' && customElements.whenDefined) {
      customElements.whenDefined('sticky-add-to-cart').then(function () {
        var inp = section.querySelector('.lt-bb-card__input:checked');
        if (inp) inp.dispatchEvent(new Event('change', { bubbles: true }));
      });
    }
  })();
</script>

{% stylesheet %}
/* ===================================================
   LT PDP Hero — Cursor-Style Overrides
   lt-pdp.css tokens are remapped via {% style %} above.
   This block handles structural overrides that need
   CSS (not just token swaps).
   =================================================== */

/* Section background */
.lt-pdp-hero-section {
  background: var(--lt-bg, #f7f7f4);
}

/* Title — cursor H2 style (36px / weight 400 / tight tracking) */
.lt-pdp-hero__title {
  font-size: 36px !important;
  font-weight: 400 !important;
  line-height: 1.15 !important;
  letter-spacing: -0.72px !important;
}

/* Tagline — lighter, no italic */
.lt-pdp-hero__tagline {
  font-style: normal !important;
  opacity: 1 !important;
  font-size: 13px !important;
}

/* Gallery frame — sharp corners */
.lt-pdp-hero__gallery-frame {
  border-radius: 4px !important;
}

.lt-pdp-hero .product-gallery-item,
.lt-pdp-hero .product-gallery-item img {
  border-radius: 4px !important;
}

/* Purchase block — flat, no border */
.lt-purchase-block {
  border: none !important;
  background: var(--lt-surface, #f2f1ed) !important;
  border-radius: 4px !important;
}

/* Direct price display — no-subscription mode */
.lt-price-direct {
  padding: 16px 20px;
  display: flex;
  align-items: baseline;
  gap: 10px;
  flex-wrap: wrap;
}
.lt-price-direct__amount {
  font-size: 22px;
  font-weight: 500;
  letter-spacing: -0.3px;
  color: var(--lt-text, #26251e);
}
.lt-price-direct__compare {
  font-size: 15px;
  opacity: 0.45;
  text-decoration: line-through;
  color: var(--lt-text, #26251e);
}
.lt-price-direct__note {
  font-size: 12px;
  opacity: 0.6;
  color: var(--lt-text, #26251e);
  width: 100%;
  margin-top: -4px;
}

/* Buy-box cards — flat cursor style */
.lt-bb-card {
  background: var(--lt-bg, #f7f7f4) !important;
  border: 1px solid var(--lt-border, rgba(38,37,30,0.1)) !important;
  border-radius: 4px !important;
  box-shadow: none !important;
}

.lt-bb-card.is-selected {
  background: #fff !important;
  border-color: var(--lt-text, #26251e) !important;
  border-width: 1.5px !important;
  box-shadow: none !important;
}

.lt-bb-card__perks {
  background: transparent !important;
  border-radius: 0 0 4px 4px !important;
}

.lt-bb-card__radio {
  border-color: var(--lt-border, rgba(38,37,30,0.2)) !important;
}

.lt-bb-card.is-selected .lt-bb-card__radio {
  border-color: var(--lt-text, #26251e) !important;
}

.lt-bb-card.is-selected .lt-bb-card__radio::after {
  background: var(--lt-text, #26251e) !important;
}

/* Card title — weight 400 */
.lt-bb-card__title {
  font-weight: 400 !important;
}

/* ATC — über .button--solid (theme.css: --color-text-main) erzwingen */
.lt-pdp-hero__atc.button,
#lt-hero-atc {
  border-radius: 999px !important;
  font-weight: 500 !important;
  font-size: 15px !important;
  background: var(--color-dark) !important;
  border-color: var(--color-dark) !important;
  color: var(--color-text-on-dark) !important;
  white-space: normal;
}

.lt-pdp-hero__atc.button .button__text,
#lt-hero-atc .button__text {
  color: var(--color-text-on-dark) !important;
  white-space: normal;
  line-height: var(--leading-tight);
  text-align: center;
}

.lt-pdp-hero__atc.button .button__preloader circle,
#lt-hero-atc .button__preloader circle {
  stroke: var(--color-text-on-dark) !important;
}

.no-touchevents .lt-pdp-hero__atc.button:hover,
.no-touchevents #lt-hero-atc:hover {
  background: var(--color-dark) !important;
  border-color: var(--color-dark) !important;
  filter: brightness(1.12);
}

/* Sticky ATC button */
.lt-sticky-atc__right .button,
#lt-sticky-atc .lt-sticky-btn {
  border-radius: 999px !important;
  background: var(--lt-cta-bg, #26251e) !important;
  color: #fff !important;
  border-color: var(--lt-cta-bg, #26251e) !important;
}

/* Gallery slider — keep arrows/progress hidden */
.lt-pdp-hero .css-slider-button,
.lt-pdp-hero .css-slider-nav,
.lt-pdp-hero .css-slider-progress {
  display: none !important;
}

@media screen and (min-width: 768px) {
  .lt-pdp-hero .css-slider-dot-navigation,
  .lt-pdp-hero .css-slider-navigation-container {
    display: none !important;
  }
}

@media screen and (max-width: 767px) {
  .lt-pdp-hero .css-slider-navigation-container {
    display: flex !important;
    justify-content: center;
    margin-top: 12px;
  }

  .lt-pdp-hero .css-slider-dot-navigation {
    display: block !important;
  }
}

/* Once card — remove focus outline (shows as double border) */
.lt-bb-card:focus-within {
  outline: none !important;
}

/* Trust bar — adjust border color */
.lt-pdp-hero__trust {
  border-top-color: var(--lt-border, rgba(38,37,30,0.1)) !important;
  border-bottom-color: var(--lt-border, rgba(38,37,30,0.1)) !important;
}

/* Doctor/founder block — no teal accent */
.lt-pdp-hero__doctor {
  background: var(--lt-surface, #f2f1ed) !important;
  border-left: 2px solid var(--lt-border, rgba(38,37,30,0.15)) !important;
}

/* Savings badge — muted cursor tone */
.lt-price-row__saving {
  border-radius: 4px !important;
}

.lt-bb-card__badge {
  border-radius: 4px !important;
}

/* Value stack */
.lt-value-stack {
  border: 1px solid var(--lt-border, rgba(38,37,30,0.1));
  border-radius: 4px;
  padding: 16px;
  display: flex;
  flex-direction: column;
}

.lt-value-stack__header {
  font-size: 11px !important;
  font-weight: 500 !important;
  letter-spacing: 0.07em !important;
  text-transform: uppercase !important;
  color: var(--lt-muted, rgba(38,37,30,0.55)) !important;
  margin: 0 0 8px !important;
}

.lt-value-stack__item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  border-bottom: 1px solid var(--lt-border, rgba(38,37,30,0.08));
  gap: 12px;
}

.lt-value-stack__item-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
  min-width: 0;
}

.lt-value-stack__item-title {
  font-size: 14px;
  font-weight: 500;
  color: var(--lt-text, #26251e);
}

.lt-value-stack__item-sub {
  font-size: 12px;
  color: var(--lt-muted, rgba(38,37,30,0.55));
}

.lt-value-stack__item-price {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 1px;
  flex-shrink: 0;
}

.lt-value-stack__item-was {
  font-size: 11px;
  color: var(--lt-muted, rgba(38,37,30,0.4));
  text-decoration: line-through;
}

.lt-value-stack__item-label {
  font-size: 13px;
  font-weight: 500;
  color: var(--lt-text, #26251e);
}

.lt-value-stack__item-label--free {
  color: var(--lt-text, #26251e);
}

.lt-value-stack__total {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 8px;
  padding-top: 12px;
  border-top: 1px solid color-mix(in srgb, var(--lt-text, #26251e) 12%, transparent);
  opacity: 0.5;
}

.lt-value-stack__total-label {
  font-size: var(--font-size-sm, 12px);
  font-weight: 400;
  color: var(--lt-text, #26251e);
}

.lt-value-stack__total-value {
  font-size: var(--font-size-sm, 12px);
  font-weight: 500;
  color: var(--lt-text, #26251e);
  text-decoration: line-through;
}

.lt-value-stack__pay-today {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 12px;
  margin-top: 4px;
  border-top: 1px solid color-mix(in srgb, var(--lt-text, #26251e) 10%, transparent);
}

.lt-value-stack__pay-label {
  font-size: var(--font-size-lg, 17px);
  font-weight: 700;
  color: var(--lt-text, #26251e);
}

.lt-value-stack__pay-price {
  font-size: var(--font-size-lg, 17px);
  font-weight: 700;
  letter-spacing: -0.3px;
  color: var(--lt-text, #26251e);
}

/* Unselected cards — muted */
.lt-bb-card:not(.is-selected) {
  opacity: 0.6;
  transition: opacity 0.15s ease;
}

.lt-bb-card:not(.is-selected):hover {
  opacity: 0.85;
}

/* Payment icons */
.lt-payment-icons {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  align-items: center;
  justify-content: center;
  margin-top: 12px;
}

.lt-payment-icon {
  height: 24px;
  width: auto;
  border-radius: 3px;
  opacity: 0.65;
}

{% endstylesheet %}

