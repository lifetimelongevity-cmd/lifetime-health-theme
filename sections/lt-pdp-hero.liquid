{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign default_to_first_variant = true
  assign gallery_layout = 'slider'
  assign gallery_mobile_width = 100
  assign lt_variant_1 = current_variant
  assign lt_variant_3 = blank
  assign lt_variant_6 = blank
  for variant in product.variants
    assign lt_variant_options = variant.options | join: ' ' | downcase
    if lt_variant_1 == blank and lt_variant_options contains '1'
      assign lt_variant_1 = variant
    endif
    if lt_variant_3 == blank and lt_variant_options contains '3'
      assign lt_variant_3 = variant
    endif
    if lt_variant_6 == blank and lt_variant_options contains '6'
      assign lt_variant_6 = variant
    endif
  endfor
  if lt_variant_1 == blank
    assign lt_variant_1 = current_variant
  endif
  assign lt_has_pack_variants = false
  if lt_variant_3 != blank and lt_variant_6 != blank
    if lt_variant_3.id != lt_variant_1.id and lt_variant_6.id != lt_variant_1.id
      assign lt_has_pack_variants = true
    endif
  endif
  assign lt_base_price = lt_variant_1.price
  assign lt_compare_price = lt_variant_1.compare_at_price | default: 0
  assign lt_sub_1 = lt_base_price | times: 0.85 | round
  assign lt_sub_3 = lt_base_price | times: 3 | times: 0.85 | round
  assign lt_sub_6 = lt_base_price | times: 6 | times: 0.85 | round
  if settings.show_currency_codes
    assign iso_code = localization.country.currency.iso_code | prepend: ' '
  endif
-%}

<section id="lt-pdp-hero-{{ section.id }}" class="lt-pdp-hero-section">
  <div class="lt-pdp-hero__container">
    <product-page
      id="product-{{ section.id }}"
      class="lt-pdp-hero"
      data-collection="{{ collection.handle }}"
      data-id="{{ product.id }}"
      data-availability="{{ product.available }}"
      data-js-product-component
    >
      <div class="lt-pdp-hero__gallery-wrap element--is-sticky">
        <div class="lt-pdp-hero__gallery-frame">
          {%- if section.settings.show_badge -%}
            <span class="lt-pdp-hero__badge lt-badge">{{ section.settings.badge_text | default: 'Bestseller' | escape }}</span>
          {%- endif -%}

          <div class="product-gallery product-gallery--slider lap--grid--slider-container" data-js-product-gallery>
            {%- if product.media.size > 1 -%}
              <css-slider
                data-options='
                  {
                    "selector": ".product-gallery-item",
                    "autoHeight": false,
                    "navigationDOM": "<span class=\"css-slider-button css-slider-prev\" style=\"display:none\"><svg fill=\"none\" height=\"11\" viewBox=\"0 0 6 11\" width=\"6\" xmlns=\"http://www.w3.org/2000/svg\"><path clip-rule=\"evenodd\" d=\"m4.32845 10.0708-4.18198-4.18194c-.195261-.19526-.195261-.51185 0-.70711l4.18198-4.181979c.19527-.195262.51185-.195262.70711 0 .19526.195259.19526.511849 0 .707109l-3.32843 3.32842s-.70713.4647-.00002 1l3.32845 3.32843c.19526.19526.19526.51185 0 .70707-.19526.1953-.51185.1953-.70711 0z\" fill=\"#000\" fill-rule=\"evenodd\"/></svg></span><span class=\"css-slider-button css-slider-next\" style=\"display:none\"><svg fill=\"none\" height=\"11\" viewBox=\"0 0 6 11\" width=\"6\" xmlns=\"http://www.w3.org/2000/svg\"><path clip-rule=\"evenodd\" d=\"m.853555.999962 4.181985 4.181978c.19526.19526.19526.51185 0 .70711l-4.181983 4.18195c-.195263.1953-.511845.1953-.707108 0-.1952631-.19523-.1952632-.51181 0-.70708l3.328431-3.32842s.70713-.4647.00002-1l-3.328453-3.32843c-.1952626-.19526-.1952627-.51185 0-.707108.195263-.195262.511845-.195262.707108 0z\" fill=\"#000\" fill-rule=\"evenodd\"/></svg></span>",
                    "thumbnailsDOM": "<div class=\"css-slider-dot-navigation\" style=\"display:none;--size:{{ product.media.size }}\"></div>",
                    "listenScroll": false
                  }
                '
                class="css-slider--bottom-navigation element--border-radius"
                style="display:block"
              >
            {%- endif -%}

            <div class="grid grid--slider grid-1 lap--grid--slider grid--gap-small" style="--mobile-media-width: {{ gallery_mobile_width }}%">
              {%- if product.media.size == 0 -%}
                {%- unless settings.product_card_fallback_image == blank -%}
                  {%- render 'product-media',
                    fallback: true,
                    aspect_ratio: 1,
                    fit: true,
                    layout: gallery_layout,
                    desktop_width: 'one-half',
                    mobile_width: gallery_mobile_width,
                    enable_zoom: false,
                    index: 0
                  -%}
                {%- else -%}
                  <div class="product-gallery-item" style="padding-top: 100%">
                    {%- render 'lazy-svg', image: 'product-1', ratio: 1, class: 'svg-placeholder svg-placeholder--background' -%}
                  </div>
                {%- endunless -%}
              {%- else -%}
                {%- for media in product.media -%}
                  {%- render 'product-media',
                    media: media,
                    enable_zoom: false,
                    loop: false,
                    index: forloop.index0,
                    aspect_ratio: 1,
                    fit: true,
                    layout: gallery_layout,
                    desktop_width: 'one-half',
                    mobile_width: gallery_mobile_width,
                    autoplay: false,
                    video_fit: true
                  -%}
                  {%- if media.media_type == 'external_video' or media.media_type == 'video' -%}
                    {%- assign video_script = true -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            </div>

            {%- if product.media.size > 1 -%}</css-slider>{%- endif -%}

            {%- if product.media.size > 1 -%}
              <div class="product-gallery__thumbnails" aria-hidden="true">
                <div class="product-gallery__thumbnails-holder">
                  {%- for media in product.media -%}
                    <button class="thumbnail element--border-radius" data-index="{{ forloop.index0 }}" tabindex="0">
                      {%- render 'lazy-image-small',
                        image: media.preview_image,
                        aspect_ratio: settings.cart_image_ratio,
                        fit: settings.cart_image_fit,
                        class: 'thumbnail__image'
                      -%}
                      {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                        <span class="thumbnail__badge">{%- render 'theme-symbols', icon: 'badge-video-thumbnail' -%}</span>
                      {%- elsif media.media_type == 'model' -%}
                        <span class="thumbnail__badge">{%- render 'theme-symbols', icon: 'badge-model-thumbnail' -%}</span>
                      {%- endif -%}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>
        {%- if section.settings.show_benefits_icons -%}
          <div class="lt-benefits-icons lt-benefits-icons--desktop" aria-label="Produktvorteile">
            <div class="lt-benefit-item">
              <span class="lt-benefit-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.2" opacity="0.35"></circle>
                  <path d="M6.5 9.2l1.8 1.8 3.3-3.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </span>
              <p>{{ section.settings.benefit_1_text | default: 'Kollagen Typ I kommt in Haut, Knochen, Sehnen und Bändern vor' }}</p>
            </div>
            <div class="lt-benefit-item">
              <span class="lt-benefit-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.2" opacity="0.35"></circle>
                  <path d="M9 4.5c1.6 1.1 2.5 2.2 2.5 3.7 0 1.6-1 2.6-2.5 3.3-1.5-.7-2.5-1.7-2.5-3.3 0-1.5.9-2.6 2.5-3.7Z" stroke="currentColor" stroke-width="1.1"></path>
                </svg>
              </span>
              <p>{{ section.settings.benefit_2_text | default: 'Kollagen Typ III kommt in Blutgefäßen, Organen und im Darm vor' }}</p>
            </div>
            <div class="lt-benefit-item">
              <span class="lt-benefit-icon" aria-hidden="true">
                <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                  <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.2" opacity="0.35"></circle>
                  <path d="M9 4v7.4m0 0L6.8 9.2M9 11.4l2.2-2.2" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              </span>
              <p>{{ section.settings.benefit_3_text | default: 'Leicht löslich und geschmacksneutral' }}</p>
            </div>
          </div>
        {%- endif -%}
      </div>

      <div class="lt-pdp-hero__content lt-hero-text element--is-sticky">
        {%- assign lt_trust_1 = section.settings.trust_1 | default: '90-Tage-Zell-Versprechen — kein Formular, kein Aufwand' -%}
        {%- assign lt_trust_2 = 'Laborgeprüft · Vegan · Ohne Zusatzstoffe' -%}
        {%- assign lt_trust_3 = section.settings.trust_3 | default: 'Über 1.000 zufriedene Kund:innen' -%}
        {%- assign lt_stack_header = section.settings.stack_header | default: 'Was du heute bekommst' -%}
        {%- assign lt_stack_product_sub = section.settings.stack_product_sub | default: '30 Tage Vorrat · liposomal · 250 mg' -%}
        {%- assign lt_stack_guide_title = section.settings.stack_guide_title | default: 'Longevity-Protokoll PDF' -%}
        {%- assign lt_stack_guide_sub = section.settings.stack_guide_sub | default: 'Wann & womit · Dr. Limmroth' -%}
        {%- assign lt_stack_bonus_title = section.settings.stack_bonus_title | default: '10 % Rabatt auf den AGE & DNA-Test' -%}
        {%- assign lt_stack_bonus_sub = section.settings.stack_bonus_sub | default: 'Exklusiv für Neukund:innen' -%}
        {%- assign lt_stack_total_label = section.settings.stack_total_label | default: 'Gesamtwert' -%}
        {%- assign lt_stack_old_total = section.settings.stack_old_total | default: '69,80 €' -%}
        {%- assign lt_stack_guide_price = section.settings.stack_guide_price | default: 'Gratis' -%}
        {%- assign lt_stack_bonus_price = section.settings.stack_bonus_price | default: '10 % Rabatt' -%}
        {%- assign lt_pill_1_label = section.settings.pill_1_label | default: '1 Monat' -%}
        {%- assign lt_pill_2_label = section.settings.pill_2_label | default: '2 Monate' -%}
        {%- assign lt_pill_3_label = section.settings.pill_3_label | default: '3 Monate' -%}
        {%- assign lt_pill_1_qty = section.settings.pill_1_quantity | default: 1 -%}
        {%- assign lt_pill_2_qty = section.settings.pill_2_quantity | default: 2 -%}
        {%- assign lt_pill_3_qty = section.settings.pill_3_quantity | default: 3 -%}
        {%- assign lt_pill_1_once = section.settings.pill_1_once_price_cents | default: 3990 -%}
        {%- assign lt_pill_2_once = section.settings.pill_2_once_price_cents | default: 7980 -%}
        {%- assign lt_pill_3_once = section.settings.pill_3_once_price_cents | default: 11970 -%}
        {%- assign lt_pill_1_sub = section.settings.pill_1_sub_price_cents | default: 3392 -%}
        {%- assign lt_pill_2_sub = section.settings.pill_2_sub_price_cents | default: 6783 -%}
        {%- assign lt_pill_3_sub = section.settings.pill_3_sub_price_cents | default: 10175 -%}
        {%- assign lt_rating = product.metafields.loox.avg_rating | default: 0 | plus: 0 -%}
        {%- assign lt_count = product.metafields.loox.num_reviews | default: 0 | plus: 0 -%}
        <button type="button" class="lt-pdp-hero__rating lt-hero-stars" data-lt-reviews-scroll>
          <span class="lt-pdp-hero__stars">★★★★★</span>
          <span class="lt-pdp-hero__score">
            {%- if lt_count > 0 -%}
              {{ lt_rating | round: 1 | replace: '.', ',' }}
            {%- else -%}
              4,8
            {%- endif -%}
          </span>
          <span class="lt-pdp-hero__count">
            ·
            {%- if lt_count > 0 -%}
              {{ lt_count }} Bewertungen
            {%- else -%}
              1.200+ Bewertungen
            {%- endif -%}
          </span>
        </button>

        <h1 class="lt-pdp-hero__title lt-hero-title">{{ product.title | escape }}</h1>

        <p class="lt-pdp-hero__tagline lt-hero-tagline">
          {{ product.metafields.custom.tagline | default: section.settings.tagline | default: 'Nicotinamid Adenin Dinukleotid · liposomal' }}
        </p>

        <p class="lt-pdp-hero__headline-copy lt-hero-headline">
          NAD⁺, das wirklich ankommt — nicht bloß geschluckt wird.
        </p>

        <div class="lt-pdp-hero__bullets lt-hero-bullets">
          <div class="lt-pdp-hero__bullet">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1" opacity="0.35"></circle>
              <path d="M5 8l2.5 2.5 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span>Direktes NAD⁺ — kein Umweg über NR oder NMN</span>
          </div>
          <div class="lt-pdp-hero__bullet">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1" opacity="0.35"></circle>
              <path d="M5 8l2.5 2.5 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span>Liposomale Hülle schützt bis zur Zellmembran</span>
          </div>
          <div class="lt-pdp-hero__bullet">
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1" opacity="0.35"></circle>
              <path d="M5 8l2.5 2.5 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            <span>250 mg pro Kapsel · messbare Wirkung ab 4 Wochen</span>
          </div>
        </div>

        <p class="lt-price-context">Wähle deine Kaufoption</p>

        <div class="lt-price-row" data-update-block="price-compact-main">
          <div class="lt-price-row__line">
            <span class="lt-price-row__current lt-price-main" data-js-product-price-original>{{ lt_base_price | money }}</span>
            <del class="lt-price-row__compare" data-js-product-price-compare>{% if lt_compare_price > lt_base_price %}{{ lt_compare_price | money }}{% endif %}</del>
            <span class="lt-price-row__saving lt-save-badge" data-js-product-price-saving>{% if lt_compare_price > lt_base_price %}Du sparst {{ lt_compare_price | minus: lt_base_price | money }}{% endif %}</span>
          </div>
        </div>

        <script id="lt-selling-plans-data" type="application/json">
          {
            "plans": [
              {%- for group in product.selling_plan_groups -%}
                {%- for plan in group.selling_plans -%}
                  {
                    "id": {{ plan.id }},
                    "name": {{ plan.name | json }},
                    "price_adjustments": [
                      {%- for adj in plan.price_adjustments -%}
                        {
                          "value": {{ adj.value }},
                          "value_type": {{ adj.value_type | json }}
                        }
                        {%- unless forloop.last -%},{%- endunless -%}
                      {%- endfor -%}
                    ]
                  }
                  {%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
                {%- unless forloop.last -%},{%- endunless -%}
              {%- endfor -%}
            ]
          }
        </script>

        <div class="lt-purchase-block">

          <div class="lt-toggle-container">
            <button id="lt-toggle-once" class="lt-toggle-pill lt-toggle--active" type="button">
              Einmalig
            </button>
            <button id="lt-toggle-sub" class="lt-toggle-pill" type="button">
              <span class="lt-pill-popular">{{ section.settings.sub_toggle_badge | default: 'Beliebt' }}</span>
              Abo &amp; Sparen
            </button>
          </div>

          <div class="lt-sub-banner" style="display:none">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1" opacity="0.5"></circle>
              <path d="M4.5 7l2 2 3-3" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg>
            {{ section.settings.sub_banner_text | default: 'Spare 15 % auf jede Lieferung · jederzeit kündbar' }}
          </div>

          <div class="lt-quantity-grid">
            <div class="lt-quantity-pill lt-quantity-pill--active" data-quantity="{{ lt_pill_1_qty }}" data-once-price="{{ lt_pill_1_once }}" data-sub-price="{{ lt_pill_1_sub }}">
              {%- if section.settings.pill_1_show_badge -%}
                <span class="lt-pill-recommended">{{ section.settings.pill_1_badge_text | default: 'Empfohlen' }}</span>
              {%- endif -%}
              <span class="lt-pill-name">{{ lt_pill_1_label }}</span>
              <span class="lt-pill-price">{{ lt_pill_1_once | money }}</span>
              <span class="lt-pill-discount">−15 %</span>
            </div>

            <div class="lt-quantity-pill" data-quantity="{{ lt_pill_2_qty }}" data-once-price="{{ lt_pill_2_once }}" data-sub-price="{{ lt_pill_2_sub }}">
              {%- if section.settings.pill_2_show_badge -%}
                <span class="lt-pill-recommended">{{ section.settings.pill_2_badge_text | default: 'Empfohlen' }}</span>
              {%- endif -%}
              <span class="lt-pill-name">{{ lt_pill_2_label }}</span>
              <span class="lt-pill-price">{{ lt_pill_2_once | money }}</span>
              <span class="lt-pill-discount">−15 %</span>
            </div>

            <div class="lt-quantity-pill" data-quantity="{{ lt_pill_3_qty }}" data-once-price="{{ lt_pill_3_once }}" data-sub-price="{{ lt_pill_3_sub }}">
              {%- if section.settings.pill_3_show_badge -%}
                <span class="lt-pill-recommended">{{ section.settings.pill_3_badge_text | default: 'Empfohlen' }}</span>
              {%- endif -%}
              <span class="lt-pill-name">{{ lt_pill_3_label }}</span>
              <span class="lt-pill-price">{{ lt_pill_3_once | money }}</span>
              <span class="lt-pill-discount">−15 %</span>
            </div>
          </div>

          <div class="lt-value-stack">
            <p class="lt-stack-header">{{ lt_stack_header }}</p>

            <div class="lt-stack-row">
              <div class="lt-stack-icon lt-stack-icon--image">
                {%- if product.featured_image != blank -%}
                  {{
                    product.featured_image
                    | image_url: width: 96
                    | image_tag: loading: 'lazy', alt: product.title, widths: '48,72,96'
                  }}
                {%- else -%}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <rect x="3" y="2" width="10" height="12" rx="2" stroke="currentColor" stroke-width="1" opacity="0.6"></rect>
                    <path d="M6 6h4M6 9h3" stroke="currentColor" stroke-width="1" stroke-linecap="round" opacity="0.5"></path>
                  </svg>
                {%- endif -%}
              </div>
              <div class="lt-stack-text">
                <p class="lt-stack-title">{{ product.title }} · 60 Kapseln</p>
                <p class="lt-stack-sub">{{ lt_stack_product_sub }}</p>
              </div>
              <span class="lt-stack-price-col" data-lt-stack-product-price>{{ lt_base_price | money }}</span>
            </div>

            <div class="lt-stack-row">
              <div class="lt-stack-icon lt-stack-icon--image">
                {%- if section.settings.stack_guide_image != blank -%}
                  {{
                    section.settings.stack_guide_image
                    | image_url: width: 96
                    | image_tag: loading: 'lazy', alt: lt_stack_guide_title, widths: '48,72,96'
                  }}
                {%- else -%}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <path d="M8 2l1.5 4H14l-3.5 2.5 1.5 4L8 10l-4 2.5 1.5-4L2 6h4.5L8 2Z" fill="currentColor" opacity="0.3"></path>
                  </svg>
                {%- endif -%}
              </div>
              <div class="lt-stack-text">
                <p class="lt-stack-title">{{ lt_stack_guide_title }}</p>
                <p class="lt-stack-sub">{{ lt_stack_guide_sub }}</p>
              </div>
              <span class="lt-stack-free">{{ lt_stack_guide_price }}</span>
            </div>

            <div class="lt-stack-row">
              <div class="lt-stack-icon lt-stack-icon--image">
                {%- if section.settings.stack_bonus_image != blank -%}
                  {{
                    section.settings.stack_bonus_image
                    | image_url: width: 96
                    | image_tag: loading: 'lazy', alt: lt_stack_bonus_title, widths: '48,72,96'
                  }}
                {%- else -%}
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none">
                    <circle cx="8" cy="8" r="6.5" stroke="currentColor" stroke-width="1.2" opacity="0.55"></circle>
                    <path d="M5.2 10.8 10.8 5.2M6 5.4a.9.9 0 1 0 0-1.8.9.9 0 0 0 0 1.8Zm4 5.2a.9.9 0 1 0 0-1.8.9.9 0 0 0 0 1.8Z" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path>
                  </svg>
                {%- endif -%}
              </div>
              <div class="lt-stack-text">
                <p class="lt-stack-title">{{ lt_stack_bonus_title }}</p>
                <p class="lt-stack-sub">{{ lt_stack_bonus_sub }}</p>
              </div>
              <span class="lt-stack-free">{{ lt_stack_bonus_price }}</span>
            </div>

            <div class="lt-stack-total">
              <div class="lt-stack-total-left">
                <span class="lt-stack-total-label">{{ lt_stack_total_label }}</span>
                <span class="lt-stack-total-was" data-lt-stack-total-was>{{ lt_stack_old_total }}</span>
              </div>
              <div class="lt-stack-total-right">
                <span class="lt-stack-total-price" data-lt-stack-total-price>{{ lt_base_price | money }}</span>
                <span class="lt-stack-total-day" data-lt-stack-total-day></span>
              </div>
            </div>
          </div>
        </div>

        {%- assign product_form_id = 'product-form-' | append: section.id -%}
        <product-form
          id="add-to-cart-{{ section.id }}"
          class="product-form"
          {% if settings.cart_action == 'overlay' %}
            data-ajax-cart
            data-js-product-form
          {% endif %}
        >
          {%- form 'product',
            product,
            id: product_form_id,
            class: 'form',
            novalidate: 'novalidate',
            data-type: 'add-to-cart-form'
          -%}
            <input type="hidden" name="id" value="{{ lt_variant_1.id }}" data-lt-variant-input>
            <input type="hidden" name="quantity" value="1" data-lt-quantity-input>
            <input type="hidden" id="lt-selling-plan-input" name="selling_plan" value="">
            <div class="product__cart-functions">
              <div class="flex-buttons">
                <button
                  id="lt-hero-atc"
