                      {%- else -%}
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M4.25 1.75h4.1L11 4.4v7.85H4.25V1.75Z" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"></path>
                          <path d="M8.35 1.75V4.4H11" stroke="currentColor" stroke-width="1.1" stroke-linejoin="round"></path>
                          <path d="M5.8 7.1h3.4M5.8 9.25h3.4" stroke="currentColor" stroke-width="1.1" stroke-linecap="round"></path>
                        </svg>
