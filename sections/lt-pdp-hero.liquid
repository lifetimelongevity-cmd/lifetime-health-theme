            assign bb_b2 = section.settings.bb_benefit_2 | default: 'Jederzeit kündbar'
            assign bb_b3 = section.settings.bb_benefit_3 | default: 'Willkommens-Angebote zur ersten Lieferung'
            if section.settings.bb_sub1_subline != blank
              assign bb_sub1_sub = section.settings.bb_sub1_subline
            else
              assign bb_sub1_sub = lt_pill_1_label
            endif
            if section.settings.bb_once_subline != blank
              assign bb_once_sub = section.settings.bb_once_subline
            else
              assign bb_once_sub = lt_pill_1_label
            endif
          -%}

          {%- if section.settings.bb_intro != blank -%}
            <div class="lt-bb__intro rte">{{ section.settings.bb_intro }}</div>
          {%- endif -%}

          <script id="lt-selling-plans-data" type="application/json">
            {
              "plans": [
                {%- for group in product.selling_plan_groups -%}
                  {%- for plan in group.selling_plans -%}
                    {
                      "id": {{ plan.id }},
                      "name": {{ plan.name | json }},
                      "price_adjustments": [
                        {%- for adj in plan.price_adjustments -%}
                          {
                            "value": {{ adj.value }},
                            "value_type": {{ adj.value_type | json }}
                          }
                          {%- unless forloop.last -%},{%- endunless -%}
                        {%- endfor -%}
                      ]
                    }
                    {%- unless forloop.last -%},{%- endunless -%}
                  {%- endfor -%}
                  {%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              ]
            }
          </script>
        {%- endif -%}

        <div class="visually-hidden" data-update-block="price-compact-main">
          <div class="lt-price-row__line">
            <span class="lt-price-row__current lt-price-main" data-js-product-price-original>{{ lt_base_price | money }}</span>
            <del class="lt-price-row__compare" data-js-product-price-compare>{% if lt_compare_price > lt_base_price %}{{ lt_compare_price | money }}{% endif %}</del>
            <span class="lt-price-row__saving lt-save-badge" data-js-product-price-saving>{% if lt_compare_price > lt_base_price %}Du sparst {{ lt_compare_price | minus: lt_base_price | money }}{% endif %}</span>
          </div>
        </div>

        {%- if lt_show_sub or section.settings.show_price_standalone -%}
          <div class="lt-purchase-block">
            {%- if section.settings.show_promo_banner and section.settings.promo_banner_title != blank -%}
              <div class="lt-promo-banner" role="note">
                <span class="lt-promo-banner__tag">{{ section.settings.promo_banner_tag | default: 'Aktion' | escape }}</span>
                <span class="lt-promo-banner__text">
                  <span class="lt-promo-banner__title">{{ section.settings.promo_banner_title | escape }}</span>
                  {%- if section.settings.promo_banner_note != blank -%}
                    <span class="lt-promo-banner__note">{{ section.settings.promo_banner_note | escape }}</span>
                  {%- endif -%}
                  {%- if section.settings.promo_banner_deadline != blank -%}
                    <span class="lt-promo-banner__timer" data-lt-promo-deadline="{{ section.settings.promo_banner_deadline | escape }}" hidden>
                      {{ section.settings.promo_banner_timer_label | default: 'Endet in' | escape }} <strong data-lt-promo-countdown>–</strong>
                    </span>
                  {%- endif -%}
                </span>
              </div>
              <script>
                (function () {
                  var banner = document.currentScript.previousElementSibling;
                  var el = banner && banner.querySelector('[data-lt-promo-deadline]');
                  if (!el) return;
                  var out = el.querySelector('[data-lt-promo-countdown]');
                  var deadline = new Date(el.getAttribute('data-lt-promo-deadline')).getTime();
                  if (isNaN(deadline)) return;
                  function pad(n) { return n < 10 ? '0' + n : '' + n; }
                  function tick() {
                    var diff = deadline - Date.now();
                    if (diff <= 0) { el.hidden = true; return; }
                    var d = Math.floor(diff / 86400000);
                    var h = Math.floor((diff % 86400000) / 3600000);
                    var m = Math.floor((diff % 3600000) / 60000);
                    var s = Math.floor((diff % 60000) / 1000);
                    var txt = (d > 0 ? d + ' T ' : '') + pad(h) + ':' + pad(m) + ':' + pad(s);
                    if (out) { out.textContent = txt; } else { el.textContent = txt; }
                    el.hidden = false;
                  }
                  tick();
                  setInterval(tick, 1000);
                })();
              </script>
            {%- endif -%}
            {%- liquid
              assign lt_show_sizes = false
              if section.settings.show_size_selector and product.variants.size > 1
                assign lt_show_sizes = true
              endif
              assign lt_disc = section.settings.sub_discount_percent | default: 10
              assign lt_sub_mult = 100 | minus: lt_disc
              # Abo = kleinste Gramm-Variante (nicht stur variants.first → robust gegen Umsortierung)
              assign lt_abo_variant = product.variants.first
              assign lt_abo_min = 9999999
              for v in product.variants
                assign vg = v.title | replace: ' ', '' | replace: 'g', '' | replace: 'G', '' | times: 1
                if vg > 0 and vg < lt_abo_min
                  assign lt_abo_min = vg
                  assign lt_abo_variant = v
                endif
              endfor
              assign lt_abo_grams = lt_abo_variant.title | replace: ' ', '' | replace: 'g', '' | replace: 'G', '' | times: 1
              # Abo-Preis aus der echten Selling-Plan-Allocation (Appstle), Fallback price × (100 − Rabatt)
              assign lt_abo_alloc = lt_abo_variant.selling_plan_allocations.first
              if lt_abo_alloc
                assign lt_abo_sub = lt_abo_alloc.price
              else
                assign lt_abo_sub = lt_abo_variant.price | times: lt_sub_mult | divided_by: 100
              endif
              # Deep-Link (?variant=, z. B. GMC-Shopping-Klick) → Einmalkauf + Größe vorwählen statt Abo.
              # Nur bei aktiver Größen-Auswahl; sonst bleibt das Abo-Default unverändert (andere PDPs).
              assign lt_deeplinked = false
              if lt_show_sizes and product.selected_variant != blank
                assign lt_deeplinked = true
              endif
              # SSR-aktive Variante für hidden id + ATC-Disabled: Abo→kleinste Größe, Deep-Link→gewählte Größe
              assign lt_active_variant = lt_abo_variant
              if lt_deeplinked
                assign lt_active_variant = lt_preselect_variant
              endif
            -%}
            {%- if lt_show_sub -%}
            <div
              class="lt-bb"
              data-lt-buy-box
              data-supply-days="{{ bb_supply_days | plus: 0 }}"
              data-discount-pct="{{ section.settings.sub_discount_percent | default: 10 }}"
              role="radiogroup"
              aria-label="Kaufoption wählen"
            >
              <label
                class="lt-bb-card lt-bb-card--sub{% unless lt_deeplinked %} is-selected{% endunless %}"
