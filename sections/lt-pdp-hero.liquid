}

/* Sichtbarer Tastatur-Fokus für die neuen Text-Trigger (a11y) */
.lt-pdp-hero__trust-link:focus-visible,
.lt-bb__size-hint:focus-visible {
  outline: 0.125rem solid var(--lt-text);
  outline-offset: 0.125rem;
}

/* Buy-box cards — flat cursor style */
.lt-bb-card {
  background: var(--lt-bg, #f7f7f4) !important;
  border: 1px solid var(--lt-border, rgba(38,37,30,0.1)) !important;
  border-radius: 4px !important;
  box-shadow: none !important;
}

.lt-bb-card.is-selected {
