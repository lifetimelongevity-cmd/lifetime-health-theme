<script src="{{ 'section-main-product.js' | asset_url }}" defer></script>
{%- if video_script -%}
  <script>
    KrownAssetLoader.loadScript('{{ "component-video.js" | asset_url }}');
  </script>
{%- endif -%}
<script>
  (function() {
    const section = document.getElementById('lt-pdp-hero-{{ section.id }}');
    if (!section) return;

    const ltStickyShowCompare = section.dataset.ltStickyShowCompare !== '0';

    const reviewButton = section.querySelector('[data-lt-reviews-scroll]');

    function markLooxSection() {
      const looxRoot = document.querySelector(
        '#looxReviews, .loox-dynamic-section, [class*="loox-dynamic-section"], .loox-v2-widget-container'
      );
      if (!looxRoot) return false;

      const looxSection = looxRoot.closest('[id^="shopify-section-"]') || looxRoot.closest('.shopify-section') || looxRoot;
      looxSection.classList.add('lt-loox-section');

      if (!document.getElementById('lt-reviews') && !looxRoot.id) {
        looxRoot.id = 'lt-reviews';
      }

      return true;
    }

    if (!markLooxSection()) {
      const looxObserver = new MutationObserver(function() {
        if (markLooxSection()) looxObserver.disconnect();
      });
      looxObserver.observe(document.body, { childList: true, subtree: true });
      window.setTimeout(function() {
        looxObserver.disconnect();
      }, 12000);
    }

    if (reviewButton) {
      reviewButton.addEventListener('click', function() {
        const target = document.getElementById('lt-reviews')
          || document.querySelector('.lt-loox-section');
        if (target) target.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    const buyBox = section.querySelector('[data-lt-buy-box]');
    const plansData = section.querySelector('#lt-selling-plans-data');
    const ltPlans = plansData ? JSON.parse(plansData.textContent).plans : [];

    const planInput = section.querySelector('#lt-selling-plan-input');
    const quantityInput = section.querySelector('[data-lt-quantity-input]');
    const mainPrice = section.querySelector('.lt-price-main');
    const priceCompare = section.querySelector('[data-js-product-price-compare]');
    const priceSaving = section.querySelector('[data-js-product-price-saving]');
    const baseComparePrice = {{ lt_compare_price | default: 0 }};

    if (!buyBox) return;

    const supplyDays = Math.max(1, parseFloat(buyBox.dataset.supplyDays) || 30);
    const badgeDiscountPct = Math.max(0, parseInt(buyBox.dataset.discountPct, 10) || 0);
    const productPageId = 'product-{{ section.id }}';

    function formatPrice(cents) {
      return (cents / 100).toFixed(2).replace('.', ',') + ' €';
    }

    // grams>0 → €/g (reiner Preis-pro-Gramm, keine Verzehr-/Dosis-/Dauer-Aussage); sonst Legacy €/Tag
    function formatUnit(cents, grams, qty) {
      if (grams > 0) {
        const perGram = (cents / 100) / grams;
        return perGram.toFixed(2).replace('.', ',') + ' €/g';
      }
      const totalDays = Math.max(1, supplyDays * Math.max(1, qty || 1));
      const perDay = (cents / 100) / totalDays;
      return perDay.toFixed(2).replace('.', ',') + ' €/Tag';
    }

    function escapeLtHtml(str) {
      return String(str)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;');
    }

    /** Vergleichspreis für Sticky (wie Buy-Box / updatePriceMeta) */
    function stickyCompareCents(isSub, qty, onceCents, subCents, currentCents, perSizeCompare) {
      if (isSub) {
        return onceCents > subCents ? onceCents : 0;
      }
      var fallback = baseComparePrice > 0 ? baseComparePrice * qty : 0;
      var shopCompare = (!isNaN(perSizeCompare) && perSizeCompare > 0) ? perSizeCompare : fallback;
      return shopCompare > onceCents ? shopCompare : 0;
    }

    function buildStickyPriceInner(currentCents, compareCents) {
      var main = formatPrice(currentCents);
      var h =
        '<span class="sticky-add-to-cart__price-original text-weight--bold">' +
        escapeLtHtml(main) +
        '</span>';
      if (ltStickyShowCompare && compareCents > currentCents) {
        h +=
          '<del class="sticky-add-to-cart__price-compare">' +
          escapeLtHtml(formatPrice(compareCents)) +
          '</del>';
      }
      return h;
    }

    function syncStickyAtcPrice(isSub, qty, onceCents, subCents, currentCents, perSizeCompare) {
      var cmp = stickyCompareCents(isSub, qty, onceCents, subCents, currentCents, perSizeCompare);
      var inner = buildStickyPriceInner(currentCents, cmp);
      var wrapped =
        '<span class="show-block-if-variant-selected">' + inner + '</span>';

      var stickyRoot = document.querySelector('#lt-sticky-atc [data-js-atc-price]');
      if (stickyRoot) stickyRoot.innerHTML = inner;

      var hidden = document.querySelector('#' + productPageId + ' [data-update-block="price-sticky-main"]');
      if (hidden) hidden.innerHTML = wrapped;
    }

    // Sticky-Subline: Größen-Label der AKTIVEN Auswahl voranstellen. Sticky liegt nach
    // Upgrade an <body> → document-weit suchen. Basis-Text einmalig cachen (kein Doppeln).
    function updateStickySubline(short) {
      const el = document.querySelector('#lt-sticky-atc [data-lt-sticky-atc-subline]');
      if (!el) return;
      if (stickySublineBase === null) stickySublineBase = el.textContent.trim();
      if (short) el.textContent = stickySublineBase ? (short + ' · ' + stickySublineBase) : short;
    }

    function savingsPct(onceC, subC) {
      if (!onceC || onceC <= subC) return 0;
      return Math.round((1 - subC / onceC) * 100);
    }

    function getRadio(card) {
      return card.querySelector('.lt-bb-card__input');
    }

    function updatePriceMeta(isSub, qty, onceCents, currentCents, perSizeCompare) {
      const fallback = baseComparePrice > 0 ? baseComparePrice * qty : 0;
      const onceCompare = (!isNaN(perSizeCompare) && perSizeCompare > 0) ? perSizeCompare : fallback;
      const compareCents = isSub ? onceCents : onceCompare;
      const savingCents = compareCents > currentCents ? compareCents - currentCents : 0;

      if (priceCompare) {
        priceCompare.textContent = compareCents > currentCents ? formatPrice(compareCents) : '';
      }
      if (priceSaving) {
        priceSaving.textContent = savingCents > 0 ? 'Du sparst ' + formatPrice(savingCents) : '';
      }
    }

    function updateCardFacades() {
      const cards = section.querySelectorAll('[data-lt-bb-card]');
      const subCards = [];

      cards.forEach(card => {
        const input = getRadio(card);
        if (!input) return;

        const kind = card.dataset.bbKind;
        const qty = Math.max(1, parseInt(input.dataset.quantity, 10) || 1);
        const grams = parseInt(input.dataset.grams, 10) || 0;
        const onceC = parseInt(input.dataset.oncePrice, 10) || 0;
        const subC = parseInt(input.dataset.subPrice, 10) || 0;
        const compareEl = card.querySelector('[data-lt-bb-compare]');
        const currentEl = card.querySelector('[data-lt-bb-current]');
        const unitEl = card.querySelector('[data-lt-bb-unit]');
        const badgeEl = card.querySelector('[data-lt-bb-badge]');

        if (kind === 'sub') {
          const pct = badgeDiscountPct > 0 ? badgeDiscountPct : savingsPct(onceC, subC);
          subCards.push({ card, badgeEl, pct });

          if (badgeEl) {
            if (pct > 0) {
              badgeEl.textContent = 'SPARE ' + pct + '%';
              badgeEl.hidden = false;
            } else {
              badgeEl.textContent = '';
              badgeEl.hidden = true;
            }
          }
          if (compareEl) {
            if (onceC > subC) {
              compareEl.textContent = formatPrice(onceC);
              compareEl.hidden = false;
            } else {
              compareEl.textContent = '';
              compareEl.hidden = true;
            }
          }
          if (currentEl) currentEl.textContent = formatPrice(subC);
          if (unitEl) {
            unitEl.textContent = formatUnit(subC, grams, qty);
          }
        } else {
          // Per-size compare (from size selector) takes precedence over the section-level compare
          const perSizeCompare = parseInt(input.dataset.comparePrice, 10);
          const shopCompare = (!isNaN(perSizeCompare) && perSizeCompare > 0)
            ? perSizeCompare
            : (baseComparePrice > 0 ? baseComparePrice * qty : 0);
          if (compareEl) {
            if (shopCompare > onceC) {
              compareEl.textContent = formatPrice(shopCompare);
              compareEl.hidden = false;
            } else {
              compareEl.textContent = '';
              compareEl.hidden = true;
            }
          }
          if (currentEl) currentEl.textContent = formatPrice(onceC);
          if (unitEl) {
            unitEl.textContent = formatUnit(onceC, grams, qty);
          }
          const saleBadgeEl = card.querySelector('[data-lt-bb-sale-badge]');
          if (saleBadgeEl) {
            const salePct = shopCompare > onceC ? savingsPct(shopCompare, onceC) : 0;
            if (salePct > 0) {
              saleBadgeEl.textContent = '−' + salePct + '%';
              saleBadgeEl.hidden = false;
            } else {
              saleBadgeEl.textContent = '';
              saleBadgeEl.hidden = true;
            }
          }
        }
      });

      if (subCards.length === 2) {
        const a = subCards[0].pct;
        const b = subCards[1].pct;
        const firstStrong = a >= b;
        [subCards[0], subCards[1]].forEach((entry, i) => {
          const el = entry.badgeEl;
          if (!el || el.hidden) return;
          const strong = i === 0 ? firstStrong : !firstStrong;
          el.classList.toggle('lt-bb-card__badge--strong', strong);
          el.classList.toggle('lt-bb-card__badge--muted', !strong);
        });
      }
    }

    function syncFromCard(card) {
      const input = getRadio(card);
      if (!input) return;

      const kind = card.dataset.bbKind;
      const qty = Math.max(1, parseInt(input.dataset.quantity, 10) || 1);
      const onceCents = parseInt(input.dataset.oncePrice, 10) || 0;
      const subCents = parseInt(input.dataset.subPrice, 10) || 0;
      const perSizeCompare = parseInt(input.dataset.comparePrice, 10);
      const isSub = kind === 'sub';
      const currentCents = isSub ? subCents : onceCents;

      if (variantInput && input.dataset.variantId) variantInput.value = input.dataset.variantId;
      if (quantityInput) quantityInput.value = String(qty);
      if (planInput) {
        planInput.value = isSub && ltPlans.length ? String(ltPlans[0].id) : '';
      }
      if (mainPrice) mainPrice.textContent = formatPrice(currentCents);

      updateCardFacades();
      updatePriceMeta(isSub, qty, onceCents, currentCents, perSizeCompare);

      syncStickyAtcPrice(isSub, qty, onceCents, subCents, currentCents, perSizeCompare);
      updateStickySubline(input.dataset.sizeShort);

      section.querySelectorAll('[data-lt-sub-only]').forEach(el => {
        el.hidden = !isSub;
      });

      var atcTextEl = section.querySelector('[data-js-product-add-to-cart-text]');
      var atcLabel =
        (isSub ? 'Abo' : 'Einmalig') + ': ' + formatPrice(currentCents) + ' — Jetzt kaufen →';
      if (atcTextEl) {
        atcTextEl.textContent = atcLabel;
      }
      var atcBtn = section.querySelector('#lt-hero-atc');
      if (atcBtn) {
        atcBtn.setAttribute('aria-label', atcLabel.replace(' →', ''));
      }
    }

    function selectCard(card) {
      if (!card) return;
      section.querySelectorAll('[data-lt-bb-card]').forEach(c => {
        c.classList.toggle('is-selected', c === card);
        const inp = getRadio(c);
        if (inp) inp.checked = c === card;
      });
      syncFromCard(card);
    }

    section.querySelectorAll('[data-lt-bb-card]').forEach(card => {
      const input = getRadio(card);
      if (!input) return;
      input.addEventListener('change', function() {
        if (this.checked) selectCard(card);
      });
    });

    // No selling plans → hide subscription card and or-divider, pre-select once card
    if (ltPlans.length === 0) {
      const noSubCard = section.querySelector('.lt-bb-card--sub');
      const noOrDiv  = section.querySelector('.lt-bb__or');
      if (noSubCard) {
        noSubCard.hidden = true;
        const noSubRadio = noSubCard.querySelector('.lt-bb-card__input');
        if (noSubRadio) noSubRadio.checked = false;
      }
      if (noOrDiv) noOrDiv.hidden = true;
      const noOnceCard = section.querySelector('.lt-bb-card--once');
      if (noOnceCard) {
        noOnceCard.classList.add('is-selected');
        const noOnceRadio = noOnceCard.querySelector('.lt-bb-card__input');
        if (noOnceRadio) noOnceRadio.checked = true;
      }
    }

    // --- Größen-Auswahl (Varianten) -------------------------------------
    // Eine Kachel pro Variante. Pro Größe: Variant-ID ins Formular, Einmal-/
    // Abo-/Vergleichspreis auf die Kaufoption-Karten, dann bestehende
    // Sync-Logik (syncFromCard) neu anwerfen. Wenn keine Größen-Gruppe da
    // ist, bleibt das Verhalten unverändert.
    const sizeGroup = section.querySelector('[data-lt-size-group]');
    const variantInput = section.querySelector('[data-lt-variant-input]');
    const appstleWidget = section.querySelector('#lt-appstle-widget');
    let stickySublineBase = null; // SSR-Subline-Text, einmalig gecacht (sonst doppeltes Voranstellen)

    // Größe betrifft NUR den Einmalkauf. Schreibt die Daten der gewählten Größe auf die
    // Einmal-Karte; selectOnce=true wählt den Einmalkauf zusätzlich aus. Abo-Karte bleibt 30 g.
    function applySize(sizeInput, selectOnce) {
      if (!sizeInput) return;
      const onceCard = section.querySelector('.lt-bb-card--once');
      const onceRadio = onceCard ? getRadio(onceCard) : null;
      if (onceRadio) {
        onceRadio.dataset.variantId = sizeInput.dataset.variantId || '';
        onceRadio.dataset.oncePrice = sizeInput.dataset.oncePrice || '0';
        onceRadio.dataset.comparePrice = sizeInput.dataset.comparePrice || '0';
        onceRadio.dataset.grams = sizeInput.dataset.grams || '0';
        onceRadio.dataset.sizeShort = sizeInput.dataset.sizeShort || '';
        onceRadio.dataset.quantity = '1';
      }
      if (appstleWidget && sizeInput.dataset.variantId) {
        appstleWidget.setAttribute('data-variant-id', sizeInput.dataset.variantId);
      }
      section.querySelectorAll('[data-lt-size]').forEach(pill => {
        const inp = pill.querySelector('.lt-size__input');
        const on = inp === sizeInput;
        pill.classList.toggle('is-selected', on);
        if (inp) inp.checked = on;
      });
      if (selectOnce && onceCard) {
        selectCard(onceCard);
      } else {
        updateCardFacades();
      }
    }

    // Einmal-Karte ist immer ein <div> (kein <label>, weil die Größen-Radios darin liegen) → Klick-Auswahl per JS.
    const onceCardEl = section.querySelector('.lt-bb-card--once');
    if (onceCardEl) {
      onceCardEl.addEventListener('click', function(e) {
        if (e.target.closest('[data-lt-size]')) return;
        selectCard(onceCardEl);
      });
    }

    // Größen-Hinweis (Abo-Default): öffnet den Einmalkauf, der die Größen-Pills zeigt
    const sizeHintEl = section.querySelector('[data-lt-size-hint]');
    if (sizeHintEl && onceCardEl) {
      sizeHintEl.addEventListener('click', function() {
        selectCard(onceCardEl);
        onceCardEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      });
    }

    if (sizeGroup) {
      // Größe antippen → Einmalkauf + diese Größe
      sizeGroup.querySelectorAll('.lt-size__input').forEach(inp => {
        inp.addEventListener('change', function() {
          if (this.checked) applySize(this, true);
        });
      });
      // Init: Basis-Größe (30 g bzw. Deep-Link) in die Einmal-Karte schreiben, OHNE sie zu
      // erzwingen — die Default-Auswahl (Abo/Einmal) kommt aus dem SSR-checked-State.
      const baseSize = sizeGroup.querySelector('.lt-size__input:checked:not(:disabled)')
        || sizeGroup.querySelector('.lt-size__input:not(:disabled)');
      if (baseSize) {
        baseSize.checked = true;
        applySize(baseSize, false);
      }
    }
    // --------------------------------------------------------------------

    const initialCard = section.querySelector('.lt-bb-card__input:checked')?.closest('[data-lt-bb-card]');
    if (initialCard) {
      selectCard(initialCard);
    } else {
      updateCardFacades();
    }

    /* Nach deferred section-main-product.js: StickyAddToCart kann Initial-HTML setzen — Buy-Box erneut anwenden */
    if (typeof customElements !== 'undefined' && customElements.whenDefined) {
      customElements.whenDefined('sticky-add-to-cart').then(function () {
        var inp = section.querySelector('.lt-bb-card__input:checked');
        if (inp) inp.dispatchEvent(new Event('change', { bubbles: true }));
      });
    }
  })();
</script>

{% stylesheet %}
/* ===================================================
   LT PDP Hero — Cursor-Style Overrides
   lt-pdp.css tokens are remapped via the style block above.
   This block handles structural overrides that need
   CSS (not just token swaps).
   =================================================== */

/* Section background */
.lt-pdp-hero-section {
  background: var(--lt-bg, #f7f7f4);
}

/* Heading stack — Abstand zu den Bullets darunter */
.lt-pdp-hero__heading {
  margin-bottom: var(--space-5);
}

/* Gallery frame — sharp corners */
.lt-pdp-hero__gallery-frame {
  border-radius: 4px !important;
}

.lt-pdp-hero .product-gallery-item,
.lt-pdp-hero .product-gallery-item img {
  border-radius: 4px !important;
}

/* Purchase block — handled below (white surface + border) */

/* Direct price display — no-subscription mode */
.lt-price-direct {
  padding: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 6px;
  margin-top: var(--space-5);
}
.lt-price-direct__row {
  display: flex;
  align-items: baseline;
  gap: 10px;
}
.lt-price-direct__compare {
  font-size: 14px;
  opacity: 0.5;
  text-decoration: line-through;
  color: var(--lt-text, #26251e);
  line-height: 1.2;
}
.lt-price-direct__amount {
  font-size: 36px;
  font-weight: 600;
  letter-spacing: -0.5px;
  line-height: 1;
  color: var(--lt-text, #26251e);
}
.lt-price-direct__savings {
  display: inline-block;
  font-size: 12px;
  font-weight: 500;
  padding: 4px 10px;
  border-radius: 999px;
  background: rgba(38, 37, 30, 0.06);
  color: var(--lt-text, #26251e);
  margin-top: 6px;
}
.lt-price-direct__note {
  font-size: 13px;
  opacity: 0.7;
  color: var(--lt-text, #26251e);
  margin-top: 8px;
  line-height: 1.4;
}

/* Inline-Dialog-Trigger (Trust-4) — wirkt wie verlinkter Text, nicht wie Button */
.lt-pdp-hero__trust-link {
  appearance: none;
  -webkit-appearance: none;
  background: none;
  border: 0;
  padding: 0;
  font: inherit;
  color: inherit;
  text-align: left;
  cursor: pointer;
  text-decoration: underline dotted;
  text-underline-offset: 0.125em;
}

/* Größen-Hinweis unter der Buy-Box */
.lt-bb__size-hint {
  display: block;
  appearance: none;
  -webkit-appearance: none;
  background: none;
  border: 0;
  padding: 0;
  margin-top: var(--space-4);
