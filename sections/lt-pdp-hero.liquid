              data-discount-pct="{{ section.settings.sub_discount_percent | default: 10 }}"
              role="radiogroup"
              aria-label="Kaufoption wählen"
            >
              <label
                class="lt-bb-card lt-bb-card--sub is-selected"
                data-lt-bb-card
                data-bb-kind="sub"
              >
                <input
                  type="radio"
                  class="lt-bb-card__input"
                  name="lt-bb-{{ section.id }}"
                  value="sub-1"
                  checked
                  data-quantity="{{ lt_pill_1_qty }}"
                  data-once-price="{{ lt_pill_1_once }}"
                  data-sub-price="{{ lt_pill_1_sub }}"
                >
                <span class="lt-bb-card__body">
                  <span class="lt-bb-card__head">
                    <span class="lt-bb-card__radio" aria-hidden="true"></span>
                    <span class="lt-bb-card__row">
                      <span class="lt-bb-card__meta">
                        <span class="lt-bb-card__title-row">
                          <span class="lt-bb-card__title">{{ bb_sub1_title | escape }}</span>
                          <span class="lt-bb-card__badge lt-bb-card__badge--strong" data-lt-bb-badge>SPARE 0%</span>
                        </span>
                        <span class="lt-bb-card__sub">{{ bb_sub1_sub | escape }}</span>
                      </span>
                      <span class="lt-bb-card__prices">
                        <del class="lt-bb-card__compare" data-lt-bb-compare></del>
                        <span class="lt-bb-card__current" data-lt-bb-current></span>
                        <span class="lt-bb-card__unit" data-lt-bb-unit></span>
                      </span>
                    </span>
                  </span>
                  <span class="lt-bb-card__perks">
                    <span class="lt-bb-card__perk">
