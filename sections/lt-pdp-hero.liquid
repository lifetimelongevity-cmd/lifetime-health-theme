                  value="sub-1"
                  {% unless lt_deeplinked %}checked{% endunless %}
                  data-quantity="{{ lt_pill_1_qty }}"
                  {%- if lt_show_sizes -%}
                  data-once-price="{{ lt_abo_variant.price }}"
                  data-sub-price="{{ lt_abo_sub }}"
                  data-variant-id="{{ lt_abo_variant.id }}"
                  data-grams="{{ lt_abo_grams }}"
                  data-size-short="{{ lt_abo_variant.title | escape }}"
                  {%- else -%}
                  data-once-price="{{ lt_pill_1_once }}"
                  data-sub-price="{{ lt_pill_1_sub }}"
                  {%- endif -%}
                >
                <span class="lt-bb-card__body">
                  <span class="lt-bb-card__head">
                    <span class="lt-bb-card__radio" aria-hidden="true"></span>
                    <span class="lt-bb-card__row">
                      <span class="lt-bb-card__meta">
                        <span class="lt-bb-card__title-row">
                          <span class="lt-bb-card__title">{{ bb_sub1_title | escape }}</span>
                          <span class="lt-bb-card__badge lt-bb-card__badge--strong" data-lt-bb-badge>SPARE {{ section.settings.sub_discount_percent | default: 10 }}%</span>
                        </span>
                        <span class="lt-bb-card__sub">{{ bb_sub1_sub | escape }}</span>
                      </span>
                      <span class="lt-bb-card__prices">
                        <del class="lt-bb-card__compare" data-lt-bb-compare></del>
                        <span class="lt-bb-card__current" data-lt-bb-current></span>
                        <span class="lt-bb-card__unit" data-lt-bb-unit></span>
                      </span>
                    </span>
                  </span>
                  <span class="lt-bb-card__perks">
                    <span class="lt-bb-card__perk">
                      {%- if section.settings.bb_perk_1_icon != blank -%}
                        {{
                          section.settings.bb_perk_1_icon
                          | image_url: width: 56
                          | image_tag: loading: 'lazy', class: 'lt-bb-card__perk-icon', alt: ''
                        }}
                      {%- else -%}
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M8.25 4H2.25v5.5H3.4" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"></path>
                          <path d="M8.25 5.75h2.1l1.55 1.9V9.5h-1.05" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"></path>
                          <circle cx="4.8" cy="9.5" r="0.95" stroke="currentColor" stroke-width="1.1"></circle>
                          <circle cx="9.6" cy="9.5" r="0.95" stroke="currentColor" stroke-width="1.1"></circle>
                        </svg>
                      {%- endif -%}
                      <span>{{ bb_b1 | escape }}</span>
                    </span>
                    <span class="lt-bb-card__perk">
                      {%- if section.settings.bb_perk_2_icon != blank -%}
                        {{
                          section.settings.bb_perk_2_icon
                          | image_url: width: 56
                          | image_tag: loading: 'lazy', class: 'lt-bb-card__perk-icon', alt: ''
                        }}
                      {%- else -%}
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <path d="M2.25 7a4.75 4.75 0 1 0 1.4-3.36L2.25 5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"></path>
                          <path d="M2.25 2.5V5h2.5" stroke="currentColor" stroke-width="1.1" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                      {%- endif -%}
                      <span>{{ bb_b2 | escape }}</span>
                    </span>
                    <span class="lt-bb-card__perk">
                      {%- if section.settings.bb_perk_3_icon != blank -%}
                        {{
                          section.settings.bb_perk_3_icon
                          | image_url: width: 56
                          | image_tag: loading: 'lazy', class: 'lt-bb-card__perk-icon', alt: ''
