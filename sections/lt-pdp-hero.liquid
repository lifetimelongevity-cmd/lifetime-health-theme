                        </svg>
                      {%- endif -%}
                      <span>{{ bb_b1 | escape }}</span>
                    </span>
                    <span class="lt-bb-card__perk">
                      {%- if section.settings.bb_perk_2_icon != blank -%}
                        {{
                          section.settings.bb_perk_2_icon
                          | image_url: width: 56
                          | image_tag: loading: 'lazy', class: 'lt-bb-card__perk-icon', alt: ''
                        }}
                      {%- else -%}
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1" opacity="0.4"></circle>
                          <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                      {%- endif -%}
                      <span>{{ bb_b2 | escape }}</span>
                    </span>
                    <span class="lt-bb-card__perk">
                      {%- if section.settings.bb_perk_3_icon != blank -%}
                        {{
                          section.settings.bb_perk_3_icon
                          | image_url: width: 56
                          | image_tag: loading: 'lazy', class: 'lt-bb-card__perk-icon', alt: ''
                        }}
                      {%- else -%}
                        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                          <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1" opacity="0.4"></circle>
                          <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
                        </svg>
                      {%- endif -%}
                      <span>{{ bb_b3 | escape }}</span>
                    </span>
                  </span>
                </span>
              </label>

              <div class="lt-bb__or" role="presentation">
                <span class="lt-bb__or-line" aria-hidden="true"></span>
                <span class="lt-bb__or-text">{{ bb_or_label | escape }}</span>
                <span class="lt-bb__or-line" aria-hidden="true"></span>
              </div>

              <label class="lt-bb-card lt-bb-card--once" data-lt-bb-card data-bb-kind="once">
                <input
                  type="radio"
                  class="lt-bb-card__input"
                  name="lt-bb-{{ section.id }}"
                  value="once"
                  data-quantity="{{ lt_pill_1_qty }}"
                  data-once-price="{{ lt_pill_1_once }}"
                  data-sub-price="{{ lt_pill_1_sub }}"
