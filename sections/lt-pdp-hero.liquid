{%- liquid
  if section.settings.product != blank
    assign product = all_products[section.settings.product]
  endif
  assign current_variant = product.selected_or_first_available_variant
  assign default_to_first_variant = true
  assign gallery_layout = 'slider'
  assign gallery_mobile_width = 100
  assign lt_variant_1 = current_variant
  assign lt_variant_3 = blank
  assign lt_variant_6 = blank
  for variant in product.variants
    assign lt_variant_options = variant.options | join: ' ' | downcase
    if lt_variant_1 == blank and lt_variant_options contains '1'
      assign lt_variant_1 = variant
    endif
    if lt_variant_3 == blank and lt_variant_options contains '3'
      assign lt_variant_3 = variant
    endif
    if lt_variant_6 == blank and lt_variant_options contains '6'
      assign lt_variant_6 = variant
    endif
  endfor
  if lt_variant_1 == blank
    assign lt_variant_1 = current_variant
  endif
  assign lt_has_pack_variants = false
  if lt_variant_3 != blank and lt_variant_6 != blank
    if lt_variant_3.id != lt_variant_1.id and lt_variant_6.id != lt_variant_1.id
      assign lt_has_pack_variants = true
    endif
  endif
  assign lt_base_price = lt_variant_1.price
  assign lt_compare_price = lt_variant_1.compare_at_price | default: 0
  assign lt_sub_1 = lt_base_price | times: 0.85 | round
  assign lt_sub_3 = lt_base_price | times: 3 | times: 0.85 | round
  assign lt_sub_6 = lt_base_price | times: 6 | times: 0.85 | round
  if settings.show_currency_codes
    assign iso_code = localization.country.currency.iso_code | prepend: ' '
  endif
-%}

{% style %}
  #lt-pdp-hero-{{ section.id }} {
    /* Cursor design tokens — override lt-* vars at section scope */
    --lt-bg:           {{ section.settings.color_bg }};
    --lt-surface:      {{ section.settings.color_card_bg }};
    --lt-border:       {{ section.settings.color_text | color_modify: 'alpha', 0.1 }};
    --lt-text:         {{ section.settings.color_text }};
    --lt-muted:        {{ section.settings.color_text | color_modify: 'alpha', 0.55 }};
    --lt-cta-bg:       {{ section.settings.color_text }};
    --lt-cta-hover:    {{ section.settings.color_text | color_modify: 'alpha', 0.82 }};
    --lt-primary:      {{ section.settings.color_text }};
    --lt-primary-dark: {{ section.settings.color_text }};
    --lt-success-bg:   {{ section.settings.color_text | color_modify: 'alpha', 0.06 }};
    --lt-success-text: {{ section.settings.color_text }};
    --lt-radius-sm:    4px;
    --lt-radius-md:    4px;
    --lt-radius-lg:    4px;
    --lt-shadow:       none;
  }
{% endstyle %}

{%- liquid
  # Sticky: kein Streichpreis auf product.14_1_test (Template-Suffix), Editor-sicher
  assign lt_sticky_show_compare_price = true
  if template.suffix == '14_1_test'
    assign lt_sticky_show_compare_price = false
  elsif section.settings.sticky_show_compare_price == false
    assign lt_sticky_show_compare_price = false
  endif
-%}

<section
  id="lt-pdp-hero-{{ section.id }}"
  class="lt-pdp-hero-section"
  data-lt-sticky-show-compare="{% if lt_sticky_show_compare_price %}1{% else %}0{% endif %}"
>
  <div class="lt-pdp-hero__container">
    <product-page
      id="product-{{ section.id }}"
      class="lt-pdp-hero"
      data-collection="{{ collection.handle }}"
      data-id="{{ product.id }}"
      data-availability="{{ product.available }}"
      data-js-product-component
    >
      <div class="lt-pdp-hero__gallery-wrap element--is-sticky">
        <div class="lt-pdp-hero__gallery-frame">
          {%- if section.settings.show_badge -%}
            <span class="lt-pdp-hero__badge lt-badge">{{ section.settings.badge_text | default: 'Bestseller' | escape }}</span>
          {%- endif -%}

          <div class="product-gallery product-gallery--slider lap--grid--slider-container" data-js-product-gallery>
            {%- if product.media.size > 1 -%}
              <css-slider
                data-options='
                  {
                    "selector": ".product-gallery-item",
                    "autoHeight": false,
                    "navigationDOM": "<span class=\"css-slider-button css-slider-prev\" style=\"display:none\"><svg fill=\"none\" height=\"11\" viewBox=\"0 0 6 11\" width=\"6\" xmlns=\"http://www.w3.org/2000/svg\"><path clip-rule=\"evenodd\" d=\"m4.32845 10.0708-4.18198-4.18194c-.195261-.19526-.195261-.51185 0-.70711l4.18198-4.181979c.19527-.195262.51185-.195262.70711 0 .19526.195259.19526.511849 0 .707109l-3.32843 3.32842s-.70713.4647-.00002 1l3.32845 3.32843c.19526.19526.19526.51185 0 .70707-.19526.1953-.51185.1953-.70711 0z\" fill=\"#000\" fill-rule=\"evenodd\"/></svg></span><span class=\"css-slider-button css-slider-next\" style=\"display:none\"><svg fill=\"none\" height=\"11\" viewBox=\"0 0 6 11\" width=\"6\" xmlns=\"http://www.w3.org/2000/svg\"><path clip-rule=\"evenodd\" d=\"m.853555.999962 4.181985 4.181978c.19526.19526.19526.51185 0 .70711l-4.181983 4.18195c-.195263.1953-.511845.1953-.707108 0-.1952631-.19523-.1952632-.51181 0-.70708l3.328431-3.32842s.70713-.4647.00002-1l-3.328453-3.32843c-.1952626-.19526-.1952627-.51185 0-.707108.195263-.195262.511845-.195262.707108 0z\" fill=\"#000\" fill-rule=\"evenodd\"/></svg></span>",
                    "thumbnailsDOM": "<div class=\"css-slider-dot-navigation\" style=\"display:none;--size:{{ product.media.size }}\"></div>",
                    "listenScroll": false
                  }
                '
                class="css-slider--bottom-navigation element--border-radius"
                style="display:block"
              >
            {%- endif -%}

            <div class="grid grid--slider grid-1 lap--grid--slider grid--gap-small" style="--mobile-media-width: {{ gallery_mobile_width }}%">
              {%- if product.media.size == 0 -%}
                {%- unless settings.product_card_fallback_image == blank -%}
                  {%- render 'product-media',
                    fallback: true,
                    aspect_ratio: 1,
                    fit: true,
                    layout: gallery_layout,
                    desktop_width: 'one-half',
                    mobile_width: gallery_mobile_width,
                    enable_zoom: false,
                    index: 0
                  -%}
                {%- else -%}
                  <div class="product-gallery-item" style="padding-top: 100%">
                    {%- render 'lazy-svg', image: 'product-1', ratio: 1, class: 'svg-placeholder svg-placeholder--background' -%}
                  </div>
                {%- endunless -%}
              {%- else -%}
                {%- for media in product.media -%}
                  {%- render 'product-media',
                    media: media,
                    enable_zoom: false,
                    loop: false,
                    index: forloop.index0,
                    aspect_ratio: 1,
                    fit: true,
                    layout: gallery_layout,
                    desktop_width: 'one-half',
                    mobile_width: gallery_mobile_width,
                    autoplay: false,
                    video_fit: true
                  -%}
                  {%- if media.media_type == 'external_video' or media.media_type == 'video' -%}
                    {%- assign video_script = true -%}
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            </div>

            {%- if product.media.size > 1 -%}</css-slider>{%- endif -%}

            {%- if product.media.size > 1 -%}
              <div class="product-gallery__thumbnails" aria-hidden="true">
                <div class="product-gallery__thumbnails-holder">
                  {%- for media in product.media -%}
                    <button class="thumbnail element--border-radius" data-index="{{ forloop.index0 }}" tabindex="0">
                      {%- render 'lazy-image-small',
                        image: media.preview_image,
                        aspect_ratio: settings.cart_image_ratio,
                        fit: settings.cart_image_fit,
                        class: 'thumbnail__image'
                      -%}
                      {%- if media.media_type == 'video' or media.media_type == 'external_video' -%}
                        <span class="thumbnail__badge">{%- render 'theme-symbols', icon: 'badge-video-thumbnail' -%}</span>
                      {%- elsif media.media_type == 'model' -%}
                        <span class="thumbnail__badge">{%- render 'theme-symbols', icon: 'badge-model-thumbnail' -%}</span>
                      {%- endif -%}
                    </button>
                  {%- endfor -%}
                </div>
              </div>
            {%- endif -%}
          </div>
        </div>
        {%- if section.settings.show_benefits_icons -%}
          <div class="lt-benefits-icons lt-benefits-icons--desktop" aria-label="Produktvorteile">
            <div class="lt-benefit-item">
              <span class="lt-benefit-icon" aria-hidden="true">
                {%- if section.settings.benefit_1_icon != blank -%}
                  {{
                    section.settings.benefit_1_icon
                    | image_url: width: 96
                    | image_tag: loading: 'lazy', class: 'lt-benefit-icon__img', alt: ''
                  }}
                {%- else -%}
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.2" opacity="0.35"></circle>
                    <path d="M6.5 9.2l1.8 1.8 3.3-3.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                {%- endif -%}
              </span>
              <p>{{ section.settings.benefit_1_text }}</p>
            </div>
            <div class="lt-benefit-item">
              <span class="lt-benefit-icon" aria-hidden="true">
                {%- if section.settings.benefit_2_icon != blank -%}
                  {{
                    section.settings.benefit_2_icon
                    | image_url: width: 96
                    | image_tag: loading: 'lazy', class: 'lt-benefit-icon__img', alt: ''
                  }}
                {%- else -%}
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.2" opacity="0.35"></circle>
                    <path d="M6.5 9.2l1.8 1.8 3.3-3.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                {%- endif -%}
              </span>
              <p>{{ section.settings.benefit_2_text }}</p>
            </div>
            <div class="lt-benefit-item">
              <span class="lt-benefit-icon" aria-hidden="true">
                {%- if section.settings.benefit_3_icon != blank -%}
                  {{
                    section.settings.benefit_3_icon
                    | image_url: width: 96
                    | image_tag: loading: 'lazy', class: 'lt-benefit-icon__img', alt: ''
                  }}
                {%- else -%}
                  <svg width="18" height="18" viewBox="0 0 18 18" fill="none">
                    <circle cx="9" cy="9" r="8" stroke="currentColor" stroke-width="1.2" opacity="0.35"></circle>
                    <path d="M6.5 9.2l1.8 1.8 3.3-3.3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                {%- endif -%}
              </span>
              <p>{{ section.settings.benefit_3_text }}</p>
            </div>
          </div>
        {%- endif -%}
      </div>

      <div class="lt-pdp-hero__content lt-hero-text element--is-sticky">
        {%- assign lt_trust_1 = section.settings.trust_1 | default: '90-Tage Geld-zurück-Garantie — kein Formular, kein Aufwand' -%}
        {%- assign lt_trust_2 = section.settings.trust_2 | default: 'Gratisversand · Laborgeprüft · Vegan' -%}
        {%- assign lt_trust_3 = section.settings.trust_3 | default: '>1.000 Kund:innen vertrauen LIFETIME' -%}
        {%- assign lt_pill_1_label = section.settings.pill_1_label | default: '1 Monat' -%}
        {%- assign lt_pill_1_qty = section.settings.pill_1_quantity | default: 1 -%}
        {%- assign lt_pill_1_once = section.settings.pill_1_once_price_cents | default: 3990 -%}
        {%- assign lt_pill_1_sub = section.settings.pill_1_sub_price_cents | default: 3392 -%}
        {%- assign lt_rating = product.metafields.loox.avg_rating | default: 0 | plus: 0 -%}
        {%- assign lt_count = product.metafields.loox.num_reviews | default: 0 | plus: 0 -%}
        {%- assign lt_show_sub = section.settings.show_subscription_toggle -%}

        {%- comment -%}Reusable blocks — captured early so they can be placed before or after CTA depending on lt_show_sub{%- endcomment -%}
        {%- capture lt_trust_block -%}
          <div class="lt-pdp-hero__trust lt-trust">
            <div class="lt-pdp-hero__trust-item">
              {%- if section.settings.trust_1_icon != blank -%}
                {{
                  section.settings.trust_1_icon
                  | image_url: width: 72
                  | image_tag: loading: 'lazy', class: 'lt-trust-icon-img', alt: ''
                }}
              {%- else -%}
                <svg class="lt-trust-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M9 2L3.5 4.6v4.2c0 3.6 2.4 6 5.5 7.2 3.1-1.2 5.5-3.6 5.5-7.2V4.6L9 2Z" stroke="currentColor" stroke-width="1.2"></path>
                  <path d="M6.7 9l1.7 1.7L11.5 7.6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              {%- endif -%}
              <span>{{ lt_trust_1 }}</span>
            </div>
            <div class="lt-pdp-hero__trust-item">
              {%- if section.settings.trust_2_icon != blank -%}
                {{
                  section.settings.trust_2_icon
                  | image_url: width: 64
                  | image_tag: loading: 'lazy', class: 'lt-trust-icon-img', alt: ''
                }}
              {%- else -%}
                <svg class="lt-trust-icon" width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                  <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1" opacity="0.35"></circle>
                  <path d="M5 8l2.5 2.5 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
                </svg>
              {%- endif -%}
              <span>{{ lt_trust_2 }}</span>
            </div>
            <div class="lt-pdp-hero__trust-item">
              {%- if section.settings.trust_3_icon != blank -%}
                {{
                  section.settings.trust_3_icon
                  | image_url: width: 72
                  | image_tag: loading: 'lazy', class: 'lt-trust-icon-img', alt: ''
                }}
              {%- else -%}
                <svg class="lt-trust-icon" width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
                  <path d="M9 2.4l1.8 3.8 4.2.5-3.1 2.9.8 4.1L9 11.6l-3.7 2.1.8-4.1L3 6.7l4.2-.5L9 2.4Z" stroke="currentColor" stroke-width="1.2" stroke-linejoin="round"></path>
                </svg>
              {%- endif -%}
              <span>{{ lt_trust_3 }}</span>
            </div>
          </div>
        {%- endcapture -%}

        {%- capture lt_doctor_block -%}
          {%- if section.settings.show_doctor_badge -%}
            <div class="lt-founder-block">
              <div class="lt-founder-top">
                <div class="lt-founder-avatar">
                  {%- liquid
                    assign founder_img_url = ''
                    if section.settings.founder_image != blank
                      assign founder_img_url = section.settings.founder_image | image_url: width: 120
                    elsif section.settings.founder_image_url != blank
                      assign founder_img_url = section.settings.founder_image_url
                    endif
                  -%}
                  {%- if founder_img_url != blank -%}
                    <img
                      src="{{ founder_img_url }}"
                      alt="Prof. Dr. med. Volker Limmroth"
                      width="52"
                      height="52"
                      loading="lazy">
                  {%- else -%}
                    <span class="lt-founder-initials">VL</span>
                  {%- endif -%}
                </div>
                <div class="lt-founder-meta">
                  <p class="lt-founder-endorsed">
                    {{ section.settings.founder_endorsed | default: 'Wissenschaftlich entwickelt von' | escape }}
                  </p>
                  <p class="lt-founder-name">
                    {{ section.settings.founder_name | default: 'Prof. Dr. med. Volker Limmroth' | escape }}
                  </p>
                  <p class="lt-founder-title">
                    {{ section.settings.founder_title | default: 'Chefarzt Neurologie · Longevity-Experte · Spiegel-Bestseller-Autor' | escape }}
                  </p>
                </div>
                <div class="lt-founder-seal" aria-label="Wissenschaftlich geprüft">
                  <svg width="20" height="20" viewBox="0 0 20 20" fill="none">
                    <path d="M10 2L3 5v6c0 4 3 7 7 7 s7-3 7-7V5L10 2Z" stroke="currentColor" stroke-width="1.2" fill="none"></path>
                    <path d="M7 10l2 2 4-4" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"></path>
                  </svg>
                </div>
              </div>
              <div class="lt-founder-credentials">
                <span class="lt-founder-cred">Chefarzt Neurologie</span>
                <span class="lt-founder-cred">ARD · RTL · SAT1</span>
                <span class="lt-founder-cred">Spiegel Bestseller</span>
                <span class="lt-founder-cred">20+ Jahre Forschung</span>
              </div>
            </div>
          {%- endif -%}
        {%- endcapture -%}

        {%- capture lt_value_stack_block -%}
          {%- if section.settings.show_value_stack -%}
            <div class="lt-value-stack">
              <h3 class="lt-value-stack__header">{{ section.settings.stack_header | escape }}</h3>
              {%- if section.settings.show_stack_product_line -%}
                <div class="lt-value-stack__item">
                  <div class="lt-value-stack__item-info">
                    <span class="lt-value-stack__item-title">{{ product.title | escape }}</span>
                    {%- if section.settings.stack_product_sub != blank -%}
                      <span class="lt-value-stack__item-sub">{{ section.settings.stack_product_sub | escape }}</span>
                    {%- endif -%}
                  </div>
                  <div class="lt-value-stack__item-price">
                    <span class="lt-value-stack__item-label" data-lt-stack-product-price>{{ lt_base_price | money }}</span>
                  </div>
                </div>
              {%- endif -%}
              {%- if section.settings.stack_guide_title != blank -%}
                {%- assign guide_cents = section.settings.stack_guide_value_cents | default: 0 -%}
                <div class="lt-value-stack__item">
                  <div class="lt-value-stack__item-info">
                    <span class="lt-value-stack__item-title">{{ section.settings.stack_guide_title | escape }}</span>
                    {%- if section.settings.stack_guide_sub != blank -%}
                      <span class="lt-value-stack__item-sub">{{ section.settings.stack_guide_sub | escape }}</span>
                    {%- endif -%}
                  </div>
                  <div class="lt-value-stack__item-price">
                    {%- if guide_cents > 0 -%}
                      <del class="lt-value-stack__item-was">{{ guide_cents | money }}</del>
                    {%- endif -%}
                    <span class="lt-value-stack__item-label lt-value-stack__item-label--free">{{ section.settings.stack_guide_price | default: 'Gratis' | escape }}</span>
                  </div>
                </div>
              {%- endif -%}
              {%- if section.settings.stack_bonus_title != blank -%}
                {%- assign bonus_cents = section.settings.stack_bonus_value_cents | default: 0 -%}
                <div class="lt-value-stack__item">
                  <div class="lt-value-stack__item-info">
                    <span class="lt-value-stack__item-title">{{ section.settings.stack_bonus_title | escape }}</span>
                    {%- if section.settings.stack_bonus_sub != blank -%}
                      <span class="lt-value-stack__item-sub">{{ section.settings.stack_bonus_sub | escape }}</span>
                    {%- endif -%}
                  </div>
                  <div class="lt-value-stack__item-price">
                    {%- if bonus_cents > 0 -%}
                      <del class="lt-value-stack__item-was">{{ bonus_cents | money }}</del>
                    {%- endif -%}
                    <span class="lt-value-stack__item-label lt-value-stack__item-label--free">{{ section.settings.stack_bonus_price | default: 'Gratis' | escape }}</span>
                  </div>
                </div>
              {%- endif -%}
              {%- if section.settings.stack_extra_title != blank -%}
                <div class="lt-value-stack__item">
                  <div class="lt-value-stack__item-info">
                    <span class="lt-value-stack__item-title">{{ section.settings.stack_extra_title | escape }}</span>
                    {%- if section.settings.stack_extra_sub != blank -%}
                      <span class="lt-value-stack__item-sub">{{ section.settings.stack_extra_sub | escape }}</span>
                    {%- endif -%}
                  </div>
                  <div class="lt-value-stack__item-price">
                    <span class="lt-value-stack__item-label lt-value-stack__item-label--free">{{ section.settings.stack_extra_price | default: 'Enthalten' | escape }}</span>
                  </div>
                </div>
              {%- endif -%}
              <div class="lt-value-stack__total">
                <span class="lt-value-stack__total-label">{{ section.settings.stack_total_label | default: 'Gesamtwert' | escape }}</span>
                <span class="lt-value-stack__total-value" data-lt-stack-total>{{ section.settings.stack_old_total | escape }}</span>
              </div>
              {%- unless lt_show_sub -%}
                {%- if section.settings.stack_pay_today_label != blank -%}
                  <div class="lt-value-stack__pay-today">
                    <span class="lt-value-stack__pay-label">{{ section.settings.stack_pay_today_label | escape }}</span>
                    <span class="lt-value-stack__pay-price">{{ lt_pill_1_once | money }}</span>
                  </div>
                {%- endif -%}
              {%- endunless -%}
            </div>
          {%- endif -%}
        {%- endcapture -%}

        {%- if section.settings.show_rating -%}
        <button type="button" class="lt-pdp-hero__rating lt-hero-stars" data-lt-reviews-scroll>
          <span class="lt-pdp-hero__stars">★★★★★</span>
          <span class="lt-pdp-hero__score">
            {%- if lt_count > 0 -%}
              {{ lt_rating | round: 1 | replace: '.', ',' }}
            {%- else -%}
              4,8
            {%- endif -%}
          </span>
          <span class="lt-pdp-hero__count">
            ·
            {%- if lt_count > 0 -%}
              {{ lt_count }} Bewertungen
            {%- else -%}
              1.200+ Bewertungen
            {%- endif -%}
          </span>
        </button>
        {%- endif -%}

        <h1 class="lt-pdp-hero__title lt-hero-title">{{ product.title | escape }}</h1>

        <p class="lt-pdp-hero__tagline lt-hero-tagline">
          {{ product.metafields.custom.tagline | default: section.settings.tagline | default: 'Uthever® NMN · >99,9 % Reinheit · laborgeprüft in Deutschland' }}
        </p>

        {%- if section.settings.hero_headline != blank -%}
          <p class="lt-pdp-hero__headline-copy lt-hero-headline">{{ section.settings.hero_headline | escape }}</p>
        {%- endif -%}

        <div class="lt-pdp-hero__bullets lt-hero-bullets">
          {%- assign hb1 = section.settings.hero_bullet_1 | default: 'Uthever® NMN mit >99,9 % Reinheit — Rohstoff laborgeprüft in Deutschland' -%}
          {%- assign hb2 = section.settings.hero_bullet_2 | default: 'GMP & HACCP — arztgeführtes Unternehmen aus Berlin' -%}
          {%- assign hb3 = section.settings.hero_bullet_3 | default: '30 g Pulver · ca. 60 Portionen à 500 mg (1 Messlöffel)' -%}
          <div class="lt-pdp-hero__bullet">
            {%- if section.settings.hero_bullet_1_icon != blank -%}
              {{
                section.settings.hero_bullet_1_icon
                | image_url: width: 64
                | image_tag: loading: 'lazy', class: 'lt-hero-bullet-icon', alt: ''
              }}
            {%- else -%}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <circle cx="8" cy="8" r="7" stroke="currentColor" stroke-width="1" opacity="0.35"></circle>
                <path d="M5 8l2.5 2.5 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"></path>
