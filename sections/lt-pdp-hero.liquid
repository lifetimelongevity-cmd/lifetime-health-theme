                        <span class="lt-size__name">{{ variant.title | escape }}</span>
                        <span class="lt-size__save">{%- if v_compare > variant.price -%}−{{ v_compare | minus: variant.price | money }}{%- endif -%}</span>
                      </label>
                    {%- endfor -%}
                  </div>
                {%- endif -%}
