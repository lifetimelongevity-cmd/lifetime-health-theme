}

/* Unselected cards — muted */
.lt-bb-card:not(.is-selected) {
  opacity: 0.6;
  transition: opacity 0.15s ease;
}

.lt-bb-card:not(.is-selected):hover {
  opacity: 0.85;
}

/* Payment icons */
.lt-payment-icons {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  align-items: center;
  justify-content: center;
  margin-top: 12px;
}

.lt-payment-icon {
  height: 24px;
  width: auto;
  border-radius: 3px;
  opacity: 0.65;
}

/* Größen-Auswahl — segmentierte Pills (flat, wie Buy-Box-Karten) */
.lt-size {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 8px;
  margin-top: var(--space-5);
  margin-bottom: var(--space-4);
}
/* Größenauswahl sitzt IN der Einmalkauf-Karte → erst sichtbar wenn Einmalkauf gewählt, vom Kartenrand eingerückt */
.lt-bb-card--once { cursor: pointer; }
.lt-bb-card--once .lt-size { margin: 2px var(--space-4) var(--space-4); }
.lt-bb-card--once:not(.is-selected) .lt-size { display: none; }
/* Streichpreis-Zeile auch ohne compare (30 g) reservieren → kein Höhen-Sprung beim Größenwechsel.
   display:block schlägt bewusst die globale .lt-bb-card__compare:empty{display:none} UND das per JS
   gesetzte [hidden] (compareEl.hidden=true bei 30 g). :has(.lt-size)-Scope NICHT entfernen. */
.lt-bb-card--once:has(.lt-size) .lt-bb-card__compare {
  display: block;
  min-height: 1.4em;
}
.lt-size__pill {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 2px;
  min-height: 48px;
  padding: 8px 6px;
  border: 1px solid var(--lt-border, rgba(38,37,30,0.1));
  border-radius: 4px;
  background: var(--lt-bg, #f7f7f4);
  cursor: pointer;
  text-align: center;
  transition: border-color 0.15s ease, background 0.15s ease, opacity 0.15s ease;
}
.lt-size__pill:not(.is-selected) { opacity: 0.6; }
.no-touchevents .lt-size__pill:not(.is-selected):hover { opacity: 0.85; }
.lt-size__pill.is-selected {
  background: #fff;
  border-color: var(--lt-text, #26251e);
  border-width: 1.5px;
  opacity: 1;
}
/* Fokus-Ring nur per Tastatur (focus-visible) → kein Doppelrahmen beim Klick. Sibling-Pattern statt
   :has() → Indikator hängt nicht an :has-Support (WCAG 2.4.7 auch auf alten Browsern gewährleistet). */
.lt-size__input:focus-visible ~ .lt-size__name {
  outline: 2px solid var(--lt-text, #26251e);
  outline-offset: 3px;
  border-radius: 2px;
}
.lt-size__input {
  position: absolute;
  width: 1px;
  height: 1px;
  margin: 0;
  opacity: 0;
  pointer-events: none;
}
.lt-size__name {
  font-size: 15px;
  font-weight: 500;
  line-height: 1.1;
  color: var(--lt-text, #26251e);
}
.lt-size__save {
  display: block;
  min-height: 14px;
  font-size: 12px;
  font-weight: 500;
  line-height: 1.15;
  color: var(--lt-muted, rgba(38,37,30,0.55));
}
.lt-size__input:disabled ~ .lt-size__name,
.lt-size__input:disabled ~ .lt-size__save {
  opacity: 0.4;
  text-decoration: line-through;
}

/* Verifiable purity proof — batch COA link */
.lt-pdp-hero__coa {
  display: flex;
  align-items: flex-start;
  gap: var(--space-3, 0.5rem);
  margin-top: var(--space-4, 0.75rem);
}
.lt-pdp-hero__coa-icon {
  flex: 0 0 auto;
  margin-top: 2px;
  color: var(--lt-text, #26251e);
}
.lt-pdp-hero__coa-text {
  display: flex;
  flex-direction: column;
  gap: 2px;
  font-size: 0.875rem;
  line-height: 1.3;
}
.lt-pdp-hero__coa-line {
  display: flex;
  flex-wrap: wrap;
  align-items: baseline;
  gap: 0 var(--space-3, 0.5rem);
}
.lt-pdp-hero__coa-purity {
  font-weight: 600;
  color: var(--lt-text, #26251e);
}
.lt-pdp-hero__coa-link {
  color: var(--lt-text, #26251e);
  text-decoration: underline dotted;
  text-underline-offset: 2px;
}
.lt-pdp-hero__coa-caption {
  font-size: 0.75rem;
  color: var(--lt-muted, rgba(38, 37, 30, 0.55));
}

