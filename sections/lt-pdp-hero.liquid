              assign bb_sub1_sub = section.settings.bb_sub1_subline
            else
              assign bb_sub1_sub = lt_pill_1_label
            endif
            if section.settings.bb_once_subline != blank
              assign bb_once_sub = section.settings.bb_once_subline
            else
              assign bb_once_sub = lt_pill_1_label
            endif
          -%}

          {%- if section.settings.bb_intro != blank -%}
            <div class="lt-bb__intro rte">{{ section.settings.bb_intro }}</div>
          {%- endif -%}

          <script id="lt-selling-plans-data" type="application/json">
            {
              "plans": [
                {%- for group in product.selling_plan_groups -%}
                  {%- for plan in group.selling_plans -%}
                    {
                      "id": {{ plan.id }},
                      "name": {{ plan.name | json }},
                      "price_adjustments": [
                        {%- for adj in plan.price_adjustments -%}
                          {
                            "value": {{ adj.value }},
                            "value_type": {{ adj.value_type | json }}
                          }
                          {%- unless forloop.last -%},{%- endunless -%}
                        {%- endfor -%}
                      ]
                    }
                    {%- unless forloop.last -%},{%- endunless -%}
                  {%- endfor -%}
                  {%- unless forloop.last -%},{%- endunless -%}
                {%- endfor -%}
              ]
            }
          </script>
        {%- endif -%}

        <div class="visually-hidden" data-update-block="price-compact-main">
