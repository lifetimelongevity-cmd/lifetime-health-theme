{% comment %}
  lt-hp-loop — Lösung Der Loop (Section 3)
  ─────────────────────────────────────────
  §12 Build Spec:
  - Surface:          --color-surface-secondary (warm — visueller Rhythmus: hell nach dunklem Hero/Ticker)
  - Dominant element: Step 1 Card (is_primary) — größer, teal-getönt, mit Produkt-Link
  - Heading size:     --text-h1 Section · --text-h2 primary Step · --text-h3 secondary Steps
  - Content pattern:  3-Step horizontal flow (mit optionaler Connector-Linie) + Expert-Quote + CTA
  - CTA:              volle cta-Variante — zweiter Kaufimpuls, direkt nach Limmroth-Zitat
  - Removed:          Icons (Step-Numbers kommunizieren Reihenfolge deutlicher),
                      sekundäre Step-CTAs (nur Step 1 hat Produkt-Link — keine CTA-Konkurrenz)
  - Quality move:     Step 1 (is_primary) erhält --color-surface-benefit Background + teal Border —
                      das visuelle Gewicht macht sofort klar: hier ist der Einstieg.
                      Limmroth-Zitat als Trust-Brücke direkt vor dem zweiten Kaufimpuls.
{% endcomment %}

{%- liquid
  assign hp_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign hp_headline_lg = true
  endif
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    {%- if section.settings.color_bg != blank -%}
    background: {{ section.settings.color_bg }};
    {%- endif -%}
    {%- if section.settings.color_text != blank -%}
    color: {{ section.settings.color_text }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    {%- endif -%}
    padding-top:    {{ section.settings.padding_top | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
  }
{% endstyle %}

<span id="loop" aria-hidden="true" style="display:block;height:0;visibility:hidden;"></span>
<section id="shopify-section-{{ section.id }}" class="loop">
  <div class="loop__container">

    {%- comment -%}=== Section Header ==={%- endcomment -%}
    <div class="loop__header crs-heading-stack crs-heading-stack--align-center{% if hp_headline_lg %} crs-heading-stack--headline-lg{% endif %} crs-heading-stack--homepage-truth">
      {%- if section.settings.kicker != blank -%}
        <p class="crs-heading-stack__kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      <div class="crs-heading-stack__pair">
        <h2 class="crs-heading-stack__title">{{ section.settings.headline | escape }}</h2>
        {%- if section.settings.subheadline != blank -%}
          <p class="crs-heading-stack__subtitle">{{ section.settings.subheadline | escape }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%}=== Steps ==={%- endcomment -%}
    <div class="loop__steps">
      {%- assign step_index = 0 -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'loop_step' -%}
          {%- assign step_index = step_index | plus: 1 -%}

          {%- comment -%} Connector between steps {%- endcomment -%}
          {%- if step_index > 1 and section.settings.show_connector_line -%}
            <div class="loop__connector" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round">
                <line x1="5" y1="12" x2="19" y2="12"/>
                <polyline points="13 6 19 12 13 18"/>
              </svg>
            </div>
          {%- endif -%}

          <div
            class="loop__step{% if block.settings.step_is_primary %} loop__step--primary{% endif %}"
            {{ block.shopify_attributes }}
          >
            <div class="loop__step-number-row">
              <span class="loop__step-number">{{ block.settings.step_number | escape }}</span>
              {%- if block.settings.step_label != blank -%}
                <span class="loop__step-label">{{ block.settings.step_label | escape }}</span>
              {%- endif -%}
            </div>

            <h3 class="loop__step-headline">{{ block.settings.step_headline | escape }}</h3>

            {%- if block.settings.step_body != blank -%}
              <p class="loop__step-body">{{ block.settings.step_body | escape }}</p>
            {%- endif -%}

            {%- if block.settings.step_product_url != blank and block.settings.step_product_name != blank -%}
              <a href="{{ block.settings.step_product_url }}" class="loop__step-link">
                {{ block.settings.step_product_name | escape }}
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <line x1="5" y1="12" x2="19" y2="12"/>
                  <polyline points="12 5 19 12 12 19"/>
                </svg>
              </a>
            {%- endif -%}
          </div>

        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- comment -%}=== Primary CTA — zweiter Kaufimpuls ==={%- endcomment -%}
    {%- if section.settings.cta_label != blank -%}
      <div class="loop__cta-wrap">
        <a href="{{ section.settings.cta_url | default: '#' }}" class="loop__cta">
          {{ section.settings.cta_label | escape }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
/* ================================================================
   lt-hp-loop — Lösung: Test → Profil → Protokoll
   Token refs: §3 (colors, spacing, type), §5 (Card Info, Buttons)
   ================================================================ */

/* — Section shell — */
.loop {
  background: var(--color-surface-secondary);
}

.loop__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--space-5);
}

/* — Section header — */
.loop__header {
  max-width: 640px;
  margin: 0 auto var(--space-9);  /* 80px → steps */
}


/* — Steps grid — */
/*
  DECISION: flex row with connectors between cards.
  Connectors are flex-shrink: 0; cards take remaining space equally.
  Primary card (Step 1) is visually differentiated by surface, not by size.
*/
.loop__steps {
  display: flex;
  align-items: stretch;
  gap: 0;
  margin-bottom: var(--space-7);   /* 48px → CTA */
}

/* — Connector arrow between steps — */
.loop__connector {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: var(--space-7);           /* 48px */
  color: var(--color-text-muted);
}

/* — Step card — */
.loop__step {
  flex: 1;
  background: var(--color-surface-primary);  /* white on warm surface — creates lift */
  border-radius: var(--radius-md);
  padding: var(--space-6);         /* 32px */
  box-shadow: var(--shadow-sm);
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

/* Primary step — Step 1 elevated, white on warm surface */
.loop__step--primary {
  background: var(--color-surface-primary);
  border: 1.5px solid var(--color-border-default);
  box-shadow: var(--shadow-md);
}

/* — Step number row — */
.loop__step-number-row {
  display: flex;
  align-items: baseline;
  gap: var(--space-3);
}

.loop__step-number {
  font-family: var(--font-heading);
  font-size: var(--text-display);  /* 48px — large, commands attention */
  font-weight: var(--weight-regular);
  line-height: var(--leading-stat);
  color: var(--color-text-primary);
  letter-spacing: -0.03em;
}

.loop__step--primary .loop__step-number {
  color: var(--color-text-primary);
}

/* Non-primary steps: muted number */
.loop__step:not(.loop__step--primary) .loop__step-number {
  color: var(--color-gray-400);
}

.loop__step-label {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-medium);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-muted);
}

.loop__step:not(.loop__step--primary) .loop__step-label {
  color: var(--color-text-muted);
}

/* — Step headline — */
.loop__step-headline {
  font-family: var(--font-heading);
  font-size: var(--text-h3);      /* 24px — compact in card context */
  font-weight: var(--weight-regular);
  line-height: var(--leading-tight);
  color: var(--color-text-primary);
  margin: 0;
}

/* — Step body — */
.loop__step-body {
  font-family: var(--font-body);
  font-size: var(--text-body);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-text-secondary);
  margin: 0;
  flex: 1;
}

/* — Step product link — */
.loop__step-link {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  margin-top: auto;
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  font-weight: var(--weight-medium);
  color: var(--color-text-primary);
  text-decoration: none;
  border-bottom: 1px solid var(--color-border-default);
  padding-bottom: 1px;
  transition: color var(--ease-default), border-color var(--ease-default);
}

.loop__step-link:hover {
  color: var(--color-dark);
  border-color: var(--color-dark);
}

/* — Primary CTA — */
.loop__cta-wrap {
  display: flex;
  justify-content: center;
}

.loop__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 52px;
  padding: 14px var(--space-8);    /* 64px horizontal — wide, confident */
  border-radius: var(--radius-full);
  background: var(--color-cta-bg);
  color: var(--color-cta-text);
  font-family: var(--font-body);
  font-size: var(--text-body);
  font-weight: var(--weight-semibold);
  text-decoration: none;
  letter-spacing: 0.01em;
  transition: opacity var(--ease-default);
}

.loop__cta:hover {
  opacity: 0.88;
}

/* — Responsive — */
@media screen and (max-width: 1024px) {
  .loop__steps {
    gap: var(--space-4);
  }

  .loop__connector {
    display: none;
  }
}

@media screen and (max-width: 768px) {
  .loop__container {
    padding: 0 var(--space-4);
  }

  .loop__header {
    margin-bottom: var(--space-7);
  }

  .loop__steps {
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-7);
  }

  .loop__connector {
    display: none;
  }

  .loop__step-number {
    font-size: var(--text-h1);    /* 36px on mobile */
  }

}
{% endstylesheet %}

