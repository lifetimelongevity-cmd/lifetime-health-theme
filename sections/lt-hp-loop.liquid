{% comment %} lt-hp-loop — Stub. Liquid pending. {% endcomment %}

{% schema %}
{
  "name": "HP Loop",
  "settings": [
    { "type": "color", "id": "color_bg", "label": "Hintergrundfarbe" },
    { "type": "color", "id": "color_text", "label": "Textfarbe" },
    { "type": "range", "id": "padding_top", "label": "Abstand oben", "min": 0, "max": 200, "step": 8, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Abstand unten", "min": 0, "max": 200, "step": 8, "default": 80, "unit": "px" },
    { "type": "text", "id": "kicker", "label": "Kicker" },
    { "type": "text", "id": "headline", "label": "Headline" },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline" },
    { "type": "checkbox", "id": "show_connector_line", "label": "Verbindungslinie anzeigen", "default": true },
    { "type": "text", "id": "cta_label", "label": "CTA Text" },
    { "type": "url", "id": "cta_url", "label": "CTA Link" },
    { "type": "textarea", "id": "expert_quote", "label": "Experten-Zitat" },
    { "type": "text", "id": "expert_name", "label": "Experten-Name" },
    { "type": "text", "id": "expert_title", "label": "Experten-Titel" },
    { "type": "text", "id": "expert_image_url", "label": "Experten-Foto URL" }
  ],
  "blocks": [
    {
      "type": "loop_step",
      "name": "Loop-Schritt",
      "settings": [
        { "type": "text", "id": "step_number", "label": "Nummer" },
        { "type": "text", "id": "step_label", "label": "Label" },
        { "type": "text", "id": "step_headline", "label": "Headline" },
        { "type": "textarea", "id": "step_body", "label": "Beschreibung" },
        { "type": "text", "id": "step_product_name", "label": "Produktname" },
        { "type": "url", "id": "step_product_url", "label": "Produkt-Link" },
        { "type": "checkbox", "id": "step_is_primary", "label": "Primärer Schritt", "default": false }
      ]
    }
  ],
  "presets": [{ "name": "HP Loop" }]
}
{% endschema %}
