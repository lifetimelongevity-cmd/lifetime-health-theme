{% comment %}
  LT Page — Report Intro
  Warm split hero for the What's Inside page.
{% endcomment %}

<section
  id="lt-page-report-intro-{{ section.id }}"
  class="lt-page-report-intro"
  aria-labelledby="lt-page-report-intro-heading-{{ section.id }}"
>
  <div class="container container--large remove-empty-space">
    <div class="lt-page-report-intro__split{% if section.settings.app_image != blank or section.settings.app_image_url != blank %} lt-page-report-intro__split--has-image{% endif %}">
      <div class="lt-page-report-intro__content">
        <div class="crs-heading-stack crs-heading-stack--align-left">
          {%- if section.settings.kicker != blank -%}
            <p class="crs-heading-stack__kicker">{{ section.settings.kicker | escape }}</p>
          {%- endif -%}
          <div class="crs-heading-stack__pair">
            <h1 class="crs-heading-stack__title lt-page-report-intro__h1" id="lt-page-report-intro-heading-{{ section.id }}">
              {{- section.settings.heading | escape -}}
            </h1>
            {%- if section.settings.subheading != blank -%}
              <p class="crs-heading-stack__subtitle lt-page-report-intro__subline">{{ section.settings.subheading | escape }}</p>
            {%- endif -%}
          </div>
        </div>
      </div>

      {%- if section.settings.app_image != blank or section.settings.app_image_url != blank -%}
        <div class="lt-page-report-intro__media">
          <div class="lt-page-report-intro__media-frame">
            {%- if section.settings.app_image != blank -%}
              {{
                section.settings.app_image
                | image_url: width: 900
                | image_tag:
                  loading: 'lazy',
                  class: 'lt-page-report-intro__app-img',
                  alt: section.settings.app_image_alt | default: 'LIFETIME App'
              }}
            {%- elsif section.settings.app_image_url != blank -%}
              <img
                src="{{ section.settings.app_image_url | escape }}"
                alt="{{ section.settings.app_image_alt | default: 'LIFETIME App' | escape }}"
                loading="lazy"
                class="lt-page-report-intro__app-img"
                width="420"
              >
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% stylesheet %}
  .lt-page-report-intro {
    padding-block: var(--space-9);
    background: var(--color-surface-secondary);
  }

  .lt-page-report-intro__split {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-7);
    align-items: center;
  }

  @media screen and (min-width: 980px) {
    .lt-page-report-intro__split--has-image {
      grid-template-columns: minmax(0, 1fr) minmax(300px, 420px);
    }
  }

  .lt-page-report-intro__content {
    min-width: 0;
  }

  .lt-page-report-intro__h1 {
    font-size: var(--text-h1);
  }

  .lt-page-report-intro__subline {
    max-width: 62rem;
  }

  .lt-page-report-intro__media {
    min-width: 0;
  }

  .lt-page-report-intro__media-frame {
    display: flex;
    justify-content: center;
    align-items: center;
    padding: clamp(1rem, 3vw, 1.5rem);
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.68), rgba(255, 255, 255, 0.9));
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-xl);
    box-shadow: 0 22px 36px rgba(38, 37, 30, 0.08);
  }

  .lt-page-report-intro__app-img {
    display: block;
    width: 100%;
    max-width: 320px;
    height: auto;
    border-radius: calc(var(--radius-xl) - 4px);
    box-shadow: 0 12px 24px rgba(38, 37, 30, 0.14);
  }

  @media screen and (max-width: 767px) {
    .lt-page-report-intro {
      padding-block: var(--space-8);
    }

    .lt-page-report-intro__split {
      gap: var(--space-6);
    }

    .lt-page-report-intro__app-img {
      max-width: 220px;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LT Page Report Intro",
  "tag": "section",
  "class": "section-lt-page-report-intro",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "187 Reports · 16 Kategorien"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift (H1)",
      "default": "Was steckt drin — alle 187 Reports im Überblick"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Einleitungstext"
    },
    {
      "type": "header",
      "content": "App-Screenshot"
    },
    {
      "type": "image_picker",
      "id": "app_image",
      "label": "App-Screenshot (Upload)"
    },
    {
      "type": "url",
      "id": "app_image_url",
      "label": "App-Screenshot (URL)"
    },
    {
      "type": "text",
      "id": "app_image_alt",
      "label": "Alt-Text Screenshot"
    }
  ],
  "presets": [
    {
      "name": "LT Page Report Intro"
    }
  ]
}
{% endschema %}
