{% comment %}
  LT Page — Report Intro
  ──────────────────────────────────────────────────────────────────────────────
  §12 Build Spec:
  - Surface:         --color-surface-primary (white, clean page opening)
  - Dominant:        H1 — page orientation, erste Section der Seite
  - Content:         3 count-badges + anatomy stepper (5 Schritte)
  - CTA:             keiner — Seite öffnet den Inhalt, kein Verkaufstext
  - Removed:         decorative dividers, trust badges (gehören auf PDP)
  - Quality move:    Anatomy-Stepper als 2-col split mit App-Screenshot rechts —
                     zeigt sofort, wie ein echter Report in der App aussieht
  - App-Screenshot:  SNPs-Ansicht (app-snps-detail.png) — zeigt Schritt 5 live
{% endcomment %}

<div class="container container--large remove-empty-space">
  <section
    id="lt-page-report-intro-{{ section.id }}"
    class="lt-page-report-intro"
    aria-labelledby="lt-page-report-intro-heading-{{ section.id }}"
  >

    <div class="lt-page-report-intro__header crs-heading-stack crs-heading-stack--align-left">
      {%- if section.settings.kicker != blank -%}
        <p class="crs-heading-stack__kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      <div class="crs-heading-stack__pair">
        <h1 class="crs-heading-stack__title lt-page-report-intro__h1" id="lt-page-report-intro-heading-{{ section.id }}">
          {{- section.settings.heading | escape -}}
        </h1>
        {%- if section.settings.subheading != blank -%}
          <p class="crs-heading-stack__subtitle">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    </div>

    <div class="lt-page-report-intro__badges" role="list" aria-label="Report-Übersicht">
      {%- if section.settings.badge_1_text != blank -%}
        <div class="lt-page-report-intro__badge" role="listitem">
          <svg class="lt-page-report-intro__badge-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9.5 2A2.5 2.5 0 0 1 12 4.5v15a2.5 2.5 0 0 1-4.96-.46 2.5 2.5 0 0 1-2.96-3.08 3 3 0 0 1-.34-5.58 2.5 2.5 0 0 1 1.32-4.24 2.5 2.5 0 0 1 1.98-3A2.5 2.5 0 0 1 9.5 2Z"/><path d="M14.5 2A2.5 2.5 0 0 0 12 4.5v15a2.5 2.5 0 0 0 4.96-.46 2.5 2.5 0 0 0 2.96-3.08 3 3 0 0 0 .34-5.58 2.5 2.5 0 0 0-1.32-4.24 2.5 2.5 0 0 0-1.98-3A2.5 2.5 0 0 0 14.5 2Z"/></svg>
          <span>{{ section.settings.badge_1_text | escape }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.badge_2_text != blank -%}
        <div class="lt-page-report-intro__badge" role="listitem">
          <svg class="lt-page-report-intro__badge-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>
          <span>{{ section.settings.badge_2_text | escape }}</span>
        </div>
      {%- endif -%}
      {%- if section.settings.badge_3_text != blank -%}
        <div class="lt-page-report-intro__badge" role="listitem">
          <svg class="lt-page-report-intro__badge-icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="3" y1="9" x2="21" y2="9"/><line x1="9" y1="21" x2="9" y2="9"/></svg>
          <span>{{ section.settings.badge_3_text | escape }}</span>
        </div>
      {%- endif -%}
    </div>

    {%- if section.settings.show_anatomy and section.blocks.size > 0 -%}
      <div class="lt-page-report-intro__anatomy">
        <div class="lt-page-report-intro__steps">
          {%- for block in section.blocks -%}
            <div class="lt-page-report-intro__step" {{ block.shopify_attributes }}>
              <div class="lt-page-report-intro__step-number" aria-hidden="true">{{ forloop.index }}</div>
              <div class="lt-page-report-intro__step-body">
                {%- if block.settings.title != blank -%}
                  <p class="lt-page-report-intro__step-title">{{ block.settings.title | escape }}</p>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="lt-page-report-intro__step-description">{{ block.settings.description | escape }}</p>
                {%- endif -%}
              </div>
            </div>
          {%- endfor -%}
        </div>

        {%- if section.settings.app_image != blank -%}
          <div class="lt-page-report-intro__app-visual">
            {{
              section.settings.app_image
              | image_url: width: 600
              | image_tag:
                loading: 'lazy',
                class: 'lt-page-report-intro__app-img',
                alt: section.settings.app_image_alt | default: 'LIFETIME App Report-Ansicht'
            }}
          </div>
        {%- elsif section.settings.app_image_url != blank -%}
          <div class="lt-page-report-intro__app-visual">
            <img
              src="{{ section.settings.app_image_url | escape }}"
              alt="{{ section.settings.app_image_alt | default: 'LIFETIME App Report-Ansicht' | escape }}"
            loading="lazy"
            class="lt-page-report-intro__app-img"
            width="320"
            >
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

  </section>
</div>

{% stylesheet %}
  .lt-page-report-intro {
    padding-block: var(--space-9);
    background: var(--color-surface-primary);
  }

  @media screen and (max-width: 768px) {
    .lt-page-report-intro {
      padding-block: var(--space-8);
    }
  }

  .lt-page-report-intro__h1 {
    font-size: var(--text-h1);
  }

  /* ── Badges ── */
  .lt-page-report-intro__badges {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-6);
  }

  .lt-page-report-intro__badge {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    padding: 8px var(--space-4);
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border-default);
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-medium);
    color: var(--color-text-primary);
    line-height: var(--leading-tight);
  }

  .lt-page-report-intro__badge-icon {
    flex-shrink: 0;
    color: var(--color-text-secondary);
  }

  /* ── Anatomy Block ── */
  .lt-page-report-intro__anatomy {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-top: var(--space-8);
    align-items: start;
  }

  @media screen and (min-width: 900px) {
    .lt-page-report-intro__anatomy {
      grid-template-columns: 1fr 280px;
      align-items: center;
    }
  }

  /* ── Steps ── */
  .lt-page-report-intro__steps {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .lt-page-report-intro__step {
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: var(--space-4);
    padding: var(--space-5) 0;
    border-bottom: 1px solid var(--color-border-default);
    align-items: start;
  }

  .lt-page-report-intro__step:first-child {
    border-top: 1px solid var(--color-border-default);
  }

  .lt-page-report-intro__step-number {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full);
    background: var(--color-surface-secondary);
    border: 1px solid var(--color-border-default);
    font-family: var(--font-heading);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-bold);
    color: var(--color-text-secondary);
    line-height: 1;
    margin-top: 2px; /* intentional: visual alignment with step title */
  }

  .lt-page-report-intro__step-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .lt-page-report-intro__step-title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: var(--text-body);
    font-weight: var(--weight-bold);
    color: var(--color-text-primary);
    line-height: var(--leading-tight);
  }

  .lt-page-report-intro__step-description {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    color: var(--color-text-secondary);
    line-height: var(--leading-body);
  }

  /* ── App Screenshot ── */
  .lt-page-report-intro__app-visual {
    display: flex;
    justify-content: center;
  }

  .lt-page-report-intro__app-img {
    display: block;
    width: 100%;
    max-width: 260px;
    height: auto;
    border-radius: var(--radius-lg);
  }

  @media screen and (max-width: 899px) {
    .lt-page-report-intro__app-img {
      max-width: 200px;
      margin: 0 auto;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LT Page Report Intro",
  "tag": "section",
  "class": "section-lt-page-report-intro",
  "enabled_on": {
    "templates": ["page"]
  },
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "187 Reports · 16 Kategorien"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift (H1)",
      "default": "Was steckt drin — alle 187 Reports im Überblick"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Einleitungstext"
    },
    {
      "type": "header",
      "content": "Orientierungs-Badges"
    },
    {
      "type": "text",
      "id": "badge_1_text",
      "label": "Badge 1",
      "default": "5 Epigenetik-Reports"
    },
    {
      "type": "text",
      "id": "badge_2_text",
      "label": "Badge 2",
      "default": "47 DNA-Basics Reports"
    },
    {
      "type": "text",
      "id": "badge_3_text",
      "label": "Badge 3",
      "default": "135+ DNA-Details Reports"
    },
    {
      "type": "header",
      "content": "Report-Anatomie"
    },
    {
      "type": "checkbox",
      "id": "show_anatomy",
      "label": "Anatomy-Element anzeigen",
      "default": true
    },
    {
      "type": "header",
      "content": "App-Screenshot (rechts)"
    },
    {
      "type": "image_picker",
      "id": "app_image",
      "label": "App-Screenshot (Bild-Upload)"
    },
    {
      "type": "url",
      "id": "app_image_url",
      "label": "App-Screenshot (URL-Fallback)",
      "info": "Nur wenn kein Bild hochgeladen. Aus Theme-Assets: app-snps-detail.png"
    },
    {
      "type": "text",
      "id": "app_image_alt",
      "label": "Alt-Text Screenshot"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Report-Schritt",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Schrittbezeichnung",
          "default": "Dein Ergebnis"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Kurzerklärung",
          "default": "Dein persönlicher Wert, eingeordnet auf einer Skala"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LT Page Report Intro",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "title": "Dein Ergebnis",
            "description": "Dein persönlicher Wert, eingeordnet auf einer Skala"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Was bedeutet das?",
            "description": "Was dein Ergebnis biologisch bedeutet, wissenschaftlich erklärt"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Was soll ich tun?",
            "description": "Konkrete, auf dich zugeschnittene Handlungsempfehlungen"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Wissenschaftlicher Hinweis",
            "description": "Die zugrundeliegende Forschung und Algorithmus-Logik"
          }
        },
        {
          "type": "step",
          "settings": {
            "title": "Relevante SNPs",
            "description": "Deine spezifischen Genvarianten — rsID, Allel, Referenzstudie"
          }
        }
      ]
    }
  ]
}
{% endschema %}
