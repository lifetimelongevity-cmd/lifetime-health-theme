{% style %}
  #section-{{ section.id }} {
    --sq-text:     {{ settings.color_text_main | default: '#161514' }};
    --sq-text-sec: {{ settings.color_text_main | color_modify: 'alpha', 0.5 | default: 'rgba(22,21,20,0.5)' }};
    --sq-bg:       {{ settings.color_background_main | default: '#ffffff' }};
    --sq-card-bg:  {{ settings.color_background_main | default: '#ffffff' }};
    --sq-border:   {{ settings.color_text_main | color_modify: 'alpha', 0.1 | default: 'rgba(22,21,20,0.1)' }};
  }
{% endstyle %}

<div class="sq-section" id="section-{{ section.id }}">
  <div class="sq-container">

    {%- if section.settings.heading != blank -%}
      <h2 class="sq-section-heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="sq-grid">
        {%- for block in section.blocks -%}
          <div class="sq-card" {{ block.shopify_attributes }}>
            <figure class="sq-figure">
              <blockquote class="sq-blockquote">
                <p class="sq-quote-text">{{ block.settings.quote | escape }}</p>
              </blockquote>
              <div class="sq-author">
                {%- if block.settings.avatar != blank -%}
                  <div class="sq-avatar">
                    {{
                      block.settings.avatar
                      | image_url: width: 84
                      | image_tag:
                        width: 42,
                        height: 42,
                        loading: 'lazy',
                        alt: block.settings.name | escape
                    }}
                  </div>
                {%- endif -%}
                <figcaption class="sq-figcaption">
                  <span class="sq-name">{{ block.settings.name | escape }}</span>
                  <span class="sq-role">{{ block.settings.role | escape }}</span>
                </figcaption>
              </div>
            </figure>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
/* ===================================================
   Social Quotes Grid — crs-social-quotes.liquid
   =================================================== */

.sq-section {
  padding: 64px 0;
  background: var(--sq-bg, #fff);
}

.sq-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
}

/* Optional section heading */
.sq-section-heading {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: clamp(1.5rem, 2.5vw, 2.25rem) !important;
  font-weight: 700 !important;
  line-height: 1.15 !important;
  letter-spacing: -.025em !important;
  color: var(--sq-text, #161514) !important;
  margin: 0 0 40px !important;
}

/* Grid */
.sq-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 16px;
}

/* Card */
.sq-card {
  background: var(--sq-card-bg, #fff);
  border: 1px solid var(--sq-border, rgba(22,21,20,0.1));
  border-radius: 14px;
  padding: 28px;
  display: flex;
  flex-direction: column;
}

/* Figure */
.sq-figure {
  display: flex;
  flex-direction: column;
  height: 100%;
  margin: 0;
}

/* Quote */
.sq-blockquote {
  flex: 1;
  margin: 0 0 20px;
}

.sq-quote-text {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  font-size: .9375rem;
  line-height: 1.65;
  color: var(--sq-text, #161514);
  margin: 0;
  white-space: pre-wrap;
}

/* Author row */
.sq-author {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: auto;
}

.sq-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 1.5px solid var(--sq-border, rgba(22,21,20,0.1));
}

.sq-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.sq-figcaption {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sq-name {
  font-size: .875rem;
  font-weight: 600;
  line-height: 1.3;
  color: var(--sq-text, #161514);
}

.sq-role {
  font-size: .8125rem;
  line-height: 1.3;
  color: var(--sq-text-sec, rgba(22,21,20,0.5));
}

/* Tablet — 2 columns */
@media (max-width: 1024px) {
  .sq-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Mobile — 1 column */
@media (max-width: 640px) {
  .sq-section {
    padding: 40px 0;
  }

  .sq-container {
    padding: 0 16px;
  }

  .sq-grid {
    grid-template-columns: 1fr;
    gap: 12px;
  }

  .sq-card {
    padding: 22px;
  }
}
{% endstylesheet %}

