{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.1 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="sq-section" id="section-{{ section.id }}">
  <div class="sq-container">

    {%- if section.settings.heading != blank -%}
      <h2 class="sq-section-heading">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="sq-grid">
        {%- for block in section.blocks -%}
          <div class="sq-card" {{ block.shopify_attributes }}>
            <figure class="sq-figure">
              <blockquote class="sq-blockquote">
                <p class="sq-quote-text">{{ block.settings.quote | escape }}</p>
              </blockquote>
              <div class="sq-author">
                {%- if block.settings.avatar != blank -%}
                  <div class="sq-avatar">
                    {{
                      block.settings.avatar
                      | image_url: width: 84
                      | image_tag:
                        width: 42,
                        height: 42,
                        loading: 'lazy',
                        alt: block.settings.name | escape
                    }}
                  </div>
                {%- endif -%}
                <figcaption class="sq-figcaption">
                  <span class="sq-name">{{ block.settings.name | escape }}</span>
                  <span class="sq-role">{{ block.settings.role | escape }}</span>
                </figcaption>
              </div>
            </figure>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
/* ===================================================
   Social Quotes Grid — crs-social-quotes.liquid
   =================================================== */

.sq-section {
  background: var(--crs-bg, #f7f7f4);
}

.sq-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Optional section heading */
.sq-section-heading {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: 36px !important;
  font-weight: 400 !important;
  line-height: 1.15 !important;
  letter-spacing: -0.72px !important;
  color: var(--crs-text, #26251e) !important;
  margin: 0 0 32px !important;
}

/* Grid */
.sq-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

/* Card */
.sq-card {
  background: var(--crs-card-bg, #f2f1ed);
  border-radius: 4px;
  padding: 20px;
  display: flex;
  flex-direction: column;
}

/* Figure */
.sq-figure {
  display: flex;
  flex-direction: column;
  height: 100%;
  margin: 0;
}

/* Quote */
.sq-blockquote {
  flex: 1;
  margin: 0 0 20px;
}

.sq-quote-text {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  font-size: 16px;
  line-height: 1.65;
  color: var(--crs-text, #26251e);
  margin: 0;
  white-space: pre-wrap;
}

/* Author row */
.sq-author {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-top: auto;
}

.sq-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 1.5px solid var(--crs-border, rgba(38,37,30,0.1));
}

.sq-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.sq-figcaption {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.sq-name {
  font-size: .875rem;
  font-weight: 600;
  line-height: 1.3;
  color: var(--crs-text, #26251e);
}

.sq-role {
  font-size: .8125rem;
  line-height: 1.3;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
}

/* Tablet — 2 columns */
@media (max-width: 1024px) {
  .sq-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Mobile — 1 column */
@media (max-width: 640px) {
  .sq-grid {
    grid-template-columns: 1fr;
  }
}
{% endstylesheet %}

