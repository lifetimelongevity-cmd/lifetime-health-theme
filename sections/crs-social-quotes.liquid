{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_sq_kicker = section.settings.kicker | strip
  assign crs_sq_head = section.settings.heading | strip
  assign crs_sq_sub = section.settings.subheading | strip
  if crs_sq_kicker == '__none__'
    assign crs_sq_kicker = ''
  endif
  if crs_sq_head == '__none__'
    assign crs_sq_head = ''
  endif
  if crs_sq_sub == '__none__'
    assign crs_sq_sub = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.05 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="sq-section" id="section-{{ section.id }}">
  <div class="sq-container">

    {%- if crs_sq_kicker != blank or crs_sq_head != blank or crs_sq_sub != blank -%}
      <div class="sq-section-head crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
        {%- if crs_sq_kicker != blank -%}
          <p class="crs-heading-stack__kicker">{{ crs_sq_kicker | escape }}</p>
        {%- endif -%}
        {%- if crs_sq_head != blank or crs_sq_sub != blank -%}
          <div class="crs-heading-stack__pair">
            {%- if crs_sq_head != blank -%}
              <h2 class="crs-heading-stack__title">{{ crs_sq_head | escape | newline_to_br }}</h2>
            {%- endif -%}
            {%- if crs_sq_sub != blank -%}
              <p class="crs-heading-stack__subtitle">{{ crs_sq_sub | escape | newline_to_br }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="sq-grid">
        {%- for block in section.blocks -%}
          <div class="sq-card" {{ block.shopify_attributes }}>
            {%- if block.settings.avatar != blank -%}
              <div class="sq-image">
                {{
                  block.settings.avatar
                  | image_url: width: 600
                  | image_tag:
                    loading: 'lazy',
                    class: 'sq-image-img',
                    alt: block.settings.name | escape
                }}
              </div>
            {%- endif -%}
            <figure class="sq-figure">
              <blockquote class="sq-blockquote">
                <p class="sq-quote-text">{{ block.settings.quote | escape }}</p>
              </blockquote>
              <figcaption class="sq-figcaption">
                <span class="sq-name">{{ block.settings.name | escape }}</span>
                <span class="sq-role">{{ block.settings.role | escape }}</span>
              </figcaption>
            </figure>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
/* ===================================================
   Social Quotes Grid — crs-social-quotes.liquid
   =================================================== */

.sq-section {
  background: var(--crs-bg, #f7f7f4);
}

.sq-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 var(--space-5);
}

.sq-section-head {
  margin-bottom: var(--space-7);
}

/* Grid */
.sq-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: var(--space-3);
  align-items: start;
}

/* Card — quadratische Kachel, kompakter als 4:3-Layout */
.sq-card {
  box-sizing: border-box;
  background: var(--crs-card-bg, #f2f1ed);
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  border-radius: var(--radius-sm);
  padding: var(--space-4);
  display: flex;
  flex-direction: column;
  overflow: hidden;
  aspect-ratio: 1 / 1;
  width: 100%;
  max-width: 100%;
}

/* Testimonial-Bild: quadratisch, oben bündig mit Kartenkante */
.sq-image {
  flex-shrink: 0;
  width: calc(100% + 2 * var(--space-4));
  aspect-ratio: 1 / 1;
  overflow: hidden;
  border-radius: var(--radius-sm) var(--radius-sm) 0 0;
  margin: calc(-1 * var(--space-4)) calc(-1 * var(--space-4)) var(--space-3) calc(-1 * var(--space-4));
}

.sq-image-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center top;
  display: block;
}

/* Figure */
.sq-figure {
  display: flex;
  flex-direction: column;
  flex: 1;
  min-height: 0;
  margin: 0;
}

/* Quote */
.sq-blockquote {
  flex: 1;
  min-height: 0;
  margin: 0 0 var(--space-3);
  overflow: hidden;
}

.sq-quote-text {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  font-size: var(--text-body-sm, 14px);
  line-height: var(--leading-relaxed, 1.6);
  color: var(--crs-text, #26251e);
  margin: 0;
  white-space: pre-wrap;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 7;
  overflow: hidden;
}

.sq-figcaption {
  display: flex;
  flex-direction: column;
  gap: var(--space-1);
  flex-shrink: 0;
  margin-top: auto;
}

.sq-name {
  font-size: .875rem;
  font-weight: 600;
  line-height: 1.3;
  color: var(--crs-text, #26251e);
}

.sq-role {
  font-size: .8125rem;
  line-height: 1.3;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
}

/* Tablet — 2 columns */
@media (max-width: 1024px) {
  .sq-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

/* Mobile — 1 column */
@media (max-width: 640px) {
  .sq-grid {
    grid-template-columns: 1fr;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Social Quotes",
  "tag": "section",
  "class": "crs-social-quotes",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
