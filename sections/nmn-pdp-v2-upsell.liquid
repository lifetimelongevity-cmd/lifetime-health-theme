{% comment %}
  NMN PDP alternative (product.13-2_nmn): Upsell — 2 Karten, immer 2 Spalten.
{% endcomment %}

<div
  class="nmn2-upsell"
  id="nmn2-upsell-{{ section.id }}"
  role="region"
  {% if section.settings.heading != blank %}
    aria-labelledby="nmn2-upsell-heading-{{ section.id }}"
  {% else %}
    aria-label="Weitere Produkte"
  {% endif %}
>
  <div class="container container--large">
    {%- if section.settings.heading != blank -%}
      <h2 class="nmn2-upsell__title" id="nmn2-upsell-heading-{{ section.id }}">{{ section.settings.heading | escape }}</h2>
    {%- endif -%}

    <ul class="nmn2-upsell__grid" role="list">
      {%- for block in section.blocks -%}
        {%- if block.type == 'card' -%}
          {%- liquid
            assign card_product = block.settings.product
            assign card_title = block.settings.title
            assign card_desc = block.settings.description
            assign card_price = block.settings.price_text
            assign card_btn = block.settings.button_label
            assign card_href = block.settings.button_url
            assign card_img = block.settings.image
            if card_product != blank
              if card_title == blank
                assign card_title = card_product.title
              endif
              assign card_href = card_product.url
              if card_img == blank and card_product.featured_image
                assign card_img = card_product.featured_image
              endif
            endif
            assign img_alt = card_title
            if img_alt == blank and card_product != blank
              assign img_alt = card_product.title
            endif
            if img_alt == blank
              assign img_alt = 'Produkt'
            endif
          -%}
          <li class="nmn2-upsell__card" {{ block.shopify_attributes }}>
            {%- if card_href != blank -%}
              <a class="nmn2-upsell__card-hit" href="{{ card_href }}">
                <span class="nmn2-upsell__media">
                  {%- if card_img != blank -%}
                    {{
                      card_img
                      | image_url: width: 600
                      | image_tag: loading: 'lazy', class: 'nmn2-upsell__img', widths: '200, 400, 600', sizes: '(max-width: 749px) 45vw, 280px', alt: img_alt
                    }}
                  {%- else -%}
                    <span class="nmn2-upsell__placeholder">
                      {%- if block.settings.placeholder_label != blank -%}
                        {{- block.settings.placeholder_label | escape -}}
                      {%- else -%}
                        Produktbild
                      {%- endif -%}
                    </span>
                  {%- endif -%}
                </span>
                <span class="nmn2-upsell__body">
                  {%- if card_title != blank -%}
                    <span class="nmn2-upsell__name">{{ card_title | escape }}</span>
                  {%- endif -%}
                  {%- if card_desc != blank -%}
                    <span class="nmn2-upsell__desc">{{ card_desc | escape }}</span>
                  {%- endif -%}
                  {%- if card_price != blank -%}
                    <span class="nmn2-upsell__price">{{ card_price | escape }}</span>
                  {%- endif -%}
                </span>
                {%- if card_btn != blank -%}
                  <span class="nmn2-upsell__btn">{{ card_btn | escape }}</span>
                {%- endif -%}
              </a>
            {%- else -%}
              <div class="nmn2-upsell__card-hit nmn2-upsell__card-hit--static">
                <span class="nmn2-upsell__media">
                  {%- if card_img != blank -%}
                    {{
                      card_img
                      | image_url: width: 600
                      | image_tag: loading: 'lazy', class: 'nmn2-upsell__img', widths: '200, 400, 600', sizes: '(max-width: 749px) 45vw, 280px', alt: img_alt
                    }}
                  {%- else -%}
                    <span class="nmn2-upsell__placeholder">
                      {%- if block.settings.placeholder_label != blank -%}
                        {{- block.settings.placeholder_label | escape -}}
                      {%- else -%}
                        Produktbild
                      {%- endif -%}
                    </span>
                  {%- endif -%}
                </span>
                <span class="nmn2-upsell__body">
                  {%- if card_title != blank -%}
                    <span class="nmn2-upsell__name">{{ card_title | escape }}</span>
                  {%- endif -%}
                  {%- if card_desc != blank -%}
                    <span class="nmn2-upsell__desc">{{ card_desc | escape }}</span>
                  {%- endif -%}
                  {%- if card_price != blank -%}
                    <span class="nmn2-upsell__price">{{ card_price | escape }}</span>
                  {%- endif -%}
                </span>
              </div>
            {%- endif -%}
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>
  </div>
</div>

{% stylesheet %}
  .nmn2-upsell {
    padding-block: var(--space-9);
    background: var(--color-surface-secondary);
  }

  @media screen and (max-width: 749px) {
    .nmn2-upsell {
      padding-block: var(--space-8);
    }
  }

  .nmn2-upsell__title {
    margin: 0 0 var(--space-6);
    font-family: var(--font-heading);
    font-size: var(--text-h2);
    font-weight: var(--weight-bold);
    line-height: var(--leading-heading);
    text-align: center;
    color: var(--color-text-primary);
  }

  .nmn2-upsell__grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: var(--space-5);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nmn2-upsell__card {
    margin: 0;
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    background: var(--color-surface-primary);
    border-radius: var(--radius-lg);
    border: 1px solid var(--color-border-default);
    box-shadow: var(--shadow-sm);
    min-width: 0;
  }

  @media screen and (min-width: 750px) {
    .nmn2-upsell__card {
      padding: var(--space-5);
    }
  }

  .nmn2-upsell__card-hit {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
    text-decoration: none;
    color: inherit;
    border-radius: var(--radius-md);
    transition: opacity var(--ease-default);
    min-width: 0;
  }

  .nmn2-upsell__card-hit:hover {
    opacity: 0.92;
  }

  .nmn2-upsell__card-hit:focus-visible {
    outline: 2px solid var(--color-teal-dark);
    outline-offset: var(--space-2);
  }

  .nmn2-upsell__card-hit--static {
    cursor: default;
  }

  .nmn2-upsell__card-hit--static:hover {
    opacity: 1;
  }

  .nmn2-upsell__media {
    display: block;
    aspect-ratio: 1;
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--color-gray-200);
  }

  .nmn2-upsell__img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .nmn2-upsell__placeholder {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
    padding: var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-micro);
    font-weight: var(--weight-medium);
    line-height: var(--leading-tight);
    text-align: center;
    color: var(--color-text-muted);
  }

  .nmn2-upsell__body {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }

  .nmn2-upsell__name {
    font-family: var(--font-heading);
    font-size: var(--text-body);
    font-weight: var(--weight-bold);
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
  }

  @media screen and (min-width: 750px) {
    .nmn2-upsell__name {
      font-size: var(--text-section);
    }
  }

  .nmn2-upsell__desc {
    font-family: var(--font-body);
    font-size: var(--text-micro);
    font-weight: var(--weight-regular);
    line-height: var(--leading-relaxed);
    color: var(--color-text-secondary);
  }

  @media screen and (min-width: 750px) {
    .nmn2-upsell__desc {
      font-size: var(--text-body-sm);
    }
  }

  .nmn2-upsell__price {
    font-family: var(--font-heading);
    font-size: var(--text-body-sm);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--color-text-primary);
  }

  @media screen and (min-width: 750px) {
    .nmn2-upsell__price {
      font-size: var(--text-body-lg);
    }
  }

  .nmn2-upsell__btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    margin: 0;
    padding: var(--space-3) var(--space-4);
    border: none;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: var(--text-micro);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    text-align: center;
    text-decoration: none;
    cursor: pointer;
    background: var(--color-button-primary-bg);
    color: var(--color-button-primary-text);
    transition: opacity var(--ease-default), transform var(--ease-default);
  }

  @media screen and (min-width: 750px) {
    .nmn2-upsell__btn {
      font-size: var(--text-body-sm);
      padding: var(--space-4) var(--space-5);
    }
  }

  .nmn2-upsell__btn:hover {
    opacity: 0.94;
  }

  .nmn2-upsell__btn:focus-visible {
    outline: 2px solid var(--color-teal-dark);
    outline-offset: var(--space-2);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NMN V2 Upsell",
  "tag": "section",
  "class": "section-nmn2-upsell",
  "max_blocks": 4,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Passt gut dazu"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Karte",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Produkt (optional)"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Bild (optional, überschreibt Produkt)"
        },
        {
          "type": "text",
          "id": "placeholder_label",
          "label": "Platzhalter-Text ohne Bild",
          "default": "Produktbild"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "NMN + NAD⁺-Booster Bundle"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Kurzbeschreibung",
          "default": "Die komplette NAD⁺-Strategie in einem Paket."
        },
        {
          "type": "text",
          "id": "price_text",
          "label": "Preis (Text)",
          "info": "Leer lassen, um die Preiszeile auszublenden."
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button-Text",
          "default": "Zum Produkt"
        },
        {
          "type": "text",
          "id": "button_url",
          "label": "Link (ohne Produkt)",
          "default": "/collections/all",
          "info": "Wird ignoriert, wenn ein Produkt gewählt ist."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "NMN V2 Upsell",
      "settings": {
        "heading": "Passt gut dazu"
      },
      "blocks": [
        {
          "type": "card",
          "settings": {
            "title": "NMN + NAD⁺-Booster Bundle",
            "description": "Die komplette NAD⁺-Strategie in einem Paket.",
            "price_text": "",
            "button_label": "Zum Bundle",
            "button_url": "/collections/all",
            "placeholder_label": "Bundle"
          }
        },
        {
          "type": "card",
          "settings": {
            "title": "NAD⁺-Booster (liposomal)",
            "description": "Liposomale Aufnahme für maximale Bioverfügbarkeit.",
            "price_text": "34,90 €/Monat Abo",
            "button_label": "Zum Booster",
            "button_url": "/collections/all",
            "placeholder_label": "NAD⁺ Booster"
          }
        }
      ]
    }
  ]
}
{% endschema %}
