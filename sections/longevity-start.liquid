<section class="lt-start-v2" aria-label="Dein Einstieg in Longevity">
  <div class="lt-start-v2__wrap">
    <h2 class="lt-start-v2__title lt-animate-up" style="--delay: 0.1s">
      So startest du mit Longevity
    </h2>

    <div class="lt-start-v2__grid">

      <article class="lt-v2-card lt-v2-card--start lt-animate-up" style="--delay: 0.2s">
        <div class="lt-v2-card__glow lt-v2-card__glow--mint"></div>
        <div class="lt-v2-card__chip">Verstehen</div>
        <h3 class="lt-v2-card__h">Teste deinen Körper</h3>
        <p class="lt-v2-card__p">Finde heraus, wie schnell du alterst.</p>
        <a class="lt-v2-card__btn" href="/products/lifetime-age-dna">
          <span>Zum Test</span>
          <svg class="lt-v2-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </article>

      <article class="lt-v2-card lt-v2-card--start lt-animate-up" style="--delay: 0.3s">
        <div class="lt-v2-card__glow lt-v2-card__glow--teal"></div>
        <div class="lt-v2-card__chip">Optimieren</div>
        <h3 class="lt-v2-card__h">Entdecke Nährstoffe</h3>
        <p class="lt-v2-card__p">Nährstoffe für gesundes Altern.</p>
        <a class="lt-v2-card__btn" href="/collections/naehrstoffe">
          <span>Alle Nährstoffe</span>
          <svg class="lt-v2-card__arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </article>

    </div>
  </div>
</section>

<style>
  .lt-start-v2 {
    --mint: #65C0B6;
    --dark: #0B0F12;
    --bg-warm: #F6F4F1;
    --text-muted: rgba(11, 15, 18, 0.6);

    background: var(--bg-warm);
    padding: 40px 40px;
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    color: var(--dark);
    overflow: hidden;
  }

  .lt-start-v2__wrap {
    max-width: 1000px;
    margin: 0 auto;
  }

  .lt-start-v2__title {
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 800;
    text-align: center;
    letter-spacing: -0.02em;
    margin-bottom: 60px;
    line-height: 1.1;
  }

  .lt-start-v2__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 32px;
  }
  @media (min-width: 768px) {
    .lt-start-v2__grid { grid-template-columns: 1fr 1fr; }
  }

  .lt-v2-card--start {
    position: relative;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(255, 255, 255, 0.6);
    border-radius: 10px;
    padding: 48px 32px;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.05);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    overflow: hidden;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .lt-v2-card--start:hover {
    transform: translateY(-8px);
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.08);
  }

  .lt-v2-card__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.5s ease;
    z-index: 0;
  }
  .lt-v2-card--start:hover .lt-v2-card__glow { opacity: 1; }

  .lt-v2-card__glow--mint {
    background: radial-gradient(circle at 50% 50%, rgba(101, 192, 182, 0.1) 0%, transparent 70%);
  }
  .lt-v2-card__glow--teal {
    background: radial-gradient(circle at 50% 50%, rgba(54, 79, 86, 0.08) 0%, transparent 70%);
  }

  .lt-v2-card__chip {
    position: relative;
    z-index: 1;
    padding: 6px 16px;
    background: rgba(255, 255, 255, 0.8);
    border: 1px solid rgba(0, 0, 0, 0.05);
    border-radius: 100px;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--text-muted);
    margin-bottom: 24px;
  }

  .lt-v2-card__h {
    position: relative;
    z-index: 1;
    font-size: clamp(24px, 4vw, 32px);
    font-weight: 800;
    margin: 0 0 12px;
    letter-spacing: -0.01em;
  }
  .lt-v2-card__p {
    position: relative;
    z-index: 1;
    font-size: 18px;
    color: var(--text-muted);
    margin: 0 0 40px;
    line-height: 1.4;
  }

  .lt-v2-card__btn {
    position: relative;
    z-index: 1;
    margin-top: auto;
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: var(--dark);
    color: #fff;
    padding: 16px 24px;
    border-radius: 100px;
    text-decoration: none;
    font-weight: 700;
    font-size: 16px;
    transition: transform 0.2s ease;
  }
  .lt-v2-card__btn:hover { transform: scale(1.02); }
  .lt-v2-card__arrow { width: 18px; height: 18px; transition: transform 0.2s ease; }
  .lt-v2-card__btn:hover .lt-v2-card__arrow { transform: translateX(3px); }

  @keyframes ltFadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  .lt-animate-up {
    opacity: 0;
    animation: ltFadeUp 0.8s ease forwards;
    animation-delay: var(--delay);
  }
  .lt-start-v2 .lt-animate-up        { animation-play-state: paused; }
  .lt-start-v2.is-visible .lt-animate-up { animation-play-state: running; }
</style>

<script>
  (function() {
    var section = document.querySelector('.lt-start-v2');
    if (!section) return;
    var observer = new IntersectionObserver(function(entries) {
      entries.forEach(function(entry) {
        if (entry.isIntersecting) {
          section.classList.add('is-visible');
          observer.unobserve(entry.target);
        }
      });
    }, { threshold: 0.1 });
    observer.observe(section);
  })();
</script>

{% schema %}
{
  "name": "Longevity Start",
  "tag": "div",
  "settings": []
}
{% endschema %}
