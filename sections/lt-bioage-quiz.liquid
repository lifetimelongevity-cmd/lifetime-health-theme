        "mid":  { "hot": "Du bist nicht weit weg. Drei Stellen entscheiden.",       "cool": "Solide Basis. Drei Hebel bringen dich nach vorn." },
        "high": { "hot": "",                                                        "cool": "Du machst vieles richtig. Drei feine Justierungen, mehr nicht." },
        "top":  { "hot": "",                                                        "cool": "Dein Lebensstil arbeitet für dich. Was fehlt, ist die Bestätigung." }
      },
