          </section>

          <section class="bq-zone bq-cta-block">
            <p class="bq-price">{{ section.settings.price_line | default: '349 € · einmalig · lebenslang in der App' }}</p>
            <a href="{{ section.settings.cta_primary_url | default: '/products/age-dna-test' }}" class="bq-cta" data-cta-primary>
              <span data-cta-primary-label>{{ section.settings.cta_primary_label | default: 'AGE & DNA-Test starten →' }}</span>
            </a>
            <a href="{{ section.settings.cta_secondary_url | default: '/pages/longevity-coach' }}" class="bq-cta-secondary" data-cta-secondary>
              <span data-cta-secondary-label>{{ section.settings.cta_secondary_label | default: 'Oder: 15 Min kostenfrei mit einem Longevity-Experten sprechen' }}</span>
            </a>
            <ul class="bq-trust" role="list">
              <li>Eurofins ISO-zertifiziert</li>
              <li>DSGVO-konform</li>
