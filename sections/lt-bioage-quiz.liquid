            <li><button type="button" class="bq-option" data-answer="2"><span class="bq-option-marker">C</span><span>Häufig angespannt</span></button></li>
            <li><button type="button" class="bq-option" data-answer="1"><span class="bq-option-marker">D</span><span>Dauerhaft unter Druck</span></button></li>
