{%- comment -%}
  LIFETIME · Biologisches-Alter Quiz
  - 8 Fragen + Email-Gate + 5-Zonen-Result
  - Desktop: 2-Spalten Split (Bild · Content), Mobile: stacked
  - State in localStorage
  - Tokens: Lifetime Design System v2
{%- endcomment -%}

{% style %}
  #lt-bioage-{{ section.id }} {
    /* Scoped tokens (Lifetime DS v2) */
    --f-h: "Helvetica Neue", Helvetica, Arial, sans-serif;
    --f-b: "Lato", -apple-system, BlinkMacSystemFont, sans-serif;
    --c-warm: #F7F7F4;
    --c-warm-2: #F2F1ED;
    --c-warm-3: #EDEBE6;
    --c-text: #26251E;
    --c-text-2: #525252;
    --c-text-3: #8A8778;
    --c-text-on-dark: #F7F7F4;
    --c-dark: #364F56;
    --c-dark-2: #2D4249;
    --c-teal: #65C0B6;
    --c-line: rgba(38,37,30,.12);
    --c-line-2: rgba(38,37,30,.06);
    --c-line-strong: rgba(54,79,86,.14);
    --r-md: 12px;
    --r-lg: 16px;
    --r-full: 999px;
    --ease-default: .2s ease;
    --ease-smooth: .4s ease;

    background: var(--c-warm);
    color: var(--c-text);
    font-family: var(--f-b);
    padding: 80px 0;
  }

  @media (max-width: 749px) {
    #lt-bioage-{{ section.id }} { padding: 40px 0; }
  }

  #lt-bioage-{{ section.id }} *,
  #lt-bioage-{{ section.id }} *::before,
  #lt-bioage-{{ section.id }} *::after { box-sizing: border-box; }

  #lt-bioage-{{ section.id }} .bq-frame {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* ── Layout: Split (Desktop) / Stacked (Mobile) ── */
  #lt-bioage-{{ section.id }} .bq-stage {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: stretch;
    background: var(--c-warm);
    border-radius: var(--r-lg);
    overflow: hidden;
    min-height: 640px;
  }

  @media (max-width: 959px) {
    #lt-bioage-{{ section.id }} .bq-stage {
      grid-template-columns: 5fr 7fr;
      gap: 32px;
      min-height: 560px;
    }
  }

  @media (max-width: 749px) {
    #lt-bioage-{{ section.id }} .bq-stage {
      grid-template-columns: 1fr;
      gap: 0;
      min-height: 0;
    }
  }

  /* ── Image panel ── */
  #lt-bioage-{{ section.id }} .bq-image {
    position: relative;
    background: var(--c-warm-3);
    overflow: hidden;
    min-height: 100%;
  }

  @media (max-width: 749px) {
    #lt-bioage-{{ section.id }} .bq-image {
      aspect-ratio: 4 / 5;
      min-height: 0;
    }
  }

  #lt-bioage-{{ section.id }} .bq-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity var(--ease-smooth);
  }

  #lt-bioage-{{ section.id }} .bq-image img.is-active { opacity: 1; }

  /* ── Content panel ── */
  #lt-bioage-{{ section.id }} .bq-content {
    padding: 80px 64px;
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  @media (max-width: 959px) {
    #lt-bioage-{{ section.id }} .bq-content { padding: 56px 40px; }
  }

  @media (max-width: 749px) {
    #lt-bioage-{{ section.id }} .bq-content { padding: 32px 24px; }
  }

  /* ── Progress ── */
  #lt-bioage-{{ section.id }} .bq-progress {
    margin-bottom: 48px;
  }

  #lt-bioage-{{ section.id }} .bq-progress-track {
    height: 2px;
    background: var(--c-line-2);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 12px;
  }

  #lt-bioage-{{ section.id }} .bq-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--c-teal);
    transition: width var(--ease-smooth);
  }

  #lt-bioage-{{ section.id }} .bq-progress-counter {
    margin: 0;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c-text-2);
  }

  /* ── Step ── */
  #lt-bioage-{{ section.id }} .bq-step { display: none; flex-direction: column; flex: 1; }
  #lt-bioage-{{ section.id }} .bq-step.is-active { display: flex; }

  #lt-bioage-{{ section.id }} .bq-question {
    font-family: var(--f-h);
    font-size: clamp(28px, 3vw, 36px);
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.012em;
    color: var(--c-text);
    margin: 0 0 32px;
  }

  /* ── Why-tooltip ── */
  #lt-bioage-{{ section.id }} .bq-why {
    margin: 24px 0 0;
    padding: 14px 0 0;
    border-top: 1px solid var(--c-line);
    color: var(--c-text-2);
    opacity: 0.7;
    font-size: 13px;
    line-height: 1.5;
  }

  #lt-bioage-{{ section.id }} .bq-why-label {
    display: block;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin-bottom: 4px;
  }

  /* ── Options ── */
  #lt-bioage-{{ section.id }} .bq-options {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #lt-bioage-{{ section.id }} .bq-option {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 0 24px;
    height: 56px;
    width: 100%;
    background: transparent;
    border: 1px solid var(--c-line);
    border-radius: var(--r-full);
    color: var(--c-text);
    font-family: var(--f-b);
    font-size: 18px;
    text-align: left;
    cursor: pointer;
    transition: border-color var(--ease-default), background-color var(--ease-default);
  }

  #lt-bioage-{{ section.id }} .bq-option:hover {
    border-color: var(--c-line-strong);
  }

  #lt-bioage-{{ section.id }} .bq-option.is-selected {
    border-color: var(--c-text);
    border-width: 1.5px;
    padding: 0 23.5px;
  }

  #lt-bioage-{{ section.id }} .bq-option-marker {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--c-line);
    color: var(--c-text-2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: border-color var(--ease-default), color var(--ease-default);
  }

  #lt-bioage-{{ section.id }} .bq-option.is-selected .bq-option-marker {
    border-color: var(--c-text);
    color: var(--c-text);
  }

  /* ── Footer / Controls ── */
  #lt-bioage-{{ section.id }} .bq-controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-top: auto;
    padding-top: 32px;
  }

  #lt-bioage-{{ section.id }} .bq-back {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    border: 1px solid var(--c-line);
    background: transparent;
    color: var(--c-text);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 18px;
    transition: border-color var(--ease-default);
  }

  #lt-bioage-{{ section.id }} .bq-back:hover { border-color: var(--c-line-strong); }
  #lt-bioage-{{ section.id }} .bq-back[hidden] { display: none; }

  #lt-bioage-{{ section.id }} .bq-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 52px;
    padding: 0 32px;
    background: var(--c-dark);
    color: var(--c-text-on-dark);
    border: 0;
    border-radius: var(--r-full);
    font-family: var(--f-b);
    font-size: 16px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    text-decoration: none;
    transition: background-color var(--ease-default);
  }

  #lt-bioage-{{ section.id }} .bq-cta:hover { background: var(--c-dark-2); }
  #lt-bioage-{{ section.id }} .bq-cta:disabled { opacity: 0.4; cursor: not-allowed; }

  /* ── Email gate ── */
  #lt-bioage-{{ section.id }} .bq-gate-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }

  #lt-bioage-{{ section.id }} .bq-input {
    height: 56px;
    padding: 0 24px;
    background: transparent;
    border: 1px solid var(--c-line);
    border-radius: var(--r-full);
    font-family: var(--f-b);
    font-size: 16px;
    color: var(--c-text);
    width: 100%;
  }

  #lt-bioage-{{ section.id }} .bq-input:focus {
    outline: none;
    border-color: var(--c-text);
  }

  #lt-bioage-{{ section.id }} .bq-gate-fineprint {
    font-size: 12px;
    color: var(--c-text-2);
    opacity: 0.7;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  #lt-bioage-{{ section.id }} .bq-gate-fineprint a { color: inherit; text-decoration: underline; }

  /* ── Result ── */
  #lt-bioage-{{ section.id }} .bq-result.is-active { display: flex; flex-direction: column; }

  #lt-bioage-{{ section.id }} .bq-zone { padding: 0; margin-bottom: 56px; }
  #lt-bioage-{{ section.id }} .bq-zone:last-child { margin-bottom: 0; }

  /* Z1 — Anchor */
  #lt-bioage-{{ section.id }} .bq-anchor { text-align: center; padding: 32px 0; }

  #lt-bioage-{{ section.id }} .bq-anchor-label {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin: 0 0 16px;
  }

  #lt-bioage-{{ section.id }} .bq-anchor-number {
    font-family: var(--f-h);
    font-size: clamp(48px, 8vw, 72px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.02em;
    margin: 0;
  }

  #lt-bioage-{{ section.id }} .bq-anchor-arrow {
    color: var(--c-teal);
    font-size: 0.6em;
    margin-right: 8px;
    vertical-align: middle;
  }

  #lt-bioage-{{ section.id }} .bq-anchor-context {
    font-size: 14px;
    color: var(--c-text-2);
    margin: 16px 0 0;
  }

  /* Z2 — Mirror */
  #lt-bioage-{{ section.id }} .bq-mirror {
    font-family: var(--f-h);
    font-size: 28px;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.012em;
    margin: 0;
    text-align: center;
    max-width: 560px;
    margin-inline: auto;
  }

  /* Z3 — Hebel */
  #lt-bioage-{{ section.id }} .bq-hebels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  @media (max-width: 749px) {
    #lt-bioage-{{ section.id }} .bq-hebels { grid-template-columns: 1fr; }
  }

  #lt-bioage-{{ section.id }} .bq-hebel {
    background: var(--c-warm-2);
    border: 1px solid var(--c-line);
    border-radius: var(--r-md);
    padding: 32px 24px;
  }

  #lt-bioage-{{ section.id }} .bq-hebel-kicker {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin: 0 0 12px;
  }

  #lt-bioage-{{ section.id }} .bq-hebel-title {
    font-family: var(--f-h);
    font-size: 24px;
    font-weight: 500;
    line-height: 1.15;
    letter-spacing: -0.01em;
    margin: 0 0 12px;
  }

  #lt-bioage-{{ section.id }} .bq-hebel-body {
    font-size: 16px;
    line-height: 1.4;
    color: var(--c-text-2);
    margin: 0;
  }

  /* Z4 — Bridge */
  #lt-bioage-{{ section.id }} .bq-bridge {
    font-family: var(--f-h);
    font-size: 24px;
    font-weight: 400;
    line-height: 1.25;
    letter-spacing: -0.01em;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }

  /* Z5 — Close */
  #lt-bioage-{{ section.id }} .bq-close {
    border-top: 1px solid var(--c-line);
    border-bottom: 1px solid var(--c-line);
    padding: 40px 0;
    margin-bottom: 48px;
  }

  #lt-bioage-{{ section.id }} .bq-close-kicker {
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin: 0 0 24px;
  }

  #lt-bioage-{{ section.id }} .bq-categories {
    display: flex;
    flex-direction: column;
    gap: 24px;
    margin: 0 0 24px;
    padding: 0;
    list-style: none;
  }

  #lt-bioage-{{ section.id }} .bq-cat-title {
    font-family: var(--f-h);
    font-size: 20px;
    font-weight: 500;
    margin: 0 0 4px;
  }

  #lt-bioage-{{ section.id }} .bq-cat-desc {
    font-size: 14px;
    color: var(--c-text-2);
    margin: 0;
  }

  #lt-bioage-{{ section.id }} .bq-close-meta {
    font-size: 13px;
    color: var(--c-text-2);
    opacity: 0.7;
    margin: 0;
  }

  #lt-bioage-{{ section.id }} .bq-cta-block {
    text-align: center;
  }

  #lt-bioage-{{ section.id }} .bq-price {
    font-size: 14px;
    color: var(--c-text-2);
    margin: 0 0 16px;
  }

  #lt-bioage-{{ section.id }} .bq-cta-secondary {
    display: block;
    margin-top: 16px;
    font-size: 14px;
    color: var(--c-text-2);
    text-decoration: underline;
  }

  #lt-bioage-{{ section.id }} .bq-trust {
    margin: 24px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px 16px;
    font-size: 12px;
    color: var(--c-text-3);
  }

  #lt-bioage-{{ section.id }} .bq-trust li::after {
    content: "·";
    margin-left: 16px;
    color: var(--c-line);
  }

  #lt-bioage-{{ section.id }} .bq-trust li:last-child::after { content: ""; margin: 0; }

  #lt-bioage-{{ section.id }} .bq-reset {
    margin: 32px auto 0;
    display: block;
    background: transparent;
    border: 0;
    color: var(--c-text-3);
    font-size: 12px;
    cursor: pointer;
    text-decoration: underline;
  }

  /* Result needs full-width content panel — Bild verschwindet */
  #lt-bioage-{{ section.id }}.is-result .bq-image { display: none; }
  #lt-bioage-{{ section.id }}.is-result .bq-stage { grid-template-columns: 1fr; min-height: 0; }
  #lt-bioage-{{ section.id }}.is-result .bq-content { padding-block: 64px; }
{% endstyle %}

<section id="lt-bioage-{{ section.id }}" class="lt-bioage-quiz" data-section-id="{{ section.id }}" data-section-type="lt-bioage-quiz">
  <div class="bq-frame">
    <div class="bq-stage">
      {%- comment -%} Image panel — wechselt pro Step {%- endcomment -%}
      <div class="bq-image" data-image-panel>
        {%- assign step_keys = 'q1,q2,q3,q4,q5,q6,q7,q8,gate' | split: ',' -%}
        {%- for key in step_keys -%}
          {%- assign img_setting = 'image_' | append: key -%}
          {%- assign img = section.settings[img_setting] -%}
          {%- if img != blank -%}
            {{ img | image_url: width: 1200 | image_tag:
                loading: 'lazy',
                alt: '',
                widths: '480,720,1080,1200',
                sizes: '(min-width: 750px) 50vw, 100vw',
                class: 'bq-step-image',
                data-step-key: key }}
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="bq-content">
        <div class="bq-progress" data-progress hidden>
          <div class="bq-progress-track"><div class="bq-progress-fill" data-progress-fill></div></div>
          <p class="bq-progress-counter" data-progress-counter></p>
        </div>

        {%- comment -%} ───── 8 Fragen ───── {%- endcomment -%}

        <div class="bq-step" data-step="q1" data-key="q1">
          <h2 class="bq-question">Wie alt bist du?</h2>
          <ul class="bq-options" role="radiogroup" aria-label="Alter">
            <li><button type="button" class="bq-option" data-answer="0" data-value="under-30"><span class="bq-option-marker">A</span><span>Unter 30</span></button></li>
            <li><button type="button" class="bq-option" data-answer="1" data-value="30-39"><span class="bq-option-marker">B</span><span>30 — 39</span></button></li>
            <li><button type="button" class="bq-option" data-answer="2" data-value="40-49"><span class="bq-option-marker">C</span><span>40 — 49</span></button></li>
            <li><button type="button" class="bq-option" data-answer="3" data-value="50-59"><span class="bq-option-marker">D</span><span>50 — 59</span></button></li>
            <li><button type="button" class="bq-option" data-answer="4" data-value="60-plus"><span class="bq-option-marker">E</span><span>60 +</span></button></li>
          </ul>
          <div class="bq-why">
            <span class="bq-why-label">Warum wir das fragen</span>
            Dein biologisches Alter wird im Verhältnis zu deinem tatsächlichen Alter berechnet — nicht gegen einen Durchschnitt.
          </div>
        </div>

        <div class="bq-step" data-step="q2" data-key="q2" data-cat="ernaehrung">
          <h2 class="bq-question">Wie viel auf deinem Teller ist pflanzlich?</h2>
          <ul class="bq-options" role="radiogroup">
            <li><button type="button" class="bq-option" data-answer="4"><span class="bq-option-marker">A</span><span>Fast alles</span></button></li>
            <li><button type="button" class="bq-option" data-answer="3"><span class="bq-option-marker">B</span><span>Mehr als die Hälfte</span></button></li>
            <li><button type="button" class="bq-option" data-answer="2"><span class="bq-option-marker">C</span><span>Etwa die Hälfte</span></button></li>
            <li><button type="button" class="bq-option" data-answer="1"><span class="bq-option-marker">D</span><span>Eher wenig</span></button></li>
            <li><button type="button" class="bq-option" data-answer="0"><span class="bq-option-marker">E</span><span>Kaum etwas</span></button></li>
          </ul>
          <div class="bq-why">
            <span class="bq-why-label">Warum wir das fragen</span>
            Eine überwiegend pflanzliche Ernährung ist in Längsschnittstudien mit 2 — 3 Jahren längerer Lebenserwartung verknüpft.
          </div>
        </div>

        <div class="bq-step" data-step="q3" data-key="q3" data-cat="ernaehrung">
          <h2 class="bq-question">Wie oft isst du Fertiggerichte oder Fast Food?</h2>
          <ul class="bq-options" role="radiogroup">
            <li><button type="button" class="bq-option" data-answer="4"><span class="bq-option-marker">A</span><span>Selten</span></button></li>
            <li><button type="button" class="bq-option" data-answer="3"><span class="bq-option-marker">B</span><span>1 — 2× pro Woche</span></button></li>
            <li><button type="button" class="bq-option" data-answer="1"><span class="bq-option-marker">C</span><span>3 — 4× pro Woche</span></button></li>
            <li><button type="button" class="bq-option" data-answer="0"><span class="bq-option-marker">D</span><span>Fast täglich</span></button></li>
          </ul>
          <div class="bq-why">
            <span class="bq-why-label">Warum wir das fragen</span>
            Jede zusätzliche tägliche Portion ultra-verarbeiteter Kost erhöht laut BMJ-Daten das Risiko für frühzeitige Alterung.
          </div>
        </div>

        <div class="bq-step" data-step="q4" data-key="q4" data-cat="bewegung">
          <h2 class="bq-question">Wie viele Tage pro Woche bewegst du dich gezielt?</h2>
          <ul class="bq-options" role="radiogroup">
            <li><button type="button" class="bq-option" data-answer="4"><span class="bq-option-marker">A</span><span>5 + Tage</span></button></li>
            <li><button type="button" class="bq-option" data-answer="3"><span class="bq-option-marker">B</span><span>3 — 4 Tage</span></button></li>
            <li><button type="button" class="bq-option" data-answer="2"><span class="bq-option-marker">C</span><span>1 — 2 Tage</span></button></li>
            <li><button type="button" class="bq-option" data-answer="1"><span class="bq-option-marker">D</span><span>Selten</span></button></li>
            <li><button type="button" class="bq-option" data-answer="0"><span class="bq-option-marker">E</span><span>Nie</span></button></li>
          </ul>
          <div class="bq-why">
            <span class="bq-why-label">Warum wir das fragen</span>
            150 Minuten moderate Bewegung pro Woche senken die Gesamtsterblichkeit um rund 30 %.
          </div>
        </div>

        <div class="bq-step" data-step="q5" data-key="q5" data-cat="genuss">
          <h2 class="bq-question">Wie hältst du es mit Alkohol und Nikotin?</h2>
          <ul class="bq-options" role="radiogroup">
            <li><button type="button" class="bq-option" data-answer="4"><span class="bq-option-marker">A</span><span>Beides nicht</span></button></li>
            <li><button type="button" class="bq-option" data-answer="3"><span class="bq-option-marker">B</span><span>Selten Alkohol</span></button></li>
            <li><button type="button" class="bq-option" data-answer="2"><span class="bq-option-marker">C</span><span>Regelmäßig Alkohol</span></button></li>
            <li><button type="button" class="bq-option" data-answer="1"><span class="bq-option-marker">D</span><span>Gelegentlich Nikotin</span></button></li>
            <li><button type="button" class="bq-option" data-answer="0"><span class="bq-option-marker">E</span><span>Beides regelmäßig</span></button></li>
          </ul>
          <div class="bq-why">
            <span class="bq-why-label">Warum wir das fragen</span>
