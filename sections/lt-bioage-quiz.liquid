{%- comment -%}
  LIFETIME · Biologisches-Alter Quiz
  - 8 Fragen + Email-Gate + 5-Zonen-Result
  - Desktop: 2-Spalten Split (Bild · Content), Mobile: stacked
  - State in localStorage
  - Tokens: Lifetime Design System v2
{%- endcomment -%}

{% style %}
  #lt-bioage-{{ section.id }} {
    /* Scoped tokens (Lifetime DS v2) */
    --f-h: "Helvetica Neue", Helvetica, Arial, sans-serif;
    --f-b: "Lato", -apple-system, BlinkMacSystemFont, sans-serif;
    --c-warm: #F7F7F4;
    --c-warm-2: #F2F1ED;
    --c-warm-3: #EDEBE6;
    --c-text: #26251E;
    --c-text-2: #525252;
    --c-text-3: #8A8778;
    --c-text-on-dark: #F7F7F4;
    --c-dark: #364F56;
    --c-dark-2: #2D4249;
    --c-teal: #65C0B6;
    --c-line: rgba(38,37,30,.12);
    --c-line-2: rgba(38,37,30,.06);
    --c-line-strong: rgba(54,79,86,.14);
    --r-md: 12px;
    --r-lg: 16px;
    --r-full: 999px;
    --ease-default: .2s ease;
    --ease-smooth: .4s ease;

    background: var(--c-warm);
    color: var(--c-text);
    font-family: var(--f-b);
    padding: 16px 0;
  }

  #lt-bioage-{{ section.id }} *,
  #lt-bioage-{{ section.id }} *::before,
  #lt-bioage-{{ section.id }} *::after { box-sizing: border-box; }

  #lt-bioage-{{ section.id }} .bq-frame {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 16px;
  }

  /* ── Layout: Split (Desktop) / Stacked (Mobile) ── */
  /* Stage targets the viewport so the active step never scrolls. */
  #lt-bioage-{{ section.id }} .bq-stage {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
    align-items: stretch;
    background: var(--c-warm);
    border-radius: var(--r-lg);
    overflow: hidden;
    height: min(560px, calc(100dvh - 32px));
  }

  @media (max-width: 959px) {
    #lt-bioage-{{ section.id }} .bq-stage {
      grid-template-columns: 5fr 7fr;
      gap: 16px;
    }
  }

  @media (max-width: 749px) {
    #lt-bioage-{{ section.id }} .bq-stage {
      grid-template-columns: 1fr;
      grid-template-rows: 22dvh 1fr;
      gap: 0;
      height: calc(100dvh - 32px);
      max-height: none;
    }
  }

  /* ── Image panel ── */
  #lt-bioage-{{ section.id }} .bq-image {
    position: relative;
    background: var(--c-warm-3);
    overflow: hidden;
    min-height: 100%;
  }

  #lt-bioage-{{ section.id }} .bq-image img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity var(--ease-smooth);
  }

  #lt-bioage-{{ section.id }} .bq-image img.is-active { opacity: 1; }

  /* ── Content panel ── */
  #lt-bioage-{{ section.id }} .bq-content {
    padding: 24px 32px;
    display: flex;
    flex-direction: column;
    min-height: 0;
    height: 100%;
    overflow: hidden;
  }

  @media (max-width: 959px) {
    #lt-bioage-{{ section.id }} .bq-content { padding: 20px 24px; }
  }

  @media (max-width: 749px) {
    #lt-bioage-{{ section.id }} .bq-content { padding: 16px 16px 12px; }
  }

  /* ── Progress ── */
  #lt-bioage-{{ section.id }} .bq-progress {
    margin-bottom: 16px;
    flex: 0 0 auto;
  }

  #lt-bioage-{{ section.id }} .bq-progress-row {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 8px;
    min-height: 24px;
  }

  #lt-bioage-{{ section.id }} .bq-progress-track {
    flex: 1 1 auto;
    height: 2px;
    background: var(--c-line-2);
    border-radius: 2px;
    overflow: hidden;
  }

  #lt-bioage-{{ section.id }} .bq-progress-fill {
    height: 100%;
    width: 0%;
    background: var(--c-teal);
    transition: width var(--ease-smooth);
  }

  #lt-bioage-{{ section.id }} .bq-progress-counter {
    margin: 0;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-text-3);
  }

  /* ── Step ── */
  #lt-bioage-{{ section.id }} .bq-step { display: none; flex-direction: column; flex: 1 1 auto; min-height: 0; }
  #lt-bioage-{{ section.id }} .bq-step.is-active { display: flex; }

  #lt-bioage-{{ section.id }} .bq-question {
    font-family: var(--f-h);
    font-size: clamp(18px, 1.8vw, 22px);
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.012em;
    color: var(--c-text);
    margin: 0 0 14px;
  }

  /* ── Why-tooltip ── */
  #lt-bioage-{{ section.id }} .bq-why {
    margin: 12px 0 0;
    padding: 8px 0 0;
    border-top: 1px solid var(--c-line);
    color: var(--c-text-2);
    opacity: 0.65;
    font-size: 11px;
    line-height: 1.4;
  }

  #lt-bioage-{{ section.id }} .bq-why-label {
    display: block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin-bottom: 2px;
  }

  /* ── Options ── */
  #lt-bioage-{{ section.id }} .bq-options {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #lt-bioage-{{ section.id }} .bq-option {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 14px;
    height: 36px;
    width: 100%;
    background: transparent;
    border: 1px solid var(--c-line);
    border-radius: var(--r-full);
    color: var(--c-text);
    font-family: var(--f-b);
    font-size: 13px;
    text-align: left;
    cursor: pointer;
    transition: border-color var(--ease-default), background-color var(--ease-default);
  }

  #lt-bioage-{{ section.id }} .bq-option:hover {
    border-color: var(--c-line-strong);
  }

  #lt-bioage-{{ section.id }} .bq-option.is-selected {
    border-color: var(--c-text);
    border-width: 1.5px;
    padding: 0 13.5px;
  }

  #lt-bioage-{{ section.id }} .bq-option-marker {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    border: 1px solid var(--c-line);
    color: var(--c-text-2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 9px;
    font-weight: 500;
    letter-spacing: 0.04em;
    transition: border-color var(--ease-default), color var(--ease-default);
  }

  #lt-bioage-{{ section.id }} .bq-option.is-selected .bq-option-marker {
    border-color: var(--c-text);
    color: var(--c-text);
  }

  /* ── Inline back button (in progress row) ── */
  #lt-bioage-{{ section.id }} .bq-back {
    flex: 0 0 auto;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    border: 1px solid var(--c-line);
    background: transparent;
    color: var(--c-text-2);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 11px;
    transition: border-color var(--ease-default), color var(--ease-default);
  }

  #lt-bioage-{{ section.id }} .bq-back:hover { border-color: var(--c-line-strong); color: var(--c-text); }
  #lt-bioage-{{ section.id }} .bq-back[hidden] { display: none; }

  #lt-bioage-{{ section.id }} .bq-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    height: 44px;
    padding: 0 24px;
    background: var(--c-dark);
    color: var(--c-text-on-dark);
    border: 0;
    border-radius: var(--r-full);
    font-family: var(--f-b);
    font-size: 15px;
    font-weight: 600;
    letter-spacing: 0.01em;
    cursor: pointer;
    text-decoration: none;
    transition: background-color var(--ease-default);
  }

  #lt-bioage-{{ section.id }} .bq-cta:hover { background: var(--c-dark-2); }
  #lt-bioage-{{ section.id }} .bq-cta:disabled { opacity: 0.4; cursor: not-allowed; }

  /* ── Email gate ── */
  #lt-bioage-{{ section.id }} .bq-gate-form {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 24px;
  }

  #lt-bioage-{{ section.id }} .bq-input {
    height: 44px;
    padding: 0 18px;
    background: transparent;
    border: 1px solid var(--c-line);
    border-radius: var(--r-full);
    font-family: var(--f-b);
    font-size: 15px;
    color: var(--c-text);
    width: 100%;
  }

  #lt-bioage-{{ section.id }} .bq-input:focus {
    outline: none;
    border-color: var(--c-text);
  }

  #lt-bioage-{{ section.id }} .bq-gate-fineprint {
    font-size: 12px;
    color: var(--c-text-2);
    opacity: 0.7;
    line-height: 1.5;
    margin: 8px 0 0;
  }

  #lt-bioage-{{ section.id }} .bq-gate-fineprint a { color: inherit; text-decoration: underline; }

  /* ── Result ── */
  #lt-bioage-{{ section.id }} .bq-result.is-active {
    display: flex;
    flex-direction: column;
    max-width: 720px;
    width: 100%;
    margin: 0 auto;
  }

  #lt-bioage-{{ section.id }} .bq-zone { padding: 0; margin-bottom: 32px; }
  #lt-bioage-{{ section.id }} .bq-zone:last-child { margin-bottom: 0; }

  #lt-bioage-{{ section.id }} .bq-zone-heading {
    font-family: var(--f-h);
    font-size: 11px;
    font-weight: 500;
    line-height: 1;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin: 0 0 16px;
  }

  /* Z1 — Anchor (hero) */
  #lt-bioage-{{ section.id }} .bq-anchor {
    text-align: center;
    padding: 8px 0 8px;
    margin-bottom: 56px;
  }

  #lt-bioage-{{ section.id }} .bq-anchor-label {
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin: 0 0 18px;
  }

  #lt-bioage-{{ section.id }} .bq-anchor-numbers {
    display: inline-flex;
    align-items: baseline;
    gap: clamp(20px, 4vw, 40px);
    margin: 0;
  }

  #lt-bioage-{{ section.id }} .bq-anchor-pass {
    text-align: right;
    color: var(--c-text-3);
  }

  #lt-bioage-{{ section.id }} .bq-anchor-bio {
    text-align: left;
  }

  #lt-bioage-{{ section.id }} .bq-anchor-side-label {
    font-family: var(--f-b);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-text-3);
    display: block;
    margin-bottom: 6px;
  }

  #lt-bioage-{{ section.id }} .bq-anchor-pass-num {
    font-family: var(--f-h);
    font-size: clamp(28px, 4.5vw, 40px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.015em;
    color: var(--c-text-2);
  }

  #lt-bioage-{{ section.id }} .bq-anchor-number {
    font-family: var(--f-h);
    font-size: clamp(72px, 12vw, 120px);
    font-weight: 400;
    line-height: 1;
    letter-spacing: -0.025em;
    margin: 0;
    color: var(--c-text);
  }

  #lt-bioage-{{ section.id }} .bq-anchor-arrow {
    font-size: 0.4em;
    margin-right: 8px;
    vertical-align: 0.18em;
    color: var(--c-text-3);
    transition: color var(--ease-default);
  }

  #lt-bioage-{{ section.id }} .bq-anchor[data-direction="lower"] .bq-anchor-arrow { color: var(--c-teal); }
  #lt-bioage-{{ section.id }} .bq-anchor[data-direction="higher"] .bq-anchor-arrow { color: var(--c-sand, #C7A39B); }

  #lt-bioage-{{ section.id }} .bq-anchor-context {
    font-size: 13px;
    color: var(--c-text-2);
    margin: 16px 0 0;
  }

  #lt-bioage-{{ section.id }} .bq-mirror {
    font-family: var(--f-h);
    font-size: clamp(16px, 1.6vw, 18px);
    font-weight: 500;
    line-height: 1.35;
    letter-spacing: -0.01em;
    color: var(--c-text);
    margin: 14px 0 0;
  }

  /* Z2 — Highlighted test categories as typo list */
  #lt-bioage-{{ section.id }} .bq-categories {
    display: flex;
    flex-direction: column;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #lt-bioage-{{ section.id }} .bq-categories li {
    padding: 14px 0;
    border-top: 1px solid var(--c-line);
  }

  #lt-bioage-{{ section.id }} .bq-categories li:last-child {
    border-bottom: 1px solid var(--c-line);
  }

  #lt-bioage-{{ section.id }} .bq-cat-title {
    font-family: var(--f-h);
    font-size: 17px;
    font-weight: 500;
    line-height: 1.2;
    margin: 0 0 2px;
  }

  #lt-bioage-{{ section.id }} .bq-cat-desc {
    font-size: 13px;
    line-height: 1.4;
    color: var(--c-text-2);
    margin: 0;
  }

  /* Z3 — All categories collapsible */
  #lt-bioage-{{ section.id }} .bq-all {
    margin-top: -8px;
    margin-bottom: 24px;
  }

  #lt-bioage-{{ section.id }} .bq-all-summary {
    list-style: none;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 14px 16px;
    background: var(--c-warm-3);
    border-radius: var(--r-md);
    font-size: 13px;
    color: var(--c-text);
    transition: background-color var(--ease-default);
  }

  #lt-bioage-{{ section.id }} .bq-all-summary:hover { background: var(--c-warm-2); }

  #lt-bioage-{{ section.id }} .bq-all-summary::-webkit-details-marker { display: none; }

  #lt-bioage-{{ section.id }} .bq-all-summary::after {
    content: "+";
    font-size: 20px;
    color: var(--c-text);
    line-height: 1;
    transition: transform var(--ease-default);
  }

  #lt-bioage-{{ section.id }} details[open] .bq-all-summary::after { content: "−"; }

  #lt-bioage-{{ section.id }} .bq-all-summary-hint {
    color: var(--c-text-3);
    font-size: 11px;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin-left: auto;
    padding-right: 8px;
  }

  #lt-bioage-{{ section.id }} .bq-all-body { padding: 14px 0 4px; }

  #lt-bioage-{{ section.id }} .bq-all-group { margin-bottom: 16px; }
  #lt-bioage-{{ section.id }} .bq-all-group:last-child { margin-bottom: 0; }

  #lt-bioage-{{ section.id }} .bq-all-group-label {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin: 0 0 8px;
  }

  #lt-bioage-{{ section.id }} .bq-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #lt-bioage-{{ section.id }} .bq-pill {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border: 1px solid var(--c-line);
    border-radius: var(--r-full);
    font-size: 11px;
    color: var(--c-text-2);
    background: transparent;
  }

  #lt-bioage-{{ section.id }} .bq-pill.is-highlight {
    border-color: var(--c-teal);
    color: var(--c-text);
    font-weight: 500;
  }

  /* Z4 — Hebel — action cards with teal accent */
  #lt-bioage-{{ section.id }} .bq-hebels {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 12px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media (max-width: 749px) {
    #lt-bioage-{{ section.id }} .bq-hebels { grid-template-columns: 1fr; }
  }

  #lt-bioage-{{ section.id }} .bq-hebel {
    position: relative;
    background: var(--c-warm-2);
    border: 1px solid var(--c-line);
    border-left: 2px solid var(--c-teal);
    border-radius: var(--r-md);
    padding: 16px 18px 16px 20px;
  }

  #lt-bioage-{{ section.id }} .bq-hebel-kicker {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin: 0 0 6px;
  }

  #lt-bioage-{{ section.id }} .bq-hebel-title {
    font-family: var(--f-h);
    font-size: 17px;
    font-weight: 500;
    line-height: 1.2;
    letter-spacing: -0.01em;
    margin: 0 0 6px;
  }

  #lt-bioage-{{ section.id }} .bq-hebel-body {
    font-size: 13px;
    line-height: 1.4;
    color: var(--c-text-2);
    margin: 0;
  }

  /* Z5 — Limmroth Microline */
  #lt-bioage-{{ section.id }} .bq-authority {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 16px 0;
    border-top: 1px solid var(--c-line);
    border-bottom: 1px solid var(--c-line);
  }

  #lt-bioage-{{ section.id }} .bq-authority-img {
    flex: 0 0 auto;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    object-fit: cover;
    background: var(--c-warm-3);
  }

  #lt-bioage-{{ section.id }} .bq-authority-text {
    line-height: 1.3;
  }

  #lt-bioage-{{ section.id }} .bq-authority-label {
    display: block;
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--c-text-3);
    margin-bottom: 2px;
  }

  #lt-bioage-{{ section.id }} .bq-authority-name {
    font-size: 13px;
    color: var(--c-text);
  }

  #lt-bioage-{{ section.id }} .bq-cta-block {
    text-align: center;
    padding-top: 8px;
  }

  #lt-bioage-{{ section.id }} .bq-price {
    font-size: 13px;
    color: var(--c-text-2);
    margin: 0 0 16px;
  }

  #lt-bioage-{{ section.id }} .bq-cta-block .bq-cta {
    height: 56px;
    padding: 0 32px;
    font-size: 16px;
    width: 100%;
    max-width: 360px;
  }

  #lt-bioage-{{ section.id }} .bq-cta-secondary {
    display: block;
    margin-top: 14px;
    font-size: 13px;
    color: var(--c-text-2);
    text-decoration: underline;
  }

  #lt-bioage-{{ section.id }} .bq-trust {
    margin: 20px 0 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 4px 16px;
    font-size: 12px;
    color: var(--c-text-3);
  }

  #lt-bioage-{{ section.id }} .bq-trust li::after {
    content: "·";
    margin-left: 16px;
    color: var(--c-line);
  }

  #lt-bioage-{{ section.id }} .bq-trust li:last-child::after { content: ""; margin: 0; }

  #lt-bioage-{{ section.id }} .bq-reset {
    margin: 40px auto 0;
    display: block;
    background: transparent;
    border: 0;
    color: var(--c-text-3);
    font-size: 11px;
    letter-spacing: 0.04em;
    cursor: pointer;
    text-decoration: underline;
    opacity: 0.6;
  }

  #lt-bioage-{{ section.id }} .bq-reset:hover { opacity: 1; }

  /* Result needs full-width content panel — Bild verschwindet, Höhe natürlich */
  #lt-bioage-{{ section.id }}.is-result .bq-image { display: none; }
  #lt-bioage-{{ section.id }}.is-result .bq-stage {
    grid-template-columns: 1fr;
    grid-template-rows: 1fr;
    height: auto;
    max-height: none;
  }
  #lt-bioage-{{ section.id }}.is-result .bq-content {
    height: auto;
    overflow: visible;
    padding: 40px 32px 48px;
  }
  @media (max-width: 749px) {
    #lt-bioage-{{ section.id }}.is-result .bq-content { padding: 24px 20px 36px; }
  }
{% endstyle %}

<section id="lt-bioage-{{ section.id }}" class="lt-bioage-quiz" data-section-id="{{ section.id }}" data-section-type="lt-bioage-quiz">
  <div class="bq-frame">
    <div class="bq-stage">
      {%- comment -%} Image panel — wechselt pro Step {%- endcomment -%}
      <div class="bq-image" data-image-panel>
        {%- assign step_keys = 'q1,q2,q3,q4,q5,q6,q7,q8,gate' | split: ',' -%}
        {%- for key in step_keys -%}
          {%- assign img_setting = 'image_' | append: key -%}
          {%- assign img = section.settings[img_setting] -%}
          {%- if img != blank -%}
            {{ img | image_url: width: 1200 | image_tag:
                loading: 'lazy',
                alt: '',
                widths: '480,720,1080,1200',
                sizes: '(min-width: 750px) 50vw, 100vw',
                class: 'bq-step-image',
                data-step-key: key }}
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="bq-content">
        <div class="bq-progress" data-progress hidden>
