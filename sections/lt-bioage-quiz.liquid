<script>
(function() {
  var root = document.getElementById('lt-bioage-{{ section.id }}');
  if (!root) return;

  var config = {};
  try { config = JSON.parse(root.querySelector('[data-bq-config]').textContent); } catch (e) {}

  var STORAGE_KEY = 'lt_bioage_{{ section.id }}';
  var STEP_ORDER = ['q1','q2','q3','q4','q5','q6','q7','q8','gate','result'];
  var QUESTION_STEPS = STEP_ORDER.slice(0, 8);

  var state = {
    current: 'q1',
    answers: {},   // { q1: 2, q2: 4, ... }
    email: ''
  };

  // Restore
  try {
    var saved = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}');
    if (saved && saved.answers) state = Object.assign(state, saved);
  } catch (e) {}

  var imagePanel = root.querySelector('[data-image-panel]');
  var progressEl = root.querySelector('[data-progress]');
  var progressFill = root.querySelector('[data-progress-fill]');
  var progressCounter = root.querySelector('[data-progress-counter]');
  var controlsEl = root.querySelector('[data-controls]');
  var backBtn = root.querySelector('[data-back]');

  function persist() {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(state)); } catch (e) {}
  }

  function show(stepKey) {
    state.current = stepKey;
    persist();

    root.querySelectorAll('.bq-step').forEach(function(el) {
      el.classList.toggle('is-active', el.dataset.step === stepKey);
    });

    // Image
    var imgKey = stepKey === 'result' ? 'gate' : stepKey;
    root.querySelectorAll('.bq-step-image').forEach(function(img) {
      img.classList.toggle('is-active', img.dataset.stepKey === imgKey);
    });

    // Result mode → hide image panel via class
    root.classList.toggle('is-result', stepKey === 'result');

    // Progress visibility + value
    var qIdx = QUESTION_STEPS.indexOf(stepKey);
    if (qIdx >= 0) {
      progressEl.hidden = false;
      progressFill.style.width = (((qIdx + 1) / QUESTION_STEPS.length) * 100) + '%';
      progressCounter.textContent = 'Frage ' + (qIdx + 1) + ' von ' + QUESTION_STEPS.length;
    } else {
      progressEl.hidden = true;
    }

    // Controls (back) — visible during questions + gate, not on result
    var canGoBack = stepKey !== 'q1' && stepKey !== 'result';
    if (controlsEl) {
      controlsEl.hidden = stepKey === 'result';
      backBtn.hidden = !canGoBack;
    }

    // Restore selected answer visually
    var stepEl = root.querySelector('.bq-step[data-step="' + stepKey + '"]');
    if (stepEl) {
      var ans = state.answers[stepKey];
      stepEl.querySelectorAll('.bq-option').forEach(function(btn) {
        btn.classList.toggle('is-selected', String(ans) === btn.dataset.answer);
      });
    }

    // Render result if needed
    if (stepKey === 'result') renderResult();

    // Focus question heading for a11y
    var h = stepEl && stepEl.querySelector('.bq-question');
    if (h) {
      h.setAttribute('tabindex', '-1');
      try { h.focus({ preventScroll: false }); } catch (e) { h.focus(); }
    }
  }

  function next() {
    var idx = STEP_ORDER.indexOf(state.current);
    if (idx < 0 || idx >= STEP_ORDER.length - 1) return;
    var nextStep = STEP_ORDER[idx + 1];
    // Skip from q8 → gate → result via explicit handlers; default just advances
    show(nextStep);
  }

  function back() {
    var idx = STEP_ORDER.indexOf(state.current);
    if (idx <= 0) return;
    show(STEP_ORDER[idx - 1]);
  }

  // ── Option clicks (auto-advance) ──
  root.querySelectorAll('.bq-step .bq-option').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var stepEl = btn.closest('.bq-step');
      var stepKey = stepEl.dataset.step;
      var value = parseInt(btn.dataset.answer, 10);
      state.answers[stepKey] = value;
      persist();

      stepEl.querySelectorAll('.bq-option').forEach(function(b) { b.classList.remove('is-selected'); });
      btn.classList.add('is-selected');

      setTimeout(next, 250);
    });
  });

  // ── Back button ──
  backBtn.addEventListener('click', back);

  // ── Gate submit ──
  var gateForm = root.querySelector('[data-gate-form]');
  if (gateForm) {
    gateForm.addEventListener('submit', function(e) {
      e.preventDefault();
      var input = root.querySelector('[data-email-input]');
      var email = (input.value || '').trim();
      if (!email || !/^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(email)) {
        input.focus();
        return;
      }
      state.email = email;
      persist();
      show('result');
    });
  }

  // ── Reset ──
  var resetBtn = root.querySelector('[data-reset]');
  if (resetBtn) {
    resetBtn.addEventListener('click', function() {
      try { localStorage.removeItem(STORAGE_KEY); } catch (e) {}
      state = { current: 'q1', answers: {}, email: '' };
      root.querySelectorAll('.bq-option.is-selected').forEach(function(b) { b.classList.remove('is-selected'); });
      var emailInput = root.querySelector('[data-email-input]');
      if (emailInput) emailInput.value = '';
      show('q1');
    });
  }

  // ── Result computation ──
  function getCategoryScores() {
    var out = {};
    Object.keys(config.categories).forEach(function(cat) {
      var qs = config.categories[cat].questions;
      var sum = 0, count = 0;
      qs.forEach(function(q) {
        if (typeof state.answers[q] === 'number') { sum += state.answers[q]; count++; }
      });
      out[cat] = count ? (sum / count) : 4; // neutral if missing
    });
    return out;
  }

  function getTotalScore() {
    var keys = ['q2','q3','q4','q5','q6','q7','q8'];
    return keys.reduce(function(acc, k) {
      return acc + (typeof state.answers[k] === 'number' ? state.answers[k] : 0);
    }, 0);
  }

  function getDelta(score) {
    // Score 0..28 → Delta -7..+7 (positive = älter als Pass)
    return Math.round((14 - score) / 2);
  }

  function getChronoEstimate() {
    var bucket = state.answers.q1;
    if (typeof bucket !== 'number') return 45;
    return config.ageMidpoint[String(bucket)] || 45;
  }

  function pickWeakest(scores) {
    return Object.keys(scores)
      .map(function(k) { return { cat: k, score: scores[k] }; })
      .sort(function(a, b) { return a.score - b.score; })
      .slice(0, 3);
  }

  function getMirrorVariant(score, vitalityAnswer) {
    // Range
    var range = score <= 9 ? 'low' : score <= 16 ? 'mid' : score <= 23 ? 'high' : 'top';
    // Hot: low/mid AND vitality ≤ 2 (low)
    var hot = (range === 'low' || range === 'mid') && typeof vitalityAnswer === 'number' && vitalityAnswer <= 2;
    var variant = hot ? 'hot' : 'cool';
    return { range: range, variant: variant };
  }

  function renderResult() {
    var score = getTotalScore();
    var delta = getDelta(score);
    var chrono = getChronoEstimate();
    var bioAge = chrono + delta;

    // Z1 — Anchor
    var arrow = root.querySelector('[data-anchor-arrow]');
    var num = root.querySelector('[data-anchor-number]');
    var ctx = root.querySelector('[data-anchor-context]');
    if (delta < 0)      arrow.textContent = '▼';
    else if (delta > 0) arrow.textContent = '▲';
    else                arrow.textContent = '–';
    num.textContent = String(bioAge);
    if (delta === 0) {
      ctx.textContent = 'Auf Höhe deines Pass-Alters.';
    } else if (delta < 0) {
      ctx.textContent = Math.abs(delta) + ' Jahre unter deinem Pass-Alter.';
    } else {
      ctx.textContent = delta + ' Jahre über deinem Pass-Alter.';
    }

    // Z2 — Mirror
    var mv = getMirrorVariant(score, state.answers.q8);
    var mirror = (config.mirror[mv.range] || {})[mv.variant];
    if (!mirror) mirror = (config.mirror[mv.range] || {}).cool || '';
    root.querySelector('[data-mirror]').textContent = mirror;

    // Z3 — Hebel (3 schwächste Kategorien)
    var scores = getCategoryScores();
    var weakest = pickWeakest(scores);
    var hebelsEl = root.querySelector('[data-hebels]');
    hebelsEl.innerHTML = '';
    weakest.forEach(function(w) {
      var h = config.hebel[w.cat];
      var cat = config.categories[w.cat];
      if (!h || !cat) return;
      var li = document.createElement('li');
      li.className = 'bq-hebel';
      li.innerHTML =
        '<p class="bq-hebel-kicker">' + cat.label + '</p>' +
        '<h3 class="bq-hebel-title">' + h.title + '</h3>' +
        '<p class="bq-hebel-body">' + h.body + '</p>';
      hebelsEl.appendChild(li);
    });

    // Z5 — Categories (mapped from weakest, fallback when score >= 24)
    var catsEl = root.querySelector('[data-categories]');
    catsEl.innerHTML = '';
    var sourceCats = [];
    if (score >= 24) {
      sourceCats = config.fallbackCategories;
    } else {
      sourceCats = weakest.map(function(w) { return config.categoryMap[w.cat]; }).filter(Boolean);
    }
    sourceCats.forEach(function(c) {
      var li = document.createElement('li');
      li.innerHTML =
        '<p class="bq-cat-title">' + c.title + '</p>' +
        '<p class="bq-cat-desc">' + c.desc + '</p>';
      catsEl.appendChild(li);
    });

    // CTA variant — Cool flips primary/secondary
    if (mv.variant === 'cool' && config.ctaCool) {
      var primary = root.querySelector('[data-cta-primary]');
      var primaryLabel = root.querySelector('[data-cta-primary-label]');
      var secondary = root.querySelector('[data-cta-secondary]');
      var secondaryLabel = root.querySelector('[data-cta-secondary-label]');
      if (primary && primaryLabel)   { primary.href = config.ctaCool.primaryUrl;   primaryLabel.textContent = config.ctaCool.primaryLabel; }
      if (secondary && secondaryLabel) { secondary.href = config.ctaCool.secondaryUrl; secondaryLabel.textContent = config.ctaCool.secondaryLabel; }
    }
  }

  // Init — start at q1 (or restored step, but only if quiz not completed)
  var initStep = state.current && STEP_ORDER.indexOf(state.current) >= 0 ? state.current : 'q1';
  // Don't auto-restore to gate/result on fresh load — start clean
  if (initStep === 'gate' || initStep === 'result') initStep = 'q1';
  show(initStep);
})();
</script>

