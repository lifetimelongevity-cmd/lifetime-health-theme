{% comment %}
  lt-hp-problem — Die Lücke (Section 2)
  ──────────────────────────────────────
  §12 Build Spec:
  - Surface:          --color-surface-primary (weiß — harter visueller Schnitt nach dunklem Ticker,
                      signalisiert Übergang von Emotion zu Fakten)
  - Dominant element: Headline "Wer im Dunkeln optimiert, rät." — Provokation in einem Satz
  - Heading size:     --text-h1 Section · --text-stat (56px) Stat-Werte — Zahlen dominieren
  - Content pattern:  stat-callout × 3 auf hellem Hintergrund (Inversion des Dark-Musters)
  - CTA:              keiner — Spannung darf hier nicht aufgelöst werden, sie trägt in Section 3
  - Removed:          CTA (bewusst — kein Kaufimpuls hier), dekorative Trennlinien
  - Quality move:     Stat-Werte als dominantes Textelement in Heading-Font + --text-stat auf
                      weißem Hintergrund — ungewöhnliche Größe auf hellem Surface erzeugt
                      Stopp-Effekt ohne dekorative Überlastung.
                      stat_source als Micro-Text — Quellenangabe signalisiert Seriosität,
                      ohne den Blick auf die Hauptaussage zu stören.
{% endcomment %}

{%- liquid
  assign hp_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign hp_headline_lg = true
  endif
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    {%- if section.settings.color_bg != blank -%}
    background: {{ section.settings.color_bg }};
    {%- endif -%}
    {%- if section.settings.color_text != blank -%}
    color: {{ section.settings.color_text }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    {%- endif -%}
    padding-top:    {{ section.settings.padding_top | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
  }
{% endstyle %}

<section id="shopify-section-{{ section.id }}" class="prob">
  <div class="prob__container">

    {%- comment -%}=== Section Header ==={%- endcomment -%}
    <div class="prob__header crs-heading-stack crs-heading-stack--align-center{% if hp_headline_lg %} crs-heading-stack--headline-lg{% endif %} crs-heading-stack--homepage-truth">
      {%- if section.settings.kicker != blank -%}
        <p class="crs-heading-stack__kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      <div class="crs-heading-stack__pair">
        <h2 class="crs-heading-stack__title">{{ section.settings.headline | escape }}</h2>
        {%- if section.settings.subheadline != blank -%}
          <p class="crs-heading-stack__subtitle">{{ section.settings.subheadline | escape }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%}=== Stat Banner (Blueprint from Social Proof) ==={%- endcomment -%}
    {%- assign prob_stat_count = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'stat' -%}
        {%- assign prob_stat_count = prob_stat_count | plus: 1 -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if prob_stat_count > 0 -%}
      {%- assign prob_stat_index = 0 -%}
      <div class="prob__stat-banner{% if prob_stat_count > 1 %} prob__stat-banner--multi{% endif %}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            {%- assign prob_stat_index = prob_stat_index | plus: 1 -%}
            <div class="prob__stat-item" {{ block.shopify_attributes }}>
              {%- if block.settings.stat_value != blank -%}
                <p class="prob__stat-value">{{ block.settings.stat_value | escape }}</p>
              {%- endif -%}
              {%- if block.settings.stat_label != blank -%}
                <p class="prob__stat-label">{{ block.settings.stat_label | escape }}</p>
              {%- endif -%}
              {%- if block.settings.stat_source != blank -%}
                <p class="prob__stat-source">{{ block.settings.stat_source | escape }}</p>
              {%- endif -%}
            </div>
            {%- if prob_stat_index < prob_stat_count -%}
              <div class="prob__stat-divider" aria-hidden="true"></div>
            {%- endif -%}
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
/* ================================================================
   lt-hp-problem — Die Lücke (Destabilisierungs-Block)
   Token refs: §3 (colors, type), §5 (Stat Callout — helle Variante)
   ================================================================ */

/* — Section shell — */
.prob {
  background: var(--color-surface-primary);
}

.prob__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--space-5);
}

/* — Section header — */
.prob__header {
  max-width: 680px;
  margin: 0 auto var(--space-9);   /* 80px → stats */
}


/* — Stat banner (same blueprint as social-proof stats) — */
.prob__stat-banner {
  background: var(--color-surface-secondary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-lg);
  padding: var(--space-7) var(--space-6);
  margin: 0;
  display: flex;
  align-items: center;
  gap: var(--space-4);
}

.prob__stat-banner--multi {
  flex-direction: row;
  align-items: stretch;
  gap: 0;
}

.prob__stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-3);
  flex: 1;
  padding: var(--space-4) var(--space-5);
}

.prob__stat-divider {
  width: 1px;
  background: var(--color-border-default);
  align-self: stretch;
  flex-shrink: 0;
  margin: var(--space-4) 0;
}

/* Stat value — the dominant element */
/*
  DECISION: --text-h1 (36px) not --text-stat (56px) because these
  stats contain multi-word text values ("15 Jahre", "Nicht sichtbar").
  Full stat-size would create too many broken lines at 36px container width.
  --text-h1 still commands authority at this size without linebreak chaos.
*/
.prob__stat-value {
  font-family: var(--font-heading);
  font-size: var(--text-display); /* 48px */
  font-weight: var(--weight-regular);
  line-height: var(--leading-tight);
  color: var(--color-text-primary);
  letter-spacing: -0.02em;
  margin: 0;
}

/* Stat label */
.prob__stat-label {
  font-family: var(--font-body);
  font-size: var(--text-body);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--color-text-secondary);
  max-width: 260px;
  margin: 0;
}

/* Source citation */
.prob__stat-source {
  font-family: var(--font-body);
  font-size: var(--text-micro);   /* 12px */
  font-weight: var(--weight-regular);
  color: var(--color-text-muted);
  max-width: 260px;
  margin: 0;
}

/* — Responsive — */
@media screen and (max-width: 1024px) {
  .prob__stat-value {
    font-size: var(--text-h1);
  }
}

@media screen and (max-width: 768px) {
  .prob__container {
    padding: 0 var(--space-4);
  }

  .prob__header {
    margin-bottom: var(--space-7);
  }

  .prob__stat-banner {
    padding: var(--space-5) var(--space-4);
  }

  .prob__stat-banner--multi {
    flex-direction: column;
    gap: 0;
  }

  .prob__stat-divider {
    width: 100%;
    height: 1px;
    margin: 0;
    align-self: auto;
  }

  .prob__stat-item {
    padding: var(--space-5) var(--space-4);
  }

  .prob__stat-value {
    font-size: var(--text-h1);
  }
}
{% endstylesheet %}

