{% comment %}
  lt-science-messebenen — Messebenen & LIFETIME-Instrument
  ─────────────────────────────────────────────────────────
  §12 Build Spec:
  - Surface:         --color-surface-secondary (#f2f1ed) als ruhige Basis
  - Dominant:        Eine volle, dunkelgrüne Hauptfläche zeigt die beiden
                     LIFETIME-Messebenen nebeneinander
  - Context:         Blutmarker erscheinen bewusst erst darunter als
                     zurückgenommene Einordnung mit geringerer Opazität
  - Story:           Genetik = Ausgangslage
                     Epigenetik = bisherige Entwicklung
                     Blutmarker = kurzfristige Momentaufnahme
{% endcomment %}

{%- liquid
  assign measurements_align = section.settings.content_align | default: 'left'
  if measurements_align != 'left' and measurements_align != 'center' and measurements_align != 'right'
    assign measurements_align = 'left'
  endif
  assign measurements_kicker = section.settings.kicker | strip
  assign measurements_heading = section.settings.heading | strip
  assign measurements_subheading = section.settings.subheading | strip
  if measurements_kicker == '__none__'
    assign measurements_kicker = ''
  endif
  assign measurements_heading_lg = false
  if section.settings.heading_size == 'product_title'
    assign measurements_heading_lg = true
  endif

  assign has_context_blocks = false
  assign has_main_blocks = false
  assign main_block_count = 0
  for block in section.blocks
    if block.settings.is_lifetime
      assign has_main_blocks = true
      assign main_block_count = main_block_count | plus: 1
    else
      assign has_context_blocks = true
    endif
  endfor
-%}

{% style %}
  #section-{{ section.id }} {
    --sm-bg: {{ section.settings.color_bg }};
    --sm-card-bg: {{ section.settings.color_card_bg }};
    --sm-text: {{ section.settings.color_text }};
    --sm-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --sm-text-muted: {{ section.settings.color_text | color_modify: 'alpha', 0.38 }};
    --sm-border: {{ section.settings.color_text | color_modify: 'alpha', 0.08 }};
    --sm-accent: {{ section.settings.color_accent }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<section class="science-msmt" id="section-{{ section.id }}">
  <div class="science-msmt__container">

    {%- if measurements_kicker != blank or measurements_heading != blank or measurements_subheading != blank -%}
      <header class="science-msmt__header crs-heading-stack crs-heading-stack--align-{{ measurements_align }}{% if measurements_heading_lg %} crs-heading-stack--headline-lg{% endif %}">
        {%- if measurements_kicker != blank -%}
          <p class="crs-heading-stack__kicker">{{ measurements_kicker | escape }}</p>
        {%- endif -%}
        <div class="crs-heading-stack__pair">
          {%- if measurements_heading != blank -%}
            <h2 class="crs-heading-stack__title">{{ measurements_heading | escape | newline_to_br }}</h2>
          {%- endif -%}
          {%- if measurements_subheading != blank -%}
            <p class="crs-heading-stack__subtitle">{{ measurements_subheading | escape | newline_to_br }}</p>
          {%- endif -%}
        </div>
      </header>
    {%- endif -%}

    {%- if has_main_blocks -%}
      <div class="science-msmt__main-shell">
        <div class="science-msmt__main-topline">
          {%- if section.settings.main_col_label != blank -%}
            <p class="science-msmt__col-label science-msmt__col-label--on-dark">{{ section.settings.main_col_label | escape }}</p>
          {%- endif -%}
          <p class="science-msmt__main-topline-text">Von Ausgangslage zu biologischer Entwicklung.</p>
        </div>

        <div class="science-msmt__main-grid science-msmt__main-grid--count-{{ main_block_count }}">
          {%- for block in section.blocks -%}
            {%- if block.settings.is_lifetime -%}
              <article class="science-msmt__main-panel" {{ block.shopify_attributes }}>
                {%- if block.settings.label != blank -%}
                  <p class="science-msmt__main-label">{{ block.settings.label | escape }}</p>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="science-msmt__main-title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.strength != blank -%}
                  <p class="science-msmt__main-body">{{ block.settings.strength | escape }}</p>
                {%- endif -%}
                {%- if block.settings.note != blank -%}
                  <p class="science-msmt__main-note">{{ block.settings.note | escape }}</p>
                {%- endif -%}
              </article>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.main_closing != blank -%}
          <div class="science-msmt__main-closing">
            <p class="science-msmt__main-closing-text">{{ section.settings.main_closing | escape }}</p>
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if has_context_blocks -%}
      <div class="science-msmt__context-copy">
        <p class="science-msmt__context-copy-label">{{ section.settings.context_col_label | default: 'Im Unterschied zu Blutmarkern' | escape }}</p>
        {%- for block in section.blocks -%}
          {%- unless block.settings.is_lifetime -%}
            {%- if block.settings.strength != blank -%}
              <p class="science-msmt__context-copy-text">{{ block.settings.strength | escape }}</p>
            {%- endif -%}
            {%- if block.settings.limitation != blank -%}
              <p class="science-msmt__context-copy-text science-msmt__context-copy-text--muted">{{ block.settings.limitation | escape }}</p>
            {%- endif -%}
            {%- if block.settings.note != blank -%}
              <p class="science-msmt__context-copy-note">{{ block.settings.note | escape }}</p>
            {%- endif -%}
          {%- endunless -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

{% stylesheet %}
  .science-msmt {
    background: var(--sm-bg, #f2f1ed);
  }

  .science-msmt__container {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: var(--space-5);
  }

  .science-msmt__header {
    max-width: 48rem;
    margin-bottom: var(--space-8);
  }

  .science-msmt__header.crs-heading-stack--align-center {
    margin-inline: auto;
  }

  .science-msmt__col-label {
    font-family: var(--font-body);
    font-size: var(--text-micro);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sm-text-muted, rgba(38, 37, 30, 0.38));
    margin: 0 0 var(--space-4);
  }

  .science-msmt__col-label--on-dark {
    color: rgba(247, 247, 244, 0.5);
    margin-bottom: var(--space-5);
  }

  .science-msmt__main-shell {
    display: grid;
    gap: var(--space-6);
    padding: clamp(2rem, 3vw, 3rem);
    border-radius: var(--radius-lg);
    background: var(--sm-accent, #364f56);
  }

  .science-msmt__main-topline {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 34rem;
  }

  .science-msmt__main-topline-text {
    margin: 0;
    font-family: var(--font-heading);
    font-size: var(--text-section);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    color: rgba(247, 247, 244, 0.82);
  }

  .science-msmt__main-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0;
    border-top: 1px solid rgba(247, 247, 244, 0.12);
    border-bottom: 1px solid rgba(247, 247, 244, 0.12);
  }

  .science-msmt__main-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    min-width: 0;
    padding: var(--space-6) var(--space-5);
  }

  .science-msmt__main-panel + .science-msmt__main-panel {
    border-inline-start: 1px solid rgba(247, 247, 244, 0.12);
  }

  .science-msmt__main-label {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-micro);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(247, 247, 244, 0.5);
  }

  .science-msmt__main-title {
    margin: 0;
    font-family: var(--font-heading);
    font-size: var(--text-body-lg);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    color: #f7f7f4;
  }

  .science-msmt__main-body {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-relaxed);
    color: rgba(247, 247, 244, 0.75);
  }

  .science-msmt__main-note {
    margin: auto 0 0;
    padding-top: var(--space-4);
    border-top: 1px solid rgba(247, 247, 244, 0.14);
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    font-style: italic;
    line-height: var(--leading-relaxed);
    color: rgba(247, 247, 244, 0.55);
  }

  .science-msmt__main-closing {
    padding-top: var(--space-2);
  }

  .science-msmt__main-closing-text {
    margin: 0;
    font-family: var(--font-heading);
    font-size: var(--text-section);
    font-weight: var(--weight-regular);
    line-height: var(--leading-tight);
    color: #f7f7f4;
  }

  .science-msmt__context-copy {
    max-width: 52rem;
    margin-top: var(--space-5);
  }

  .science-msmt__context-copy-label {
    margin: 0 0 var(--space-3);
    font-family: var(--font-body);
    font-size: var(--text-micro);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--sm-text-muted, rgba(38, 37, 30, 0.38));
  }

  .science-msmt__context-copy-text,
  .science-msmt__context-copy-note {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-body);
    line-height: var(--leading-relaxed);
    color: var(--sm-text-sec, rgba(38, 37, 30, 0.6));
  }

  .science-msmt__context-copy-text + .science-msmt__context-copy-text,
  .science-msmt__context-copy-text + .science-msmt__context-copy-note,
  .science-msmt__context-copy-note + .science-msmt__context-copy-text,
  .science-msmt__context-copy-note + .science-msmt__context-copy-note {
    margin-top: var(--space-3);
  }

  .science-msmt__context-copy-text--muted,
  .science-msmt__context-copy-note {
    color: var(--sm-text-muted, rgba(38, 37, 30, 0.44));
  }

  .science-msmt__context-copy-note {
    font-style: italic;
  }

  @media screen and (max-width: 1024px) {
    .science-msmt__main-grid {
      grid-template-columns: 1fr;
    }
  }

  @media screen and (max-width: 767px) {
    .science-msmt__container {
      padding-inline: var(--space-4);
    }

    .science-msmt__header {
      margin-bottom: var(--space-7);
    }

    .science-msmt__main-shell {
      padding: var(--space-5);
      gap: var(--space-5);
      border-radius: var(--radius-md);
    }

    .science-msmt__main-topline-text {
      font-size: var(--text-body-lg);
    }

    .science-msmt__main-panel {
      padding: var(--space-5) 0;
    }

    .science-msmt__main-panel + .science-msmt__main-panel {
      border-inline-start: 0;
      border-top: 1px solid rgba(247, 247, 244, 0.12);
    }

    .science-msmt__context-copy {
      margin-top: var(--space-4);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Science Measurements",
  "tag": "section",
  "class": "lt-science-messebenen",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund (Kontext)",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "color",
      "id": "color_accent",
      "label": "LIFETIME-Fläche (rechte Spalte)",
      "default": "#364f56"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Ausrichtung (Überschrift)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Überschrift Größe",
      "options": [
        { "value": "section", "label": "Standard (Abschnitt)" },
        { "value": "product_title", "label": "Wie Produkttitel" }
      ],
      "default": "section"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Überschrift",
      "default": "Warum LIFETIME auf das misst, was wirklich bleibt."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Unterüberschrift",
      "default": "Nicht jede Messung beantwortet dieselbe Frage."
    },
    {
      "type": "text",
      "id": "context_col_label",
      "label": "Label Kontextzeile unten",
      "default": "Im Unterschied zu Blutmarkern"
    },
    {
      "type": "text",
      "id": "main_col_label",
      "label": "Label Hauptfläche",
      "default": "Das LIFETIME-Instrument"
    },
    {
      "type": "textarea",
      "id": "main_closing",
      "label": "Abschluss-Synthese (rechte Spalte, unten)",
      "info": "Erscheint nach allen LIFETIME-Blöcken als abschließende Einordnung."
    }
  ],
  "blocks": [
    {
      "type": "measurement",
      "name": "Messebene",
      "settings": [
        {
          "type": "checkbox",
          "id": "is_lifetime",
          "label": "LIFETIME-Instrument (rechte Spalte)",
          "default": false,
          "info": "Aktiviert: Erscheint in der dunklen LIFETIME-Hauptfläche rechts."
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Blutmarker"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Nützliche Momentaufnahme"
        },
        {
          "type": "textarea",
          "id": "strength",
          "label": "Haupttext"
        },
        {
          "type": "textarea",
          "id": "limitation",
          "label": "Grenze / Einordnung (nur Kontext-Karte)"
        },
        {
          "type": "textarea",
          "id": "note",
          "label": "Hinweis / Synthese (kursiv)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Science Measurements",
      "blocks": [
        {
          "type": "measurement",
          "settings": {
            "is_lifetime": false,
            "label": "Blutmarker",
            "title": "Nützliche Momentaufnahme",
            "strength": "Für viele medizinische Fragen das richtige Instrument.",
            "note": "Wir messen keine Blutmarker."
          }
        },
        {
          "type": "measurement",
          "settings": {
            "is_lifetime": true,
            "label": "Genetik",
            "title": "Dein unveränderlicher Bauplan"
          }
        },
        {
          "type": "measurement",
          "settings": {
            "is_lifetime": true,
            "label": "Epigenetik",
            "title": "Wie du bisher gelebt hast — sichtbar gemacht"
          }
        }
      ]
    }
  ]
}
{% endschema %}
