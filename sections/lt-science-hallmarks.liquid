{%- liquid
  assign hallmarks_align = section.settings.content_align | default: 'left'
  if hallmarks_align != 'left' and hallmarks_align != 'center' and hallmarks_align != 'right'
    assign hallmarks_align = 'left'
  endif
  assign hallmarks_kicker = section.settings.kicker | strip
  assign hallmarks_heading = section.settings.heading | strip
  assign hallmarks_subheading = section.settings.subheading | strip
  assign hallmarks_source = section.settings.source_text | strip
  if hallmarks_kicker == '__none__'
    assign hallmarks_kicker = ''
  endif
  assign hallmarks_heading_lg = false
  if section.settings.heading_size == 'product_title'
    assign hallmarks_heading_lg = true
  endif
-%}

{% style %}
  #section-{{ section.id }} {
    --science-hallmarks-bg: {{ section.settings.color_bg }};
    --science-hallmarks-card-bg: {{ section.settings.color_card_bg }};
    --science-hallmarks-text: {{ section.settings.color_text }};
    --science-hallmarks-text-secondary: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --science-hallmarks-text-muted: {{ section.settings.color_text | color_modify: 'alpha', 0.35 }};
    --science-hallmarks-border: {{ section.settings.color_text | color_modify: 'alpha', 0.08 }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<section class="science-hallmarks" id="section-{{ section.id }}">
  <div class="science-hallmarks__container">

    {%- if hallmarks_kicker != blank or hallmarks_heading != blank or hallmarks_subheading != blank -%}
      <header class="science-hallmarks__header crs-heading-stack crs-heading-stack--align-{{ hallmarks_align }}{% if hallmarks_heading_lg %} crs-heading-stack--headline-lg{% endif %}">
        {%- if hallmarks_kicker != blank -%}
          <p class="crs-heading-stack__kicker">{{ hallmarks_kicker | escape }}</p>
        {%- endif -%}
        <div class="crs-heading-stack__pair">
          {%- if hallmarks_heading != blank -%}
            <h2 class="crs-heading-stack__title">{{ hallmarks_heading | escape | newline_to_br }}</h2>
          {%- endif -%}
          {%- if hallmarks_subheading != blank -%}
            <p class="crs-heading-stack__subtitle">{{ hallmarks_subheading | escape | newline_to_br }}</p>
          {%- endif -%}
        </div>
      </header>
    {%- endif -%}

    <div class="science-hallmarks__body-wrap">
      {%- assign in_group = false -%}
      {%- for block in section.blocks -%}

        {%- if block.type == 'category_header' -%}
          {%- if in_group -%}
            </ol>
          </div>
          {%- endif -%}
          <div class="science-hallmarks__category" {{ block.shopify_attributes }}>
            <div class="science-hallmarks__cat-row">
              {%- if block.settings.category_name != blank -%}
                <span class="science-hallmarks__cat-label">{{ block.settings.category_name | escape }}</span>
              {%- endif -%}
              {%- if block.settings.category_desc != blank -%}
                <span class="science-hallmarks__cat-desc">{{ block.settings.category_desc | escape }}</span>
              {%- endif -%}
            </div>
            <ol class="science-hallmarks__grid" role="list">
          {%- assign in_group = true -%}

        {%- elsif block.type == 'hallmark' -%}
          {%- unless in_group -%}
            <div class="science-hallmarks__category">
              <ol class="science-hallmarks__grid" role="list">
            {%- assign in_group = true -%}
          {%- endunless -%}
          {%- assign hallmark_number = block.settings.number | strip -%}
          <li class="science-hallmarks__card" {{ block.shopify_attributes }}>
            <div class="science-hallmarks__card-inner">
              {%- if block.settings.name != blank -%}
                <h3 class="science-hallmarks__name">
                  {%- if hallmark_number != blank -%}
                    <span class="science-hallmarks__num" aria-hidden="true">{{ hallmark_number | escape }}</span>
                  {%- endif -%}
                  {{ block.settings.name | escape }}
                </h3>
              {%- endif -%}
              {%- if block.settings.body != blank -%}
                <p class="science-hallmarks__desc">{{ block.settings.body | escape }}</p>
              {%- endif -%}
            </div>
          </li>

        {%- endif -%}
      {%- endfor -%}
      {%- if in_group -%}
          </ol>
        </div>
      {%- endif -%}
    </div>

    {%- if hallmarks_source != blank -%}
      <div class="science-hallmarks__source">
        <p class="science-hallmarks__source-text">{{ hallmarks_source | escape }}</p>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  .science-hallmarks {
    background: var(--science-hallmarks-bg, #f7f7f4);
  }

  .science-hallmarks__container {
    max-width: 1280px;
    margin-inline: auto;
    padding-inline: var(--space-5);
  }

  .science-hallmarks__header {
    max-width: 48rem;
    margin-bottom: var(--space-8);
  }

  .science-hallmarks__header.crs-heading-stack--align-center {
    margin-inline: auto;
  }

  /* ─── CATEGORY GROUPS ─── */
  .science-hallmarks__body-wrap {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }

  .science-hallmarks__category {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  .science-hallmarks__cat-row {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    padding-bottom: var(--space-4);
    border-bottom: 1px solid var(--science-hallmarks-border, rgba(38, 37, 30, 0.08));
  }

  .science-hallmarks__cat-label {
    font-family: var(--font-body);
    font-size: var(--text-micro);
    font-weight: var(--weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--science-hallmarks-text-secondary, rgba(38, 37, 30, 0.6));
    white-space: nowrap;
  }

  .science-hallmarks__cat-desc {
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body);
    color: var(--science-hallmarks-text-muted, rgba(38, 37, 30, 0.35));
  }

  /* ─── GRID ─── */
  .science-hallmarks__grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: var(--space-3);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  /* ─── CARD ─── */
  .science-hallmarks__card {
    min-width: 0;
  }

  .science-hallmarks__card-inner {
    padding: var(--space-5);
    border-radius: var(--radius-md);
    background: var(--science-hallmarks-card-bg, #f2f1ed);
    height: 100%;
  }

  .science-hallmarks__name {
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    margin: 0 0 var(--space-3);
    font-family: var(--font-heading);
    font-size: var(--text-body);
    font-weight: var(--weight-semibold);
    line-height: var(--leading-tight);
    color: var(--science-hallmarks-text, #26251e);
  }

  .science-hallmarks__num {
    font-family: var(--font-body);
    font-size: var(--text-micro);
    font-weight: var(--weight-regular);
    color: var(--science-hallmarks-text-muted, rgba(38, 37, 30, 0.35));
    flex-shrink: 0;
    line-height: 1;
    position: relative;
    top: -1px;
  }

  .science-hallmarks__desc {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-relaxed);
    color: var(--science-hallmarks-text-secondary, rgba(38, 37, 30, 0.6));
  }

  /* ─── SOURCE ─── */
  .science-hallmarks__source {
    margin-top: var(--space-7);
    padding-top: var(--space-4);
    border-top: 1px solid var(--science-hallmarks-border, rgba(38, 37, 30, 0.08));
  }

  .science-hallmarks__source-text {
    margin: 0;
    font-family: var(--font-body);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body);
    color: var(--science-hallmarks-text-muted, rgba(38, 37, 30, 0.35));
  }

  /* ─── RESPONSIVE ─── */
  @media screen and (max-width: 1024px) {
    .science-hallmarks__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .science-hallmarks__cat-row {
      flex-direction: column;
      gap: var(--space-2);
    }
  }

  @media screen and (max-width: 767px) {
    .science-hallmarks__container {
      padding-inline: var(--space-4);
    }

    .science-hallmarks__grid {
      grid-template-columns: 1fr;
      gap: var(--space-2);
    }

    .science-hallmarks__body-wrap {
      gap: var(--space-6);
    }

    .science-hallmarks__card-inner {
      padding: var(--space-4);
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Science Hallmarks",
  "tag": "section",
  "class": "lt-science-hallmarks",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Ausrichtung (Überschrift)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Überschrift Größe",
      "options": [
        { "value": "section", "label": "Standard (Abschnitt)" },
        { "value": "product_title", "label": "Wie Produkttitel" }
      ],
      "default": "section"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Überschrift",
      "default": "12 Mechanismen. Ein biologischer Prozess."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Unterüberschrift",
      "default": "Altern ist kein einzelnes Ereignis, sondern das Zusammenspiel zentraler Prozesse in unseren Zellen."
    },
    {
      "type": "text",
      "id": "source_text",
      "label": "Quellenzeile",
      "default": "Quelle: Lopez-Otin et al., Cell 2023"
    }
  ],
  "blocks": [
    {
      "type": "category_header",
      "name": "Kategorie-Trenner",
      "settings": [
        {
          "type": "text",
          "id": "category_name",
          "label": "Kategorie-Label",
          "default": "Primäre Hallmarks"
        },
        {
          "type": "text",
          "id": "category_desc",
          "label": "Kurzbeschreibung (optional)",
          "info": "Erscheint neben dem Kategorie-Label als ergänzende Einordnung."
        }
      ]
    },
    {
      "type": "hallmark",
      "name": "Hallmark",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Nummer",
          "default": "01"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Genomische Instabilität"
        },
        {
          "type": "textarea",
          "id": "body",
          "label": "Beschreibung",
          "default": "Mit der Zeit sammeln sich Schäden in unserer DNA an."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Science Hallmarks",
      "blocks": [
        {
          "type": "category_header",
          "settings": {
            "category_name": "Primäre Hallmarks",
            "category_desc": "Ursachen biologischer Alterung"
          }
        },
        {
          "type": "hallmark",
          "settings": {
            "number": "01",
            "name": "Genomische Instabilität",
            "body": "Mit der Zeit sammeln sich Schäden in unserer DNA an."
          }
        }
      ]
    }
  ]
}
{% endschema %}
