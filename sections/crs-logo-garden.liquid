{% style %}
  #section-{{ section.id }} {
    --lg-text:    {{ settings.color_text_main | default: '#161514' }};
    --lg-text-sec: {{ settings.color_text_main | color_modify: 'alpha', 0.5 | default: 'rgba(22,21,20,0.5)' }};
    --lg-bg:      {{ settings.color_background_main | default: '#ffffff' }};
    --lg-card-bg: {{ settings.color_background_main | default: '#ffffff' }};
    --lg-border:  {{ settings.color_text_main | color_modify: 'alpha', 0.1 | default: 'rgba(22,21,20,0.1)' }};
  }
{% endstyle %}

<div class="lg-section" id="section-{{ section.id }}">
  <div class="lg-container">

    {%- if section.settings.heading != blank -%}
      <p class="lg-heading">{{ section.settings.heading | escape }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="lg-grid" role="list">
        {%- for block in section.blocks -%}
          <li class="lg-card" {{ block.shopify_attributes }}>
            {%- if block.settings.url != blank -%}
              <a href="{{ block.settings.url }}" class="lg-card-link" aria-label="{{ block.settings.alt | escape }}" target="_blank" rel="noopener">
            {%- endif -%}

            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 400
                | image_tag:
                  loading: 'lazy',
                  class: 'lg-logo',
                  alt: block.settings.alt | escape
              }}
            {%- else -%}
              <span class="lg-logo-placeholder">{{ block.settings.alt | escape }}</span>
            {%- endif -%}

            {%- if block.settings.url != blank -%}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
/* ===================================================
   Logo Garden — lt-logo-garden.liquid
   =================================================== */

.lg-section {
  padding: 56px 0;
  background: var(--lg-bg, #fff);
}

.lg-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
}

/* Heading */
.lg-heading {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: .875rem !important;
  font-weight: 500 !important;
  line-height: 1.5 !important;
  letter-spacing: 0 !important;
  text-align: center !important;
  color: var(--lg-text-sec, rgba(22,21,20,0.5)) !important;
  margin: 0 0 32px !important;
}

/* Grid */
.lg-grid {
  display: grid;
  grid-template-columns: repeat(8, 1fr);
  gap: 12px;
  list-style: none;
  margin: 0;
  padding: 0;
}

/* Card */
.lg-card {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 4rem;
  background: var(--lg-card-bg, #fff);
  border: 1px solid var(--lg-border, rgba(22,21,20,0.1));
  border-radius: 10px;
  overflow: hidden;
  transition: border-color 0.18s ease, box-shadow 0.18s ease;
}

.lg-card:hover {
  border-color: var(--lg-border, rgba(22,21,20,0.18));
  box-shadow: 0 2px 12px rgba(0,0,0,.06);
}

.lg-card-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  padding: 12px 16px;
  text-decoration: none;
}

/* Logo image */
.lg-logo {
  max-width: 100%;
  max-height: 28px;
  width: auto;
  height: auto;
  object-fit: contain;
  display: block;
  filter: grayscale(1);
  opacity: .65;
  transition: opacity 0.18s ease, filter 0.18s ease;
}

.lg-card:hover .lg-logo {
  opacity: .9;
  filter: grayscale(.4);
}

/* Fallback text when no image */
.lg-logo-placeholder {
  font-size: .75rem;
  color: var(--lg-text-sec, rgba(22,21,20,0.5));
  text-align: center;
  padding: 8px;
  line-height: 1.3;
}

/* Responsive — 4 columns on tablet */
@media (max-width: 1024px) {
  .lg-grid {
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }

  .lg-card {
    height: 4.5rem;
  }
}

/* Responsive — 2 columns on mobile */
@media (max-width: 480px) {
  .lg-section {
    padding: 40px 0;
  }

  .lg-container {
    padding: 0 16px;
  }

  .lg-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
  }

  .lg-card {
    height: 5rem;
  }

  .lg-logo {
    max-height: 32px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Logo Garden",
  "tag": "section",
  "class": "lt-logo-garden",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Unverzichtbar für tausende Teams"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo-Bild"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Markenname / Alt-Text",
          "default": "Markenname"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo Garden",
      "blocks": [
        { "type": "logo", "settings": { "alt": "Sentry" } },
        { "type": "logo", "settings": { "alt": "Discord" } },
        { "type": "logo", "settings": { "alt": "Rippling" } },
        { "type": "logo", "settings": { "alt": "Sierra" } },
        { "type": "logo", "settings": { "alt": "Shopify" } },
        { "type": "logo", "settings": { "alt": "Datadog" } },
        { "type": "logo", "settings": { "alt": "Airtable" } },
        { "type": "logo", "settings": { "alt": "Samsara" } }
      ]
    }
  ]
}
{% endschema %}
