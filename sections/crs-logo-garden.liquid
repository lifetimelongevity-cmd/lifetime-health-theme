{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.05 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="lg-section" id="section-{{ section.id }}">
  <div class="lg-container">

    {%- if section.settings.heading != blank -%}
      <p class="lg-heading">{{ section.settings.heading | escape }}</p>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <ul class="lg-grid" role="list">
        {%- for block in section.blocks -%}
          <li class="lg-card" {{ block.shopify_attributes }}>
            {%- if block.settings.url != blank -%}
              <a href="{{ block.settings.url }}" class="lg-card-link" aria-label="{{ block.settings.alt | escape }}" target="_blank" rel="noopener">
            {%- endif -%}

            {%- if block.settings.image != blank -%}
              {{
                block.settings.image
                | image_url: width: 400
                | image_tag:
                  loading: 'lazy',
                  class: 'lg-logo',
                  alt: block.settings.alt | escape
              }}
            {%- else -%}
              <span class="lg-logo-placeholder">{{ block.settings.alt | escape }}</span>
            {%- endif -%}

            {%- if block.settings.url != blank -%}
              </a>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
/* ===================================================
   Logo Garden — crs-logo-garden.liquid
   =================================================== */

.lg-section {
  background: var(--crs-bg, #f7f7f4);
}

.lg-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Heading */
.lg-heading {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: .875rem !important;
  font-weight: 500 !important;
  line-height: 1.5 !important;
  letter-spacing: 0 !important;
  text-align: center !important;
  color: var(--crs-text-sec, rgba(38,37,30,0.6)) !important;
  margin: 0 0 32px !important;
}

/* Logos — zentriert (flex), unabhängig von der Anzahl */
.lg-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  align-items: stretch;
  gap: var(--space-2);
  list-style: none;
  margin: 0;
  padding: 0;
}

/* Card */
.lg-card {
  box-sizing: border-box;
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: min(11rem, 42vw);
  height: 4rem;
  background: var(--crs-card-bg, #f2f1ed);
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  border-radius: 4px;
  overflow: hidden;
  transition: opacity 0.18s ease;
}

.lg-card:hover {
  opacity: .8;
}

.lg-card-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 100%;
  padding: 12px 16px;
  text-decoration: none;
}

/* Logo image */
.lg-logo {
  max-width: 100%;
  max-height: 28px;
  width: auto;
  height: auto;
  object-fit: contain;
  display: block;
  filter: grayscale(1);
  opacity: .65;
  transition: opacity 0.18s ease, filter 0.18s ease;
}

.lg-card:hover .lg-logo {
  opacity: .9;
  filter: grayscale(.4);
}

/* Fallback text when no image */
.lg-logo-placeholder {
  font-size: .75rem;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
  text-align: center;
  padding: 8px;
  line-height: 1.3;
}

@media (max-width: 1024px) {
  .lg-card {
    width: min(10rem, 22vw);
    height: 4.5rem;
  }
}

@media (max-width: 480px) {
  .lg-card {
    flex: 0 0 calc(50% - var(--space-2));
    width: calc(50% - var(--space-2));
    max-width: calc(50% - var(--space-2));
    height: 5rem;
  }

  .lg-logo {
    max-height: 32px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Logo Garden",
  "tag": "section",
  "class": "crs-logo-garden",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 56
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Unverzichtbar für tausende Teams"
    }
  ],
  "blocks": [
    {
      "type": "logo",
      "name": "Logo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Logo-Bild"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Markenname / Alt-Text",
          "default": "Markenname"
        },
        {
          "type": "url",
          "id": "url",
          "label": "Link (optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Logo Garden",
      "blocks": [
        { "type": "logo", "settings": { "alt": "Sentry" } },
        { "type": "logo", "settings": { "alt": "Discord" } },
        { "type": "logo", "settings": { "alt": "Rippling" } },
        { "type": "logo", "settings": { "alt": "Sierra" } },
        { "type": "logo", "settings": { "alt": "Shopify" } },
        { "type": "logo", "settings": { "alt": "Datadog" } },
        { "type": "logo", "settings": { "alt": "Airtable" } },
        { "type": "logo", "settings": { "alt": "Samsara" } }
      ]
    }
  ]
}
{% endschema %}
