{%- liquid
  assign toc_id = section.settings.anchor_id | default: 'guide-inhalt'
  assign toc_title = section.settings.heading | default: 'Inhalt'
-%}

{% style %}
  #shopify-section-{{ section.id }} {
    background: {{ section.settings.color_bg }};
    color: {{ section.settings.color_text }};
    border-top: 1px solid {{ section.settings.color_border }};
    border-bottom: 1px solid {{ section.settings.color_border }};
    position: sticky;
    top: 64px;
    z-index: 30;
  }

  @media screen and (max-width: 767px) {
    #shopify-section-{{ section.id }} {
      top: 56px;
    }
  }
{% endstyle %}

<nav id="{{ toc_id | escape }}" class="lt-guide-nav" aria-label="{{ toc_title | escape }}">
  <div class="lt-guide-nav__container">
    <div class="lt-guide-nav__left">
      <p class="lt-guide-nav__eyebrow">{{ toc_title | escape }}</p>
      <p class="lt-guide-nav__current" data-guide-current>Kapitel 1</p>
    </div>

    <div class="lt-guide-nav__right">
      <div class="lt-guide-nav__progress" aria-hidden="true">
        <span class="lt-guide-nav__progress-fill" data-guide-progress></span>
      </div>
      <button type="button" class="lt-guide-nav__button" data-guide-open aria-haspopup="dialog" aria-expanded="false">
        Inhalt
      </button>
    </div>
  </div>

  <dialog class="lt-guide-sheet" data-guide-sheet aria-label="{{ toc_title | escape }}">
    <div class="lt-guide-sheet__surface">
      <div class="lt-guide-sheet__header">
        <p class="lt-guide-sheet__title">{{ toc_title | escape }}</p>
        <button type="button" class="lt-guide-sheet__close" data-guide-close aria-label="Schließen">×</button>
      </div>

      <ul class="lt-guide-sheet__list" role="list">
        {%- for block in section.blocks -%}
          {%- assign target_id = block.settings.target_id | strip -%}
          <li class="lt-guide-sheet__item" {{ block.shopify_attributes }}>
            {%- if target_id != blank -%}
              <button
                type="button"
                class="lt-guide-sheet__link"
                data-guide-link
                data-target-id="{{ target_id | escape }}"
              >
                {{ block.settings.label | escape }}
              </button>
            {%- else -%}
              <p class="lt-guide-sheet__group">{{ block.settings.label | escape }}</p>
            {%- endif -%}
          </li>
        {%- endfor -%}
      </ul>
    </div>
  </dialog>
</nav>

{% stylesheet %}
.lt-guide-nav__container {
  max-width: 1320px;
  margin: 0 auto;
  padding: 10px var(--space-5);
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: center;
  gap: var(--space-4);
}

.lt-guide-nav__left {
  min-width: 0;
}

.lt-guide-nav__eyebrow {
  margin: 0;
  font-size: var(--text-micro);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-secondary);
}

.lt-guide-nav__current {
  margin: 2px 0 0;
  font-size: var(--text-body-sm);
  color: var(--color-text-primary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.lt-guide-nav__right {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.lt-guide-nav__progress {
  width: 96px;
  height: 6px;
  border-radius: 999px;
  background: var(--color-border-default);
  overflow: hidden;
}

.lt-guide-nav__progress-fill {
  display: block;
  width: 0%;
  height: 100%;
  background: var(--color-surface-accent);
  transition: width 220ms ease;
}

.lt-guide-nav__button {
  min-height: 36px;
  padding: 6px 12px;
  border-radius: 999px;
  border: 1px solid var(--color-border-default);
  background: var(--color-surface-primary);
  color: var(--color-text-primary);
  font-size: var(--text-body-sm);
}

.lt-guide-sheet {
  width: min(720px, calc(100vw - 24px));
  border: none;
  border-radius: var(--radius-md);
  padding: 0;
  background: transparent;
}

.lt-guide-sheet::backdrop {
  background: rgba(38, 37, 30, 0.38);
}

.lt-guide-sheet__surface {
  background: var(--color-surface-primary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-md);
  max-height: min(80vh, 760px);
  overflow: auto;
}

.lt-guide-sheet__header {
  position: sticky;
  top: 0;
  z-index: 1;
  background: var(--color-surface-primary);
  border-bottom: 1px solid var(--color-border-default);
  padding: 12px var(--space-4);
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.lt-guide-sheet__title {
  margin: 0;
  font-size: var(--text-body);
  font-weight: 600;
}

.lt-guide-sheet__close {
  width: 36px;
  height: 36px;
  border-radius: 999px;
  border: 1px solid var(--color-border-default);
  background: var(--color-surface-primary);
  color: var(--color-text-primary);
  font-size: 20px;
  line-height: 1;
}

.lt-guide-sheet__list {
  list-style: none;
  margin: 0;
  padding: 8px;
  display: grid;
  gap: 4px;
}

.lt-guide-sheet__group {
  margin: 8px 4px 2px;
  font-size: var(--text-micro);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--color-text-secondary);
}

.lt-guide-sheet__link {
  width: 100%;
  text-align: left;
  min-height: 44px;
  padding: 10px 12px;
  border-radius: 10px;
  border: 1px solid transparent;
  background: transparent;
  color: var(--color-text-primary);
  font-size: var(--text-body-sm);
}

.lt-guide-sheet__link.is-active {
  border-color: var(--color-border-default);
  background: var(--color-surface-secondary);
}

@media screen and (max-width: 767px) {
  .lt-guide-nav__container {
    padding: 8px var(--space-4);
  }

  .lt-guide-nav__progress {
    width: 72px;
  }

  .lt-guide-sheet {
    width: 100vw;
    max-width: none;
    margin: 0;
    border-radius: 0;
  }

  .lt-guide-sheet__surface {
    border-radius: 0;
    max-height: 84vh;
  }
}
{% endstylesheet %}

{% javascript %}
(function () {
  const nav = document.querySelector('.lt-guide-nav');
  if (!nav) return;

  const sheet = nav.querySelector('[data-guide-sheet]');
  const openBtn = nav.querySelector('[data-guide-open]');
  const closeBtn = nav.querySelector('[data-guide-close]');
  const currentEl = nav.querySelector('[data-guide-current]');
  const progressEl = nav.querySelector('[data-guide-progress]');
  const linkButtons = Array.from(nav.querySelectorAll('[data-guide-link]'));
  if (!sheet || !openBtn || !closeBtn || !linkButtons.length || !currentEl || !progressEl) return;

  const targets = linkButtons
    .map((btn) => {
      const id = btn.getAttribute('data-target-id');
      const el = id ? document.getElementById(id) : null;
      return el ? { btn, el, label: btn.textContent?.trim() || '' } : null;
    })
    .filter(Boolean);

  if (!targets.length) return;

  const chapterCount = targets.length;

  const setActive = (id) => {
    let activeIndex = 0;
    targets.forEach(({ btn, el }, index) => {
      const active = el.id === id;
      btn.classList.toggle('is-active', active);
      if (active) activeIndex = index;
    });

    const chapterLabel = targets[activeIndex]?.label || 'Kapitel';
    currentEl.textContent = `${activeIndex + 1}/${chapterCount} - ${chapterLabel}`;
    const progress = ((activeIndex + 1) / chapterCount) * 100;
    progressEl.style.width = `${progress}%`;
  };

  const getTopOffset = () => {
    const navHeight = nav.getBoundingClientRect().height;
    const headerOffset = window.matchMedia('(max-width: 767px)').matches ? 56 : 64;
    return navHeight + headerOffset + 12;
  };

  const scrollToTarget = (el) => {
    const y = window.scrollY + el.getBoundingClientRect().top - getTopOffset();
    window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
  };

  const openSheet = () => {
    if (!sheet.open) sheet.showModal();
    openBtn.setAttribute('aria-expanded', 'true');
  };

  const closeSheet = () => {
    if (sheet.open) sheet.close();
    openBtn.setAttribute('aria-expanded', 'false');
  };

  openBtn.addEventListener('click', openSheet);
  closeBtn.addEventListener('click', closeSheet);

  sheet.addEventListener('click', (event) => {
    const rect = sheet.getBoundingClientRect();
    const isBackdropClick =
      event.clientX < rect.left ||
      event.clientX > rect.right ||
      event.clientY < rect.top ||
      event.clientY > rect.bottom;
    if (isBackdropClick) closeSheet();
  });

  targets.forEach(({ btn, el }) => {
    btn.addEventListener('click', () => {
      scrollToTarget(el);
      setActive(el.id);
      closeSheet();
    });
  });

  const observer = new IntersectionObserver(
    (entries) => {
      const visible = entries
        .filter((entry) => entry.isIntersecting)
        .sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
      if (visible.length) setActive(visible[0].target.id);
    },
    { rootMargin: '-42% 0px -48% 0px', threshold: 0.01 }
  );

  targets.forEach(({ el }) => observer.observe(el));
  setActive(targets[0].el.id);
})();
{% endjavascript %}

{% schema %}
{
  "name": "LT Guide TOC",
  "tag": "section",
  "class": "lt-guide-toc-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Navigation title",
      "default": "Inhalt"
    },
    {
      "type": "text",
      "id": "anchor_id",
      "label": "TOC anchor id",
      "default": "guide-inhalt"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Background",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Text color",
      "default": "#26251e"
    },
    {
      "type": "color",
      "id": "color_border",
      "label": "Border color",
      "default": "#e5e2da"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 12
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Nav item",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Priorisiere deinen Schlaf"
        },
        {
          "type": "text",
          "id": "target_id",
          "label": "Target id (leave empty for group labels)",
          "default": "kapitel-schlaf"
        }
      ]
    }
  ],
  "max_blocks": 20,
  "presets": [
    {
      "name": "LT Guide TOC",
      "blocks": [
        { "type": "item", "settings": { "label": "Level I", "target_id": "" } },
        { "type": "item", "settings": { "label": "Priorisiere deinen Schlaf", "target_id": "kapitel-schlaf" } },
        { "type": "item", "settings": { "label": "Bleibe ständig in Bewegung", "target_id": "kapitel-bewegung" } },
        { "type": "item", "settings": { "label": "Iss die richtigen Nährstoffe", "target_id": "kapitel-ernaehrung" } }
      ]
    }
  ]
}
{% endschema %}
