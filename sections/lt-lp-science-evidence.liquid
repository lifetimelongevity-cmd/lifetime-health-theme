          "default": "Die erste epigenetische Uhr, die biologisches Alter über DNA-Methylierung misst. Über 8.000 Zitationen. Grundlage moderner Longevity-Diagnostik."
        },
        {
          "type": "url",
          "id": "study_link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
