  ],
  "presets": [
    {
      "name": "LP Scarcity Risk",
      "blocks": [
        {
          "type": "reassurance_item",
          "settings": {
            "icon": "ph:flask-thin",
            "label": "Limitiertes Volumen",
            "title": "50 Kits pro Woche",
            "body": "Eurofins Genomics analysiert Proben manuell unter klinischen Bedingungen. Das limitiert die Kapazität. Wir bieten 50 Kits pro Woche an, damit jede Probe mit derselben Sorgfalt verarbeitet wird."
