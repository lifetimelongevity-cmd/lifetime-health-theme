      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "default": 64
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Bevor du bestellst"
