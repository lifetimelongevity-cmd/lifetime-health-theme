{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_tl_kicker = section.settings.kicker | strip
  assign crs_tl_head = section.settings.headline | strip
  assign crs_tl_sub = section.settings.subheading | strip
  if crs_tl_sub == '__none__'
    assign crs_tl_sub = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif
  assign tl_has_intro_header = false
  if crs_tl_kicker != blank or crs_tl_head != blank or crs_tl_sub != blank
    assign tl_has_intro_header = true
  endif
  assign tl_show_intro_col = false
  if tl_has_intro_header or section.settings.image != blank
    assign tl_show_intro_col = true
  endif
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.05 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div
  class="tl-section{% if section.settings.image != blank %} tl-section--has-image{% else %} tl-section--no-image{% endif %}"
  id="section-{{ section.id }}"
>
  <div class="tl-container">
    <div class="tl-layout{% if tl_show_intro_col == false %} tl-layout--timeline-only{% endif %}">

      {%- if tl_show_intro_col -%}
        {%- comment -%} Spalte 1 (Desktop): Kicker, Überschrift, Unterzeile, optional Bild darunter {%- endcomment -%}
        <div class="tl-intro">
          {%- if tl_has_intro_header -%}
            <div class="tl-header crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
              {%- if crs_tl_kicker != blank -%}
                <p class="crs-heading-stack__kicker">{{ crs_tl_kicker | escape }}</p>
              {%- endif -%}
              {%- if crs_tl_head != blank or crs_tl_sub != blank -%}
                <div class="crs-heading-stack__pair">
                  {%- if crs_tl_head != blank -%}
                    <h2 class="crs-heading-stack__title">{{ crs_tl_head | escape | newline_to_br }}</h2>
                  {%- endif -%}
                  {%- if crs_tl_sub != blank -%}
                    <p class="crs-heading-stack__subtitle">{{ crs_tl_sub | escape | newline_to_br }}</p>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if section.settings.image != blank -%}
            <div class="tl-media">
              {{
                section.settings.image
                | image_url: width: 1000
                | image_tag:
                  loading: 'lazy',
                  class: 'tl-image',
                  alt: section.settings.image_alt | escape
              }}
            </div>
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- comment -%} Spalte 2 (Desktop): Timeline {%- endcomment -%}
      {%- if section.blocks.size > 0 -%}
        <div class="tl-timeline">
          <div class="tl-items">
            {%- for block in section.blocks -%}
              <div class="tl-item{% if block.settings.is_active %} tl-item--active{% endif %}" {{ block.shopify_attributes }}>

                {%- if block.settings.time_label != blank -%}
                  <span class="tl-badge">{{ block.settings.time_label | escape }}</span>
                {%- endif -%}

                {%- if block.settings.step_title != blank -%}
                  <h3 class="tl-step-title">{{ block.settings.step_title | escape }}</h3>
                {%- endif -%}

                {%- if block.settings.step_body != blank -%}
                  <p class="tl-step-body">{{ block.settings.step_body | escape }}</p>
                {%- endif -%}

                {%- if section.settings.show_callout
                  and block.settings.show_callout_box
                  and block.settings.callout_text != blank
                -%}
                  <div class="tl-callout">{{ block.settings.callout_text | escape }}</div>
                {%- endif -%}

              </div>
            {%- endfor -%}
          </div>
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% stylesheet %}
/* ===================================================
   Timeline Split — crs-timeline.liquid
   =================================================== */

.tl-section {
  background: var(--crs-bg, #f7f7f4);
}

.tl-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--space-5);
}

/* Desktop: Intro links, Timeline rechts — volle Containerbreite (kein 720px-Cap) */
.tl-layout {
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: var(--space-5);
  align-items: start;
}

.tl-layout--timeline-only {
  grid-template-columns: minmax(0, 1fr);
}

/* Mit Bild: Bild unter der Headline in Spalte 1, Timeline in Spalte 2 über volle Höhe */
.tl-section--has-image .tl-timeline {
  grid-row: 1 / span 2;
  grid-column: 2;
}

.tl-section--has-image .tl-intro {
  grid-column: 1;
  grid-row: 1;
}

.tl-section--has-image .tl-media {
  grid-column: 1;
  grid-row: 2;
}

.tl-intro {
  min-width: 0;
  align-self: start;
  padding-right: var(--space-7);
  padding-top: var(--space-1);
  position: sticky;
  top: 80px;
}

.tl-timeline {
  min-width: 0;
}

/* Header block */
.tl-header {
  margin-bottom: var(--space-7);
}

/* Timeline items */
.tl-items {
  position: relative;
  padding-left: 24px;
  border-left: 1px solid var(--crs-border, rgba(38, 37, 30, 0.06));
}

.tl-item {
  position: relative;
  margin-bottom: 32px;
}

.tl-item:last-child {
  margin-bottom: 0;
}

/* Dot */
.tl-item::before {
  content: '';
  position: absolute;
  left: -30px;
  top: 4px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--crs-card-bg, #f2f1ed);
  border: 1.5px solid rgba(38,37,30,0.3);
  box-sizing: border-box;
}

.tl-item--active::before {
  background: rgba(38,37,30,0.8);
  border-color: rgba(38,37,30,0.8);
}

/* Time badge */
.tl-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 400;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
  background: var(--crs-card-bg, #f2f1ed);
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  border-radius: 20px;
  padding: 2px 10px;
  margin-bottom: 6px;
}

/* Step title */
.tl-step-title {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: 16px !important;
  font-weight: 500 !important;
  line-height: 1.4 !important;
  letter-spacing: 0 !important;
  color: var(--crs-text, #26251e) !important;
  margin: 0 0 4px !important;
}

/* Step body */
.tl-step-body {
  font-size: 14px;
  font-weight: 400;
  line-height: 1.65;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
  margin: 0;
}

/* Callout */
.tl-callout {
  box-sizing: border-box;
  background: rgba(38,37,30,0.05);
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  border-radius: 4px;
  padding: 10px 12px;
  margin-top: 8px;
  font-size: 13px;
  line-height: 1.6;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
}

.tl-media {
  margin-top: var(--space-5);
}

.tl-image {
  width: 100%;
  height: auto;
  border-radius: var(--radius-sm);
  object-fit: cover;
  display: block;
}

/* Tablet/Mobile: Intro → Timeline → Bild */
@media (max-width: 1024px) {
  .tl-layout {
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  .tl-section--has-image .tl-timeline {
    grid-column: 1;
    grid-row: auto;
  }

  .tl-section--has-image .tl-intro {
    grid-column: 1;
    grid-row: auto;
  }

  .tl-section--has-image .tl-media {
    grid-column: 1;
    grid-row: auto;
  }

  .tl-media {
    margin-top: 0;
  }

  .tl-intro {
    position: static;
    top: auto;
    padding-right: 0;
    padding-top: 0;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Timeline Split",
  "tag": "section",
  "class": "crs-timeline",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Ausrichtung (Überschrift)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Überschrift Größe",
      "options": [
        { "value": "section", "label": "Standard (Abschnitt)" },
        { "value": "product_title", "label": "Wie Produkttitel" }
      ],
      "default": "section",
      "info": "Zeilenumbruch: Enter in Überschrift/Unterüberschrift."
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "WAS KANNST DU ERWARTEN?"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Überschrift",
      "default": "Aus Forschung wird Alltag"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Unterüberschrift (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "checkbox",
      "id": "show_callout",
      "label": "Hinweis-Boxen (Callouts) anzeigen",
      "default": true,
      "info": "Wenn aus, werden Callout-Texte der Schritte nicht gerendert."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild (optional)",
      "info": "Desktop: unter der Headline (linke Spalte). Mobile: direkt unter Headline, vor den Timeline-Schritten."
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Bild Alt-Text"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Zeitpunkt",
      "settings": [
        {
          "type": "text",
          "id": "time_label",
          "label": "Zeit-Badge",
          "default": "Nach 4 Wochen"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Titel",
          "default": "Mehr Energie"
        },
        {
          "type": "textarea",
          "id": "step_body",
          "label": "Beschreibung",
          "default": "NAD⁺-Stoffwechsel: erste messbare Veränderungen. Viele berichten von einem konstanteren Energiegefühl im Alltag."
        },
        {
          "type": "checkbox",
          "id": "is_active",
          "label": "Aktiver Zeitpunkt (gefüllter Punkt)",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_callout_box",
          "label": "Callout-Box anzeigen",
          "default": false
        },
        {
          "type": "textarea",
          "id": "callout_text",
          "label": "Callout-Text",
          "default": "Nach Absetzen: NAD⁺ fällt in 4 Wochen auf Ausgangswert zurück — Kontinuität ist entscheidend."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Timeline Split",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "time_label": "Nach 4 Wochen",
            "step_title": "Mehr Energie",
            "step_body": "Erste messbare NAD⁺-Veränderungen. Viele berichten von konstanterer Energie im Alltag – ohne Nachmittagstief.",
            "is_active": true,
            "show_callout_box": false,
            "callout_text": ""
          }
        },
        {
          "type": "step",
          "settings": {
            "time_label": "Nach 2 Monaten",
            "step_title": "Spürbar fitter",
            "step_body": "Im 6-Minuten-Gehtest legten NMN-Teilnehmer signifikant mehr Strecke zurück als Placebo. Biologisches Alter blieb stabil.",
            "is_active": true,
            "show_callout_box": false,
            "callout_text": ""
          }
        },
        {
          "type": "step",
          "settings": {
            "time_label": "Nach 3 Monaten",
            "step_title": "Herz & Stoffwechsel",
            "step_body": "Verbesserte Insulinsensitivität. NAD⁺-Werte im Blut mehr als verdoppelt. Tendenz zu reduzierter arterieller Steifheit.",
            "is_active": true,
            "show_callout_box": false,
            "callout_text": ""
          }
        },
        {
          "type": "step",
          "settings": {
            "time_label": "Nach 4 Monaten",
            "step_title": "Zelluläre Langzeitwirkung",
            "step_body": "Kumulative Effekte auf Zellreparatur, mitochondriale Funktion und Gefäßgesundheit. Je länger, desto tiefer die Wirkung.",
            "is_active": false,
            "show_callout_box": true,
            "callout_text": "NAD⁺-Werte fallen 4 Wochen nach dem Absetzen auf den Ausgangswert zurück. NMN wirkt als kontinuierliche Routine – nicht als einmalige Kur."
          }
        }
      ]
    }
  ]
}
{% endschema %}
