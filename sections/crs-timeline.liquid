{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.1 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div
  class="tl-section{% if section.settings.image == blank %} tl-section--no-image{% endif %}"
  id="section-{{ section.id }}"
>
  <div class="tl-container">
    <div class="tl-layout">

      {%- comment -%} Left: Timeline {%- endcomment -%}
      <div class="tl-left">

        {%- if section.settings.kicker != blank or section.settings.headline != blank -%}
          <div class="tl-header">
            {%- if section.settings.kicker != blank -%}
              <p class="tl-kicker">{{ section.settings.kicker | escape }}</p>
            {%- endif -%}
            {%- if section.settings.headline != blank -%}
              <h2 class="tl-headline">{{ section.settings.headline | escape }}</h2>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="tl-items">
            {%- for block in section.blocks -%}
              <div class="tl-item{% if block.settings.is_active %} tl-item--active{% endif %}" {{ block.shopify_attributes }}>

                {%- if block.settings.time_label != blank -%}
                  <span class="tl-badge">{{ block.settings.time_label | escape }}</span>
                {%- endif -%}

                {%- if block.settings.step_title != blank -%}
                  <h3 class="tl-step-title">{{ block.settings.step_title | escape }}</h3>
                {%- endif -%}

                {%- if block.settings.step_body != blank -%}
                  <p class="tl-step-body">{{ block.settings.step_body | escape }}</p>
                {%- endif -%}

                {%- if section.settings.show_callout
                  and block.settings.show_callout_box
                  and block.settings.callout_text != blank
                -%}
                  <div class="tl-callout">{{ block.settings.callout_text | escape }}</div>
                {%- endif -%}

              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}

      </div>

      {%- comment -%} Right: Image (only if set) {%- endcomment -%}
      {%- if section.settings.image != blank -%}
        <div class="tl-right">
          {{
            section.settings.image
            | image_url: width: 1000
            | image_tag:
              loading: 'lazy',
              class: 'tl-image',
              alt: section.settings.image_alt | escape
          }}
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% stylesheet %}
/* ===================================================
   Timeline Split — crs-timeline.liquid
   =================================================== */

.tl-section {
  background: var(--crs-bg, #f7f7f4);
}

.tl-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Layout */
.tl-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 32px;
  align-items: start;
}

.tl-section--no-image .tl-layout {
  grid-template-columns: 1fr;
}

/* Header block */
.tl-header {
  margin-bottom: 32px;
}

.tl-kicker {
  font-size: 12px;
  font-weight: 400;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--crs-text-ter, rgba(38,37,30,0.4));
  margin: 0 0 12px;
}

.tl-headline {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: 36px !important;
  font-weight: 400 !important;
  line-height: 1.15 !important;
  letter-spacing: -0.72px !important;
  color: var(--crs-text, #26251e) !important;
  margin: 0 !important;
}

/* Timeline items */
.tl-items {
  position: relative;
  padding-left: 24px;
  border-left: 1px solid var(--crs-border, rgba(38,37,30,0.12));
}

.tl-item {
  position: relative;
  margin-bottom: 32px;
}

.tl-item:last-child {
  margin-bottom: 0;
}

/* Dot */
.tl-item::before {
  content: '';
  position: absolute;
  left: -30px;
  top: 4px;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  background: var(--crs-card-bg, #f2f1ed);
  border: 1.5px solid rgba(38,37,30,0.3);
  box-sizing: border-box;
}

.tl-item--active::before {
  background: rgba(38,37,30,0.8);
  border-color: rgba(38,37,30,0.8);
}

/* Time badge */
.tl-badge {
  display: inline-block;
  font-size: 11px;
  font-weight: 400;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
  background: var(--crs-card-bg, #f2f1ed);
  border: 1px solid var(--crs-border, rgba(38,37,30,0.1));
  border-radius: 20px;
  padding: 2px 10px;
  margin-bottom: 6px;
}

/* Step title */
.tl-step-title {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: 16px !important;
  font-weight: 500 !important;
  line-height: 1.4 !important;
  letter-spacing: 0 !important;
  color: var(--crs-text, #26251e) !important;
  margin: 0 0 4px !important;
}

/* Step body */
.tl-step-body {
  font-size: 14px;
  font-weight: 400;
  line-height: 1.65;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
  margin: 0;
}

/* Callout */
.tl-callout {
  background: rgba(38,37,30,0.05);
  border-left: 2px solid rgba(38,37,30,0.2);
  border-radius: 4px;
  padding: 10px 12px;
  margin-top: 8px;
  font-size: 13px;
  line-height: 1.6;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
}

/* Right image */
.tl-image {
  width: 100%;
  height: auto;
  border-radius: 4px;
  object-fit: cover;
  display: block;
}

/* Mobile */
@media (max-width: 1024px) {
  .tl-layout {
    grid-template-columns: 1fr;
    gap: 32px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Timeline Split",
  "tag": "section",
  "class": "crs-timeline",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "WAS KANNST DU ERWARTEN?"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Überschrift",
      "default": "Aus Forschung wird Alltag"
    },
    {
      "type": "checkbox",
      "id": "show_callout",
      "label": "Hinweis-Boxen (Callouts) anzeigen",
      "default": true,
      "info": "Wenn aus, werden Callout-Texte der Schritte nicht gerendert."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild (rechte Spalte)"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Bild Alt-Text"
    }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Zeitpunkt",
      "settings": [
        {
          "type": "text",
          "id": "time_label",
          "label": "Zeit-Badge",
          "default": "Nach 4 Wochen"
        },
        {
          "type": "text",
          "id": "step_title",
          "label": "Titel",
          "default": "Mehr Energie"
        },
        {
          "type": "textarea",
          "id": "step_body",
          "label": "Beschreibung",
          "default": "NAD⁺-Stoffwechsel: erste messbare Veränderungen. Viele berichten von einem konstanteren Energiegefühl im Alltag."
        },
        {
          "type": "checkbox",
          "id": "is_active",
          "label": "Aktiver Zeitpunkt (gefüllter Punkt)",
          "default": true
        },
        {
          "type": "checkbox",
          "id": "show_callout_box",
          "label": "Callout-Box anzeigen",
          "default": false
        },
        {
          "type": "textarea",
          "id": "callout_text",
          "label": "Callout-Text",
          "default": "Nach Absetzen: NAD⁺ fällt in 4 Wochen auf Ausgangswert zurück — Kontinuität ist entscheidend."
        }
      ]
    }
  ],
  "max_blocks": 6,
  "presets": [
    {
      "name": "Timeline Split",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "time_label": "Nach 4 Wochen",
            "step_title": "Mehr Energie",
            "step_body": "NAD⁺-Stoffwechsel: erste messbare Veränderungen. Viele berichten von einem konstanteren Energiegefühl im Alltag.",
            "is_active": true,
            "show_callout_box": false
          }
        },
        {
          "type": "step",
          "settings": {
            "time_label": "Nach 2 Monaten",
            "step_title": "Spürbar fitter",
            "step_body": "Ausdauer und Erholung verbessern sich. Erste Rückmeldungen über tieferen Schlaf und weniger Erschöpfung.",
            "is_active": true,
            "show_callout_box": false
          }
        },
        {
          "type": "step",
          "settings": {
            "time_label": "Nach 3 Monaten",
            "step_title": "Herz & Stoffwechsel",
            "step_body": "Studien zeigen Verbesserungen bei Blutdruckwerten und metabolischen Markern nach 90 Tagen konsistenter Einnahme.",
            "is_active": true,
            "show_callout_box": false
          }
        },
        {
          "type": "step",
          "settings": {
            "time_label": "Nach 4 Monaten",
            "step_title": "Deep Longevity Benefits",
            "step_body": "DNA-Reparaturmechanismen, mitochondriale Funktion und zellulare Regeneration auf messbarem Niveau aktiv.",
            "is_active": true,
