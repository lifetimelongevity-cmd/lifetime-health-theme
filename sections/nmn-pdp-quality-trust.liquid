{% comment %}
  NMN PDP: compact product-quality cards (differentiation vs. pills/badges).
  Template: product.13_nmn — placed after NAD mechanism section.
{% endcomment %}

<div class="container container--large container--vertical-space-small remove-empty-space">
  <section
    class="nmn-pdp-quality-trust"
    aria-labelledby="nmn-quality-trust-heading-{{ section.id }}"
  >
    <header class="nmn-pdp-quality-trust__header">
      {%- unless section.settings.section_label == blank -%}
        <p class="nmn-pdp-quality-trust__label">{{ section.settings.section_label | escape }}</p>
      {%- endunless -%}
      {%- unless section.settings.heading == blank -%}
        <h2
          class="nmn-pdp-quality-trust__heading text-weight--bold"
          id="nmn-quality-trust-heading-{{ section.id }}"
        >
          {{- section.settings.heading | escape -}}
        </h2>
      {%- endunless -%}
    </header>

    <div class="nmn-pdp-quality-trust__grid" role="list">
      {%- for block in section.blocks -%}
        {%- case block.type -%}
          {%- when 'point' -%}
            <article
              class="nmn-pdp-quality-trust__card"
              role="listitem"
              {{ block.shopify_attributes }}
            >
              {%- unless block.settings.title == blank -%}
                <h3 class="nmn-pdp-quality-trust__title text-weight--bold">
                  {{- block.settings.title | escape -}}
                </h3>
              {%- endunless -%}
              {%- unless block.settings.text == blank -%}
                <p class="nmn-pdp-quality-trust__text">{{ block.settings.text | escape }}</p>
              {%- endunless -%}
            </article>
        {%- endcase -%}
      {%- endfor -%}
    </div>
  </section>
</div>

{% stylesheet %}
  .nmn-pdp-quality-trust__header {
    margin-bottom: 2rem;
    max-width: 40rem;
  }

  .nmn-pdp-quality-trust__label {
    margin: 0 0 1rem;
    font-family: var(--font-stack-body-primary);
    font-size: 0.75rem;
    line-height: 1.4;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-secondary-text-main);
  }

  .nmn-pdp-quality-trust__heading {
    margin: 0;
    font-family: var(--font-stack-headings-primary);
    font-size: clamp(1.5rem, 2.5vw, 1.75rem);
    line-height: 1.15;
    letter-spacing: -0.02em;
    color: var(--color-text-main);
    max-width: 36ch;
  }

  .nmn-pdp-quality-trust__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0;
    margin: 0;
    padding: 0;
    list-style: none;
    border: 1px solid color-mix(in srgb, var(--color-borders-main) 92%, var(--color-text-main));
    border-radius: 0.75rem;
    background: var(--color-background-main);
    overflow: hidden;
  }

  @media screen and (min-width: 600px) {
    .nmn-pdp-quality-trust__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  .nmn-pdp-quality-trust__card {
    margin: 0;
    padding: 1.5rem;
    border: 0;
    border-radius: 0;
    background: transparent;
    box-shadow: none;
    border-bottom: 1px solid color-mix(in srgb, var(--color-borders-main) 94%, var(--color-text-main));
  }

  @media screen and (max-width: 599px) {
    .nmn-pdp-quality-trust__card:last-child {
      border-bottom: 0;
    }
  }

  @media screen and (min-width: 600px) {
    .nmn-pdp-quality-trust__card:nth-child(odd) {
      border-inline-end: 1px solid color-mix(in srgb, var(--color-borders-main) 94%, var(--color-text-main));
    }

    .nmn-pdp-quality-trust__card:nth-last-child(-n + 2) {
      border-bottom: 0;
    }
  }

  .nmn-pdp-quality-trust__title {
    margin: 0 0 0.5rem;
    font-family: var(--font-stack-headings-primary);
    font-size: 1.25rem;
    line-height: 1.25;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-main);
  }

  .nmn-pdp-quality-trust__text {
    margin: 0;
    font-family: var(--font-stack-body-primary);
    font-size: 1rem;
    line-height: 1.4;
    color: var(--color-secondary-text-main);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "NMN PDP — Produktqualität",
  "tag": "section",
  "class": "section-nmn-pdp-quality-trust",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Sektions-Label",
      "default": "PRODUKTQUALITÄT"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Qualität, auf die du dich verlassen kannst"
    }
  ],
  "blocks": [
    {
      "type": "point",
      "name": "Qualitätspunkt",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Titel"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Kurztext",
          "default": "Kurze Erklärung"
        }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "NMN PDP — Produktqualität",
      "category": "Product",
      "settings": {
        "section_label": "PRODUKTQUALITÄT",
        "heading": "Qualität, auf die du dich verlassen kannst"
      },
      "blocks": [
        {
          "type": "point",
          "settings": {
            "title": "Uthever® Markenrohstoff",
            "text": "Einer der weltweit führenden NMN-Rohstoffe mit geprüfter Qualität"
          }
        },
        {
          "type": "point",
          "settings": {
            "title": ">99 % Reinheit",
            "text": "Frei von unnötigen Zusätzen – für maximale Qualität"
          }
        },
        {
          "type": "point",
          "settings": {
            "title": "Unabhängig laborgeprüft",
            "text": "Jede Charge wird zusätzlich extern getestet"
          }
        },
        {
          "type": "point",
          "settings": {
            "title": "Hergestellt nach höchsten Standards",
            "text": "Produktion unter kontrollierten Bedingungen"
          }
        }
      ]
    }
  ]
}
{% endschema %}
