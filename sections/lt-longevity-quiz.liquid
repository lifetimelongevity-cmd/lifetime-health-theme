{% comment %}
  LIFETIME — Longevity Quiz Section
  ────────────────────────────────────────────────────────────
  Finale Empfehlungsmatrix:
    Energie      → NMN (primär) | Kreatin | TMG
    Fokus        → Kreatin (primär) | Fisetin | Trans-Resveratrol
    Schlaf       → Schlafspray (primär) | Spermidin | Kreatin
    Langlebigkeit → NMN (primär) | Trans-Resveratrol | CaAKG
  ────────────────────────────────────────────────────────────
{% endcomment %}

{{ 'section-lt-longevity-quiz.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign p_energie_primary = all_products[section.settings.product_energie_primary]
  assign p_energie_sec1    = all_products[section.settings.product_energie_sec1]
  assign p_energie_sec2    = all_products[section.settings.product_energie_sec2]

  assign p_fokus_primary   = all_products[section.settings.product_fokus_primary]
  assign p_fokus_sec1      = all_products[section.settings.product_fokus_sec1]
  assign p_fokus_sec2      = all_products[section.settings.product_fokus_sec2]

  assign p_schlaf_primary  = all_products[section.settings.product_schlaf_primary]
  assign p_schlaf_sec1     = all_products[section.settings.product_schlaf_sec1]
  assign p_schlaf_sec2     = all_products[section.settings.product_schlaf_sec2]

  assign p_lang_primary    = all_products[section.settings.product_lang_primary]
  assign p_lang_sec1       = all_products[section.settings.product_lang_sec1]
  assign p_lang_sec2       = all_products[section.settings.product_lang_sec2]

  assign quiz_advisor_image_src = section.settings.advisor_image | strip
  if quiz_advisor_image_src contains 'shopify://shop_images/'
    assign quiz_advisor_image_src = quiz_advisor_image_src | remove: 'shopify://shop_images/' | file_url
  elsif quiz_advisor_image_src != blank
    unless quiz_advisor_image_src contains '://'
      assign quiz_advisor_image_src = quiz_advisor_image_src | file_url
    endunless
  endif
-%}

<section class="lt-quiz" id="lt-longevity-quiz">
  <div class="lt-quiz__container">

    {%- if section.settings.label != blank or section.settings.title != blank or section.settings.subtitle != blank -%}
      <div class="lt-quiz__header">
        {%- if section.settings.label != blank -%}
          <p class="lt-quiz__label">{{ section.settings.label | escape }}</p>
        {%- endif -%}
        <div class="lt-quiz__title-group">
          {%- if section.settings.title != blank -%}
            <h2 class="lt-quiz__title">{{ section.settings.title | escape }}</h2>
          {%- endif -%}
          {%- if section.settings.subtitle != blank -%}
            <p class="lt-quiz__subtitle">{{ section.settings.subtitle | escape }}</p>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    <div class="lt-quiz__progress" role="progressbar" aria-valuemin="0" aria-valuemax="100" aria-valuenow="0" aria-valuetext="Frage 1 von 8">
      <div class="lt-quiz__progress-line" aria-hidden="true">
        <div class="lt-quiz__progress-line-track"></div>
        <div class="lt-quiz__progress-bar" id="lt-quiz-progress-bar"></div>
      </div>
      <ol class="lt-quiz__milestones" id="lt-quiz-milestones"></ol>
    </div>
    <p class="lt-quiz__step-counter" id="lt-quiz-step-counter" aria-live="polite">Frage 1 von 8</p>

    <div class="lt-quiz__steps" id="lt-quiz-steps"></div>
    <div class="lt-quiz__results" id="lt-quiz-results" hidden></div>

  </div>
</section>

