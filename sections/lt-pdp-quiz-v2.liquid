{%- comment -%}
  LIFETIME — AGE & DNA Quiz v2 (Skeleton, Step 1+2)
  ──────────────────────────────────────────────────
  Implementiert Schritt 1 + 2 aus docs/lifetime-quiz-spec.md:
    1. Section-Skeleton + State-Maschine (intro → q1..q7 → loading → result)
    2. Slider-Frage (Q1 Schlaf) als Snippet, voll funktionsfähig

  Layout-Architektur ist bereits final (40/60-Grid + Fullscreen-Modus),
  damit Q2-Q7 visuell konsistent landen. Matrix-Slot ist als Platzhalter
  angelegt — Inhalt folgt in Schritt 3.
{%- endcomment -%}

{{ 'section-lt-pdp-quiz-v2.css' | asset_url | stylesheet_tag }}
<noscript>
  <link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/thin/style.css">
</noscript>
<link rel="stylesheet" href="https://unpkg.com/@phosphor-icons/web@2.1.1/src/thin/style.css">

{%- comment -%} Sitelink-Alias: kurzes #quiz statt #shopify-section-template--...__quiz_v2 {%- endcomment -%}
<a id="quiz" aria-hidden="true" tabindex="-1" style="display:block;scroll-margin-top:100px;"></a>

<section
  class="lt-quiz"
  data-lt-quiz-v2
  data-section-id="{{ section.id }}"
>
  {%- comment -%} Full-bleed Progress-Rail (außerhalb Container, edge-to-edge) {%- endcomment -%}
  <div class="lt-quiz__rail" aria-hidden="true">
    <div class="lt-quiz__rail-fill" data-quiz-progress-bar></div>
  </div>

  <div class="lt-quiz__container">

    {%- comment -%} Chrome-Row (Back + Counter + Close) — sichtbar während Fragen/Loading {%- endcomment -%}
    <div class="lt-quiz__topbar">
      <div class="lt-quiz__chrome-row">
        <button type="button" class="lt-quiz__back" data-quiz-back hidden aria-label="Zurück">←</button>
        <div class="lt-quiz__progress-label" data-quiz-progress-label aria-live="polite"></div>
        <button type="button" class="lt-quiz__close" data-quiz-close aria-label="Quiz schließen">×</button>
      </div>
    </div>

    {%- comment -%} ── Intro (2-Spalten: Text links, Bio-Age-Dashboard rechts) ── {%- endcomment -%}
    <div class="lt-quiz__step lt-quiz__step--intro" data-quiz-step="intro">
      <div class="lt-quiz__intro-grid">
        <div class="lt-quiz__intro-content">
          {%- render 'section-heading-crs',
              heading: 'Wie altert dein Körper',
              subheading: '…und was verraten dir deine Gene?',
              kicker: 'Dein biologischer Alterstest',
              align: 'left',
              headline_lg: true,
              extra_class: 'lt-quiz__intro-heading'
          -%}
          <p class="lt-quiz__intro-body">Das erfährst du mit unserem AGE &amp; DNA-Test. Vorab schätzt unser 2-Min-Quiz dein biologisches Alter und zeigt deine 3 relevantesten genetischen Treiber.</p>

          {%- if section.settings.intro_price != blank -%}
            <p class="lt-quiz__intro-price">{{ section.settings.intro_price | escape }}</p>
          {%- endif -%}
          <div class="lt-quiz__intro-ctas">
            {%- if section.settings.intro_cta_url != blank -%}
              <a href="{{ section.settings.intro_cta_url }}" class="lt-quiz__cta">
                {{ section.settings.intro_cta | escape }}
              </a>
            {%- else -%}
              <button type="button" class="lt-quiz__cta" data-quiz-start>
                {{ section.settings.intro_cta | escape }}
              </button>
            {%- endif -%}
            {%- if section.settings.intro_cta_secondary_label != blank -%}
              {%- if section.settings.intro_cta_secondary_url != blank -%}
                <a href="{{ section.settings.intro_cta_secondary_url }}" class="lt-quiz__cta lt-quiz__cta--ghost" data-quiz-pdp-cta="intro_secondary">
                  {{ section.settings.intro_cta_secondary_label | escape }}
                </a>
              {%- else -%}
                <button type="button" class="lt-quiz__cta lt-quiz__cta--ghost" data-quiz-start>
                  {{ section.settings.intro_cta_secondary_label | escape }}
                </button>
              {%- endif -%}
            {%- endif -%}
          </div>
          {%- if section.settings.intro_trust != blank -%}
            <p class="lt-quiz__intro-trust">{{ section.settings.intro_trust | escape }}</p>
          {%- endif -%}
        </div>

        {%- assign _intro_image = section.settings.intro_image | default: 'https://cdn.shopify.com/s/files/1/0621/2173/8340/files/lifetime-app-hand-test.png?v=1778667349' -%}
        <aside class="lt-quiz__intro-visual" aria-hidden="true">
          <img
            class="lt-quiz__intro-visual-img"
            src="{{ _intro_image }}"
            alt=""
            loading="eager"
            decoding="async"
            fetchpriority="high"
          >
        </aside>
      </div>
    </div>

    {%- comment -%} ── Fragen-Container (single column, zentriert) ────── {%- endcomment -%}
    <div class="lt-quiz__questions" data-quiz-grid hidden>

        {%- comment -%} ── Q1 Schlaf (Slider) ─────────────────────── {%- endcomment -%}
        {%- render 'lt-quiz-question-slider',
            step: 'q1',
            question_id: 'sleep',
            kicker: section.settings.q1_kicker,
            headline: section.settings.q1_headline,
            sub: section.settings.q1_sub,
            label_1: section.settings.q1_label_1,
            label_2: section.settings.q1_label_2,
            label_3: section.settings.q1_label_3,
            label_4: section.settings.q1_label_4,
            label_5: section.settings.q1_label_5,
            hint: section.settings.q1_hint
        -%}

        {%- comment -%} ── Q2 Energie (Slider) ────────────────────── {%- endcomment -%}
        {%- render 'lt-quiz-question-slider',
            step: 'q2',
            question_id: 'energy',
            kicker: 'Energie',
            headline: 'Wie ist deine Energie',
            sub: 'tagsüber?',
            label_1: 'Permanent müde',
            label_2: 'Oft müde',
            label_3: 'Wechselnd',
            label_4: 'Meistens fit',
            label_5: 'Voll Energie',
            hint: 'Müdigkeit hat oft drei genetische Quellen: Mikronährstoffe (MTHFR, VDR), Schlaf, und stille Entzündungen. Deine Antwort hilft uns, deinen Fokus zu bestimmen.'
        -%}

        {%- comment -%} ── Q3 Stress (Slider) ─────────────────────── {%- endcomment -%}
        {%- render 'lt-quiz-question-slider',
            step: 'q3',
            question_id: 'stress',
            kicker: 'Stress',
            headline: 'Wie sehr belastet dich',
            sub: 'Stress?',
            label_1: 'Sehr stark',
            label_2: 'Stark',
            label_3: 'Mittel',
            label_4: 'Wenig',
            label_5: 'Kaum',
            hint: 'Wie dein Körper Stress verarbeitet, steht in deinem COMT-Gen. Das beeinflusst Schlaf, Konzentration und sogar dein biologisches Alter.'
        -%}

        {%- comment -%} ── Q4 Gewicht (Slider) ────────────────────── {%- endcomment -%}
        {%- render 'lt-quiz-question-slider',
            step: 'q4',
            question_id: 'weight',
            kicker: 'Stoffwechsel',
            headline: 'Wie zufrieden bist du',
            sub: 'mit Gewicht und Stoffwechsel?',
            label_1: 'Gar nicht',
            label_2: 'Wenig',
            label_3: 'Mittel',
            label_4: 'Ziemlich',
            label_5: 'Sehr',
            hint: 'Dein FTO- und TCF7L2-Gen bestimmen, wie dein Körper auf Kohlenhydrate reagiert. Deine Selbsteinschätzung hilft uns, den passenden Schwerpunkt zu setzen.'
        -%}

        {%- comment -%} ── Q5 Aktivität (Single-Select Cards) ─────── {%- endcomment -%}
        {%- assign q5_options = 'aktiv|Sportlich aktiv|barbell,arm|Eher bewegungsarm|couch,wechselnd|Wechselnd|arrows-clockwise,neustart|Will neu starten|target' | split: ',' -%}
        {%- render 'lt-quiz-question-cards',
            step: 'q5',
            question_id: 'activity',
            kicker: 'Bewegung',
            headline: 'Wie aktiv bist du',
            sub: 'körperlich?',
            options: q5_options,
            hint: 'Sport wirkt genetisch verschieden. Dein ACTN3-Gen bestimmt, ob du eher Kraft- oder Ausdauertyp bist. So priorisieren wir die richtigen Empfehlungen.'
        -%}

        {%- comment -%} ── Q6 Prävention (Multi-Select Cards, max 3) ─ {%- endcomment -%}
        {%- assign q6_options = 'herz|Herz & Kreislauf|heart,kognition|Geistige Fitness|brain,haut|Haut & Haar|sparkle,supplements|Vitamine & Supplements|pill,bioalter|Biologisches Alter|dna' | split: ',' -%}
        {%- render 'lt-quiz-question-multi',
            step: 'q6',
            question_id: 'prevention',
            kicker: 'Prävention',
            headline: 'Worauf willst du dich',
            sub: 'präventiv konzentrieren?',
            options: q6_options,
            max_select: 3,
            hint: 'Manche genetischen Marker werden ab einer Lebensphase wichtiger: APOE für Herz und Kognition, AR für Haar, SIRT1 und FOXO3 für Langlebigkeit.'
        -%}

        {%- comment -%} ── Q7 Geschlecht (Single-Select Cards) ───── {%- endcomment -%}
        {%- assign q7_options = 'female|Frau|gender-female,male|Mann|gender-male,diverse|Divers / keine Angabe|gender-nonbinary' | split: ',' -%}
        {%- render 'lt-quiz-question-cards',
            step: 'q7',
            question_id: 'gender',
            kicker: 'Geschlecht',
            headline: 'Du bist…',
            options: q7_options,
            hint: 'Dein Geschlecht beeinflusst, welche genetischen Marker für dich relevanter sind, z. B. AR-Gen für Haarausfall oder hormonelle Verschiebungen. Außerdem stellen wir dein Ergebnis passend dar.'
        -%}

        {%- comment -%} ── Q8 Alter (Numeric Slider) ──────────────── {%- endcomment -%}
        {%- render 'lt-quiz-question-age',
            step: 'q8',
            question_id: 'age',
            kicker: 'Alter',
            headline: 'Wie alt bist du?',
            age_min: 25,
            age_max: 75,
            age_default: 40,
            unit_label: 'Jahre',
            hint: 'Manche Themen werden mit dem Alter relevanter (hormonelle Verschiebungen, Prävention, kognitive Reserve). Dein Alter hilft uns, die richtige Tiefe zu wählen.'
        -%}

    </div>

    {%- comment -%} ── Loading-Screen ──────────────────────────────────── {%- endcomment -%}
    <div class="lt-quiz__step lt-quiz__step--loading" data-quiz-step="loading" hidden>
      {%- render 'lt-quiz-loading' -%}
    </div>

    {%- comment -%} ── Result-Page ─────────────────────────────────────── {%- endcomment -%}
    <div class="lt-quiz__step lt-quiz__step--result" data-quiz-step="result" hidden>
      {%- render 'lt-quiz-result',
          hero_female: section.settings.hero_image_female,
          hero_male: section.settings.hero_image_male,
          cta_image: section.settings.cta_image,
          cta_image_bonus: section.settings.cta_image_bonus
      -%}
    </div>

  </div>
</section>

<script src="{{ 'lt-quiz-v2.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "LT Quiz v2",
  "tag": "section",
  "class": "section lt-quiz-section",
  "settings": [
    {
      "type": "header",
      "content": "Intro"
    },
    {
      "type": "text",
      "id": "intro_kicker",
      "label": "Intro Kicker",
      "default": "Dein biologischer Alterstest"
    },
    {
      "type": "text",
      "id": "intro_headline",
      "label": "Intro Headline",
      "default": "Wie altert dein Körper"
    },
    {
      "type": "textarea",
      "id": "intro_sub",
      "label": "Intro Sub-Headline (gleiche Größe, mit Opacity)",
      "default": "…und was verraten dir deine Gene?"
    },
    {
      "type": "textarea",
      "id": "intro_body",
      "label": "Intro Body-Paragraph",
      "default": "Das erfährst du mit unserem AGE & DNA-Test. Vorab schätzt unser 2-Min-Quiz dein biologisches Alter und zeigt deine 3 relevantesten genetischen Treiber."
    },
    {
      "type": "text",
      "id": "intro_price",
      "label": "Intro Preis-Zeile (optional, default leer)",
      "info": "Default leer — Preis kommt aus den Google-Ads-Pin-Extensions. Wenn doch im Hero gewünscht, hier eintragen."
    },
    {
      "type": "text",
      "id": "intro_cta",
      "label": "Intro CTA Primary (Label)",
      "default": "2-Min-Quiz starten →"
    },
    {
      "type": "text",
      "id": "intro_cta_url",
      "label": "Intro CTA Primary (Link, leer = startet Quiz)",
      "info": "Leer lassen damit der Button das Quiz startet. Wenn URL angegeben, wird's ein normaler Link."
    },
    {
      "type": "text",
      "id": "intro_cta_secondary_label",
      "label": "Intro CTA Sekundär (Label)",
      "default": "Jetzt Test bestellen →"
    },
    {
      "type": "text",
      "id": "intro_cta_secondary_url",
      "label": "Intro CTA Sekundär (Link, leer = startet Quiz)",
      "default": "/products/lifetime-age-dna"
    },
    {
      "type": "text",
      "id": "intro_trust",
      "label": "Intro Trust-Zeile (optional)",
      "info": "Default leer — Limmroth-Trust kommt aus der Authority-Section weiter unten."
    },
    {
      "type": "text",
      "id": "intro_image",
      "label": "Intro Hero-Bild (URL)",
      "info": "Wird rechts neben dem Intro-Text angezeigt. Komplett sichtbar (nicht beschnitten).",
      "default": "https://cdn.shopify.com/s/files/1/0621/2173/8340/files/lifetime-app-hand-test.png?v=1778667349"
    },
    {
      "type": "header",
      "content": "Result-Hero"
    },
    {
      "type": "text",
      "id": "hero_image_female",
      "label": "Hero-Bild Frau (URL)",
      "info": "Volle URL zum Bild auf dem Shopify-CDN",
      "default": "https://cdn.shopify.com/s/files/1/0621/2173/8340/files/lifetime-sport-mood-tennis-woman.png?v=1777040629"
    },
    {
      "type": "text",
      "id": "hero_image_male",
      "label": "Hero-Bild Mann/Divers (URL)",
      "info": "Fallback auch für 'diverse'",
      "default": "https://cdn.shopify.com/s/files/1/0621/2173/8340/files/lifetime-lifestyle-2_800x800.png?v=1777898071"
    },
    {
      "type": "text",
      "id": "cta_image",
      "label": "CTA-Bild Primär (Test-Kit, URL)",
      "info": "Größeres Hauptbild rechts in der Result-CTA-Card",
      "default": "https://cdn.shopify.com/s/files/1/0621/2173/8340/files/product-8585364.png?v=1768563330"
    },
    {
      "type": "text",
      "id": "cta_image_bonus",
      "label": "CTA-Bild Bonus (Longevity-Guide, URL)",
      "info": "Kleineres Bonus-Bild überlappend unten-links",
      "default": "https://cdn.shopify.com/s/files/1/0621/2173/8340/files/33eea4ca-2b8c-40f6-8a00-abced1d6c5b2-1762948710197.png?v=1762948715"
    },
    {
      "type": "header",
      "content": "Q1 Schlaf"
    },
    {
      "type": "text",
      "id": "q1_kicker",
      "label": "Kicker (Thema-Anker)",
      "default": "Schlaf"
    },
    {
      "type": "text",
      "id": "q1_headline",
      "label": "Headline",
      "default": "Wie ist dein"
    },
    {
      "type": "text",
      "id": "q1_sub",
      "label": "Sub-Headline (mit Opacity)",
      "default": "Schlaf?"
    },
    { "type": "text", "id": "q1_label_1", "label": "Label 1", "default": "Sehr schlecht" },
    { "type": "text", "id": "q1_label_2", "label": "Label 2", "default": "Schlecht" },
    { "type": "text", "id": "q1_label_3", "label": "Label 3", "default": "Mittel" },
    { "type": "text", "id": "q1_label_4", "label": "Label 4", "default": "Gut" },
    { "type": "text", "id": "q1_label_5", "label": "Label 5", "default": "Sehr gut" },
    {
      "type": "textarea",
      "id": "q1_hint",
      "label": "Warum fragen wir das?",
      "default": "Schlaf ist genetisch stark beeinflusst. Dein PER3-Gen bestimmt deinen Chronotyp, dein CYP1A2-Gen, wie schnell du Koffein abbaust. Deine Antwort hilft uns, dir die relevanten DNA-Bereiche zu zeigen."
    }
  ],
  "presets": [
    {
      "name": "LT Quiz v2"
    }
  ]
}
{% endschema %}
