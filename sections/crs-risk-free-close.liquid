{%- liquid
  assign crs_rfc_default_product_handle = ''
  if template.name == 'page' and template.suffix == 'age-dna-landing'
    assign crs_rfc_default_product_handle = 'lifetime-age-dna'
  endif
  assign crs_rfc_product = product
  if section.settings.product != blank
    assign crs_rfc_product = all_products[section.settings.product]
  elsif crs_rfc_product == blank and crs_rfc_default_product_handle != blank
    assign crs_rfc_product = all_products[crs_rfc_default_product_handle]
  endif
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_rfc_kicker = section.settings.kicker | strip
  assign crs_rfc_head = section.settings.headline | strip
  assign crs_rfc_sub = section.settings.subheading | strip
  assign crs_rfc_badge = section.settings.badge_text | strip
  assign crs_rfc_price = section.settings.price_fallback | strip
  assign crs_rfc_cta = section.settings.cta_label | strip
  if crs_rfc_kicker == '__none__'
    assign crs_rfc_kicker = ''
  endif
  if crs_rfc_sub == '__none__'
    assign crs_rfc_sub = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif

  assign crs_rfc_image = section.settings.image
  if crs_rfc_image == blank and crs_rfc_product.featured_media != blank
    assign crs_rfc_image = crs_rfc_product.featured_media.preview_image
  endif
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.08 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background:     var(--crs-bg);
  }
{% endstyle %}

<div class="rfc-section" id="section-{{ section.id }}">
  <div class="rfc-container">
    <div class="rfc-grid">
      <div class="rfc-media">
        <div class="rfc-media-card">
          {%- if crs_rfc_image != blank -%}
            {{
              crs_rfc_image
              | image_url: width: 1400
              | image_tag:
                loading: 'lazy',
                class: 'rfc-image',
                sizes: '(max-width: 767px) calc(100vw - 40px), 50vw',
                alt: section.settings.image_alt | default: crs_rfc_product.title | escape
            }}
          {%- else -%}
            <div class="rfc-image rfc-image--placeholder" aria-hidden="true"></div>
          {%- endif -%}

          {%- if crs_rfc_badge != blank -%}
            <div class="rfc-badge">
              <span>{{ crs_rfc_badge | escape }}</span>
            </div>
          {%- endif -%}
        </div>
      </div>

      <div class="rfc-copy rfc-copy--align-{{ crs_h_align }}">
        {%- if crs_rfc_kicker != blank or crs_rfc_head != blank or crs_rfc_sub != blank -%}
          <div class="crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
            {%- if crs_rfc_kicker != blank -%}
              <p class="crs-heading-stack__kicker">{{ crs_rfc_kicker | escape }}</p>
            {%- endif -%}
            {%- if crs_rfc_head != blank or crs_rfc_sub != blank -%}
              <div class="crs-heading-stack__pair">
                {%- if crs_rfc_head != blank -%}
                  <h2 class="crs-heading-stack__title">{{ crs_rfc_head | escape | newline_to_br }}</h2>
                {%- endif -%}
                {%- if crs_rfc_sub != blank -%}
                  <p class="crs-heading-stack__subtitle">{{ crs_rfc_sub | escape | newline_to_br }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}

        {%- if crs_rfc_price != blank -%}
          <p class="rfc-price" data-rfc-price>{{ crs_rfc_price | escape }}</p>
        {%- else -%}
          <p class="rfc-price" data-rfc-price hidden></p>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <ul class="rfc-trust-list" role="list">
            {%- for block in section.blocks -%}
              {%- if block.type == 'trust_line' and block.settings.text != blank -%}
                <li class="rfc-trust-item" {{ block.shopify_attributes }}>
                  <span class="rfc-trust-icon" aria-hidden="true">
                    <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                      <circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1" opacity="0.4"></circle>
                      <path d="M4 7l2 2 4-4" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"></path>
                    </svg>
                  </span>
                  <span>{{ block.settings.text | escape }}</span>
                </li>
              {%- endif -%}
            {%- endfor -%}
          </ul>
        {%- endif -%}

        {%- if crs_rfc_cta != blank -%}
          {%- if section.settings.cta_url != blank -%}
            <a href="{{ section.settings.cta_url }}" class="rfc-cta">
              {{ crs_rfc_cta | escape }}
            </a>
          {%- else -%}
            <button type="button" class="rfc-cta" data-rfc-scroll>
              {{ crs_rfc_cta | escape }}
            </button>
          {%- endif -%}
        {%- endif -%}
      </div>
    </div>
  </div>
</div>

<script>
  (function () {
    var root = document.getElementById('section-{{ section.id }}');
    if (!root) return;

    var cta = root.querySelector('[data-rfc-scroll]');
    var priceEl = root.querySelector('[data-rfc-price]');

    function syncSubscriptionPrice() {
      if (!priceEl) return;

      var subCard = document.querySelector('[data-bb-kind="sub"]');
      if (!subCard) return;

      var currentEl = subCard.querySelector('[data-lt-bb-current]');
      var unitEl = subCard.querySelector('[data-lt-bb-unit]');
      var current = currentEl ? currentEl.textContent.trim() : '';
      var unit = unitEl ? unitEl.textContent.trim() : '';

      if (!current && !unit) return;

      priceEl.hidden = false;
      priceEl.textContent = current && unit ? current + ' · ' + unit : current || unit;
    }

    syncSubscriptionPrice();

    var subCard = document.querySelector('[data-bb-kind="sub"]');
    if (subCard) {
      var priceObserver = new MutationObserver(syncSubscriptionPrice);
      priceObserver.observe(subCard, { childList: true, subtree: true, characterData: true });
      window.setTimeout(function () {
        priceObserver.disconnect();
      }, 12000);
    }

    if (!cta) return;

    cta.addEventListener('click', function () {
      var target = document.querySelector('[data-lt-buy-box]') || document.getElementById('lt-hero-atc');
      if (!target) return;

      var offset = 96;
      var y = target.getBoundingClientRect().top + window.pageYOffset - offset;
      window.scrollTo({ top: Math.max(0, y), behavior: 'smooth' });
    });
  })();
</script>

{% stylesheet %}
.rfc-section {
  background: var(--crs-bg, #f7f7f4);
}

.rfc-container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 20px;
}

.rfc-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-6);
  align-items: center;
}

.rfc-media-card {
  position: relative;
  background: transparent;
  border: none;
  border-radius: 0;
  overflow: visible;
  aspect-ratio: 6 / 5;
}

.rfc-image {
  width: 100%;
  height: 100%;
  display: block;
  object-fit: contain;
  object-position: center;
  background: transparent;
}

.rfc-image--placeholder {
  background:
    linear-gradient(180deg, rgba(255,255,255,0.26), rgba(255,255,255,0)),
    var(--crs-card-bg, #f2f1ed);
}

.rfc-badge {
  position: absolute;
  top: 16px;
  right: 16px;
  min-width: 128px;
  min-height: 42px;
  border-radius: 999px;
  background: var(--crs-text, #26251e);
  color: #fff;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 10px 16px;
  box-sizing: border-box;
  transform: rotate(-4deg);
}

.rfc-badge span {
  font-size: 10px;
  line-height: 1;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  white-space: nowrap;
}

.rfc-copy {
  display: flex;
  flex-direction: column;
  gap: var(--space-4);
}

.rfc-copy--align-left {
  align-items: flex-start;
  text-align: left;
}

.rfc-copy--align-center {
  align-items: center;
  text-align: center;
}

.rfc-copy--align-right {
  align-items: flex-end;
  text-align: right;
}

.rfc-price {
  margin: 0;
  font-size: 15px;
  font-weight: 500;
  line-height: 1.35;
  color: var(--crs-text, #26251e);
}

.rfc-trust-list {
  list-style: none;
  display: grid;
  gap: 10px;
  margin: 0;
  padding: 0;
  width: 100%;
}

.rfc-trust-item {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 15px;
  line-height: 1.4;
  color: var(--crs-text, #26251e);
}

.rfc-copy--align-center .rfc-trust-item {
  justify-content: center;
}

.rfc-copy--align-right .rfc-trust-item {
  justify-content: flex-end;
}

.rfc-trust-icon {
  flex: 0 0 auto;
  color: var(--crs-text, #26251e);
  opacity: 0.85;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.rfc-cta {
  min-height: 46px;
  padding: 0 22px;
  border: 1px solid var(--crs-text, #26251e);
  border-radius: 999px;
  background: var(--crs-text, #26251e);
  color: #fff;
  font-size: 14px;
  font-weight: 500;
  line-height: 1;
  text-align: center;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: transform 0.18s ease, opacity 0.18s ease, background-color 0.18s ease, border-color 0.18s ease;
}

.rfc-cta:hover {
  transform: translateY(-1px);
  opacity: 0.92;
}

.rfc-cta:focus-visible {
  outline: none;
  box-shadow: 0 0 0 2px var(--crs-bg, #f7f7f4), 0 0 0 4px color-mix(in srgb, var(--crs-text) 16%, transparent);
}

@media (max-width: 767px) {
  .rfc-grid {
    grid-template-columns: 1fr;
    gap: var(--space-4);
  }

  .rfc-media {
    order: 1;
  }

  .rfc-copy {
    order: 2;
  }

  .rfc-badge {
    top: 12px;
    right: 12px;
    min-width: 110px;
    min-height: 38px;
    padding: 9px 14px;
  }

  .rfc-media-card {
    aspect-ratio: 1 / 1;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Risk-Free Close",
  "tag": "section",
  "class": "crs-risk-free-close",
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Produkt",
      "info": "Optional für Landing Pages oder andere Nicht-Produkt-Templates."
    },
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 64
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Ausrichtung",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Überschrift Größe",
      "options": [
        { "value": "section", "label": "Standard (Abschnitt)" },
        { "value": "product_title", "label": "Wie Produkttitel" }
      ],
      "default": "section",
      "info": "Zeilenumbruch: Enter in Überschrift/Unterüberschrift."
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Bild Alt-Text",
      "default": "Produktbild"
    },
    {
      "type": "text",
      "id": "badge_text",
      "label": "Badge",
      "default": "Abo-Vorteil"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "Täglich besser. Monat für Monat.",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "textarea",
      "id": "headline",
      "label": "Überschrift",
      "default": "NMN wirkt — wenn man es durchhält."
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Unterüberschrift (optional)",
      "default": "Im Abo sparst du 10 %, bekommst gratis Versand und kannst jederzeit pausieren oder kündigen. Kein Risiko, voller Effekt.",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "text",
      "id": "price_fallback",
      "label": "Preis Fallback",
      "default": "35,90 € · 0,60 €/Tag",
      "info": "Wird automatisch vom Abo-Preis der Buy-Box überschrieben, falls vorhanden."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA-Label",
      "default": "Jetzt im Abo bestellen →"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA-Zielseite",
      "info": "Wenn gesetzt: direkter Link statt Scroll-Button. Für page-Templates pflicht."
    }
  ],
  "blocks": [
    {
      "type": "trust_line",
      "name": "Trust Line",
      "limit": 6,
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Trust Line"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Risk-Free Close",
      "blocks": [
        {
          "type": "trust_line",
          "settings": {
            "text": "10 % günstiger als Einzelkauf"
          }
        },
        {
          "type": "trust_line",
          "settings": {
            "text": "Gratisversand bei jeder Lieferung"
          }
        },
        {
          "type": "trust_line",
          "settings": {
            "text": "Jederzeit pausieren oder kündigen"
          }
        },
        {
          "type": "trust_line",
          "settings": {
            "text": "30 Tage Geld-zurück-Garantie"
          }
        }
      ]
    }
  ]
}
{% endschema %}
