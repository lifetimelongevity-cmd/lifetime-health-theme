<div class="ckb-section" id="section-{{ section.id }}">
  <div class="ckb-container">
    <div class="ckb-card">

      {%- comment -%} LEFT — text + testimonial {%- endcomment -%}
      <div class="ckb-content">
        <div class="ckb-text-block">
          <h2 class="ckb-heading">{{ section.settings.heading | escape }}</h2>
          <p class="ckb-subheading">{{ section.settings.subheading | escape }}</p>
        </div>

        {%- if section.settings.quote_text != blank -%}
          <figure class="ckb-quote">
            <blockquote>
              <p class="ckb-quote-body">{{ section.settings.quote_text | escape }}</p>
            </blockquote>
            <figcaption class="ckb-author">
              {%- if section.settings.author_image != blank -%}
                <div class="ckb-avatar">
                  {{
                    section.settings.author_image
                    | image_url: width: 84
                    | image_tag:
                      width: 42,
                      height: 42,
                      loading: 'lazy',
                      alt: section.settings.author_name | escape
                  }}
                </div>
              {%- endif -%}
              <div class="ckb-author-info">
                <span class="ckb-author-name">{{ section.settings.author_name | escape }}</span>
                <span class="ckb-author-role">{{ section.settings.author_role | escape }}</span>
              </div>
            </figcaption>
          </figure>
        {%- endif -%}
      </div>

      {%- comment -%} RIGHT — image {%- endcomment -%}
      <div class="ckb-visual">
        {%- if section.settings.image != blank -%}
          {{
            section.settings.image
            | image_url: width: 1400
            | image_tag:
              loading: 'lazy',
              class: 'ckb-visual-img',
              alt: section.settings.image.alt | escape
          }}
        {%- else -%}
          <div class="ckb-visual-placeholder">
            {{ 'image' | placeholder_svg_tag: 'ckb-placeholder-svg' }}
          </div>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
/* ===================================================
   Cursor Knowledge Base — cursor-knowledge-base.liquid
   =================================================== */

.ckb-section {
  padding: 60px 0;
  background: var(--color-background-main, #fff);
}

.ckb-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 24px;
}

/* Card */
.ckb-card {
  display: grid;
  grid-template-columns: 1fr 2fr;
  min-height: 560px;
  border-radius: 16px;
  overflow: hidden;
  border: 1px solid rgba(0, 0, 0, .08);
  box-shadow: 0 4px 24px rgba(0, 0, 0, .06);
  background: var(--color-background-main, #fafaf9);
}

/* Left column */
.ckb-content {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 52px 44px;
  gap: 28px;
}

.ckb-text-block {
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.ckb-heading {
  font-size: clamp(1.5rem, 2.2vw, 2.25rem);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -.03em;
  color: var(--color-foreground-main, #111) !important;
  margin: 0;
}

.ckb-subheading {
  font-size: clamp(1.5rem, 2.2vw, 2.25rem);
  font-weight: 700;
  line-height: 1.15;
  letter-spacing: -.03em;
  color: var(--color-secondary-text-main, #999);
  margin: 0;
}

/* Testimonial quote */
.ckb-quote {
  margin: 0;
  border-left: 2px solid rgba(0, 0, 0, .15);
  padding-left: 20px;
}

.ckb-quote-body {
  font-size: .9375rem;
  line-height: 1.6;
  color: var(--color-foreground-main, #111);
  margin: 0 0 16px;
}

/* Author */
.ckb-author {
  display: flex;
  align-items: center;
  gap: 12px;
}

.ckb-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  overflow: hidden;
  flex-shrink: 0;
  border: 2px solid rgba(0, 0, 0, .08);
}

.ckb-avatar img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.ckb-author-info {
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.ckb-author-name {
  font-size: .875rem;
  font-weight: 600;
  color: var(--color-foreground-main, #111);
}

.ckb-author-role {
  font-size: .8125rem;
  color: var(--color-secondary-text-main, #666);
}

/* Right column — image */
.ckb-visual {
  position: relative;
  overflow: hidden;
}

.ckb-visual-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.ckb-visual-placeholder {
  width: 100%;
  height: 100%;
  min-height: 400px;
  background: var(--color-background-main-alternate, #f0f0f0);
  display: flex;
  align-items: center;
  justify-content: center;
}

.ckb-placeholder-svg {
  width: 60px;
  height: 60px;
  opacity: .3;
}

/* Responsive — tablet */
@media (max-width: 1024px) {
  .ckb-card {
    grid-template-columns: 1fr;
    grid-template-rows: auto 360px;
  }

  .ckb-visual {
    order: -1;
  }

  .ckb-content {
    padding: 40px 32px;
  }
}

/* Responsive — mobile */
@media (max-width: 640px) {
  .ckb-section {
    padding: 40px 0;
  }

  .ckb-container {
    padding: 0 16px;
  }

  .ckb-content {
    padding: 32px 20px;
    gap: 20px;
  }

  .ckb-visual {
    min-height: 280px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Cursor Knowledge Base",
  "tag": "section",
  "class": "cursor-knowledge-base",
  "settings": [
    {
      "type": "header",
      "content": "Linke Spalte — Text"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Deine Wissensdatenbank fürs Engineering"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterüberschrift",
      "default": "Ausgelegt für komplexe Codebasen, an denen Tausende von Entwicklern arbeiten."
    },
    {
      "type": "header",
      "content": "Testimonial"
    },
    {
      "type": "textarea",
      "id": "quote_text",
      "label": "Zitat",
      "default": "Über alle Rollen und Erfahrungsstufen hinweg sehen wir einen Anstieg des PR-Volumens um über 25 % und der durchschnittlichen PR-Größe um über 100 %. Zusammengenommen bedeutet das, dass wir rund 50 % mehr Code ausliefern."
    },
    {
      "type": "image_picker",
      "id": "author_image",
      "label": "Autorenfoto"
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Name",
      "default": "Anton Andreev"
    },
    {
      "type": "text",
      "id": "author_role",
      "label": "Position",
      "default": "Principal Software Engineer, Upwork"
    },
    {
      "type": "header",
      "content": "Rechte Spalte — Bild"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bild"
    }
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Cursor Knowledge Base"
    }
  ]
}
{% endschema %}
