          "settings": {
            "step_number": "02",
            "step_title": "App scannen & Speichelprobe entnehmen",
            "step_body": "Scanne den QR-Code im Kit, um deine Probe in der App zu registrieren. Dann: Speichelprobe entnehmen – nicht-invasiv, weniger als 5 Minuten.",
            "show_callout": false,
            "callout_text": "Zertifizierungshinweis"
