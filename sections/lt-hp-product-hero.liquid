{% comment %} lt-hp-product-hero — Stub. Liquid pending. {% endcomment %}

{% schema %}
{
  "name": "HP Product Hero",
  "settings": [
    { "type": "color", "id": "color_bg", "label": "Hintergrundfarbe" },
    { "type": "color", "id": "color_text", "label": "Textfarbe" },
    { "type": "range", "id": "padding_top", "label": "Abstand oben", "min": 0, "max": 200, "step": 8, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Abstand unten", "min": 0, "max": 200, "step": 8, "default": 80, "unit": "px" },
    { "type": "text", "id": "kicker", "label": "Kicker" },
    { "type": "text", "id": "headline", "label": "Headline" },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline" },
    { "type": "text", "id": "product_image_url", "label": "Produktbild URL" },
    { "type": "text", "id": "product_price", "label": "Preis" },
    { "type": "url", "id": "product_url", "label": "Produkt-Link" },
    { "type": "text", "id": "cta_label", "label": "CTA Text" },
    { "type": "checkbox", "id": "show_lab_badge", "label": "Labor-Badge anzeigen", "default": true },
    { "type": "text", "id": "lab_badge_text", "label": "Labor-Badge Text" },
    { "type": "url", "id": "sample_report_url", "label": "Beispielbericht URL" },
    { "type": "text", "id": "sample_report_label", "label": "Beispielbericht Link-Text" }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        { "type": "text", "id": "feature_icon", "label": "Icon-Kennung" },
        { "type": "text", "id": "feature_title", "label": "Titel" },
        { "type": "textarea", "id": "feature_body", "label": "Beschreibung" }
      ]
    }
  ],
  "presets": [{ "name": "HP Product Hero" }]
}
{% endschema %}
