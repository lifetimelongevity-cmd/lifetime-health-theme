{% style %}
  #section-{{ section.id }} {
    --mg-text:     {{ settings.color_text_main | default: '#26251e' }};
    --mg-text-sec: {{ settings.color_text_main | color_modify: 'alpha', 0.6 | default: 'rgba(38,37,30,0.6)' }};
    --mg-bg:       {{ settings.color_background_main | default: '#f7f7f4' }};
    --mg-card-bg:  {{ settings.color_background_main | color_modify: 'lightness', -3 | default: '#f2f1ed' }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="mg-section" id="section-{{ section.id }}">
  <div class="mg-container">

    {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
      <div class="mg-header">
        {%- if section.settings.heading != blank -%}
          <h2 class="mg-heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheading != blank -%}
          <p class="mg-subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="mg-grid">
        {%- for block in section.blocks -%}
          <div class="mg-card" {{ block.shopify_attributes }}>
            <div class="mg-number">{{ block.settings.number | escape }}</div>
            {%- if block.settings.description != blank -%}
              <div class="mg-desc">{{ block.settings.description | escape }}</div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
/* ===================================================
   Metrics Row — crs-metrics-row.liquid
   =================================================== */

.mg-section {
  background: var(--mg-bg, #f7f7f4);
}

.mg-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Header */
.mg-header {
  margin-bottom: 32px;
}

.mg-heading {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: 36px !important;
  font-weight: 400 !important;
  line-height: 1.15 !important;
  letter-spacing: -0.72px !important;
  color: var(--mg-text, #26251e) !important;
  margin: 0 0 8px !important;
}

.mg-subheading {
  font-size: 16px;
  font-weight: 400;
  line-height: 1.6;
  color: var(--mg-text-sec, rgba(38,37,30,0.6));
  margin: 0;
}

/* Grid */
.mg-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

/* Card */
.mg-card {
  background: var(--mg-card-bg, #f2f1ed);
  border-radius: 4px;
  padding: 12.5px 15px 15px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  aspect-ratio: 16 / 9;
}

/* Big number */
.mg-number {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  font-size: 52px;
  font-weight: 400;
  line-height: 59.8px;
  letter-spacing: -1.3px;
  color: var(--mg-text, #26251e);
}

/* Description */
.mg-desc {
  font-size: 16px;
  font-weight: 400;
  line-height: 1.5;
  color: var(--mg-text, #26251e);
  margin-top: auto;
}

/* Tablet — 2 columns */
@media (max-width: 1024px) {
  .mg-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .mg-card {
    aspect-ratio: auto;
    min-height: 140px;
  }
}

/* Mobile — 1 column */
@media (max-width: 640px) {
  .mg-grid {
    grid-template-columns: 1fr;
  }

  .mg-number {
    font-size: 40px;
    line-height: 1.2;
    letter-spacing: -1px;
  }

  .mg-card {
    min-height: 120px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Metrics Row",
  "tag": "section",
  "class": "crs-metrics-row",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift (optional)"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Unterüberschrift (optional)"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "metric",
      "name": "Kennzahl",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Zahl / Wert",
          "default": ">99,9%"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Beschreibung",
          "default": "bestätigte NMN-Reinheit"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Metrics Row",
      "blocks": [
        {
          "type": "metric",
          "settings": {
            "number": ">99,9%",
            "description": "bestätigte NMN-Reinheit"
          }
        },
        {
          "type": "metric",
          "settings": {
            "number": "90 Tage",
            "description": "Geld-zurück-Garantie"
          }
        },
        {
          "type": "metric",
          "settings": {
            "number": "60 Tage",
            "description": "Versorgung pro Beutel"
          }
        }
      ]
    }
  ]
}
{% endschema %}
