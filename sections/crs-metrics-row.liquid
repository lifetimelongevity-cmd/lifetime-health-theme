{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_mg_kicker = section.settings.kicker | strip
  assign crs_mg_head = section.settings.heading | strip
  assign crs_mg_sub = section.settings.subheading | strip
  if crs_mg_kicker == '__none__'
    assign crs_mg_kicker = ''
  endif
  if crs_mg_head == '__none__'
    assign crs_mg_head = ''
  endif
  if crs_mg_sub == '__none__'
    assign crs_mg_sub = ''
  endif
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.05 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<div class="mg-section" id="section-{{ section.id }}">
  <div class="mg-container">

    {%- if crs_mg_kicker != blank or crs_mg_head != blank or crs_mg_sub != blank -%}
      <div class="mg-header crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}">
        {%- if crs_mg_kicker != blank -%}
          <p class="crs-heading-stack__kicker">{{ crs_mg_kicker | escape }}</p>
        {%- endif -%}
        {%- if crs_mg_head != blank or crs_mg_sub != blank -%}
          <div class="crs-heading-stack__pair">
            {%- if crs_mg_head != blank -%}
              <h2 class="crs-heading-stack__title">{{ crs_mg_head | escape }}</h2>
            {%- endif -%}
            {%- if crs_mg_sub != blank -%}
              <p class="crs-heading-stack__subtitle">{{ crs_mg_sub | escape }}</p>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="mg-grid">
        {%- for block in section.blocks -%}
          <div class="mg-card" {{ block.shopify_attributes }}>
            <div class="mg-number">{{ block.settings.number | escape }}</div>
            {%- if block.settings.description != blank -%}
              <div class="mg-desc">{{ block.settings.description | escape }}</div>
            {%- endif -%}
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% stylesheet %}
/* ===================================================
   Metrics Row — crs-metrics-row.liquid
   =================================================== */

.mg-section {
  background: var(--crs-bg, #f7f7f4);
}

.mg-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

/* Header */
.mg-header {
  margin-bottom: var(--space-7);
}

/* Grid */
.mg-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10px;
}

/* Card */
.mg-card {
  box-sizing: border-box;
  background: var(--crs-card-bg, #f2f1ed);
  border: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
  border-radius: 4px;
  padding: 12.5px 15px 15px;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  aspect-ratio: 16 / 9;
}

/* Big number */
.mg-number {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  font-size: 52px;
  font-weight: 400;
  line-height: 59.8px;
  letter-spacing: -1.3px;
  color: var(--crs-text, #26251e);
}

/* Description */
.mg-desc {
  font-size: 16px;
  font-weight: 400;
  line-height: 1.5;
  color: var(--crs-text, #26251e);
  margin-top: auto;
}

/* Tablet — 2 columns */
@media (max-width: 1024px) {
  .mg-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .mg-card {
    aspect-ratio: auto;
    min-height: 140px;
  }
}

/* Mobile — 1 column */
@media (max-width: 640px) {
  .mg-grid {
    grid-template-columns: 1fr;
  }

  .mg-number {
    font-size: 40px;
    line-height: 1.2;
    letter-spacing: -1px;
  }

  .mg-card {
    min-height: 120px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "Metrics Row",
  "tag": "section",
  "class": "crs-metrics-row",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Ausrichtung (Überschrift)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Unterüberschrift (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    }
  ],
  "blocks": [
    {
      "type": "metric",
      "name": "Kennzahl",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Zahl / Wert",
          "default": ">99,9%"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Beschreibung",
          "default": "bestätigte NMN-Reinheit"
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "Metrics Row",
      "blocks": [
        {
          "type": "metric",
          "settings": {
            "number": ">99,9%",
            "description": "bestätigte NMN-Reinheit"
          }
        },
        {
          "type": "metric",
          "settings": {
            "number": "90 Tage",
            "description": "Geld-zurück-Garantie"
          }
        },
        {
          "type": "metric",
          "settings": {
            "number": "60 Tage",
            "description": "Versorgung pro Beutel"
          }
        }
      ]
    }
  ]
}
{% endschema %}
