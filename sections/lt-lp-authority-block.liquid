{% style %}
  #lt-lp-authority-block-{{ section.id }} {
    --lt-lp-authority-bg: {{ section.settings.color_bg }};
    --lt-lp-authority-surface: {{ section.settings.color_card_bg }};
    --lt-lp-authority-text: {{ section.settings.color_text }};
    --lt-lp-authority-border: {{ section.settings.color_text | color_modify: 'alpha', 0.12 }};
    --lt-lp-authority-muted: {{ section.settings.color_text | color_modify: 'alpha', 0.64 }};
    --lt-lp-authority-padding-top: {{ section.settings.padding_top }}px;
    --lt-lp-authority-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<section id="lt-lp-authority-block-{{ section.id }}" class="lt-lp-authority-block-section">
  <div class="lt-lp-authority-block page-width">
    <div class="lt-lp-authority-block__card">
      <div class="lt-lp-authority-block__media">
        {%- if section.settings.founder_image_url != blank -%}
          {{
            section.settings.founder_image_url
            | image_url: width: 520
            | image_tag:
              loading: 'lazy',
              widths: '320, 420, 520',
              class: 'lt-lp-authority-block__image',
              alt: section.settings.founder_name
          }}
        {%- endif -%}
      </div>

      <div class="lt-lp-authority-block__content">
        {%- if section.settings.kicker != blank -%}
          <p class="lt-lp-authority-block__kicker">{{ section.settings.kicker | escape }}</p>
        {%- endif -%}
        {%- if section.settings.headline != blank -%}
          <h2 class="lt-lp-authority-block__headline">{{ section.settings.headline | escape }}</h2>
        {%- endif -%}
        <div class="lt-lp-authority-block__meta">
          {%- if section.settings.founder_name != blank -%}
            <p class="lt-lp-authority-block__name">{{ section.settings.founder_name | escape }}</p>
          {%- endif -%}
          {%- if section.settings.founder_title != blank -%}
            <p class="lt-lp-authority-block__title">{{ section.settings.founder_title | escape }}</p>
          {%- endif -%}
        </div>
        <div class="lt-lp-authority-block__chips" aria-label="Qualifikationen">
          {%- if section.settings.credential_chip_1 != blank -%}
            <span class="lt-lp-authority-block__chip">{{ section.settings.credential_chip_1 | escape }}</span>
          {%- endif -%}
          {%- if section.settings.credential_chip_2 != blank -%}
            <span class="lt-lp-authority-block__chip">{{ section.settings.credential_chip_2 | escape }}</span>
          {%- endif -%}
          {%- if section.settings.credential_chip_3 != blank -%}
            <span class="lt-lp-authority-block__chip">{{ section.settings.credential_chip_3 | escape }}</span>
          {%- endif -%}
          {%- if section.settings.credential_chip_4 != blank -%}
            <span class="lt-lp-authority-block__chip">{{ section.settings.credential_chip_4 | escape }}</span>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
.lt-lp-authority-block-section {
  background: var(--lt-lp-authority-bg);
  color: var(--lt-lp-authority-text);
}

.lt-lp-authority-block {
  padding-top: var(--lt-lp-authority-padding-top);
  padding-bottom: var(--lt-lp-authority-padding-bottom);
}

.lt-lp-authority-block__card {
  display: grid;
  gap: 24px;
  padding: 24px;
  border-radius: 28px;
  background: var(--lt-lp-authority-surface);
  border: 1px solid var(--lt-lp-authority-border);
}

.lt-lp-authority-block__media {
  max-width: 220px;
}

.lt-lp-authority-block__image {
  display: block;
  width: 100%;
  height: auto;
  border-radius: 24px;
}

.lt-lp-authority-block__content {
  display: grid;
  gap: 14px;
}

.lt-lp-authority-block__kicker {
  margin: 0;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--lt-lp-authority-muted);
}

.lt-lp-authority-block__headline {
  margin: 0;
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  line-height: 1.04;
  letter-spacing: -0.04em;
  color: var(--lt-lp-authority-text);
}

.lt-lp-authority-block__meta {
  display: grid;
  gap: 6px;
}

.lt-lp-authority-block__name,
.lt-lp-authority-block__title {
  margin: 0;
}

.lt-lp-authority-block__name {
  font-size: 1.05rem;
  font-weight: 600;
}

.lt-lp-authority-block__title {
  font-size: 0.98rem;
  line-height: 1.5;
  color: var(--lt-lp-authority-muted);
}

.lt-lp-authority-block__chips {
  display: flex;
  flex-wrap: wrap;
  gap: 10px;
}

.lt-lp-authority-block__chip {
  display: inline-flex;
  align-items: center;
  min-height: 38px;
  padding: 0 16px;
  border-radius: 999px;
  background: color-mix(in srgb, var(--lt-lp-authority-text) 6%, transparent);
  border: 1px solid var(--lt-lp-authority-border);
  font-size: 0.92rem;
  line-height: 1.3;
}

@media screen and (min-width: 750px) {
  .lt-lp-authority-block__card {
    grid-template-columns: minmax(180px, 240px) minmax(0, 1fr);
    align-items: center;
    gap: 32px;
    padding: 32px;
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "LT — LP Authority Block",
  "settings": [
    {
      "type": "color",
      "id": "color_bg",
      "label": "Hintergrund",
      "default": "#f7f7f4"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding oben",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding unten",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 64
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker",
      "default": "Ärztlich entwickelt"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Ein Longevity-Test auf 20+ Jahren klinischer Erfahrung."
    },
    {
      "type": "image_picker",
      "id": "founder_image_url",
      "label": "Founder Bild"
    },
    {
      "type": "text",
      "id": "founder_name",
      "label": "Founder Name",
      "default": "Prof. Dr. med. Volker Limmroth"
    },
    {
      "type": "text",
      "id": "founder_title",
      "label": "Founder Titel",
      "default": "Chefarzt Neurologie · Chief Scientific Officer LIFETIME"
    },
    {
      "type": "text",
      "id": "credential_chip_1",
      "label": "Credential Chip 1",
      "default": "Chefarzt Neurologie"
    },
    {
      "type": "text",
      "id": "credential_chip_2",
      "label": "Credential Chip 2",
      "default": "ARD · RTL · SAT1"
    },
    {
      "type": "text",
      "id": "credential_chip_3",
      "label": "Credential Chip 3",
      "default": "Spiegel Bestseller"
    },
    {
      "type": "text",
      "id": "credential_chip_4",
      "label": "Credential Chip 4",
      "default": "20+ Jahre Forschung"
    }
  ],
  "presets": [
    {
      "name": "LT — LP Authority Block"
    }
  ]
}
{% endschema %}
