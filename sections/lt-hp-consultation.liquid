      "id": "color_bg",
      "label": "Hintergrundfarbe"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe"
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline"
    },
    {
      "type": "textarea",
