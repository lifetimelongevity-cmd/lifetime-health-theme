{% comment %}
  lt-hp-consultation — Kostenfreie Beratung (Section 9)
  ───────────────────────────────────────────────────────
  §12 Build Spec:
  - Surface:          --color-surface-secondary (warm — visuell klar von den Sections davor/danach abgesetzt)
  - Dominant element: Headline — einladend, kein Feature-Text
  - Heading size:     --text-h1 (36px)
  - Content pattern:  Zentrierter Text + Verfügbarkeits-Pill + CTA (ein Fokus)
  - CTA:              "Kostenfreie Video-Beratung buchen" — konkreter Handlungsaufruf, kein "Mehr erfahren"
  - Removed:          Feature-Liste (kein Beratungs-Feature-Overload), Berater-Avatar (wenn kein Bild)
  - Quality move:     Verfügbarkeits-Pill "Nächster freier Termin: morgen" als Dringlichkeitssignal
                      direkt unter dem CTA — erzeugt sanften Handlungsdruck ohne Manipulation.
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} {
    {%- if section.settings.color_bg != blank -%}
    background: {{ section.settings.color_bg }};
    {%- endif -%}
    {%- if section.settings.color_text != blank -%}
    color: {{ section.settings.color_text }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    {%- endif -%}
    padding-top:    {{ section.settings.padding_top | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
  }
{% endstyle %}

<section id="shopify-section-{{ section.id }}" class="cons">
  <div class="cons__container">

    <div class="cons__content">

      {%- comment -%} Optional advisor avatar {%- endcomment -%}
      {%- if section.settings.advisor_image_url != blank -%}
        <div class="cons__avatar-wrap">
          <img
            src="{{ section.settings.advisor_image_url | escape }}"
            alt="LIFETIME Longevity-Experte"
            class="cons__avatar"
            loading="lazy"
            width="80"
            height="80"
          >
          <span class="cons__avatar-badge" aria-hidden="true">
            <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><circle cx="5" cy="5" r="4"/></svg>
          </span>
        </div>
      {%- endif -%}

      <div class="cons__header crs-heading-stack crs-heading-stack--align-center">
        {%- if section.settings.kicker != blank -%}
          <p class="crs-heading-stack__kicker">{{ section.settings.kicker | escape }}</p>
        {%- endif -%}
        <div class="crs-heading-stack__pair">
          <h2 class="crs-heading-stack__title">{{ section.settings.headline | escape }}</h2>
          {%- if section.settings.subheadline != blank -%}
            <p class="crs-heading-stack__subtitle">{{ section.settings.subheadline | escape }}</p>
          {%- endif -%}
        </div>
      </div>

      {%- if section.settings.cta_label != blank -%}
        <div class="cons__cta-wrap">
          <a
            href="{{ section.settings.cta_url | default: '#' }}"
            class="cons__cta"
            {%- if section.settings.cta_url == blank %} aria-disabled="true"{% endif %}
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M15.05 5A5 5 0 0 1 19 8.95M15.05 1A9 9 0 0 1 23 8.94m-1 7.98v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.72 9.16 19.79 19.79 0 0 1 1.68 .5 2 2 0 0 1 3.66 0h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 7.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16z"/>
            </svg>
            {{ section.settings.cta_label | escape }}
          </a>

          {%- if section.settings.show_availability and section.settings.availability_text != blank -%}
            <p class="cons__availability">
              <span class="cons__availability-dot" aria-hidden="true"></span>
              {{ section.settings.availability_text | escape }}
            </p>
          {%- endif -%}
        </div>
      {%- endif -%}

    </div>
  </div>
</section>

{% stylesheet %}
/* ================================================================
   lt-hp-consultation — Beratungs-CTA (Hochpreis-Hemmer)
   Token refs: §3 (colors, type, spacing), §5 (Buttons)
   ================================================================ */

/* — Section shell — */
.cons {
  background: var(--color-surface-secondary);
}

/* — Container — */
.cons__container {
  max-width: 640px;               /* narrow — conviction focus, one CTA */
  margin: 0 auto;
  padding: 0 var(--space-5);
}

/* — Content block — */
.cons__content {
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: var(--space-4);
}

/* — Advisor avatar — */
.cons__avatar-wrap {
  position: relative;
  width: 80px;
  height: 80px;
}

.cons__avatar {
  width: 80px;
  height: 80px;
  border-radius: var(--radius-full);
  object-fit: cover;
  border: 2px solid var(--color-surface-primary);
  box-shadow: var(--shadow-md);
}

/* Online indicator dot */
.cons__avatar-badge {
  position: absolute;
  bottom: 4px;
  right: 4px;
  width: 16px;
  height: 16px;
  background: var(--color-success);
  border-radius: var(--radius-full);
  border: 2px solid var(--color-surface-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-white);
}


/* — CTA wrap — */
.cons__cta-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--space-3);
  margin-top: var(--space-3);
}

/* — CTA button — */
.cons__cta {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: var(--space-2);
  min-height: 52px;
  padding: 14px var(--space-7);
  border-radius: var(--radius-full);
  background: var(--color-cta-bg);
  color: var(--color-cta-text);
  font-family: var(--font-body);
  font-size: var(--text-body);
  font-weight: var(--weight-semibold);
  text-decoration: none;
  letter-spacing: 0.01em;
  transition: opacity var(--ease-default);
}

.cons__cta:hover {
  opacity: 0.88;
}

/* — Availability pill — */
/*
  DECISION: Directly under the CTA, with a pulsing green dot.
  "Nächster freier Termin: morgen" creates soft urgency through scarcity signal.
  Green dot reinforces "online now" / availability metaphor.
*/
.cons__availability {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  font-weight: var(--weight-medium);
  color: var(--color-text-secondary);
  margin: 0;
}

.cons__availability-dot {
  display: inline-block;
  width: 8px;
  height: 8px;
  border-radius: var(--radius-full);
  background: var(--color-success);
  flex-shrink: 0;
  animation: cons-pulse 2s ease infinite;
}

@keyframes cons-pulse {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.6; transform: scale(0.85); }
}

/* — Responsive — */
@media screen and (max-width: 768px) {
  .cons__container {
    padding: 0 var(--space-4);
  }

  .cons__cta {
    width: 100%;
  }
}
{% endstylesheet %}

