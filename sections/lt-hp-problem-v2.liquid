{% comment %}
  lt-hp-problem-v2 — Problem + Arzt-Block Flow (Section 4)
  ─────────────────────────────────────────────────────────
  §12 Build Spec:
  - Surface:          --color-surface-primary / settings.color_bg — ruhige helle Fläche
                      zwischen Social Proof / Logo-Beweis und dunklem Science-Bento
  - Dominant element: Section-Headline — beide Karten bleiben bewusst sekundär
                      und verhalten sich wie ein zusammengehöriges Informationspaar
  - Heading size:     Shared homepage heading stack + card-info Typo
                      (Heading-Font für Kartentitel, Body-Font für Erklärtext)
  - Content pattern:  Zwei card-info-Karten im Homepage-Rhythmus.
                      Block 1: Problem-Framing + Invest-Pills + kompakte Note.
                      Block 2: System-vs-Longevity-Vergleich in zwei ruhigen Panels + Einordnungs-Note.
  - CTA:              Keiner — bewusst. Diese Sektion baut diagnostische Spannung auf.
                      Kein Kaufimpuls hier; das Problem muss atmen dürfen.
  - Removed:          Vertikaler Flow-Connector, farbcodierte Warn-Callouts, eigenständige
                      Sonderfarben-Logik — sie machten die Section lauter als ihre Nachbarn.
  - Quality move:     Die Vergleichslogik lebt nun in zwei ruhigen Sub-Panels innerhalb
                      einer einzigen Karte. Das erzeugt Klarheit, ohne wie ein Fremd-Widget
                      oder Editorial-Sonderformat zu wirken.
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} {
    {%- if section.settings.color_bg != blank -%}
    background: {{ section.settings.color_bg }};
    {%- endif -%}
    {%- if section.settings.color_text != blank -%}
    color: {{ section.settings.color_text }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    {%- endif -%}
    padding-top:    {{ section.settings.padding_top | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
  }
{% endstyle %}

<section id="shopify-section-{{ section.id }}" class="prob2">
  <div class="prob2__outer">

    {%- comment -%}=== Section Header ==={%- endcomment -%}
    <div class="prob2__header crs-heading-stack crs-heading-stack--align-center crs-heading-stack--homepage-truth">
      {%- if section.settings.kicker != blank -%}
        <p class="crs-heading-stack__kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      <div class="crs-heading-stack__pair">
        {%- if section.settings.headline != blank -%}
          <h2 class="crs-heading-stack__title">
            {{ section.settings.headline | escape | newline_to_br | replace: '&lt;br&gt;', '<br>' | replace: '&lt;br/&gt;', '<br>' | replace: '&lt;br /&gt;', '<br>' }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheadline != blank -%}
          <p class="crs-heading-stack__subtitle">{{ section.settings.subheadline | escape }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%}=== Cards ==={%- endcomment -%}
    <div class="prob2__grid">
      {%- for block in section.blocks -%}
        {%- comment -%}=== Block: Das Problem ==={%- endcomment -%}
        {%- if block.type == 'problem_block' -%}
          <article
            class="prob2__card prob2__card--problem"
            {% if block.settings.tag_color != blank %}style="--prob2-tag-color: {{ block.settings.tag_color }};"{% endif %}
            {{ block.shopify_attributes }}
          >

            {%- if block.settings.tag_label != blank -%}
              <p class="prob2__eyebrow">{{ block.settings.tag_label | escape }}</p>
            {%- endif -%}

            <div class="prob2__card-copy">
              {%- if block.settings.block_title != blank -%}
                <h3 class="prob2__card-title">{{ block.settings.block_title | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.block_body != blank -%}
                <p class="prob2__card-body">{{ block.settings.block_body | escape }}</p>
              {%- endif -%}
            </div>

            {%- comment -%} Invest-Pills — hardcoded, illustrative {%- endcomment -%}
            <ul class="prob2__pills" role="list" aria-label="Bereits getätigte Investitionen">
              <li class="prob2__pill">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>
                </svg>
                Sport
              </li>
              <li class="prob2__pill">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 3c0 8-6 9-6 14a6 6 0 0 0 12 0c0-5-6-6-6-14z"/>
                </svg>
                Ernährung
              </li>
              <li class="prob2__pill">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="7" y="3" width="10" height="18" rx="3"/><path d="M10 9h4M10 13h4"/>
                </svg>
                Supplemente
              </li>
              <li class="prob2__pill">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M3 18c0-7 4-13 9-13s9 6 9 13"/><path d="M12 5V3"/>
                </svg>
                Schlaf
              </li>
            </ul>

            {%- if block.settings.callout_text != blank -%}
              <div class="prob2__note">
                {%- if block.settings.callout_label != blank -%}
                  <p class="prob2__note-label">{{ block.settings.callout_label | escape }}</p>
                {%- endif -%}
                <p class="prob2__note-body">{{ block.settings.callout_text | escape }}</p>
              </div>
            {%- endif -%}

          </article>
        {%- endif -%}

        {%- comment -%}=== Block: Und dein Arzt? ==={%- endcomment -%}
        {%- if block.type == 'arzt_block' -%}
          <article
            class="prob2__card prob2__card--arzt"
            {% if block.settings.tag_color != blank %}style="--prob2-tag-color: {{ block.settings.tag_color }};"{% endif %}
            {{ block.shopify_attributes }}
          >

            {%- if block.settings.tag_label != blank -%}
              <p class="prob2__eyebrow">{{ block.settings.tag_label | escape }}</p>
            {%- endif -%}

            <div class="prob2__card-copy">
              {%- if block.settings.block_title != blank -%}
                <h3 class="prob2__card-title">{{ block.settings.block_title | escape }}</h3>
              {%- endif -%}

              {%- if block.settings.block_body != blank -%}
                <p class="prob2__card-body">{{ block.settings.block_body | escape }}</p>
              {%- endif -%}
            </div>

            {%- comment -%} 2-col system comparison {%- endcomment -%}
            <div class="prob2__compare">

              <div class="prob2__compare-col prob2__compare-col--system">
                {%- if block.settings.system_col_label != blank -%}
                  <p class="prob2__compare-col-label">
                    {{ block.settings.system_col_label | escape }}
                  </p>
                {%- endif -%}
                {%- assign system_keys = 'system_item_1,system_item_2,system_item_3,system_item_4' | split: ',' -%}
                <ul class="prob2__compare-list" role="list">
                  {%- for key in system_keys -%}
                    {%- assign item_val = block.settings[key] -%}
                    {%- if item_val != blank -%}
                      <li class="prob2__compare-item">
                        <span class="prob2__compare-dot prob2__compare-dot--muted" aria-hidden="true"></span>
                        <span class="prob2__compare-text">{{ item_val | escape }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </div>

              <div class="prob2__compare-col prob2__compare-col--longevity">
                {%- if block.settings.longevity_col_label != blank -%}
                  <p class="prob2__compare-col-label">
                    {{ block.settings.longevity_col_label | escape }}
                  </p>
                {%- endif -%}
                {%- assign longevity_keys = 'longevity_item_1,longevity_item_2,longevity_item_3,longevity_item_4' | split: ',' -%}
                <ul class="prob2__compare-list" role="list">
                  {%- for key in longevity_keys -%}
                    {%- assign item_val = block.settings[key] -%}
                    {%- if item_val != blank -%}
                      <li class="prob2__compare-item">
                        <span class="prob2__compare-dot prob2__compare-dot--teal" aria-hidden="true"></span>
                        <span class="prob2__compare-text">{{ item_val | escape }}</span>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              </div>

            </div>

            {%- if block.settings.callout_text != blank -%}
              <div class="prob2__note">
                {%- if block.settings.callout_label != blank -%}
                  <p class="prob2__note-label">{{ block.settings.callout_label | escape }}</p>
                {%- endif -%}
                <p class="prob2__note-body">{{ block.settings.callout_text | escape }}</p>
              </div>
            {%- endif -%}

          </article>
        {%- endif -%}

      {%- endfor -%}
    </div>

  </div>
</section>

{% stylesheet %}
/* ================================================================
   lt-hp-problem-v2 — Problem + Systemlücke
   Token refs: §3 (colors, spacing, type), §5 (card-info pattern)
   ================================================================ */

.prob2 {
  background: var(--color-surface-primary);
}

.prob2__outer {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--space-5);
}

.prob2__header {
  max-width: 640px;
  margin: 0 auto var(--space-8);
}

/* Desktop pair instead of bespoke editorial flow */
.prob2__grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: var(--space-4);
  align-items: stretch;
}

.prob2__card {
  display: flex;
  flex-direction: column;
  gap: var(--space-5);
  height: 100%;
  background: var(--color-surface-primary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  padding: var(--space-5);
}

.prob2__eyebrow {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-medium);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  line-height: var(--leading-tight);
  color: var(--prob2-tag-color, var(--color-text-muted));
  margin: 0;
}

.prob2__card-copy {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
}

.prob2__card-title {
  font-family: var(--font-heading);
  font-size: var(--text-section);
  font-weight: var(--weight-regular);
  line-height: var(--leading-heading);
  color: var(--crs-text, var(--color-text-primary));
  margin: 0;
}

.prob2__card-body {
  font-family: var(--font-body);
  font-size: var(--text-body);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--crs-text-sec, var(--color-text-secondary));
  margin: 0;
}

.prob2__pills {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin: 0;
  padding: 0;
  list-style: none;
}

.prob2__pill {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);
  background: var(--color-surface-secondary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-full);
  padding: var(--space-1) var(--space-3);
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-regular);
  color: var(--crs-text-sec, var(--color-text-secondary));
  line-height: 1;
}

.prob2__note {
  background: var(--color-surface-secondary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-sm);
  padding: var(--space-4);
}

.prob2__note-label {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-medium);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  color: var(--color-text-muted);
  margin: 0 0 var(--space-2);
}

.prob2__note-body {
  font-family: var(--font-body);
  font-size: var(--text-body);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--crs-text-sec, var(--color-text-secondary));
  margin: 0;
}

.prob2__compare {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-3);
}

.prob2__compare-col {
  display: flex;
  flex-direction: column;
  gap: var(--space-3);
  border-radius: var(--radius-sm);
  padding: var(--space-3) var(--space-4);
  min-width: 0;
}

.prob2__compare-col--system {
  background: var(--color-surface-secondary);
  border: 1px solid var(--color-border-default);
}

.prob2__compare-col--longevity {
  background: var(--color-surface-benefit);
  border: 1px solid var(--color-border-default);
}

.prob2__compare-col-label {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-medium);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin: 0;
}

.prob2__compare-col--system .prob2__compare-col-label { color: var(--color-text-muted); }
.prob2__compare-col--longevity .prob2__compare-col-label { color: var(--color-teal-dark); }

.prob2__compare-list {
  display: flex;
  flex-direction: column;
  gap: var(--space-2);
  list-style: none;
  margin: 0;
  padding: 0;
}

.prob2__compare-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
  margin: 0;
}

.prob2__compare-dot {
  display: block;
  width: 6px;
  height: 6px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
  margin-top: 5px;
}

.prob2__compare-dot--muted { background: var(--color-text-muted); }
.prob2__compare-dot--teal  { background: var(--color-teal-dark); }

.prob2__compare-text {
  font-family: var(--font-body);
  font-size: var(--text-body);
  font-weight: var(--weight-regular);
  line-height: var(--leading-body);
  color: var(--crs-text-sec, var(--color-text-secondary));
}

@media screen and (max-width: 1024px) {
  .prob2__grid {
    grid-template-columns: 1fr;
    gap: var(--space-5);
  }
}

@media screen and (max-width: 768px) {
  .prob2__outer {
    padding: 0 var(--space-4);
  }

  .prob2__header {
    margin-bottom: var(--space-7);
  }

  .prob2__compare {
    grid-template-columns: 1fr;
    gap: var(--space-2);
  }

  .prob2__pills {
    gap: var(--space-1);
  }
}
{% endstylesheet %}

