{% comment %}
  lt-hp-problem-v2 — Problem & Systemlücke (Option A: editorial manifest)
  ─────────────────────────────────────────────────────────
  Zentrierte Heading-Stack + horizontale System-vs-Longevity-Vergleichsleiste.
  Keine Karten, keine Pills, keine Callout-Boxen. Typografisch geführt.
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} {
    {%- if section.settings.color_bg != blank -%}
    background: {{ section.settings.color_bg }};
    {%- endif -%}
    {%- if section.settings.color_text != blank -%}
    color: {{ section.settings.color_text }};
    --prob2-text: {{ section.settings.color_text }};
    --prob2-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --prob2-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --prob2-divider: {{ section.settings.color_text | color_modify: 'alpha', 0.12 }};
    {%- endif -%}
    padding-top: {{ section.settings.padding_top | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
  }
{% endstyle %}

<section id="shopify-section-{{ section.id }}" class="prob2">
  <div class="prob2__outer">

    <div class="prob2__header crs-heading-stack crs-heading-stack--align-center crs-heading-stack--homepage-truth">
      {%- if section.settings.kicker != blank -%}
        <p class="crs-heading-stack__kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      <div class="crs-heading-stack__pair">
        {%- if section.settings.headline != blank -%}
          <h2 class="crs-heading-stack__title">
            {{ section.settings.headline | escape | newline_to_br | replace: '&lt;br&gt;', '<br>' | replace: '&lt;br/&gt;', '<br>' | replace: '&lt;br /&gt;', '<br>' }}
          </h2>
        {%- endif -%}
        {%- if section.settings.subheadline != blank -%}
          <p class="crs-heading-stack__subtitle">{{ section.settings.subheadline | escape }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="prob2__contrast" role="list" aria-label="System-Vergleich">

        <div class="prob2__contrast-labels" aria-hidden="true">
          {%- if section.settings.col_system_label != blank -%}
            <span class="prob2__contrast-col-label prob2__contrast-col-label--system">{{ section.settings.col_system_label | escape }}</span>
          {%- endif -%}
          {%- if section.settings.col_longevity_label != blank -%}
            <span class="prob2__contrast-col-label prob2__contrast-col-label--longevity">{{ section.settings.col_longevity_label | escape }}</span>
          {%- endif -%}
        </div>

        <ul class="prob2__contrast-list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'comparison_row' -%}
              <li class="prob2__contrast-row" role="listitem" {{ block.shopify_attributes }}>
                <span class="prob2__contrast-cell prob2__contrast-cell--system">{{ block.settings.system_text | escape }}</span>
                <span class="prob2__contrast-cell prob2__contrast-cell--longevity">{{ block.settings.longevity_text | escape }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>

      </div>
    {%- endif -%}

    {%- if section.settings.closing_note != blank -%}
      <p class="prob2__closing">{{ section.settings.closing_note | escape }}</p>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
.prob2 {
  background: var(--color-surface-primary);
}

.prob2__outer {
  max-width: 760px;
  margin: 0 auto;
  padding: 0 var(--space-5);
}

.prob2__header {
  margin: 0 auto var(--space-7);
}

.prob2__contrast {
  display: grid;
  grid-template-columns: 1fr 1px 1fr;
  column-gap: var(--space-6);
  row-gap: var(--space-3);
  padding: var(--space-5) 0;
  border-top: 1px solid var(--prob2-divider, var(--color-border-default));
  border-bottom: 1px solid var(--prob2-divider, var(--color-border-default));
}

.prob2__contrast-labels {
  display: contents;
}

.prob2__contrast-col-label {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-semibold);
  text-transform: uppercase;
  letter-spacing: 0.12em;
  line-height: var(--leading-tight);
  padding-bottom: var(--space-2);
  margin-bottom: var(--space-1);
  border-bottom: 1px solid var(--prob2-divider, var(--color-border-default));
}

.prob2__contrast-col-label--system {
  grid-column: 1;
  color: var(--prob2-text-ter, var(--color-text-muted));
  text-align: right;
}

.prob2__contrast-col-label--longevity {
  grid-column: 3;
  color: var(--color-teal-dark);
  text-align: left;
}

.prob2__contrast-list {
  display: contents;
  list-style: none;
  margin: 0;
  padding: 0;
}

.prob2__contrast-row {
  display: contents;
}

.prob2__contrast-row::before {
  content: "";
  grid-column: 2;
  background: var(--prob2-divider, var(--color-border-default));
  width: 1px;
  justify-self: center;
}

.prob2__contrast-cell {
  font-family: var(--font-body);
  font-size: var(--text-body);
  font-weight: var(--weight-regular);
  line-height: var(--leading-body);
}

.prob2__contrast-cell--system {
  grid-column: 1;
  color: var(--prob2-text-ter, var(--color-text-muted));
  text-align: right;
}

.prob2__contrast-cell--longevity {
  grid-column: 3;
  color: var(--prob2-text, var(--color-text-primary));
  text-align: left;
}

.prob2__closing {
  margin: var(--space-5) auto 0;
  max-width: 52ch;
  text-align: center;
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  line-height: var(--leading-relaxed);
  color: var(--prob2-text-sec, var(--color-text-secondary));
}

@media screen and (max-width: 768px) {
  .prob2__outer {
    padding: 0 var(--space-4);
  }

  .prob2__header {
    margin-bottom: var(--space-6);
  }

  .prob2__contrast {
    grid-template-columns: 1fr;
    column-gap: 0;
    row-gap: var(--space-1);
    padding: var(--space-5) 0;
  }

  .prob2__contrast-col-label {
    display: none;
  }

  .prob2__contrast-row {
    display: block;
    padding: var(--space-3) 0;
    border-bottom: 1px solid var(--prob2-divider, var(--color-border-default));
  }

  .prob2__contrast-row:last-child {
    border-bottom: none;
  }

  .prob2__contrast-row::before {
    display: none;
  }

  .prob2__contrast-cell {
    display: block;
    text-align: left;
  }

  .prob2__contrast-cell--system {
    font-size: var(--text-body-sm);
    margin-bottom: var(--space-1);
  }
}
{% endstylesheet %}

{% schema %}
{
  "name": "HP Problem v2",
  "tag": "section",
  "class": "section",
  "settings": [
    { "type": "header", "content": "Abstände" },
    { "type": "range", "id": "padding_top", "label": "Abstand oben", "min": 0, "max": 200, "step": 8, "default": 80, "unit": "px" },
    { "type": "range", "id": "padding_bottom", "label": "Abstand unten", "min": 0, "max": 200, "step": 8, "default": 80, "unit": "px" },

    { "type": "header", "content": "Farben" },
    { "type": "color", "id": "color_bg", "label": "Hintergrundfarbe", "default": "#ffffff" },
    { "type": "color", "id": "color_text", "label": "Textfarbe", "default": "#26251e" },

    { "type": "header", "content": "Kopf" },
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Warum Messen vor Optimieren kommt" },
    { "type": "text", "id": "headline", "label": "Headline", "default": "Du investierst bereits. Die Frage ist nur: in welche Richtung." },
    { "type": "textarea", "id": "subheadline", "label": "Subheadline", "default": "Krankheitsmedizin wartet auf Diagnosen. Longevity-Diagnostik zeigt dir deinen Verlauf — bevor er einer wird." },

    { "type": "header", "content": "Vergleichsleiste" },
    { "type": "text", "id": "col_system_label", "label": "Linke Spalte", "default": "Krankheitsmedizin" },
    { "type": "text", "id": "col_longevity_label", "label": "Rechte Spalte", "default": "Longevity-Diagnostik" },

    { "type": "header", "content": "Schluss-Note" },
    { "type": "textarea", "id": "closing_note", "label": "Note", "default": "Kein Ersatz für deinen Arzt. Ein Ausgangspunkt, bevor er nötig wird." }
  ],
  "blocks": [
    {
      "type": "comparison_row",
      "name": "Vergleichs-Zeile",
      "limit": 6,
      "settings": [
        { "type": "text", "id": "system_text", "label": "Links (System)", "default": "Wartet auf Diagnose" },
        { "type": "text", "id": "longevity_text", "label": "Rechts (Longevity)", "default": "Zeigt Verlauf" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Problem & Systemlücke",
      "blocks": [
        { "type": "comparison_row", "settings": { "system_text": "Wartet auf Diagnose", "longevity_text": "Zeigt Verlauf, bevor eine nötig ist" } },
        { "type": "comparison_row", "settings": { "system_text": "Aktueller Status", "longevity_text": "Altersgeschwindigkeit" } },
        { "type": "comparison_row", "settings": { "system_text": "Behandelt Symptome", "longevity_text": "Ermöglicht Prävention" } }
      ]
    }
  ]
}
{% endschema %}
