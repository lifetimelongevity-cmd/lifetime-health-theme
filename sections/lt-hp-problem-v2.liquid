{% comment %}
  lt-hp-problem-v2 — Problem + Arzt-Block Flow (Section 4)
  ─────────────────────────────────────────────────────────
  §12 Build Spec:
  - Surface:          --color-surface-primary (#f7f7f4 via settings) — warm neutral,
                      sanfte Transition nach Trust-Ticker, vor Video Authority
  - Dominant element: Section-Headline (--text-h2, 28px, Helvetica) — ein Satz pro Karte
                      erklärt das Problem und die Systemlücke
  - Heading size:     --text-h2 (28px) Section · --text-body (16px) Karten-Titel (Lato Medium)
  - Content pattern:  Zwei card-info-Blöcke mit vertikalem Flow-Connector.
                      Block 1: Problem-Framing + "Blinder Fleck"-Callout (Amber-Border).
                      Block 2: System-vs-Longevity 2-col-Vergleich + "Kein Entweder-oder"-Note (Violet-Border).
  - CTA:              Keiner — bewusst. Diese Sektion baut diagnostische Spannung auf.
                      Kein Kaufimpuls hier; das Problem muss atmen dürfen.
  - Removed:          Blöcke 3 + 4 aus der HTML-Vorlage ("Was der Test leistet" / 15-Jahre-Statistik).
                      Block 3 dupliziert product_hero; Statistik wandert in cta_close.
  - Quality move:     Flow-Connector (1px vertikale Linie zwischen den Karten) kommuniziert
                      Ursache-Wirkung ohne zusätzlichen Header-Text.
                      Tag-Labels in Akzentfarben (Bordeaux / Violet) — per Block-Setting konfigurierbar.
                      Invest-Pills (Sport, Ernährung, Supplemente, Schlaf) sind hardcoded:
                      sie sind illustrativer Beweis für "Du investierst bereits" — kein
                      konfigurierbarer Content, der in §11 gestrichen würde.
{% endcomment %}

{% style %}
  #shopify-section-{{ section.id }} {
    {%- if section.settings.color_bg != blank -%}
    background: {{ section.settings.color_bg }};
    {%- endif -%}
    {%- if section.settings.color_text != blank -%}
    color: {{ section.settings.color_text }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    {%- endif -%}
    padding-top:    {{ section.settings.padding_top | default: 80 }}px;
    padding-bottom: {{ section.settings.padding_bottom | default: 80 }}px;
  }
{% endstyle %}

<section id="shopify-section-{{ section.id }}" class="prob2">
  <div class="prob2__outer">

    {%- comment -%}=== Section Header ==={%- endcomment -%}
    <div class="prob2__header crs-heading-stack crs-heading-stack--align-center crs-heading-stack--homepage-truth">
      {%- if section.settings.kicker != blank -%}
        <p class="crs-heading-stack__kicker">{{ section.settings.kicker | escape }}</p>
      {%- endif -%}
      <div class="crs-heading-stack__pair">
        {%- if section.settings.headline != blank -%}
          <h2 class="crs-heading-stack__title">{{ section.settings.headline | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.subheadline != blank -%}
          <p class="crs-heading-stack__subtitle">{{ section.settings.subheadline | escape }}</p>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%}=== Flow ==={%- endcomment -%}
    <div class="prob2__flow">

      {%- assign block_index = 0 -%}

      {%- for block in section.blocks -%}
        {%- assign block_index = block_index | plus: 1 -%}

        {%- comment -%}=== Connector (between blocks, not after last) ==={%- endcomment -%}
        {%- if block_index > 1 -%}
          <div class="prob2__connector" aria-hidden="true"></div>
        {%- endif -%}

        {%- comment -%}=== Block: Das Problem ==={%- endcomment -%}
        {%- if block.type == 'problem_block' -%}
          <div class="prob2__card" {{ block.shopify_attributes }}>

            {%- if block.settings.tag_label != blank -%}
              <p
                class="prob2__tag"
                {%- if block.settings.tag_color != blank -%}
                  style="color: {{ block.settings.tag_color }}"
                {%- endif -%}
              >{{ block.settings.tag_label | escape }}</p>
            {%- endif -%}

            {%- if block.settings.block_title != blank -%}
              <p class="prob2__card-title">{{ block.settings.block_title | escape }}</p>
            {%- endif -%}

            {%- if block.settings.block_body != blank -%}
              <p class="prob2__card-body">{{ block.settings.block_body | escape }}</p>
            {%- endif -%}

            {%- comment -%} Invest-Pills — hardcoded, illustrative {%- endcomment -%}
            <ul class="prob2__pills" role="list" aria-label="Bereits getätigte Investitionen">
              <li class="prob2__pill">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 3"/>
                </svg>
                Sport
              </li>
              <li class="prob2__pill">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M12 3c0 8-6 9-6 14a6 6 0 0 0 12 0c0-5-6-6-6-14z"/>
                </svg>
                Ernährung
              </li>
              <li class="prob2__pill">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <rect x="7" y="3" width="10" height="18" rx="3"/><path d="M10 9h4M10 13h4"/>
                </svg>
                Supplemente
              </li>
              <li class="prob2__pill">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M3 18c0-7 4-13 9-13s9 6 9 13"/><path d="M12 5V3"/>
                </svg>
                Schlaf
              </li>
            </ul>

            {%- if block.settings.callout_text != blank -%}
              <div class="prob2__callout prob2__callout--amber">
                {%- if block.settings.callout_label != blank -%}
                  <p class="prob2__callout-label">{{ block.settings.callout_label | escape }}</p>
                {%- endif -%}
                <p class="prob2__callout-body">{{ block.settings.callout_text | escape }}</p>
              </div>
            {%- endif -%}

          </div>
        {%- endif -%}

        {%- comment -%}=== Block: Und dein Arzt? ==={%- endcomment -%}
        {%- if block.type == 'arzt_block' -%}
          <div class="prob2__card" {{ block.shopify_attributes }}>

            {%- if block.settings.tag_label != blank -%}
              <p
                class="prob2__tag"
                {%- if block.settings.tag_color != blank -%}
                  style="color: {{ block.settings.tag_color }}"
                {%- endif -%}
              >{{ block.settings.tag_label | escape }}</p>
            {%- endif -%}

            {%- if block.settings.block_title != blank -%}
              <p class="prob2__card-title">{{ block.settings.block_title | escape }}</p>
            {%- endif -%}

            {%- if block.settings.block_body != blank -%}
              <p class="prob2__card-body">{{ block.settings.block_body | escape }}</p>
            {%- endif -%}

            {%- comment -%} 2-col system comparison {%- endcomment -%}
            <div class="prob2__compare">

              <div class="prob2__compare-col">
                {%- if block.settings.system_col_label != blank -%}
                  <p class="prob2__compare-col-label prob2__compare-col-label--system">
                    {{ block.settings.system_col_label | escape }}
                  </p>
                {%- endif -%}
                {%- assign system_keys = 'system_item_1,system_item_2,system_item_3,system_item_4' | split: ',' -%}
                {%- for key in system_keys -%}
                  {%- assign item_val = block.settings[key] -%}
                  {%- if item_val != blank -%}
                    <div class="prob2__compare-item">
                      <span class="prob2__compare-dot prob2__compare-dot--muted" aria-hidden="true"></span>
                      <span class="prob2__compare-text">{{ item_val | escape }}</span>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>

              <div class="prob2__compare-col">
                {%- if block.settings.longevity_col_label != blank -%}
                  <p class="prob2__compare-col-label prob2__compare-col-label--longevity">
                    {{ block.settings.longevity_col_label | escape }}
                  </p>
                {%- endif -%}
                {%- assign longevity_keys = 'longevity_item_1,longevity_item_2,longevity_item_3,longevity_item_4' | split: ',' -%}
                {%- for key in longevity_keys -%}
                  {%- assign item_val = block.settings[key] -%}
                  {%- if item_val != blank -%}
                    <div class="prob2__compare-item">
                      <span class="prob2__compare-dot prob2__compare-dot--teal" aria-hidden="true"></span>
                      <span class="prob2__compare-text">{{ item_val | escape }}</span>
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>

            </div>

            {%- if block.settings.callout_text != blank -%}
              <div class="prob2__callout prob2__callout--violet">
                {%- if block.settings.callout_label != blank -%}
                  <p class="prob2__callout-label">{{ block.settings.callout_label | escape }}</p>
                {%- endif -%}
                <p class="prob2__callout-body">{{ block.settings.callout_text | escape }}</p>
              </div>
            {%- endif -%}

          </div>
        {%- endif -%}

      {%- endfor -%}

    </div>

  </div>
</section>

{% stylesheet %}
/* ================================================================
   lt-hp-problem-v2 — Problem + Arzt-Block Flow
   Token refs: §3 (colors, spacing, type), §5 (card-info pattern)

   Section-scoped accent tokens (no clean global mapping exists):
   These extend the token system for semantic accent colors
   specific to this component's callout pattern.
   ================================================================ */

.prob2 {
  background: var(--color-surface-primary);

  /* Amber accent — "Blinder Fleck" callout */
  --prob2-amber-border:    #EF9F27;
  --prob2-amber-label:     #854F0B;
  --prob2-amber-body:      #633806;

  /* Violet accent — "Kein Entweder-oder" callout */
  --prob2-violet-border:   #AFA9EC;
  --prob2-violet-label:    #534AB7;
  --prob2-violet-body:     #3C3489;

  /* Card background — one step darker than section surface */
  --prob2-card-bg:         #f2f1ed;
}

/* — Outer wrapper (full section width, 1200px container) — */
.prob2__outer {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 var(--space-5);
}

/* — Section header — */
.prob2__header {
  max-width: 640px;
  margin: 0 auto var(--space-6);   /* --space-6 (32px) per §6 header→content gap */
}

/* — Flow (narrow, centred — content focus not multi-column) — */
.prob2__flow {
  max-width: 680px;
  margin: 0 auto;
  display: flex;
  flex-direction: column;
}

/* — Connector between cards — */
.prob2__connector {
  width: 1px;
  height: var(--space-7);           /* 48px */
  background: var(--color-border-default);
  margin: 0 auto;
  opacity: 0.5;
}

/* — Card (card-info pattern: warm bg, radius-md, space-5 padding) — */
/*
  DECISION: shadow suppressed per §6 "No shadow on warm backgrounds."
  Section bg is #f7f7f4 (warm), card bg is #f2f1ed (warm) → no shadow.
*/
.prob2__card {
  background: var(--prob2-card-bg);
  border-radius: var(--radius-md);   /* 12px */
  padding: var(--space-5);           /* 24px */
}

/* — Tag label (10px micro, uppercase, accent color via inline style) — */
.prob2__tag {
  font-family: var(--font-body);
  font-size: var(--text-micro);      /* 12px */
  font-weight: var(--weight-medium);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  line-height: var(--leading-body);
  margin: 0 0 var(--space-2);
}

/* — Card title (Lato medium — Helvetica not allowed below --text-h3) — */
/*
  DECISION: --font-body (Lato), --text-body (16px), --weight-medium.
  Governance: "No Helvetica text smaller than --text-h3 (24px)."
  At 16px these titles need Lato. The dominance within each card
  comes from weight + contrast against the muted body text below.
*/
.prob2__card-title {
  font-family: var(--font-body);
  font-size: var(--text-body);       /* 16px */
  font-weight: var(--weight-medium);
  line-height: var(--leading-tight); /* 1.25 */
  color: var(--crs-text);
  margin: 0 0 var(--space-2);
}

/* — Card body text — */
.prob2__card-body {
  font-family: var(--font-body);
  font-size: var(--text-body-sm);    /* 14px */
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--crs-text-sec);
  margin: 0;
}

/* — Invest Pills — */
/*
  DECISION: No shadow (warm background per §6 shadow rule).
  Border uses --color-border-default.
  Icons are inline 12px SVG — smaller than icon-pack.liquid (64px), which
  is only for feature/trust sections, not micro-label contexts.
*/
.prob2__pills {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);              /* 8px — inline element gap per §6 */
  margin: var(--space-4) 0 0;
  padding: 0;
  list-style: none;
}

.prob2__pill {
  display: inline-flex;
  align-items: center;
  gap: var(--space-1);              /* 4px */
  background: var(--color-surface-primary);
  border: 1px solid var(--color-border-default);
  border-radius: var(--radius-full);
  padding: var(--space-1) var(--space-3); /* 4px 12px */
  font-family: var(--font-body);
  font-size: var(--text-micro);     /* 12px */
  font-weight: var(--weight-regular);
  color: var(--crs-text-sec);
  line-height: 1;
}

/* — Callout boxes — */
/*
  Left-border callout pattern — new component (§5 "new component logic"):
  No existing component handles "left-border accent callout with label + body."
  Closest: quote-block (centered, large text) → not appropriate.
  This is a compact inline callout — distinct enough to justify a new sub-pattern.
  Both variants (amber = warning/blind spot, violet = caveat/note) share one base class.
*/
.prob2__callout {
  margin-top: var(--space-4);
  background: var(--color-surface-primary);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  padding: var(--space-3) var(--space-4);
}

.prob2__callout--amber {
  border-left: 3px solid var(--prob2-amber-border);
}

.prob2__callout--amber .prob2__callout-label {
  color: var(--prob2-amber-label);
}

.prob2__callout--amber .prob2__callout-body {
  color: var(--prob2-amber-body);
}

.prob2__callout--violet {
  border-left: 3px solid var(--prob2-violet-border);
}

.prob2__callout--violet .prob2__callout-label {
  color: var(--prob2-violet-label);
}

.prob2__callout--violet .prob2__callout-body {
  color: var(--prob2-violet-body);
}

.prob2__callout-label {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-medium);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin: 0 0 var(--space-1);
}

.prob2__callout-body {
  font-family: var(--font-body);
  font-size: var(--text-body-sm);    /* 14px */
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  margin: 0;
}

/* — Arzt comparison grid — */
.prob2__compare {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: var(--space-3);
  margin-top: var(--space-4);
}

.prob2__compare-col {
  background: var(--color-surface-primary);
  border-radius: var(--radius-sm);
  padding: var(--space-3) var(--space-4);
}

.prob2__compare-col-label {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-medium);
  text-transform: uppercase;
  letter-spacing: 0.08em;
  margin: 0 0 var(--space-3);
}

.prob2__compare-col-label--system   { color: var(--color-text-muted); }
.prob2__compare-col-label--longevity { color: var(--color-teal-dark); }

.prob2__compare-item {
  display: flex;
  align-items: flex-start;
  gap: var(--space-2);
  margin-bottom: var(--space-2);
}

.prob2__compare-item:last-child { margin-bottom: 0; }

.prob2__compare-dot {
  display: block;
  width: 5px;
  height: 5px;
  border-radius: var(--radius-full);
  flex-shrink: 0;
  margin-top: 5px;
}

.prob2__compare-dot--muted { background: var(--color-text-muted); }
.prob2__compare-dot--teal  { background: var(--color-teal-dark); }

.prob2__compare-text {
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-regular);
  line-height: var(--leading-relaxed);
  color: var(--crs-text-sec);
}

/* — Responsive — */
@media screen and (max-width: 768px) {
  .prob2__outer {
    padding: 0 var(--space-4);     /* 16px mobile container padding per §4 */
  }

  .prob2__compare {
    grid-template-columns: 1fr;
  }

  .prob2__pills {
    gap: var(--space-1);
  }
}
{% endstylesheet %}

