{% comment %}
  LIFETIME — LT Experten-Profile (Pattern „expert-card grid")
  ───────────────────────────────────────────────────────────
  Approved Pattern, Referenz: `_examples/sections/expert-profile.liquid`.
  Karten-Grid (2×2) nach der Design-Sprache der PDP-Expert-Card
  (`sections/lt-pdp-expert.liquid` / `_examples/pdp-reference.html`):
  einheitlicher quadratischer Avatar + Meta in der Kopfzeile, Bio und
  optionales Zitat darunter. Section-Header über das kanonische
  `section-heading-crs`-Snippet.

  Warum kein Split-Layout: Die v1 dieser Section (alternierender
  2fr/3fr-Split) ist an heterogenem Material gescheitert — ungleiche
  Foto-Spaltenbreiten durch `order`-Alternierung, stark unterschiedliche
  Porträt-Hintergründe/-Ausschnitte und Leerräume bei kurzen Bios.
  Karten mit kleinem, identischem Avatar normalisieren das.

  §12 Build Spec:
  - Surface:          --color-surface-primary (hell)
  - Section label:    nein — Headline trägt den Kontext (§11)
  - Dominant element: pro Karte der Name (--text-section, bold, wie
                      alle Card-Titles der Seite); Section-Ebene:
                      Headline (headline_lg)
  - Content pattern:  expert-card × 4 im 2er-Grid — card-info-Disziplin
                      (Border + shadow-sm auf weißem Grund, --radius-md,
                      Padding --space-5)
  - CTA:              keiner
  - Removed:          alternierender Split, große Porträts, Foto-Captions,
                      Trennlinien vor dem Zitat
  - Quality move:     ein fixer 96px-Avatar mit einheitlichem Crop für
                      alle Experten — vier uneinheitliche Quellfotos
                      lesen sich als eine ruhige, gleichwertige Reihe
{% endcomment %}

{{ 'section-lt-about-experts.css' | asset_url | stylesheet_tag }}

<section class="lt-about-experts">
  <div class="lt-about-experts__container">

    {%- if section.settings.title != blank -%}
      {% render 'section-heading-crs',
        heading: section.settings.title,
        kicker: section.settings.kicker,
        align: 'left',
        headline_lg: true,
        heading_tag: 'h2',
        extra_class: 'lt-about-experts__header'
      %}
    {%- endif -%}

    <ul class="lt-about-experts__grid" role="list">
      {%- for block in section.blocks -%}
        <li class="lt-about-experts__card" {{ block.shopify_attributes }}>

          <div class="lt-about-experts__top">
            <div class="lt-about-experts__avatar">
              {%- if block.settings.photo != blank -%}
                {{
                  block.settings.photo
                  | image_url: width: 192
                  | image_tag:
                    loading: 'lazy',
                    class: 'lt-about-experts__photo',
                    width: 96,
                    height: 96,
                    alt: block.settings.name
                }}
              {%- else -%}
                <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              {%- endif -%}
            </div>

            <div class="lt-about-experts__meta">
              {%- if block.settings.role != blank -%}
                <p class="lt-about-experts__role">{{ block.settings.role | escape }}</p>
              {%- endif -%}
              {%- if block.settings.name != blank -%}
                <h3 class="lt-about-experts__name">{{ block.settings.name | escape }}</h3>
              {%- endif -%}
            </div>
          </div>

          {%- if block.settings.bio != blank -%}
            <div class="lt-about-experts__bio">{{ block.settings.bio }}</div>
          {%- endif -%}

          {%- if block.settings.quote != blank -%}
            <blockquote class="lt-about-experts__quote">
              {{ block.settings.quote | escape }}
            </blockquote>
          {%- endif -%}

        </li>
      {%- endfor -%}
    </ul>

  </div>
</section>

{% schema %}
{
  "name": "LT Experten-Profile",
  "tag": "section",
  "class": "lt-about-experts-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (micro label)",
      "info": "Optional. Leer lassen, wenn die Headline den Kontext trägt."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Unsere Experten von LIFETIME"
    }
  ],
  "blocks": [
    {
      "type": "expert",
      "name": "Experte",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Foto",
          "info": "Wird als einheitliches Quadrat (96px) beschnitten."
        },
        {
          "type": "text",
          "id": "role",
          "label": "Rolle (Eyebrow)",
          "default": "Chief Scientific Officer der LIFETIME Group"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Prof. Dr. med. Limmroth"
        },
        {
          "type": "richtext",
          "id": "bio",
          "label": "Bio",
          "default": "<p>Kurzvita des Experten.</p>"
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Zitat (optional)",
          "info": "Wird typografisch hervorgehoben. Leer lassen, wenn kein Zitat."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "LT Experten-Profile",
      "blocks": [
        { "type": "expert" },
        { "type": "expert" }
      ]
    }
  ]
}
{% endschema %}
