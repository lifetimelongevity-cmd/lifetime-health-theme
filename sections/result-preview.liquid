      "default": "#636366"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 150,
      "step": 10,
      "unit": "px",
      "default": 80
