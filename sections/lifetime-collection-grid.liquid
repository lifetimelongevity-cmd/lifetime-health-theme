{%- liquid
  case section.settings.columns_desktop
    when '2'
      assign grid_class = 'grid-2 grid-palm-1'
    when '3'
      assign grid_class = 'grid-3 grid-portable-2 grid-palm-2'
    else
      assign grid_class = 'grid-4 grid-laptop-3 grid-palm-2'
  endcase
-%}

<div
  class="container--large container--vertical-space section-{{ section.id }}-cg"
  style="background-color: {{ section.settings.section_bg_color }};"
>

  {%- if section.settings.heading != blank or section.settings.subheading != blank -%}
    <div class="cg-header crs-heading-stack crs-heading-stack--align-left">
      {%- if section.settings.subheading != blank -%}
        <p class="crs-heading-stack__kicker">{{ section.settings.subheading | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <div class="crs-heading-stack__pair">
          <h2 class="cg-heading crs-heading-stack__title">{{ section.settings.heading | escape }}</h2>
        </div>
      {%- endif -%}
    </div>
  {%- endif -%}

  <div class="grid grid--layout {{ grid_class }}">

    {%- for block in section.blocks -%}
      {%- assign product    = block.settings.product -%}
      {%- assign card_bg    = block.settings.card_bg_color -%}
      {%- assign text_color = block.settings.text_color -%}
      {%- assign cmp_color  = block.settings.compare_price_color -%}
      {%- assign use_bg_img = block.settings.image_as_background -%}

      {%- assign card_href = '#' -%}
      {%- if product != blank -%}
        {%- assign card_href = product.url -%}
      {%- elsif block.settings.custom_url != blank -%}
        {%- assign card_href = block.settings.custom_url -%}
      {%- endif -%}

      {%- comment -%} Resolve the image object once for reuse {%- endcomment -%}
      {%- assign card_image = block.settings.custom_image -%}
      {%- if card_image == blank and product != blank -%}
        {%- assign card_image = product.featured_image -%}
      {%- endif -%}
      {%- assign card_image_alt = block.settings.custom_title | escape -%}
      {%- if card_image_alt == blank and product != blank -%}
        {%- assign card_image_alt = product.featured_image.alt | escape -%}
      {%- endif -%}

      <a
        href="{{ card_href }}"
        class="cg-card{% if use_bg_img %} cg-card--bg{% endif %}"
        style="background-color: {{ card_bg }}; border-radius: {{ section.settings.card_border_radius }}px;"
        {{ block.shopify_attributes }}
      >

        {%- if use_bg_img and card_image != blank -%}
          <img
            src="{{ card_image | image_url: width: 1100 }}"
            srcset="
              {{ card_image | image_url: width: 550 }} 550w,
              {{ card_image | image_url: width: 750 }} 750w,
              {{ card_image | image_url: width: 1100 }} 1100w
            "
            sizes="(min-width: 990px) calc(100vw / {{ section.settings.columns_desktop }}), 50vw"
            alt="{{ card_image_alt }}"
            loading="lazy"
            width="{{ card_image.width }}"
            height="{{ card_image.height }}"
            class="cg-card__bg-image"
          >
          <span class="cg-card__overlay" aria-hidden="true"></span>
        {%- endif -%}

        {%- if block.settings.badge != blank -%}
          <span class="cg-badge" style="color: {{ card_bg }};">
            {{ block.settings.badge | escape }}
          </span>
        {%- endif -%}

        <div class="cg-card__body">
          <h3 class="cg-card__title" style="color: {{ text_color }};">
            {%- if product != blank -%}
              {{ product.title | escape }}
            {%- elsif block.settings.custom_title != blank -%}
              {{ block.settings.custom_title | escape }}
            {%- endif -%}
            {%- comment -%}
              Decorative arrow on feature cards (image-as-background).
              aria-hidden so screen readers don't announce "right arrow".
            {%- endcomment -%}
            {%- if use_bg_img -%}
              <span class="cg-card__arrow" aria-hidden="true">&nbsp;→</span>
            {%- endif -%}
          </h3>

          {%- assign subline = block.settings.subline -%}
          {%- if subline == blank and product != blank -%}
            {%- assign subline = product.description | strip_html | truncate: 60 -%}
          {%- endif -%}
          {%- if subline != blank -%}
            <p class="cg-card__subline" style="color: {{ text_color }};">{{ subline }}</p>
          {%- endif -%}

          {%- comment -%}
            Rating: prefer live product metafield values (Shopify Reviews / Judge.me
            all write to reviews.rating + reviews.rating_count). Fall back to the
            manual block settings. Rating = 0 means "don't show".
          {%- endcomment -%}
          {%- assign rating_value = 0 -%}
          {%- assign rating_count = block.settings.rating_count -%}
          {%- if block.settings.rating_value and block.settings.rating_value > 0 -%}
            {%- assign rating_value = block.settings.rating_value -%}
          {%- endif -%}
          {%- if product != blank -%}
            {%- if product.metafields.reviews.rating.value != blank -%}
              {%- assign rating_value = product.metafields.reviews.rating.value | times: 1 -%}
            {%- endif -%}
            {%- if product.metafields.reviews.rating_count != blank -%}
              {%- assign rating_count = product.metafields.reviews.rating_count -%}
            {%- endif -%}
          {%- endif -%}
          {%- if rating_value > 0 -%}
            {%- assign rating_fill = rating_value | times: 20 -%}
            <div
              class="cg-card__rating"
              style="color: {{ text_color }};"
              aria-label="{{ rating_value }} von 5 Sternen{% if rating_count != blank %}, {{ rating_count }} Bewertungen{% endif %}"
            >
              <span class="cg-card__stars" style="--rating-fill: {{ rating_fill }}%;" aria-hidden="true"></span>
              {%- if rating_count != blank -%}
                <span class="cg-card__rating-count" aria-hidden="true">({{ rating_count }})</span>
              {%- endif -%}
            </div>
          {%- endif -%}

          {%- if product != blank -%}
            <p class="cg-card__price" style="color: {{ text_color }};">
              {%- if product.compare_at_price > product.price -%}
                From {{ product.price | money_without_trailing_zeros }}
                <s style="color: {{ cmp_color }};">{{ product.compare_at_price | money_without_trailing_zeros }}</s>
              {%- else -%}
                {{ product.price | money_without_trailing_zeros }}
              {%- endif -%}
            </p>
          {%- endif -%}

          {%- if block.settings.button_label != blank -%}
            <span
              class="cg-card__btn"
              style="background-color: {{ block.settings.button_bg_color }}; color: {{ block.settings.button_text_color }};"
            >
              {{ block.settings.button_label | escape }}
            </span>
          {%- endif -%}
        </div>

        {%- unless use_bg_img -%}
          <div class="cg-card__image-wrap">
            {%- if card_image != blank -%}
              <img
                src="{{ card_image | image_url: width: 1100 }}"
                srcset="
                  {{ card_image | image_url: width: 550 }} 550w,
                  {{ card_image | image_url: width: 750 }} 750w,
                  {{ card_image | image_url: width: 1100 }} 1100w
                "
                sizes="(min-width: 990px) calc(100vw / {{ section.settings.columns_desktop }}), 50vw"
                alt="{{ card_image_alt }}"
                loading="lazy"
                width="{{ card_image.width }}"
                height="{{ card_image.height }}"
                class="cg-card__image"
              >
            {%- else -%}
              {{ 'product-1' | placeholder_svg_tag: 'cg-card__image cg-card__image--placeholder' }}
            {%- endif -%}
          </div>
        {%- endunless -%}

      </a>

    {%- endfor -%}
  </div>

</div>

<style>
  .section-{{ section.id }}-cg {
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  /* Scale section padding down on mobile (~0.8x, token-aligned:
     e.g. 80px desktop → 64px mobile, 64px → 48px). */
  @media (max-width: 749px) {
    .section-{{ section.id }}-cg {
      padding-top: calc({{ section.settings.padding_top }}px * 0.8);
      padding-bottom: calc({{ section.settings.padding_bottom }}px * 0.8);
    }
  }

  /* ---- Header ---- */
  .section-{{ section.id }}-cg .cg-header {
    border-top: 1px solid var(--color-border-default);
    padding-top: var(--space-6);
    margin-bottom: var(--space-5);
  }

  @media (max-width: 749px) {
    .section-{{ section.id }}-cg .cg-header {
      padding-top: var(--space-5);
      margin-bottom: var(--space-4);
    }
  }

  .section-{{ section.id }}-cg .cg-heading {
    margin: 0;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: var(--weight-bold, 700);
    line-height: var(--leading-heading, 1.15);
  }

  /* Equalize row heights for all cards */
  .section-{{ section.id }}-cg .grid {
    align-items: stretch;
  }

  /* ---- Card (default) ---- */
  .section-{{ section.id }}-cg .cg-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
    padding: var(--space-7) var(--space-2) 0;
    text-align: center;
    text-decoration: none;
    color: inherit;
  }

  @media (max-width: 749px) {
    .section-{{ section.id }}-cg .cg-card {
      padding: var(--space-6) var(--space-3) 0;
    }
  }

  /* ---- Card – background-image mode ---- */
  .section-{{ section.id }}-cg .cg-card--bg {
    padding: 0;
    justify-content: flex-end;
    /* min-height acts as a floor when this card is alone in a row;
       align-items: stretch on the grid takes over when siblings are taller */
    min-height: {{ section.settings.card_image_height }}px;
  }

  .section-{{ section.id }}-cg .cg-card__bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform var(--ease-smooth);
  }

  .section-{{ section.id }}-cg .cg-card--bg:hover .cg-card__bg-image {
    transform: scale(1.05);
  }

  /* gradient overlay so text stays readable */
  .section-{{ section.id }}-cg .cg-card__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.62) 0%, rgba(0,0,0,0.1) 55%, transparent 100%);
    pointer-events: none;
  }

  /* card body in bg mode sits on top of the overlay */
  .section-{{ section.id }}-cg .cg-card--bg .cg-card__body {
    position: relative;
    z-index: 1;
    padding: var(--space-5) var(--space-5) var(--space-6);
    margin-bottom: 0;
  }

  /* ---- Badge ---- */
  .section-{{ section.id }}-cg .cg-badge {
    position: absolute;
    top: var(--space-2);
    right: var(--space-2);
    z-index: 2;
    background: var(--color-surface-primary);
    padding: 0.15rem var(--space-2);
    font-family: var(--font-body-family);
    font-weight: var(--font-body-weight);
    font-style: var(--font-body-style);
    font-size: calc(var(--font-body-size, 1rem) * 0.5);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    line-height: 1.4;
    white-space: nowrap;
    border-radius: var(--radius-full);
  }

  @media (min-width: 750px) {
    .section-{{ section.id }}-cg .cg-badge {
      font-size: calc(var(--font-body-size, 1rem) * 0.7);
      padding: var(--space-1) var(--space-2);
      top: var(--space-3);
      right: var(--space-3);
    }
  }

  /* ---- Card body ---- */
  .section-{{ section.id }}-cg .cg-card__body {
    margin-bottom: var(--space-3);
  }

  @media (min-width: 750px) {
    .section-{{ section.id }}-cg .cg-card__body {
      margin-bottom: var(--space-6);
    }

    .section-{{ section.id }}-cg .cg-card--bg .cg-card__body {
      margin-bottom: 0;
    }
  }

  .section-{{ section.id }}-cg .cg-card__title {
    margin: 0 0 var(--space-1);
    font-family: var(--font-heading-family);
    font-weight: var(--font-heading-weight);
    font-style: var(--font-heading-style);
    font-size: calc(var(--font-body-size, 1rem) * 1.1);
    line-height: var(--line-height-heading, 1.1);
    letter-spacing: var(--letter-spacing-heading, 0);
  }

  .section-{{ section.id }}-cg .cg-card__arrow {
    display: inline-block;
    transition: transform var(--ease-default, 0.2s ease);
  }

  .section-{{ section.id }}-cg .cg-card:hover .cg-card__arrow {
    transform: translateX(4px);
  }

  @media (max-width: 749px) {
    .section-{{ section.id }}-cg .cg-card__title {
      font-size: calc(var(--font-body-size, 1rem) * 1.05);
    }
  }

  @media (min-width: 750px) {
    .section-{{ section.id }}-cg .cg-card__title {
      font-size: calc(var(--font-body-size, 1rem) * 1.5);
    }
  }

  .section-{{ section.id }}-cg .cg-card__subline {
    margin: 0 0 var(--space-2);
    font-family: var(--font-body-family);
    font-weight: var(--font-body-weight);
    font-style: var(--font-body-style);
    font-size: calc(var(--font-body-size, 1rem) * 0.9);
    line-height: var(--leading-body);
  }

  @media (max-width: 749px) {
    .section-{{ section.id }}-cg .cg-card__subline {
      font-size: calc(var(--font-body-size, 1rem) * 0.82);
      margin-bottom: var(--space-1);
    }
  }

  /* ---- Rating / social proof ---- */
  .section-{{ section.id }}-cg .cg-card__rating {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    margin: 0 0 var(--space-2);
    font-family: var(--font-body-family);
    font-size: calc(var(--font-body-size, 1rem) * 0.82);
    line-height: 1;
    justify-content: center;
  }

  .section-{{ section.id }}-cg .cg-card__stars {
    --rating-fill: 0%;
    position: relative;
    display: inline-block;
    width: 5.4em;
    height: 1em;
    line-height: 1;
    letter-spacing: 0.08em;
    font-family: Helvetica, Arial, sans-serif;
  }

  .section-{{ section.id }}-cg .cg-card__stars::before,
  .section-{{ section.id }}-cg .cg-card__stars::after {
    content: "★★★★★";
    position: absolute;
    top: 0;
    left: 0;
    line-height: 1;
  }

  .section-{{ section.id }}-cg .cg-card__stars::before {
    color: var(--color-gray-200, #E5E5E5);
  }

  .section-{{ section.id }}-cg .cg-card__stars::after {
    color: var(--color-star, #F4B740);
    width: var(--rating-fill);
    overflow: hidden;
    white-space: nowrap;
  }

  .section-{{ section.id }}-cg .cg-card__rating-count {
    opacity: 0.7;
    font-size: 0.92em;
  }

  .section-{{ section.id }}-cg .cg-card__price {
    margin: 0;
    font-family: var(--font-body-family);
    font-weight: var(--font-body-weight);
    font-style: var(--font-body-style);
    font-size: calc(var(--font-body-size, 1rem));
    line-height: 1.2;
  }

  .section-{{ section.id }}-cg .cg-card__price s {
    text-decoration: line-through;
    margin-left: var(--space-1);
  }

  /* ---- CTA Button ---- */
  .section-{{ section.id }}-cg .cg-card__btn {
    display: inline-block;
    margin-top: var(--space-4);
    padding: 0.55em 1.2em;
    font-family: var(--font-body-family);
    font-weight: var(--font-body-weight);
    font-style: var(--font-body-style);
    font-size: calc(var(--font-body-size, 1rem) * 0.85);
    letter-spacing: 0.03em;
    line-height: 1.2;
    border-radius: {{ section.settings.card_border_radius }}px;
    transition: opacity var(--ease-default);
  }

  .section-{{ section.id }}-cg .cg-card:hover .cg-card__btn {
    opacity: 0.85;
  }

  /* ---- Image (default mode) ---- */
  .section-{{ section.id }}-cg .cg-card__image-wrap {
    height: {{ section.settings.card_image_height }}px;
    max-height: {{ section.settings.card_image_height }}px;
    display: flex;
    justify-content: center;
    align-items: flex-end;
    overflow: hidden;
    flex-shrink: 0;
  }

  @media (max-width: 749px) {
    .section-{{ section.id }}-cg .cg-card__image-wrap {
      height: clamp(130px, 42vw, {{ section.settings.card_image_height }}px);
      max-height: clamp(130px, 42vw, {{ section.settings.card_image_height }}px);
    }
  }

  .section-{{ section.id }}-cg .cg-card__image {
    display: block;
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    object-position: center bottom;
    transition: transform 0.2s ease;
  }

  .section-{{ section.id }}-cg .cg-card:hover .cg-card__image {
    transform: scale(1.08);
  }

  .section-{{ section.id }}-cg .cg-card__image--placeholder {
    opacity: 0.25;
    width: auto;
    max-width: 60%;
  }
</style>

{% schema %}
{
  "name": "Collection Grid",
  "class": "container--remove-margin-before",
  "max_blocks": 12,
  "settings": [
    {
      "type": "header",
      "content": "Section header"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Collection"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 20,
      "max": 72,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" },
        { "value": "4", "label": "4 columns" }
      ],
      "default": "4"
    },
    {
      "type": "range",
      "id": "card_image_height",
      "label": "Card image area height",
      "min": 120,
      "max": 400,
      "step": 20,
      "unit": "px",
      "default": 220
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "header",
          "content": "Product"
        },
        {
          "type": "product",
          "id": "product",
          "label": "Product"
        },
        {
          "type": "text",
          "id": "subline",
          "label": "Subline / tagline",
          "info": "Short descriptor below the title. Falls back to product description if blank."
        },
        {
          "type": "header",
          "content": "Manual override (when no product is set)"
        },
        {
          "type": "text",
          "id": "custom_title",
          "label": "Custom title"
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Custom link URL"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom image"
        },
        {
          "type": "header",
          "content": "Card style"
        },
        {
          "type": "checkbox",
          "id": "image_as_background",
          "label": "Use image as full card background",
          "info": "Image fills the card as a cover. Text sits at the bottom with a gradient overlay.",
          "default": false
        },
        {
          "type": "header",
          "content": "Card colors"
        },
        {
          "type": "color",
          "id": "card_bg_color",
          "label": "Card background",
          "default": "#222222"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "compare_price_color",
          "label": "Compare-at price color",
          "default": "#dfdfdf"
        },
        {
          "type": "header",
          "content": "Badge"
        },
        {
          "type": "text",
          "id": "badge",
          "label": "Badge text",
          "info": "e.g. NEW, SALE, LIMITED TIME ONLY"
        },
        {
          "type": "header",
          "content": "Rating"
        },
        {
          "type": "range",
          "id": "rating_value",
          "label": "Star rating",
          "min": 0,
          "max": 5,
          "step": 0.1,
          "default": 0,
          "info": "Leave at 0 to hide. Overridden by product metafield reviews.rating when the product is linked."
        },
        {
          "type": "text",
          "id": "rating_count",
          "label": "Review count",
          "info": "Shown in parentheses next to the stars, e.g. 128."
        },
        {
          "type": "header",
          "content": "CTA Button (optional)"
        },
        {
          "type": "text",
          "id": "button_label",
          "label": "Button label",
          "info": "Leave blank to hide the button."
        },
        {
          "type": "color",
          "id": "button_bg_color",
          "label": "Button background",
          "default": "#ffffff"
        },
        {
          "type": "color",
          "id": "button_text_color",
          "label": "Button text color",
          "default": "#000000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection Grid",
      "blocks": [
        {
          "type": "product_card",
          "settings": {
            "custom_title": "Coffee",
            "subline": "Full-bodied coffee",
            "card_bg_color": "#926253",
            "text_color": "#ffffff",
            "compare_price_color": "#dfdfdf",
            "badge": "NEW"
          }
        },
        {
          "type": "product_card",
          "settings": {
            "custom_title": "Original",
            "subline": "Rich chocolate chai",
            "card_bg_color": "#222222",
            "text_color": "#ffffff",
            "compare_price_color": "#dfdfdf",
            "badge": "Most Popular"
          }
        },
