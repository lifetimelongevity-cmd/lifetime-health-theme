{% comment %}
  lt-routine-quiz
  ────────────────────────────────────────────────────────────
  Adaptives Quiz für /pages/meine-routine.

  Q1 (Routing) stellt 3 Bild-Karten. Die Auswahl entscheidet intern,
  welchen Pfad der Nutzer durchläuft — ohne sichtbare Weichenstellung:

    Karte 1 "Ich fühle den Unterschied" → Diagnostik, archetype = tired
    Karte 2 "Ich will verstehen"        → Diagnostik, archetype = measurer
    Karte 3 "Ich will loslegen"         → Supplement

  Diagnostik-Pfad  (Karten 1 + 2):
    Q2 Alter-Slider
    Q3 archetype-spezifische Folgefrage
    Q4 Was hast du bisher versucht?
    Q5 Intent (hot / cool)
    → Result: Archetype-Hypothesen + CTA zum AGE & DNA-Test

  Supplement-Pfad (Karte 3):
    Q2 Wo merkst du es am stärksten?   (Energie / Fokus / Schlaf / Langlebigkeit)
    → Result: Personalisiertes Bundle (primary + 2 secondaries)

  Advisor-Zeile (Prof. Limmroth) erscheint unter dem Quiz auf beiden Pfaden.
{% endcomment %}

{%- liquid
  assign p_energie_primary = all_products[section.settings.product_energie_primary]
  assign p_energie_sec1    = all_products[section.settings.product_energie_sec1]
  assign p_energie_sec2    = all_products[section.settings.product_energie_sec2]
  assign p_fokus_primary   = all_products[section.settings.product_fokus_primary]
  assign p_fokus_sec1      = all_products[section.settings.product_fokus_sec1]
  assign p_fokus_sec2      = all_products[section.settings.product_fokus_sec2]
  assign p_schlaf_primary  = all_products[section.settings.product_schlaf_primary]
  assign p_schlaf_sec1     = all_products[section.settings.product_schlaf_sec1]
  assign p_schlaf_sec2     = all_products[section.settings.product_schlaf_sec2]
  assign p_lang_primary    = all_products[section.settings.product_lang_primary]
  assign p_lang_sec1       = all_products[section.settings.product_lang_sec1]
  assign p_lang_sec2       = all_products[section.settings.product_lang_sec2]

  assign advisor_image_src = ''
  if section.settings.advisor_image != blank
    assign advisor_image_src = section.settings.advisor_image | image_url: width: 112
  endif
-%}

{{ 'section-lt-longevity-quiz.css' | asset_url | stylesheet_tag }}

{% style %}
  #lt-routine-quiz-{{ section.id }} {
    --rq-bg: {{ section.settings.color_bg }};
    --rq-text: {{ section.settings.color_text }};
    --rq-accent: {{ section.settings.color_accent }};
    --rq-card: {{ section.settings.color_card_bg }};
    --rq-cta-bg: {{ section.settings.color_cta_bg }};
    --rq-cta-text: {{ section.settings.color_cta_text }};
    --rq-muted: {{ section.settings.color_text | color_modify: 'alpha', 0.62 }};
    --rq-border: {{ section.settings.color_text | color_modify: 'alpha', 0.12 }};
    --rq-accent-soft: {{ section.settings.color_accent | color_modify: 'alpha', 0.1 }};
    --rq-accent-border: {{ section.settings.color_accent | color_modify: 'alpha', 0.4 }};
    --rq-pad-top: {{ section.settings.padding_top }}px;
    --rq-pad-bottom: {{ section.settings.padding_bottom }}px;
    background: var(--rq-bg);
    color: var(--rq-text);
    padding: var(--rq-pad-top) var(--space-4) var(--rq-pad-bottom);
    font-family: var(--font-body);
  }

  #lt-routine-quiz-{{ section.id }} *,
  #lt-routine-quiz-{{ section.id }} *::before,
  #lt-routine-quiz-{{ section.id }} *::after { box-sizing: border-box; }

  #lt-routine-quiz-{{ section.id }} .rq-frame {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    background: var(--rq-card);
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-5);
    min-height: clamp(520px, 64vh, 760px);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }
  @media (min-width: 750px) {
    #lt-routine-quiz-{{ section.id }} .rq-frame {
      padding: var(--space-7) var(--space-6);
      gap: var(--space-7);
    }
  }
  @media (min-width: 990px) {
    #lt-routine-quiz-{{ section.id }} .rq-frame {
      max-width: min(860px, 64rem);
      padding: var(--space-7);
    }
  }

  /* Progress */
  #lt-routine-quiz-{{ section.id }} .rq-progress {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }
  #lt-routine-quiz-{{ section.id }} .rq-progress[hidden] { display: none; }
  #lt-routine-quiz-{{ section.id }} .rq-progress-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: var(--space-2);
    flex: 1;
    position: relative;
  }
  #lt-routine-quiz-{{ section.id }} .rq-progress-list::before {
    content: '';
    position: absolute;
    top: 14px;
    left: calc(100% / var(--rq-steps, 1) / 2);
    right: calc(100% / var(--rq-steps, 1) / 2);
    height: 2px;
    background: var(--rq-border);
    border-radius: var(--radius-full);
    z-index: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-progress-list li {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    color: var(--rq-muted);
    transition: color 240ms var(--ease-default, ease);
  }
  #lt-routine-quiz-{{ section.id }} .rq-progress-icon {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    background: var(--rq-card);
    border: 2px solid var(--rq-border);
    display: grid;
    place-items: center;
    transition: background 240ms ease, border-color 240ms ease, color 240ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-progress-icon svg {
    width: 14px;
    height: 14px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-progress-label {
    font-size: 10px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    font-weight: var(--weight-medium);
    line-height: 1;
  }
  #lt-routine-quiz-{{ section.id }} .rq-progress-list li.is-done {
    color: var(--rq-accent);
  }
  #lt-routine-quiz-{{ section.id }} .rq-progress-list li.is-done .rq-progress-icon {
    background: var(--rq-accent);
    border-color: var(--rq-accent);
    color: var(--rq-cta-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-progress-list li[aria-current='step'] {
    color: var(--rq-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-progress-list li[aria-current='step'] .rq-progress-icon {
    background: var(--rq-card);
    border-color: var(--rq-accent);
    color: var(--rq-accent);
    box-shadow: 0 0 0 3px var(--rq-accent-soft);
  }
  @media (max-width: 540px) {
    #lt-routine-quiz-{{ section.id }} .rq-progress-label { font-size: 9px; }
    #lt-routine-quiz-{{ section.id }} .rq-progress-icon { width: 24px; height: 24px; }
    #lt-routine-quiz-{{ section.id }} .rq-progress-icon svg { width: 12px; height: 12px; }
    #lt-routine-quiz-{{ section.id }} .rq-progress-list::before { top: 12px; }
  }
  #lt-routine-quiz-{{ section.id }} .rq-back {
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--rq-muted);
    font: inherit;
    font-size: var(--text-body-sm);
    cursor: pointer;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-sm);
    min-height: 44px;
    transition: color 180ms ease, background 180ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-back:hover,
  #lt-routine-quiz-{{ section.id }} .rq-back:focus-visible {
    color: var(--rq-text);
    background: var(--rq-accent-soft);
    outline: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-back[hidden] { display: none; }

  /* Screens */
  #lt-routine-quiz-{{ section.id }} .rq-screen {
    display: none;
    flex-direction: column;
    gap: var(--space-6);
    flex: 1;
  }
  #lt-routine-quiz-{{ section.id }} .rq-screen.is-active {
    display: flex;
    animation: rqFade 260ms var(--ease-smooth, ease);
  }
  @keyframes rqFade {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0); }
  }
  #lt-routine-quiz-{{ section.id }} .rq-screen h2 {
    font-family: var(--font-heading);
    font-size: clamp(20px, 4.4vw, 24px);
    line-height: 1.25;
    font-weight: var(--weight-semibold);
    margin: 0;
    letter-spacing: -0.01em;
    outline: none;
    text-wrap: balance;
  }
  #lt-routine-quiz-{{ section.id }} .rq-kicker {
    font-size: var(--text-micro);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rq-muted);
    font-weight: var(--weight-medium);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-helper,
  #lt-routine-quiz-{{ section.id }} .rq-subhead {
    margin: 0;
    color: var(--rq-muted);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body);
  }
  #lt-routine-quiz-{{ section.id }} fieldset {
    border: 0;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  #lt-routine-quiz-{{ section.id }} legend {
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* Image cards (Q1 routing + Q2 supplement focus) */
  #lt-routine-quiz-{{ section.id }} .rq-cards {
    display: grid;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cards--route {
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card {
    flex-direction: row;
    align-items: stretch;
    min-height: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card__media {
    aspect-ratio: auto;
    flex: 0 0 33%;
    max-width: 140px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card__body {
    flex: 1 1 auto;
    justify-content: center;
    padding: var(--space-3) var(--space-4);
  }
  @media (min-width: 750px) {
    #lt-routine-quiz-{{ section.id }} .rq-cards--route {
      grid-template-columns: repeat(3, 1fr);
    }
    #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card {
      flex-direction: column;
    }
    #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card__media {
      aspect-ratio: 1 / 1;
      flex: initial;
      max-width: none;
    }
    #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card__body {
      justify-content: flex-start;
      padding: var(--space-4) var(--space-4) var(--space-5);
    }
  }
  #lt-routine-quiz-{{ section.id }} .rq-cards--focus {
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 750px) {
    #lt-routine-quiz-{{ section.id }} .rq-cards--focus {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  #lt-routine-quiz-{{ section.id }} .rq-card {
    appearance: none;
    border: 1px solid var(--rq-border);
    background: var(--rq-bg);
    color: inherit;
    font: inherit;
    text-align: left;
    padding: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card:hover,
  #lt-routine-quiz-{{ section.id }} .rq-card:focus-visible {
    border-color: var(--rq-accent-border);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md, 0 6px 18px rgba(0,0,0,.08));
    outline: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card.is-selected {
    border-color: var(--rq-accent);
    box-shadow: 0 0 0 2px var(--rq-accent-soft);
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__media {
    aspect-ratio: 1 / 1;
    background: var(--rq-accent-soft);
    overflow: hidden;
    position: relative;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__media--icon {
    display: grid;
    place-items: center;
    color: var(--rq-accent);
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__media--icon svg {
    width: 40%;
    height: 40%;
    stroke-width: 1.25;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__body {
    padding: var(--space-4) var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__label {
    font-family: var(--font-heading);
    font-size: var(--text-body);
    font-weight: var(--weight-semibold);
    line-height: 1.3;
    color: var(--rq-text);
    letter-spacing: -0.01em;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__sub {
    font-size: 13px;
    line-height: 1.4;
    color: var(--rq-muted);
  }

  /* Radio-style options (Q3 / Q4 / Q5) */
  #lt-routine-quiz-{{ section.id }} .rq-options {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-4);
    border: 1px solid var(--rq-border);
    border-radius: var(--radius-md);
    background: var(--rq-bg);
    cursor: pointer;
    min-height: 56px;
    transition: border-color 180ms ease, background 180ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-option:hover {
    border-color: var(--rq-accent-border);
    background: var(--rq-accent-soft);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-marker {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: var(--radius-full);
    border: 2px solid var(--rq-border);
    margin-top: 2px;
    transition: border-color 160ms ease, background 160ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-option--checkbox .rq-marker {
    border-radius: var(--radius-sm);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option input:checked ~ .rq-marker {
    border-color: var(--rq-accent);
    background: var(--rq-accent);
    box-shadow: inset 0 0 0 3px var(--rq-card);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option--checkbox input:checked ~ .rq-marker {
    box-shadow: inset 0 0 0 2px var(--rq-card);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option:has(input:checked) {
    border-color: var(--rq-accent);
    background: var(--rq-accent-soft);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option-label {
    font-size: 15px;
    line-height: 1.4;
    color: var(--rq-text);
  }

  /* Sliders (Q2 diagnostic) */
  #lt-routine-quiz-{{ section.id }} .rq-slider-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  #lt-routine-quiz-{{ section.id }} .rq-slider {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  #lt-routine-quiz-{{ section.id }} .rq-slider-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
    font-size: var(--text-body-sm);
    color: var(--rq-muted);
  }
  #lt-routine-quiz-{{ section.id }} .rq-slider-value {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    color: var(--rq-text);
    font-weight: var(--weight-semibold);
  }
  #lt-routine-quiz-{{ section.id }} input[type='range'] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 6px;
    background: var(--rq-border);
    border-radius: var(--radius-full);
    outline: none;
  }
  #lt-routine-quiz-{{ section.id }} input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    background: var(--rq-accent);
    cursor: pointer;
    border: 3px solid var(--rq-card);
    box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,.1));
  }
  #lt-routine-quiz-{{ section.id }} input[type='range']::-moz-range-thumb {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    background: var(--rq-accent);
    cursor: pointer;
    border: 3px solid var(--rq-card);
  }
  #lt-routine-quiz-{{ section.id }} .rq-slider-hint {
    background: var(--rq-accent-soft);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    color: var(--rq-text);
    font-size: var(--text-body-sm);
    line-height: 1.45;
    margin-top: var(--space-2);
  }

  /* CTAs */
  #lt-routine-quiz-{{ section.id }} .rq-cta-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta {
    appearance: none;
    border: 0;
    font: inherit;
    font-family: var(--font-body);
    font-weight: var(--weight-semibold);
    font-size: 15px;
    letter-spacing: 0.01em;
    min-height: 48px;
    padding: 14px 28px;
    border-radius: var(--radius-full);
    cursor: pointer;
    text-decoration: none;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    transition: background 180ms ease, transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta--primary {
    background: var(--rq-cta-bg);
    color: var(--rq-cta-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta--primary:hover,
  #lt-routine-quiz-{{ section.id }} .rq-cta--primary:focus-visible {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md, 0 6px 16px rgba(0,0,0,.12));
    outline: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta--secondary {
    background: transparent;
    color: var(--rq-text);
    border: 1px solid var(--rq-border);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta--secondary:hover,
  #lt-routine-quiz-{{ section.id }} .rq-cta--secondary:focus-visible {
    border-color: var(--rq-text);
    outline: none;
  }

  /* Diagnostic result */
  #lt-routine-quiz-{{ section.id }} .rq-anchor {
    font-family: var(--font-heading);
    font-size: clamp(22px, 5vw, 28px);
    line-height: 1.2;
    font-weight: var(--weight-semibold);
    margin: 0;
    color: var(--rq-text);
    letter-spacing: -0.015em;
    outline: none;
    text-wrap: balance;
  }
  #lt-routine-quiz-{{ section.id }} .rq-empathy {
    margin: 0;
    color: var(--rq-text);
    font-size: var(--text-body);
    line-height: 1.5;
  }
  #lt-routine-quiz-{{ section.id }} .rq-zone-heading {
    font-family: var(--font-body);
    font-size: var(--text-micro);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: var(--weight-medium);
    margin: 0;
    color: var(--rq-muted);
  }
  #lt-routine-quiz-{{ section.id }} .rq-hypotheses {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  #lt-routine-quiz-{{ section.id }} .rq-hypothesis {
    background: var(--rq-bg);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    font-size: 15px;
    line-height: 1.45;
  }

  /* Supplement result bundle */
  #lt-routine-quiz-{{ section.id }} .rq-bundle {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 750px) {
    #lt-routine-quiz-{{ section.id }} .rq-bundle {
      grid-template-columns: 1.2fr 1fr 1fr;
      align-items: stretch;
    }
  }
  #lt-routine-quiz-{{ section.id }} .rq-product {
    background: var(--rq-bg);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    border: 1px solid var(--rq-border);
  }
  #lt-routine-quiz-{{ section.id }} .rq-product--primary {
    border-color: var(--rq-accent);
    box-shadow: 0 0 0 2px var(--rq-accent-soft);
  }
  #lt-routine-quiz-{{ section.id }} .rq-product__media {
    aspect-ratio: 1 / 1;
    background: var(--rq-accent-soft);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  #lt-routine-quiz-{{ section.id }} .rq-product__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #lt-routine-quiz-{{ section.id }} .rq-product__tag {
    font-size: var(--text-micro);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rq-accent);
    font-weight: var(--weight-semibold);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-product__title {
    font-family: var(--font-heading);
    font-size: var(--text-body);
    font-weight: var(--weight-semibold);
    margin: 0;
    line-height: 1.3;
  }
  #lt-routine-quiz-{{ section.id }} .rq-product__price {
    font-size: var(--text-body-sm);
    color: var(--rq-muted);
    margin: 0;
  }

  /* Advisor line */
  #lt-routine-quiz-{{ section.id }} .rq-advisor {
    max-width: min(860px, 64rem);
    margin: var(--space-5) auto 0;
    display: flex;
    align-items: center;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    color: var(--rq-muted);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body);
  }
  #lt-routine-quiz-{{ section.id }} .rq-advisor img {
    width: 40px;
    height: 40px;
    border-radius: var(--radius-full);
    object-fit: cover;
    flex-shrink: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-advisor strong {
    color: var(--rq-text);
    font-weight: var(--weight-semibold);
    display: block;
  }

  #lt-routine-quiz-{{ section.id }} .rq-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ═══════ Result — 4-Zonen-Layout ═══════ */
  #lt-routine-quiz-{{ section.id }} .rq-result.is-active {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
    text-align: left;
  }
  #lt-routine-quiz-{{ section.id }} .rq-zone {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  #lt-routine-quiz-{{ section.id }} .rq-zone + .rq-zone {
    padding-top: var(--space-6);
    border-top: 1px solid var(--rq-border);
  }
  #lt-routine-quiz-{{ section.id }} .rq-zone-kicker {
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rq-muted);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-zone-title {
    font-size: clamp(18px, 3.6vw, 22px);
    line-height: 1.25;
    font-weight: var(--weight-semibold);
    color: var(--rq-text);
    margin: 0;
    text-wrap: balance;
  }

  /* Zone 1 — Anchor */
  #lt-routine-quiz-{{ section.id }} .rq-anchor {
    font-size: clamp(22px, 5vw, 28px);
    line-height: 1.22;
    font-weight: var(--weight-semibold);
    color: var(--rq-text);
    margin: 0;
    text-wrap: balance;
  }
  #lt-routine-quiz-{{ section.id }} .rq-anchor-felt {
    font-size: 14px;
    color: var(--rq-muted);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-empathy {
    font-size: 16px;
    line-height: 1.55;
    color: var(--rq-text);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-hypotheses {
    list-style: none;
    margin: var(--space-2) 0 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  #lt-routine-quiz-{{ section.id }} .rq-empathy {
    margin: 0;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--rq-accent-soft);
    font-size: 16px;
    line-height: 1.55;
    color: var(--rq-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-hypotheses-intro {
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--rq-muted);
    margin: var(--space-3) 0 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-hypothesis {
    padding: var(--space-4);
    border: 1px solid var(--rq-border);
    border-radius: var(--radius-md);
    background: var(--rq-bg);
  }
  #lt-routine-quiz-{{ section.id }} .rq-hypothesis-text {
    font-size: 15px;
    line-height: 1.5;
    color: var(--rq-text);
    margin: 0;
  }

  /* Zone 2 — Focus grid */
  #lt-routine-quiz-{{ section.id }} .rq-focus-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  @media (min-width: 750px) {
    #lt-routine-quiz-{{ section.id }} .rq-focus-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  #lt-routine-quiz-{{ section.id }} .rq-focus-card {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--rq-accent-soft);
    border: 1px solid var(--rq-accent-border);
    color: var(--rq-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-focus-icon {
    width: 28px;
    height: 28px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--rq-accent);
  }
  #lt-routine-quiz-{{ section.id }} .rq-focus-icon svg {
    width: 100%;
    height: 100%;
  }
  #lt-routine-quiz-{{ section.id }} .rq-focus-title {
    font-size: 15px;
    font-weight: var(--weight-semibold);
    margin: 0;
    line-height: 1.25;
  }
  #lt-routine-quiz-{{ section.id }} .rq-focus-measures {
    font-size: 13px;
    line-height: 1.45;
    color: var(--rq-text);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-focus-why {
    font-size: 12px;
    line-height: 1.45;
    color: var(--rq-muted);
    margin: 0;
  }

  /* Zone 3 — All categories */
  #lt-routine-quiz-{{ section.id }} .rq-cat-group + .rq-cat-group {
    margin-top: var(--space-5);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-group-label {
    font-size: 12px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rq-muted);
    margin: 0 0 var(--space-3);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-2);
  }
  @media (min-width: 750px) {
    #lt-routine-quiz-{{ section.id }} .rq-cat-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-item {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: var(--space-3);
    border-radius: var(--radius-sm);
    background: var(--rq-bg);
    border: 1px solid var(--rq-border);
    opacity: 0.55;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-item .rq-cat-desc {
    display: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-item.is-focus {
    opacity: 1;
    background: var(--rq-accent-soft);
    border-color: var(--rq-accent-border);
    padding-right: var(--space-6);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-item.is-focus .rq-cat-desc {
    display: block;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-item.is-focus::after {
    content: '✓';
    position: absolute;
    top: var(--space-3);
    right: var(--space-3);
    width: 18px;
    height: 18px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-full);
    background: var(--rq-accent);
    color: var(--rq-cta-text);
    font-size: 11px;
    font-weight: var(--weight-semibold);
    line-height: 1;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-title {
    font-size: 13px;
    font-weight: var(--weight-semibold);
    color: var(--rq-text);
    line-height: 1.25;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-desc {
    font-size: 11px;
    line-height: 1.4;
    color: var(--rq-muted);
    margin-top: 2px;
  }

  /* Zone 4 — CTA */
  #lt-routine-quiz-{{ section.id }} .rq-cta-headline {
    font-size: clamp(20px, 4.4vw, 26px);
    line-height: 1.22;
    font-weight: var(--weight-semibold);
    margin: 0;
    text-wrap: balance;
    color: var(--rq-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-zone--cta .rq-cta-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-3);
  }
  @media (min-width: 540px) {
    #lt-routine-quiz-{{ section.id }} .rq-zone--cta .rq-cta-row {
      flex-direction: row;
      flex-wrap: wrap;
      align-items: center;
    }
  }
  #lt-routine-quiz-{{ section.id }} .rq-trust-row {
    list-style: none;
    margin: var(--space-3) 0 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2) var(--space-4);
    font-size: 12px;
    color: var(--rq-muted);
  }
  #lt-routine-quiz-{{ section.id }} .rq-trust-row li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-trust-row li::before {
    content: '✓';
    color: var(--rq-accent);
    font-weight: var(--weight-semibold);
  }

  /* Embedded supplement quiz — visuelle Konsistenz mit Routine-Quiz */
  #lt-routine-quiz-{{ section.id }} [data-supp-embed] .lt-quiz__header {
    display: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-embed-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: var(--space-4);
    padding: 6px 10px;
    background: transparent;
    border: 0;
    color: var(--rq-muted);
    font-size: 13px;
    cursor: pointer;
  }
  #lt-routine-quiz-{{ section.id }} .rq-embed-back:hover {
    color: var(--rq-text);
  }

  /* Question counter under milestones */
  #lt-routine-quiz-{{ section.id }} .rq-progress-counter {
    margin: 6px 0 0;
    font-size: 11px;
    color: var(--rq-muted);
    text-align: center;
    letter-spacing: 0.04em;
  }
{% endstyle %}

<section id="lt-routine-quiz-{{ section.id }}" class="lt-routine-quiz" data-section-id="{{ section.id }}" data-section-type="lt-routine-quiz">
  <div class="rq-frame">

    {%- comment -%} Progress bar (hidden on route + result, shown during questions) {%- endcomment -%}
    <div class="rq-progress" data-progress hidden>
      <button type="button" class="rq-back" data-back hidden aria-label="Eine Frage zurück">← zurück</button>
      <ol class="rq-progress-list" data-progress-list aria-label="Fortschritt"></ol>
      <p class="rq-progress-counter" data-progress-counter></p>
    </div>

    {%- comment -%} Q1 — Routing (3 Bild-Karten) {%- endcomment -%}
    <div class="rq-screen is-active" data-screen="route">
      <p class="rq-kicker">{{ section.settings.route_kicker }}</p>
      <h2 tabindex="-1">{{ section.settings.route_question }}</h2>
      {%- if section.settings.route_helper != blank -%}
        <p class="rq-helper">{{ section.settings.route_helper }}</p>
      {%- endif -%}
      <ul class="rq-cards rq-cards--route" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'route_card' -%}
            <li {{ block.shopify_attributes }}>
              <button
                type="button"
                class="rq-card"
                data-route-card
                data-target-path="{{ block.settings.target_path }}"
                data-target-archetype="{{ block.settings.target_archetype }}"
              >
                <div class="rq-card__media">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 640 | image_tag:
                        loading: 'lazy',
                        alt: block.settings.image_alt,
                        widths: '320,480,640',
                        sizes: '(min-width: 750px) 32vw, 92vw' }}
                  {%- endif -%}
                </div>
                <div class="rq-card__body">
                  <span class="rq-card__label">{{ block.settings.label }}</span>
                  {%- if block.settings.sub != blank -%}
                    <span class="rq-card__sub">{{ block.settings.sub }}</span>
                  {%- endif -%}
                </div>
              </button>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    {%- comment -%} ═══════ DIAGNOSTIK-PFAD ═══════ {%- endcomment -%}

    {%- comment -%} Q2 — Alter-Slider {%- endcomment -%}
    <div class="rq-screen" data-screen="diag_age">
      <h2 tabindex="-1">{{ section.settings.diag_q2_question }}</h2>
      {%- if section.settings.diag_q2_helper != blank -%}
        <p class="rq-helper">{{ section.settings.diag_q2_helper }}</p>
      {%- endif -%}
      <div class="rq-slider-group">
        <div class="rq-slider">
          <label class="rq-slider-label" for="rq-chrono-{{ section.id }}">
            <span>{{ section.settings.diag_q2_slider1_label }}</span>
            <span class="rq-slider-value" data-chrono-display>45</span>
          </label>
          <input type="range" id="rq-chrono-{{ section.id }}" min="25" max="75" value="45" step="1" data-chrono>
        </div>
        <div class="rq-slider">
          <label class="rq-slider-label" for="rq-felt-{{ section.id }}">
            <span>{{ section.settings.diag_q2_slider2_label }}</span>
            <span class="rq-slider-value" data-felt-display>45</span>
          </label>
          <input type="range" id="rq-felt-{{ section.id }}" min="-10" max="10" value="0" step="1" data-felt-delta aria-describedby="rq-hint-{{ section.id }}">
        </div>
        <p class="rq-slider-hint" id="rq-hint-{{ section.id }}" aria-live="polite" data-slider-hint>
          {{ section.settings.diag_q2_hint_delta_zero }}
        </p>
      </div>
      <div class="rq-cta-row">
        <button type="button" class="rq-cta rq-cta--primary" data-next="diag_q3">Weiter →</button>
      </div>
    </div>

    {%- comment -%} Q3 — Archetype-spezifische Frage (dynamisch per JS gerendert) {%- endcomment -%}
    <div class="rq-screen" data-screen="diag_q3">
      <fieldset>
        <legend>
          <h2 tabindex="-1" data-q3-question>&nbsp;</h2>
        </legend>
        <div class="rq-options" role="radiogroup" data-q3-options></div>
      </fieldset>
    </div>

    {%- comment -%} Q4 — Was hast du versucht (multi) {%- endcomment -%}
    <div class="rq-screen" data-screen="diag_q4">
      <fieldset>
        <legend>
          <h2 tabindex="-1">{{ section.settings.diag_q4_question }}</h2>
          {%- if section.settings.diag_q4_helper != blank -%}
            <p class="rq-helper">{{ section.settings.diag_q4_helper }}</p>
          {%- endif -%}
        </legend>
        <div class="rq-options" data-q4-options></div>
      </fieldset>
      <div class="rq-cta-row">
        <button type="button" class="rq-cta rq-cta--primary" data-next="diag_q5">Weiter →</button>
      </div>
    </div>

    {%- comment -%} Q5 — Intent {%- endcomment -%}
    <div class="rq-screen" data-screen="diag_q5">
      <fieldset>
        <legend>
          <h2 tabindex="-1">{{ section.settings.diag_q5_question }}</h2>
        </legend>
        <div class="rq-options" role="radiogroup">
          <label class="rq-option">
            <input type="radio" name="rq-q5-{{ section.id }}" value="0" data-q5-input data-intent="hot">
            <span class="rq-marker" aria-hidden="true"></span>
            <span class="rq-option-label">{{ section.settings.diag_q5_opt_1 }}</span>
          </label>
          <label class="rq-option">
            <input type="radio" name="rq-q5-{{ section.id }}" value="1" data-q5-input data-intent="hot">
            <span class="rq-marker" aria-hidden="true"></span>
            <span class="rq-option-label">{{ section.settings.diag_q5_opt_2 }}</span>
          </label>
          <label class="rq-option">
            <input type="radio" name="rq-q5-{{ section.id }}" value="2" data-q5-input data-intent="hot">
            <span class="rq-marker" aria-hidden="true"></span>
            <span class="rq-option-label">{{ section.settings.diag_q5_opt_3 }}</span>
          </label>
          <label class="rq-option">
            <input type="radio" name="rq-q5-{{ section.id }}" value="3" data-q5-input data-intent="cool">
            <span class="rq-marker" aria-hidden="true"></span>
            <span class="rq-option-label">{{ section.settings.diag_q5_opt_4 }}</span>
          </label>
        </div>
      </fieldset>
    </div>

    {%- comment -%} Diagnostic Result — 4-Zonen finale Ansicht {%- endcomment -%}
    <div class="rq-screen rq-result" data-screen="diag_result">

      {%- comment -%} ZONE 1 · Persönlicher Anker + 3 Hypothesen {%- endcomment -%}
      <section class="rq-zone rq-zone--anchor">
        <h2 class="rq-anchor" tabindex="-1" data-anchor>&nbsp;</h2>
        <p class="rq-anchor-felt" data-anchor-felt hidden></p>
        <blockquote class="rq-empathy" data-empathy>&nbsp;</blockquote>
      </section>

      {%- comment -%} ZONE 2 · Fokus-Bereiche (archetype-spezifisch) {%- endcomment -%}
      <section class="rq-zone rq-zone--focus">
        <p class="rq-zone-kicker">Deine Fokus-Bereiche</p>
        <h3 class="rq-zone-title">Hier liegt für dich der größte Hebel.</h3>
        <ul class="rq-focus-grid" data-focus-grid role="list"></ul>
      </section>

      {%- comment -%} ZONE 3 · Alle 22 Kategorien, Fokus hervorgehoben {%- endcomment -%}
      <section class="rq-zone rq-zone--all">
        <p class="rq-zone-kicker">Im Test enthalten</p>
        <h3 class="rq-zone-title">187 Reports aus 22 Bereichen — die markierten sind für dein Profil am relevantesten.</h3>
        <div class="rq-cat-group">
          <p class="rq-cat-group-label">Epigenetik · 6 Bereiche</p>
          <ul class="rq-cat-grid" data-cat-epi role="list"></ul>
        </div>
        <div class="rq-cat-group">
          <p class="rq-cat-group-label">Genetik · 16 Bereiche</p>
          <ul class="rq-cat-grid" data-cat-dna role="list"></ul>
        </div>
      </section>

      {%- comment -%} ZONE 4 · Einziger CTA + Trust {%- endcomment -%}
      <section class="rq-zone rq-zone--cta">
        <h3 class="rq-cta-headline">Das ist, was dein Test zeigen wird. Bereit, es wirklich zu wissen?</h3>
        <div class="rq-cta-row">
          <a href="/products/age-dna-test" class="rq-cta rq-cta--primary">AGE &amp; DNA-Test starten → 349 €</a>
        </div>
        <ul class="rq-trust-row" role="list">
          <li>Eurofins</li>
          <li>DSGVO</li>
          <li>Kit-Ersatz-Garantie</li>
          <li>Lebenslang in der App</li>
        </ul>
      </section>

    </div>

    {%- comment -%} ═══════ SUPPLEMENT-PFAD ═══════ {%- endcomment -%}

    {%- comment -%} Q2 — Fokus-Auswahl (Energie / Fokus / Schlaf / Langlebigkeit) {%- endcomment -%}
    <div class="rq-screen" data-screen="supp_focus">
      <h2 tabindex="-1">{{ section.settings.supp_focus_question }}</h2>
      {%- if section.settings.supp_focus_helper != blank -%}
        <p class="rq-helper">{{ section.settings.supp_focus_helper }}</p>
      {%- endif -%}
      <ul class="rq-cards rq-cards--focus" role="list">
        {%- assign focus_keys = 'energie,fokus,schlaf,lang' | split: ',' -%}
        {%- for key in focus_keys -%}
          {%- liquid
            case key
              when 'energie'
                assign f_img   = section.settings.focus_energie_image
                assign f_alt   = section.settings.focus_energie_alt
                assign f_label = section.settings.focus_energie_label
              when 'fokus'
                assign f_img   = section.settings.focus_fokus_image
                assign f_alt   = section.settings.focus_fokus_alt
                assign f_label = section.settings.focus_fokus_label
              when 'schlaf'
                assign f_img   = section.settings.focus_schlaf_image
                assign f_alt   = section.settings.focus_schlaf_alt
                assign f_label = section.settings.focus_schlaf_label
              when 'lang'
                assign f_img   = section.settings.focus_lang_image
                assign f_alt   = section.settings.focus_lang_alt
                assign f_label = section.settings.focus_lang_label
            endcase
          -%}
          <li>
            <button type="button" class="rq-card" data-focus-card data-focus="{{ key }}">
              <div class="rq-card__media{% if f_img == blank %} rq-card__media--icon{% endif %}">
                {%- if f_img != blank -%}
                  {{ f_img | image_url: width: 480 | image_tag:
                      loading: 'lazy',
                      alt: f_alt,
                      widths: '240,360,480',
                      sizes: '(min-width: 750px) 22vw, 45vw' }}
                {%- else -%}
                  {%- case key -%}
                    {%- when 'energie' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/></svg>
                    {%- when 'fokus' -%}
                      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="1"/></svg>
                    {%- when 'schlaf' -%}
