<script>
  (function () {
    var root = document.getElementById('lt-routine-quiz-{{ section.id }}');
    if (!root) return;

    var archetypes = {}, config = {}, products = {};
    try { archetypes = JSON.parse(root.querySelector('[data-archetypes]').textContent); } catch (e) {}
    try { config     = JSON.parse(root.querySelector('[data-config]').textContent); }     catch (e) {}
    try { products   = JSON.parse(root.querySelector('[data-products]').textContent); }   catch (e) {}

    var screens = {};
    root.querySelectorAll('[data-screen]').forEach(function (el) {
      screens[el.getAttribute('data-screen')] = el;
    });

    var ICONS = {
      person:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="8" r="4"/><path d="M4 21c0-4.4 3.6-8 8-8s8 3.6 8 8"/></svg>',
      clock:    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>',
      target:   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><circle cx="12" cy="12" r="4"/><circle cx="12" cy="12" r="1"/></svg>',
      history:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7L3 8"/><path d="M3 3v5h5"/><path d="M12 7v5l3 2"/></svg>',
      compass:  '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="m15 9-4 2-2 4 4-2z"/></svg>',
      spark:    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/></svg>'
    };

    var DIAG_FLOW = [
      { id: 'route',       label: 'Start',     icon: ICONS.person  },
      { id: 'diag_age',    label: 'Alter',     icon: ICONS.clock   },
      { id: 'diag_q3',     label: 'Signal',    icon: ICONS.target  },
      { id: 'diag_q4',     label: 'Versucht',  icon: ICONS.history },
      { id: 'diag_q5',     label: 'Ziel',      icon: ICONS.compass },
      { id: 'diag_result', label: 'Ergebnis',  icon: ICONS.spark   }
    ];
    var SUPP_FLOW = [
      { id: 'route',       label: 'Start',     icon: ICONS.person },
      { id: 'supp_focus',  label: 'Fokus',     icon: ICONS.target },
      { id: 'supp_result', label: 'Routine',   icon: ICONS.spark  }
    ];

    var state = {
      path: null,              // 'diagnostics' | 'supplement'
      archetype: null,         // for diagnostics
      age_chrono: 45,
      age_felt_delta: 0,
      pain_selection: null,
      tried: [],
      intent: null,
      focus: null              // for supplement: energie/fokus/schlaf/lang
    };
    var history = [];
    var current = 'route';

    var progressEl   = root.querySelector('[data-progress]');
    var progressList = root.querySelector('[data-progress-list]');
    var backBtn      = root.querySelector('[data-back]');
    var advisorEl    = root.querySelector('[data-advisor]');

    function pushDL(payload) {
      window.dataLayer = window.dataLayer || [];
      window.dataLayer.push(payload);
    }

    function currentFlow() {
      return state.path === 'supplement' ? SUPP_FLOW : DIAG_FLOW;
    }

    function flowIndex(flow, id) {
      for (var i = 0; i < flow.length; i++) if (flow[i].id === id) return i;
      return -1;
    }

    function renderProgress() {
      var flow = currentFlow();
      var idx = flowIndex(flow, current);
      var isRoute  = current === 'route';

      if (isRoute || !state.path) {
        progressEl.hidden = true;
        return;
      }
      progressEl.hidden = false;

      // Build milestones — skip 'route', keep question screens + result
      var steps = flow.slice(1);
      var activeIdx = idx - 1;

      if (progressList.childElementCount !== steps.length) {
        progressList.innerHTML = '';
        progressList.style.setProperty('--rq-steps', String(steps.length));
        progressList.style.gridTemplateColumns = 'repeat(' + steps.length + ', 1fr)';
        steps.forEach(function (step, i) {
          var li = document.createElement('li');
          li.setAttribute('data-step', step.id);
          li.innerHTML =
            '<span class="rq-progress-icon" aria-hidden="true">' + step.icon + '</span>' +
            '<span class="rq-progress-label">' + step.label + '</span>';
          progressList.appendChild(li);
        });
      }

      progressList.querySelectorAll('li').forEach(function (li, i) {
        li.classList.remove('is-done');
        li.removeAttribute('aria-current');
        if (i < activeIdx) li.classList.add('is-done');
        if (i === activeIdx) li.setAttribute('aria-current', 'step');
      });

      var isResult = current === 'diag_result' || current === 'supp_result';
      if (backBtn) backBtn.hidden = !(idx >= 1 && !isResult);

      var counterEl = progressEl.querySelector('[data-progress-counter]');
      if (counterEl) {
        if (activeIdx >= 0 && !isResult) {
          var questionSteps = steps.filter(function (s) { return s.id !== 'diag_result' && s.id !== 'supp_result'; });
          counterEl.textContent = 'Frage ' + (activeIdx + 1) + ' von ' + questionSteps.length;
          counterEl.hidden = false;
        } else {
          counterEl.textContent = '';
          counterEl.hidden = true;
        }
      }
    }

    function focusHeading(screen) {
      var h = screens[screen].querySelector('h2');
      if (h) setTimeout(function () { try { h.focus({ preventScroll: true }); } catch (e) { h.focus(); } }, 60);
    }

    function go(screen, opts) {
      opts = opts || {};
      if (!screens[screen]) return;
      if (!opts.back && current !== screen) history.push(current);
      Object.keys(screens).forEach(function (k) { screens[k].classList.remove('is-active'); });
      screens[screen].classList.add('is-active');
      current = screen;
      renderProgress();
      focusHeading(screen);
      pushDL({
        event: 'lt_routine_quiz_step',
        step: screen,
        path: state.path,
        archetype: state.archetype,
        focus: state.focus
      });
      if (screen === 'diag_q3') renderQ3();
      if (screen === 'diag_q4') renderQ4();
      if (screen === 'diag_result') renderDiagnosticResult();
      if (screen === 'supp_result') renderSupplementResult();
    }

    function goBack() {
      if (!history.length) return;
      var prev = history.pop();
      // If going back to route, reset path so progress hides
      if (prev === 'route') state.path = null;
      go(prev, { back: true });
    }

    if (backBtn) backBtn.addEventListener('click', goBack);

    var suppBackBtn = root.querySelector('[data-supp-back]');
    if (suppBackBtn) {
      suppBackBtn.addEventListener('click', function () {
        var frame = root.querySelector('.rq-frame');
        var embed = root.querySelector('[data-supp-embed]');
        if (frame) frame.hidden = false;
        if (embed) embed.hidden = true;
        state.path = null;
        state.archetype = null;
        root.querySelectorAll('[data-route-card]').forEach(function (c) { c.classList.remove('is-selected'); });
        if (root.scrollIntoView) root.scrollIntoView({ behavior: 'smooth', block: 'start' });
      });
    }

    // ───── Q1 — Routing cards ─────
    root.querySelectorAll('[data-route-card]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        var path = btn.getAttribute('data-target-path');
        var arch = btn.getAttribute('data-target-archetype');
        state.path = path === 'supplement' ? 'supplement' : 'diagnostics';
        state.archetype = (state.path === 'diagnostics') ? (arch || 'tired') : null;

        root.querySelectorAll('[data-route-card]').forEach(function (c) { c.classList.remove('is-selected'); });
        btn.classList.add('is-selected');

        pushDL({
          event: 'lt_routine_quiz_route',
          path: state.path,
          archetype: state.archetype
        });

        if (state.path === 'supplement') {
          var frame = root.querySelector('.rq-frame');
          var embed = root.querySelector('[data-supp-embed]');
          if (frame) frame.hidden = true;
          if (embed) embed.hidden = false;
          var embedQuiz = document.getElementById('lt-longevity-quiz');
          if (embedQuiz && embedQuiz.scrollIntoView) {
            embedQuiz.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        } else {
          go('diag_age');
        }
      });
    });

    // ───── Q2 diagnostic — age sliders ─────
    var chronoInput   = root.querySelector('[data-chrono]');
    var feltInput     = root.querySelector('[data-felt-delta]');
    var chronoDisplay = root.querySelector('[data-chrono-display]');
    var feltDisplay   = root.querySelector('[data-felt-display]');
    var hintEl        = root.querySelector('[data-slider-hint]');

    function updateSliderDisplays() {
      state.age_chrono     = parseInt(chronoInput.value, 10);
      state.age_felt_delta = parseInt(feltInput.value, 10);
      var felt = state.age_chrono + state.age_felt_delta;
      chronoDisplay.textContent = state.age_chrono;
      feltDisplay.textContent   = felt;
      var hint;
      if (state.age_felt_delta > 0) hint = config.hint_pos;
      else if (state.age_felt_delta < 0) hint = config.hint_neg;
      else hint = config.hint_zero;
      hintEl.textContent = hint || '';
    }
    if (chronoInput && feltInput) {
      chronoInput.addEventListener('input', updateSliderDisplays);
      feltInput.addEventListener('input', updateSliderDisplays);
      updateSliderDisplays();
    }

    // Generic "Weiter" buttons
    root.querySelectorAll('[data-next]').forEach(function (btn) {
      btn.addEventListener('click', function () { go(btn.getAttribute('data-next')); });
    });

    // ───── Q3 — archetype-specific, built on entry ─────
    function renderQ3() {
      var data = archetypes[state.archetype];
      if (!data) return;
      var qEl  = screens.diag_q3.querySelector('[data-q3-question]');
      var opts = screens.diag_q3.querySelector('[data-q3-options]');
      if (qEl) qEl.textContent = data.q3_question || '';
      opts.innerHTML = '';
      (data.q3_options || []).forEach(function (label, i) {
        var wrap = document.createElement('label');
        wrap.className = 'rq-option';
        wrap.innerHTML =
          '<input type="radio" name="rq-q3-{{ section.id }}" value="' + i + '" data-q3-input>' +
          '<span class="rq-marker" aria-hidden="true"></span>' +
          '<span class="rq-option-label"></span>';
        wrap.querySelector('.rq-option-label').textContent = label;
        var input = wrap.querySelector('input');
        if (state.pain_selection === i) input.checked = true;
        input.addEventListener('change', function () {
          if (!input.checked) return;
          state.pain_selection = i;
          go('diag_q4');
        });
        opts.appendChild(wrap);
      });
    }

    // ───── Q4 — tried multi-select ─────
    var q4Opts = screens.diag_q4.querySelector('[data-q4-options]');
    function renderQ4() {
      if (!q4Opts || q4Opts.childElementCount) return;
      (config.diag_q4_options || []).forEach(function (label, i) {
        var wrap = document.createElement('label');
        wrap.className = 'rq-option rq-option--checkbox';
        wrap.innerHTML =
          '<input type="checkbox" value="' + i + '" data-q4-input>' +
          '<span class="rq-marker" aria-hidden="true"></span>' +
          '<span class="rq-option-label"></span>';
        wrap.querySelector('.rq-option-label').textContent = label;
        wrap.querySelector('input').addEventListener('change', function () {
          state.tried = Array.prototype.map.call(
            q4Opts.querySelectorAll('input:checked'),
            function (el) { return (config.diag_q4_options || [])[parseInt(el.value, 10)] || ''; }
          ).filter(Boolean);
        });
        q4Opts.appendChild(wrap);
      });
    }

    // ───── Q5 — intent ─────
    root.querySelectorAll('[data-q5-input]').forEach(function (input) {
      input.addEventListener('change', function () {
        if (!input.checked) return;
        state.intent = input.getAttribute('data-intent');
        go('diag_result');
      });
    });

    // ───── Diagnostic result ─────
    // ───── Result data — Kategorien + Archetype-Mapping ─────
    var EPI_CATS = [
      { id: 'koerperalter',  title: 'Körperalter',        desc: 'Höralter · Gedächtnisalter · Sehfähigkeit' },
      { id: 'bio-alter',     title: 'Biologisches Alter', desc: 'MethylPace-Score · Tempo deiner Alterung' },
      { id: 'epivitality',   title: 'EpiVitality',        desc: 'Zellaktivität · Vitalitätssignal' },
      { id: 'immunscore',    title: 'Immunscore',         desc: 'Immunaktivität · Reaktionsfähigkeit' },
      { id: 'entzuendung',   title: 'Entzündung',         desc: 'Epigenetisches Inflammations-Profil' },
      { id: 'muskelschwund', title: 'Muskelschwund',      desc: 'Signale für Muskelalterung' }
    ];
    var DNA_CATS = [
      { id: 'gesunde',        title: 'Gesunde Alterung',        desc: 'Langlebigkeit · Stoffwechsel & Alter · Muskelabbau' },
      { id: 'supplements',    title: 'Supplements',             desc: 'Kreatin · Curcumin · NMN' },
      { id: 'vitamine',       title: 'Vitamine',                desc: 'Vitamin D · Vitamin B12 · Omega-3' },
      { id: 'sensitivitaeten',title: 'Sensitivitäten',          desc: 'Gluten · Laktose · Zucker' },
      { id: 'stoffwechsel',   title: 'Stoffwechsel',            desc: 'Adipositas-Risiko · Typ-2-Diabetes · Blutdruck' },
      { id: 'fitness',        title: 'Fitness',                 desc: 'Muskelkraft · VO₂max · Anaerobe Schwelle' },
      { id: 'verletzung',     title: 'Verletzung & Regeneration', desc: 'Bandscheiben · Achillessehne · Erholungstyp' },
      { id: 'mental',         title: 'Mental Health',           desc: 'Aufmerksamkeit · Stress-Resilienz · Gedächtnis' },
      { id: 'psychologisch',  title: 'Psychologisch',           desc: 'COMT · Belohnungssensitivität · Emotionen' },
      { id: 'schlaf',         title: 'Schlaf',                  desc: 'Schlafdauer · Schlafqualität · Chronotyp' },
      { id: 'stress',         title: 'Stress',                  desc: 'Stress & Gedächtnis · Stressbewältigung' },
      { id: 'herz',           title: 'Herz',                    desc: 'Cholesterin · Herzkrankheits-Risiko · Vorhofflimmern' },
      { id: 'atemwege',       title: 'Atemwege',                desc: 'Asthma-Bezug · Lungenfunktion' },
      { id: 'augen',          title: 'Augen',                   desc: 'Makuladegeneration · Katarakt · Glaukom' },
      { id: 'haare',          title: 'Haare',                   desc: 'Haarausfall · Ergrauen · Trockenes Haar' },
      { id: 'niere',          title: 'Niere',                   desc: 'Nierenfunktion · Entgiftung · Nierensteine' }
    ];

    var ARCH_STATEMENT = {
      tired:    'dass du den Unterschied spürst — irgendetwas stimmt nicht mehr wie früher',
      measurer: 'dass du verstehen willst, wie du wirklich alterst — jenseits von Standard-Laborwerten',
      vigilant: 'dass du vorbeugen willst, weil Familiengeschichte eine Rolle spielt'
    };

    var FOCUS_BY_ARCHETYPE = {
      tired: [
        { id: 'epivitality', title: 'EpiVitality', measures: 'Wie aktiv deine Zellen epigenetisch arbeiten.',               why: 'Erklärt, warum du dich "älter" fühlst, als deine Laborwerte sagen.' },
        { id: 'entzuendung', title: 'Entzündung',  measures: 'Dein epigenetisches Entzündungsprofil.',                        why: 'Einer der Haupttreiber von Energielücken und langsamer Regeneration.' },
        { id: 'schlaf',      title: 'Schlaf',      measures: 'Deine genetische Schlafqualität, -dauer und dein Chronotyp.',    why: 'Zeigt, warum dein Schlaf nicht so erholsam ist, wie er sein könnte.' },
        { id: 'supplements', title: 'Supplements', measures: 'Wie dein Körper auf Kreatin, Curcumin, NMN und andere reagiert.', why: 'Damit dein Stack greift — nach deiner Genetik, nicht nach Trend.' }
      ],
      measurer: [
        { id: 'bio-alter',   title: 'Biologisches Alter', measures: 'Dein MethylPace-Score — das Tempo deiner biologischen Alterung.', why: 'Die eine Zahl, die dein Hausarzt nicht bestimmen kann.' },
        { id: 'entzuendung', title: 'Entzündung',         measures: 'Dein epigenetisches Entzündungsprofil.',                         why: 'Stille Inflammation ist ein zentraler Alterungstreiber. Hier siehst du sie.' },
        { id: 'immunscore',  title: 'Immunscore',         measures: 'Wie gut dein Immunsystem epigenetisch funktioniert.',            why: 'Dein Immunsystem entscheidet mit über gesunde Jahre — nicht nur über Krankheit.' },
        { id: 'gesunde',     title: 'Gesunde Alterung',   measures: 'Langlebigkeit, Stoffwechsel-Alter, Muskelabbau auf DNA-Ebene.',  why: 'Zeigt, wo du genetisch stehst — und wo du gezielt gegensteuern kannst.' }
      ],
      vigilant: [
        { id: 'herz',        title: 'Herz',                measures: 'Cholesterin-Stoffwechsel, Herzkrankheits-Risiko, Vorhofflimmern.', why: 'Familiäre Herzgeschichte wird hier entweder bestätigt oder entkräftet.' },
        { id: 'bio-alter',   title: 'Biologisches Alter', measures: 'Dein MethylPace-Score — das Tempo deiner biologischen Alterung.', why: 'Ob dein Körper schneller altert, als die Familiengeschichte vermuten lässt.' },
        { id: 'entzuendung', title: 'Entzündung',         measures: 'Dein epigenetisches Entzündungsprofil.',                          why: 'Treiber vieler chronischer Erkrankungen — oft Jahre vor Symptomen messbar.' },
        { id: 'mental',      title: 'Mental Health',      measures: 'Aufmerksamkeit, Stress-Resilienz, Gedächtnis auf genetischer Basis.', why: 'Relevant, wenn Kognition oder Demenz in der Familie ein Thema sind.' }
      ]
    };

    var FOCUS_ICONS = {
      'bio-alter':     '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="9"/><path d="M12 7v5l3 2"/></svg>',
      'epivitality':   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M13 2 3 14h7l-1 8 10-12h-7l1-8z"/></svg>',
      'entzuendung':   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 2s4 4 4 8a4 4 0 0 1-8 0c0-1 .4-2 1-3"/><path d="M9 14a5 5 0 1 0 6 0"/></svg>',
      'immunscore':    '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3 4 6v6c0 5 3.5 8 8 9 4.5-1 8-4 8-9V6z"/></svg>',
      'schlaf':        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>',
      'supplements':   '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="3" y="9" width="18" height="6" rx="3"/><path d="M12 9v6"/></svg>',
      'gesunde':       '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20 12a8 8 0 1 1-8-8"/><path d="m15 7 5 5-5 5"/></svg>',
      'herz':          '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M20.8 4.6a5.5 5.5 0 0 0-7.8 0L12 5.7l-1-1.1a5.5 5.5 0 0 0-7.8 7.8l1 1L12 21l7.8-7.6 1-1a5.5 5.5 0 0 0 0-7.8z"/></svg>',
      'mental':        '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 3a7 7 0 0 0-5 12v3a2 2 0 0 0 2 2h6a2 2 0 0 0 2-2v-3a7 7 0 0 0-5-12z"/><path d="M9 20h6"/></svg>'
    };

    function renderDiagnosticResult() {
      var data = archetypes[state.archetype] || {};
      var chrono = state.age_chrono;
      var felt   = chrono + state.age_felt_delta;
      var statement = ARCH_STATEMENT[state.archetype] || '';

      var anchorEl = root.querySelector('[data-anchor]');
      anchorEl.textContent = 'Du bist ' + chrono + '. Du hast angegeben, ' + statement + '. Das wird dein Test wahrscheinlich zeigen.';

      var feltEl = root.querySelector('[data-anchor-felt]');
      if (state.age_felt_delta !== 0) {
        feltEl.textContent = 'Gefühlt eher: ' + felt + '.';
        feltEl.hidden = false;
      } else {
        feltEl.hidden = true;
      }

      root.querySelector('[data-empathy]').textContent = data.empathy_line || '';

      // Zone 1 — Hypothesen
      var list = root.querySelector('[data-hypotheses]');
      list.innerHTML = '';
      [data.hypothesis_primary, data.hypothesis_secondary, data.hypothesis_tertiary].forEach(function (text) {
        if (!text) return;
        var li = document.createElement('li');
        li.className = 'rq-hypothesis';
        li.innerHTML = '<p class="rq-hypothesis-text"></p>';
        li.querySelector('.rq-hypothesis-text').textContent = text;
        list.appendChild(li);
      });

      // Zone 2 — Fokus-Karten
      var focusList = root.querySelector('[data-focus-grid]');
      focusList.innerHTML = '';
      var focusCats = FOCUS_BY_ARCHETYPE[state.archetype] || [];
      var focusIds = focusCats.map(function (c) { return c.id; });
      focusCats.forEach(function (cat) {
        var li = document.createElement('li');
        li.className = 'rq-focus-card';
        li.innerHTML =
          '<span class="rq-focus-icon" aria-hidden="true">' + (FOCUS_ICONS[cat.id] || '') + '</span>' +
          '<h4 class="rq-focus-title"></h4>' +
          '<p class="rq-focus-measures"></p>' +
          '<p class="rq-focus-why"></p>';
        li.querySelector('.rq-focus-title').textContent    = cat.title;
        li.querySelector('.rq-focus-measures').textContent = cat.measures;
        li.querySelector('.rq-focus-why').textContent      = cat.why;
        focusList.appendChild(li);
      });

      // Zone 3 — alle Kategorien
      function renderCatGrid(container, items) {
        container.innerHTML = '';
        items.forEach(function (cat) {
          var li = document.createElement('li');
          li.className = 'rq-cat-item' + (focusIds.indexOf(cat.id) !== -1 ? ' is-focus' : '');
          li.innerHTML =
            '<span class="rq-cat-title"></span>' +
            '<span class="rq-cat-desc"></span>';
          li.querySelector('.rq-cat-title').textContent = cat.title;
          li.querySelector('.rq-cat-desc').textContent  = cat.desc;
          container.appendChild(li);
        });
      }
      renderCatGrid(root.querySelector('[data-cat-epi]'), EPI_CATS);
      renderCatGrid(root.querySelector('[data-cat-dna]'), DNA_CATS);

      pushDL({
        event: 'lt_routine_quiz_result_shown',
        path: 'diagnostics',
        archetype: state.archetype,
        age_chrono: state.age_chrono,
        age_felt_delta: state.age_felt_delta,
        pain_selection: state.pain_selection,
        tried: state.tried,
        intent: state.intent
      });
    }

    // ───── Supplement focus cards ─────
    root.querySelectorAll('[data-focus-card]').forEach(function (btn) {
      btn.addEventListener('click', function () {
        state.focus = btn.getAttribute('data-focus');
        root.querySelectorAll('[data-focus-card]').forEach(function (c) { c.classList.remove('is-selected'); });
        btn.classList.add('is-selected');
        go('supp_result');
      });
    });

    // ───── Supplement result ─────
    function productCard(p, tag, isPrimary) {
      if (!p || !p.title) return null;
      var wrap = document.createElement('article');
      wrap.className = 'rq-product' + (isPrimary ? ' rq-product--primary' : '');
      var inner = '';
      inner += '<div class="rq-product__media">';
      if (p.image) inner += '<img src="' + p.image + '" alt="" loading="lazy">';
      inner += '</div>';
      if (tag) inner += '<p class="rq-product__tag">' + tag + '</p>';
      inner += '<h3 class="rq-product__title"></h3>';
      if (p.price) inner += '<p class="rq-product__price">' + p.price + '</p>';
      inner += '<a class="rq-cta rq-cta--secondary" href="' + (p.url || '#') + '">Ansehen →</a>';
      wrap.innerHTML = inner;
      wrap.querySelector('.rq-product__title').textContent = p.title;
      return wrap;
    }

    function renderSupplementResult() {
      var focus = state.focus || 'energie';
      var set = products[focus] || {};

      root.querySelector('[data-supp-headline]').textContent =
        config['supp_result_headline_' + focus] || '';
      root.querySelector('[data-supp-sub]').textContent =
        config['supp_result_sub_' + focus] || '';

      var bundle = root.querySelector('[data-bundle]');
      bundle.innerHTML = '';
      var primaryCard = productCard(set.primary, config.supp_primary_tag, true);
      var sec1Card    = productCard(set.sec1,    config.supp_secondary_tag, false);
      var sec2Card    = productCard(set.sec2,    config.supp_secondary_tag, false);
      if (primaryCard) bundle.appendChild(primaryCard);
      if (sec1Card)    bundle.appendChild(sec1Card);
      if (sec2Card)    bundle.appendChild(sec2Card);

      var cta = root.querySelector('[data-supp-cta-primary]');
      if (set.primary && set.primary.url) {
        cta.href = set.primary.url;
        cta.style.display = '';
      } else {
        cta.style.display = 'none';
      }

      pushDL({
        event: 'lt_routine_quiz_result_shown',
        path: 'supplement',
        focus: state.focus
      });
    }
  })();
</script>

