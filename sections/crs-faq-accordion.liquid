{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.05 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background:     var(--crs-bg);
  }
{% endstyle %}

<div class="faq-section" id="section-{{ section.id }}">
  <div class="faq-container">
    <div class="faq-layout">

      {%- comment -%} Left: sticky heading {%- endcomment -%}
      <div class="faq-left">
        {%- if section.settings.heading != blank -%}
          <h2 class="faq-heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}
      </div>

      {%- comment -%} Right: accordion items {%- endcomment -%}
      <div class="faq-right">
        {%- for block in section.blocks -%}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button
              class="faq-question"
              aria-expanded="false"
              aria-controls="faq-panel-{{ section.id }}-{{ forloop.index }}"
            >
              <span class="faq-question-text">{{ block.settings.question | escape }}</span>
              <span class="faq-toggle" aria-hidden="true">↓</span>
            </button>
            <div
              class="faq-panel"
              id="faq-panel-{{ section.id }}-{{ forloop.index }}"
              role="region"
            >
              <div class="faq-answer">
                <p>{{ block.settings.answer | escape }}</p>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

{% stylesheet %}
/* ===================================================
   FAQ Accordion — crs-faq-accordion.liquid
   =================================================== */

.faq-section {
  background: var(--crs-bg, #f2f1ed);
}

.faq-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

.faq-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}

/* Left */
.faq-left {
  padding-right: 48px;
  padding-top: 4px;
}

.faq-heading {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif !important;
  font-size: 36px !important;
  font-weight: 400 !important;
  line-height: 1.15 !important;
  letter-spacing: -0.72px !important;
  color: var(--crs-text, #26251e) !important;
  margin: 0 !important;
  position: sticky;
  top: 80px;
}

/* Right — accordion (keine Karten-Rahmen, nur horizontale Trennlinien) */
.faq-right {
  padding-top: 0;
}

.faq-item {
  border-top: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
}

.faq-item:last-child {
  border-bottom: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
}

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 15.68px 0 16.8px;
  background: none;
  border: none;
  cursor: pointer;
  gap: 16px;
  text-align: left;
}

.faq-question-text {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.5;
  color: var(--crs-text, #26251e);
}

.faq-toggle {
  font-size: 16px;
  color: var(--crs-text-ter, rgba(38,37,30,0.4));
  flex-shrink: 0;
  transition: transform 0.2s ease;
  line-height: 1;
  display: inline-block;
}

/* Panel */
.faq-panel {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.28s ease;
}

.faq-panel.is-open {
  max-height: min(120vh, 2000px);
}

.faq-answer {
  padding-bottom: 16px;
}

.faq-answer p {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.65;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
  margin: 0;
}

/* Mobile — stack */
@media (max-width: 1024px) {
  .faq-layout {
    grid-template-columns: 1fr;
    gap: 32px;
  }

  .faq-left {
    padding-right: 0;
  }

  .faq-heading {
    position: static;
    font-size: clamp(24px, 4vw, 36px) !important;
  }
}
{% endstylesheet %}

{% javascript %}
(function () {
  if (window.__crsFaqAccordionBound) return;
  window.__crsFaqAccordionBound = true;

  function panelById(root, id) {
    if (!id) return null;
    var el = document.getElementById(id);
    return el && root.contains(el) ? el : null;
  }

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.faq-section .faq-question');
    if (!btn) return;

    var section = btn.closest('.faq-section');
    if (!section) return;

    var buttons = section.querySelectorAll('.faq-question');
    var expanded = btn.getAttribute('aria-expanded') === 'true';
    var panelId = btn.getAttribute('aria-controls');
    var panel = panelById(section, panelId);
    var toggle = btn.querySelector('.faq-toggle');

    buttons.forEach(function (other) {
      if (other !== btn) {
        other.setAttribute('aria-expanded', 'false');
        var otherId = other.getAttribute('aria-controls');
        var otherPanel = panelById(section, otherId);
        var otherToggle = other.querySelector('.faq-toggle');
        if (otherPanel) otherPanel.classList.remove('is-open');
        if (otherToggle) otherToggle.textContent = '↓';
      }
    });

    if (!expanded) {
      btn.setAttribute('aria-expanded', 'true');
      if (panel) panel.classList.add('is-open');
      if (toggle) toggle.textContent = '↑';
    } else {
      btn.setAttribute('aria-expanded', 'false');
      if (panel) panel.classList.remove('is-open');
      if (toggle) toggle.textContent = '↓';
    }
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "FAQ Accordion",
  "tag": "section",
  "class": "crs-faq-accordion",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift",
      "default": "Häufige Fragen"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "FAQ-Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Frage",
          "default": "Was bedeutet Novel Food?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Antwort",
          "default": "NMN ist in der EU als Novel Food eingestuft und darf nicht als Nahrungsergänzungsmittel verkauft werden. Unser Produkt wird als Forschungsreagenz angeboten."
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "question": "Was bedeutet Novel Food?",
