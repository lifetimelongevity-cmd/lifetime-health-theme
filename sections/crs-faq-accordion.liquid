{%- liquid
  assign crs_h_align = section.settings.content_align | default: 'left'
  if crs_h_align != 'left' and crs_h_align != 'center' and crs_h_align != 'right'
    assign crs_h_align = 'left'
  endif
  assign crs_faq_kicker = section.settings.kicker | strip
  assign crs_faq_head = section.settings.heading | strip
  assign crs_faq_sub = section.settings.subheading | strip
  if crs_faq_kicker == '__none__'
    assign crs_faq_kicker = ''
  endif
  if crs_faq_sub == '__none__'
    assign crs_faq_sub = ''
  endif
  assign crs_h_headline_lg = false
  if section.settings.heading_size == 'product_title'
    assign crs_h_headline_lg = true
  endif
-%}
{% style %}
  #section-{{ section.id }} {
    --crs-bg:       {{ section.settings.color_bg }};
    --crs-card-bg:  {{ section.settings.color_card_bg }};
    --crs-text:     {{ section.settings.color_text }};
    --crs-text-sec: {{ section.settings.color_text | color_modify: 'alpha', 0.6 }};
    --crs-text-ter: {{ section.settings.color_text | color_modify: 'alpha', 0.4 }};
    --crs-border:   {{ section.settings.color_text | color_modify: 'alpha', 0.05 }};
    padding-top:    {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    background:     var(--crs-bg);
  }
{% endstyle %}

<div class="faq-section" id="section-{{ section.id }}">
  <div class="faq-container">
    <div class="faq-layout">

      {%- comment -%} Left: sticky heading {%- endcomment -%}
      <div class="faq-left">
        {%- if crs_faq_kicker != blank or crs_faq_head != blank or crs_faq_sub != blank -%}
          <div class="faq-left-inner crs-heading-stack crs-heading-stack--align-{{ crs_h_align }}{% if crs_h_headline_lg %} crs-heading-stack--headline-lg{% endif %}">
            {%- if crs_faq_kicker != blank -%}
              <p class="crs-heading-stack__kicker">{{ crs_faq_kicker | escape }}</p>
            {%- endif -%}
            {%- if crs_faq_head != blank or crs_faq_sub != blank -%}
              <div class="crs-heading-stack__pair">
                {%- if crs_faq_head != blank -%}
                  <h2 class="crs-heading-stack__title">{{ crs_faq_head | escape | newline_to_br }}</h2>
                {%- endif -%}
                {%- if crs_faq_sub != blank -%}
                  <p class="crs-heading-stack__subtitle">{{ crs_faq_sub | escape | newline_to_br }}</p>
                {%- endif -%}
              </div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>

      {%- comment -%} Right: accordion items {%- endcomment -%}
      <div class="faq-right">
        {%- for block in section.blocks -%}
          <div class="faq-item" {{ block.shopify_attributes }}>
            <button
              class="faq-question"
              id="faq-trigger-{{ section.id }}-{{ forloop.index }}"
              aria-expanded="false"
              aria-controls="faq-panel-{{ section.id }}-{{ forloop.index }}"
            >
              <span class="faq-question-text">{{ block.settings.question | escape }}</span>
              <span class="faq-toggle" aria-hidden="true">↓</span>
            </button>
            <div
              class="faq-panel"
              id="faq-panel-{{ section.id }}-{{ forloop.index }}"
              role="region"
              aria-labelledby="faq-trigger-{{ section.id }}-{{ forloop.index }}"
            >
              <div class="faq-answer">
                <p>{{ block.settings.answer | escape }}</p>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>

    </div>
  </div>
</div>

{%- capture faq_schema_items -%}
  {%- assign faq_schema_started = false -%}
  {%- for block in section.blocks -%}
    {%- assign faq_question = block.settings.question | strip -%}
    {%- assign faq_answer = block.settings.answer | strip -%}
    {%- if faq_question != blank and faq_answer != blank -%}
      {%- if faq_schema_started -%},{%- endif -%}
      {%- assign faq_schema_started = true -%}
      {
        "@type": "Question",
        "name": {{ faq_question | json }},
        "acceptedAnswer": {
          "@type": "Answer",
          "text": {{ faq_answer | strip_html | strip_newlines | json }}
        }
      }
    {%- endif -%}
  {%- endfor -%}
{%- endcapture -%}
{%- unless faq_schema_items | strip == blank -%}
  <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [{{ faq_schema_items | strip }}]
    }
  </script>
{%- endunless -%}

{% stylesheet %}
/* ===================================================
   FAQ Accordion — crs-faq-accordion.liquid
   =================================================== */

.faq-section {
  background: var(--crs-bg, #f2f1ed);
}

.faq-container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 20px;
}

.faq-layout {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 0;
}

/* Left */
.faq-left {
  padding-right: var(--space-7);
  padding-top: var(--space-1);
}

.faq-left-inner {
  position: sticky;
  top: 80px;
}

/* Right — accordion (keine Karten-Rahmen, nur horizontale Trennlinien) */
.faq-right {
  padding-top: 0;
}

.faq-item {
  border-top: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
}

.faq-item:last-child {
  border-bottom: 1px solid var(--crs-border, rgba(38, 37, 30, 0.05));
}

.faq-question {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 15.68px 0 16.8px;
  background: none;
  border: none;
  cursor: pointer;
  gap: 16px;
  text-align: left;
}

.faq-question-text {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.5;
  color: var(--crs-text, #26251e);
}

.faq-toggle {
  font-size: 16px;
  color: var(--crs-text-ter, rgba(38,37,30,0.4));
  flex-shrink: 0;
  transition: transform 0.2s ease;
  line-height: 1;
  display: inline-block;
}

/* Panel */
.faq-panel {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.28s ease;
}

.faq-panel.is-open {
  max-height: min(120vh, 2000px);
}

.faq-answer {
  padding-bottom: 16px;
}

.faq-answer p {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Helvetica, Arial, sans-serif;
  font-size: 16px;
  font-weight: 400;
  line-height: 1.65;
  color: var(--crs-text-sec, rgba(38,37,30,0.6));
  margin: 0;
}

/* Mobile — stack */
@media (max-width: 1024px) {
  .faq-layout {
    grid-template-columns: 1fr;
    gap: 32px;
  }

  .faq-left {
    padding-right: 0;
  }

  .faq-left-inner {
    position: static;
  }
}
{% endstylesheet %}

{% javascript %}
(function () {
  if (window.__crsFaqAccordionBound) return;
  window.__crsFaqAccordionBound = true;

  function panelById(root, id) {
    if (!id) return null;
    var el = document.getElementById(id);
    return el && root.contains(el) ? el : null;
  }

  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.faq-section .faq-question');
    if (!btn) return;

    var section = btn.closest('.faq-section');
    if (!section) return;

    var buttons = section.querySelectorAll('.faq-question');
    var expanded = btn.getAttribute('aria-expanded') === 'true';
    var panelId = btn.getAttribute('aria-controls');
    var panel = panelById(section, panelId);
    var toggle = btn.querySelector('.faq-toggle');

    buttons.forEach(function (other) {
      if (other !== btn) {
        other.setAttribute('aria-expanded', 'false');
        var otherId = other.getAttribute('aria-controls');
        var otherPanel = panelById(section, otherId);
        var otherToggle = other.querySelector('.faq-toggle');
        if (otherPanel) otherPanel.classList.remove('is-open');
        if (otherToggle) otherToggle.textContent = '↓';
      }
    });

    if (!expanded) {
      btn.setAttribute('aria-expanded', 'true');
      if (panel) panel.classList.add('is-open');
      if (toggle) toggle.textContent = '↑';
    } else {
      btn.setAttribute('aria-expanded', 'false');
      if (panel) panel.classList.remove('is-open');
      if (toggle) toggle.textContent = '↓';
    }
  });
})();
{% endjavascript %}

{% schema %}
{
  "name": "FAQ Accordion",
  "tag": "section",
  "class": "crs-faq-accordion",
  "settings": [
    {
      "type": "header",
      "content": "Farben"
    },
    {
      "type": "color",
      "id": "color_bg",
      "label": "Seiten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_card_bg",
      "label": "Karten-Hintergrund",
      "default": "#f2f1ed"
    },
    {
      "type": "color",
      "id": "color_text",
      "label": "Textfarbe",
      "default": "#26251e"
    },
    {
      "type": "header",
      "content": "Abstände"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Abstand oben",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Abstand unten",
      "min": 0,
      "max": 120,
      "step": 8,
      "unit": "px",
      "default": 80
    },
    {
      "type": "header",
      "content": "Inhalt"
    },
    {
      "type": "select",
      "id": "content_align",
      "label": "Ausrichtung (Überschrift)",
      "options": [
        { "value": "left", "label": "Links" },
        { "value": "center", "label": "Zentriert" },
        { "value": "right", "label": "Rechts" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Überschrift Größe",
      "options": [
        { "value": "section", "label": "Standard (Abschnitt)" },
        { "value": "product_title", "label": "Wie Produkttitel" }
      ],
      "default": "section",
      "info": "Zeilenumbruch: Enter in Überschrift/Unterüberschrift."
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Überschrift",
      "default": "Häufige Fragen"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Unterüberschrift (optional)",
      "default": "__none__",
      "info": "__none__ = ausblenden (Theme-Editor)"
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "FAQ-Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Frage",
          "default": "Was bedeutet Novel Food?"
        },
        {
          "type": "textarea",
          "id": "answer",
          "label": "Antwort",
          "default": "NMN ist in der EU als Novel Food eingestuft und darf nicht als Nahrungsergänzungsmittel verkauft werden. Unser Produkt wird als Forschungsreagenz angeboten."
        }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "FAQ Accordion",
      "blocks": [
        {
          "type": "item",
          "settings": {
            "question": "Was bedeutet Novel Food?",
            "answer": "NMN ist in der EU als Novel Food eingestuft und darf daher nicht als Nahrungsergänzungsmittel vermarktet werden. Unser Produkt wird als Forschungsreagenz angeboten – zur wissenschaftlichen Anwendung."
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "Wann spüre ich erste Ergebnisse?",
            "answer": "Viele Nutzer berichten nach 4–6 Wochen konsistenter Einnahme von mehr Energie und besserer Erholung. Messbare NAD⁺-Veränderungen im Blut zeigen sich typischerweise nach 8–12 Wochen."
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "Wie nehme ich das Pulver ein?",
            "answer": "Löse die Tagesdosis (250–500 mg) in Wasser oder einem anderen Getränk auf. Morgens auf nüchternen Magen oder zum Frühstück – was sich für dich besser anfühlt."
          }
        },
        {
          "type": "item",
          "settings": {
            "question": "Kann ich das Abo jederzeit kündigen?",
            "answer": "Ja, du kannst dein Abo jederzeit ohne Angabe von Gründen kündigen – direkt in deinem Kundenkonto oder per E-Mail. Keine Fristen, kein Kleingedrucktes."
          }
        }
      ]
    }
  ]
}
{% endschema %}
