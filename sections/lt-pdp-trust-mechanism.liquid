{% comment %}
  LT PDP — Trust pillars (card-info grid). Mechanism lives in lt-pdp-mechanism.
{% endcomment %}

<div class="container container--large remove-empty-space">
  <section
    id="lt-pdp-trust-mechanism-{{ section.id }}"
    class="lt-pdp-trust-mechanism"
    aria-labelledby="lt-pdp-trust-mechanism-heading-{{ section.id }}"
  >
    <header class="lt-pdp-trust-mechanism__section-header">
      {%- if section.settings.section_label != blank -%}
        <p class="lt-pdp-trust-mechanism__label">{{ section.settings.section_label | escape }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2
          class="lt-pdp-trust-mechanism__title"
          id="lt-pdp-trust-mechanism-heading-{{ section.id }}"
        >
          {{- section.settings.heading | escape -}}
        </h2>
      {%- endif -%}
    </header>

    {%- if section.blocks.size > 0 -%}
      <div class="lt-pdp-trust-mechanism__grid" role="list">
        {%- for block in section.blocks -%}
          {%- case block.type -%}
            {%- when 'pillar' -%}
              <article class="lt-pdp-trust-mechanism__card" role="listitem" {{ block.shopify_attributes }}>
                {%- if block.settings.title != blank -%}
                  <h3 class="lt-pdp-trust-mechanism__card-title">{{ block.settings.title | escape }}</h3>
                {%- endif -%}
                {%- if block.settings.text != blank -%}
                  <p class="lt-pdp-trust-mechanism__card-text">{{ block.settings.text | escape }}</p>
                {%- endif -%}
              </article>
          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </section>
</div>

{% stylesheet %}
  .lt-pdp-trust-mechanism {
    --dg-space-2: 0.5rem;
    --dg-space-4: 1rem;
    --dg-space-5: 1.5rem;
    --dg-space-6: 2rem;
    --dg-space-8: 4rem;
    --dg-space-9: 5rem;
    --dg-text-micro: 0.75rem;
    --dg-text-h2: 1.75rem;
    --dg-text-section: 1.25rem;
    --dg-text-body: 1rem;
    --dg-leading-heading: 1.15;
    --dg-leading-tight: 1.25;
    --dg-leading-body: 1.4;
    --dg-weight-medium: 500;
    --dg-weight-bold: 700;
    --dg-radius-md: 0.75rem;
    --dg-shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.05);
    --dg-header-max: 40rem;

    padding-block: var(--dg-space-9);
    background: var(--color-background-main-alternate, #f6f4f1);
    color: var(--color-text-main);
  }

  @media screen and (max-width: 749px) {
    .lt-pdp-trust-mechanism {
      padding-block: var(--dg-space-8);
    }
  }

  .lt-pdp-trust-mechanism__section-header {
    max-width: var(--dg-header-max);
    margin-inline: auto;
    margin-bottom: var(--dg-space-6);
    text-align: center;
  }

  .lt-pdp-trust-mechanism__label {
    margin: 0 0 var(--dg-space-4);
    font-family: var(--font-stack-body-primary);
    font-size: var(--dg-text-micro);
    line-height: var(--dg-leading-body);
    font-weight: var(--dg-weight-medium);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--color-secondary-text-main);
  }

  .lt-pdp-trust-mechanism__title {
    margin: 0;
    font-family: var(--font-stack-headings-primary);
    font-size: var(--dg-text-h2);
    line-height: var(--dg-leading-heading);
    font-weight: var(--dg-weight-bold);
    color: var(--color-text-main);
  }

  .lt-pdp-trust-mechanism__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--dg-space-5);
    align-items: stretch;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media screen and (min-width: 750px) and (max-width: 1024px) {
    .lt-pdp-trust-mechanism__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 1025px) {
    .lt-pdp-trust-mechanism__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .lt-pdp-trust-mechanism__card {
    display: flex;
    flex-direction: column;
    height: 100%;
    margin: 0;
    padding: var(--dg-space-5);
    border: 1px solid color-mix(in srgb, var(--color-borders-main) 88%, transparent);
    border-radius: var(--dg-radius-md);
    background: var(--color-background-main);
    box-shadow: none;
  }

  .lt-pdp-trust-mechanism__card-title {
    margin: 0 0 var(--dg-space-2);
    font-family: var(--font-stack-headings-primary);
    font-size: var(--dg-text-section);
    line-height: var(--dg-leading-tight);
    font-weight: var(--dg-weight-bold);
    color: var(--color-text-main);
  }

  .lt-pdp-trust-mechanism__card-text {
    margin: 0;
    font-family: var(--font-stack-body-primary);
    font-size: var(--dg-text-body);
    line-height: var(--dg-leading-body);
    font-weight: 400;
    color: var(--color-secondary-text-main);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "LT PDP Trust-Brücke",
  "tag": "section",
  "class": "section-lt-pdp-trust-mechanism",
  "enabled_on": {
    "templates": ["product"]
  },
  "settings": [
    {
      "type": "text",
      "id": "section_label",
      "label": "Sektions-Label",
      "default": "WISSEN & VERTRAUEN"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Überschrift (H2)",
      "default": "Darauf kannst du setzen"
    }
  ],
  "blocks": [
    {
      "type": "pillar",
      "name": "Vertrauenssäule",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Titel",
          "default": "Qualität"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Hochreine Rohstoffe und unabhängige Laborkontrollen – transparent und nachvollziehbar."
        }
      ]
    }
  ],
  "max_blocks": 3,
  "presets": [
    {
      "name": "LT PDP Trust-Brücke",
      "category": "Product",
      "settings": {
        "section_label": "WISSEN & VERTRAUEN",
        "heading": "Darauf kannst du setzen"
      },
      "blocks": [
        {
          "type": "pillar",
          "settings": {
            "title": "Qualität",
            "text": "Hochreine Rohstoffe und unabhängige Laborkontrollen – transparent und nachvollziehbar."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "Wissenschaft",
            "text": "Entwickelt auf Basis aktueller Forschung zu NAD⁺ – reduziert auf das, was wirklich relevant ist."
          }
        },
        {
          "type": "pillar",
          "settings": {
            "title": "LIFETIME",
            "text": "Evidenzbasierte Longevity – ohne Hype, mit klarem Anspruch an Qualität."
          }
        }
      ]
    }
  ]
}
{% endschema %}
