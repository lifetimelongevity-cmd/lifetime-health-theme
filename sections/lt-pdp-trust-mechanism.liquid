{% comment %}
  LT PDP — Trust + Mechanism Bridge (pdp-architecture §3).
  Mechanism (readable column) + visually separated trust band.
{% endcomment %}

<div class="container container--large container--vertical-space-small remove-empty-space">
<section
  id="lt-pdp-trust-mechanism-{{ section.id }}"
  class="lt-pdp-trust-mechanism"
  aria-labelledby="lt-pdp-trust-mechanism-heading-{{ section.id }}"
>
  <div class="lt-pdp-trust-mechanism__inner">
    <header class="lt-pdp-trust-mechanism__header">
      {%- if section.settings.heading != blank -%}
        <h2
          class="lt-pdp-trust-mechanism__heading"
          id="lt-pdp-trust-mechanism-heading-{{ section.id }}"
        >
          {{- section.settings.heading | escape -}}
        </h2>
      {%- endif -%}
      {%- if section.settings.subline != blank -%}
        <p class="lt-pdp-trust-mechanism__subline">{{ section.settings.subline | escape }}</p>
      {%- endif -%}
    </header>

    <div class="lt-pdp-trust-mechanism__mechanism">
      {%- if section.settings.mechanism_body != blank -%}
        <div class="lt-pdp-trust-mechanism__mechanism-body rte">
          {{ section.settings.mechanism_body }}
        </div>
      {%- endif -%}
    </div>
  </div>

  <div class="lt-pdp-trust-mechanism__trust-wrap">
    <div class="lt-pdp-trust-mechanism__inner lt-pdp-trust-mechanism__inner--trust">
      {%- if section.blocks.size > 0 -%}
        <div class="lt-pdp-trust-mechanism__trust-grid" role="list">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'pillar' -%}
                <article
                  class="lt-pdp-trust-mechanism__pillar"
                  role="listitem"
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.title != blank -%}
                    <h3 class="lt-pdp-trust-mechanism__pillar-title">{{ block.settings.title | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <p class="lt-pdp-trust-mechanism__pillar-text">{{ block.settings.text | escape }}</p>
                  {%- endif -%}
                </article>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.micro_cta != blank -%}
        <p class="lt-pdp-trust-mechanism__micro-cta">{{ section.settings.micro_cta | escape }}</p>
      {%- endif -%}
    </div>
  </div>
</section>
</div>

{% stylesheet %}
  .lt-pdp-trust-mechanism {
    --lt-tm-warm: #f6f4f1;
    --lt-tm-border: color-mix(in srgb, var(--color-borders-main, #e5e5e5) 88%, var(--color-text-main, #000));
    color: var(--color-text-main, #1f2933);
    background: var(--color-background-main, #fff);
  }

  .lt-pdp-trust-mechanism__inner {
    margin: 0;
    padding: 2.5rem 0 0;
  }

  @media screen and (min-width: 750px) {
    .lt-pdp-trust-mechanism__inner {
      padding-top: 3rem;
    }
  }

  .lt-pdp-trust-mechanism__header {
    margin-bottom: 1.5rem;
    max-width: 42rem;
  }

  @media screen and (min-width: 750px) {
    .lt-pdp-trust-mechanism__header {
      margin-bottom: 1.75rem;
    }
  }

  .lt-pdp-trust-mechanism__heading {
    margin: 0 0 0.5rem;
    font-size: clamp(1.375rem, 2.5vw, 1.75rem);
    line-height: 1.2;
    letter-spacing: -0.02em;
    font-weight: 700;
    color: var(--color-text-main, #000);
  }

  .lt-pdp-trust-mechanism__subline {
    margin: 0;
    font-size: 1.0625rem;
    line-height: 1.45;
    color: var(--color-secondary-text-main, #525252);
  }

  /* Mechanism: focused reading column */
  .lt-pdp-trust-mechanism__mechanism {
    max-width: 42rem;
    padding-bottom: 2.5rem;
  }

  @media screen and (min-width: 750px) {
    .lt-pdp-trust-mechanism__mechanism {
      padding-bottom: 3rem;
    }
  }

  .lt-pdp-trust-mechanism__mechanism-body {
    font-size: 1.125rem;
    line-height: 1.6;
    color: var(--color-text-main, #1f2933);
  }

  .lt-pdp-trust-mechanism__mechanism-body p {
    margin: 0 0 1rem;
  }

  .lt-pdp-trust-mechanism__mechanism-body p:last-child {
    margin-bottom: 0;
  }

  /* Strong separation: full-width band */
  .lt-pdp-trust-mechanism__trust-wrap {
    background: var(--lt-tm-warm);
    border-top: 1px solid var(--lt-tm-border);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.6);
  }

  .lt-pdp-trust-mechanism__inner--trust {
    padding-top: 2rem;
    padding-bottom: 2.25rem;
  }

  @media screen and (min-width: 750px) {
    .lt-pdp-trust-mechanism__inner--trust {
      padding-top: 2.5rem;
      padding-bottom: 2.75rem;
    }
  }

  .lt-pdp-trust-mechanism__trust-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem 2rem;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media screen and (min-width: 768px) {
    .lt-pdp-trust-mechanism__trust-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1.75rem 2.25rem;
    }
  }

  .lt-pdp-trust-mechanism__pillar {
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
  }

  .lt-pdp-trust-mechanism__pillar-title {
    margin: 0 0 0.35rem;
    font-size: 1rem;
    line-height: 1.3;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--color-text-main, #000);
  }

  .lt-pdp-trust-mechanism__pillar-text {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.5;
    color: var(--color-secondary-text-main, #525252);
  }

  .lt-pdp-trust-mechanism__micro-cta {
    margin: 1.75rem 0 0;
    padding-top: 1.25rem;
    border-top: 1px solid color-mix(in srgb, var(--color-borders-main, #e5e5e5) 75%, transparent);
    font-size: 0.875rem;
    line-height: 1.45;
    color: var(--color-secondary-text-main, #525252);
  }

  @media screen and (min-width: 768px) {
    .lt-pdp-trust-mechanism__micro-cta {
      margin-top: 2rem;
      max-width: 40rem;
    }
  }
{% endstylesheet %}

