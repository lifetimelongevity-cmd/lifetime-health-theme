{% comment %}
  LT PDP — Trust + Mechanism Bridge. Aligned to design-governance.md tokens & structure.
{% endcomment %}

<div class="container container--large remove-empty-space">
  <section
    id="lt-pdp-trust-mechanism-{{ section.id }}"
    class="lt-pdp-trust-mechanism"
    aria-labelledby="lt-pdp-trust-mechanism-heading-{{ section.id }}"
  >
    <div class="lt-pdp-trust-mechanism__intro">
      <header class="lt-pdp-trust-mechanism__section-header">
        {%- if section.settings.heading != blank -%}
          <h2
            class="lt-pdp-trust-mechanism__title"
            id="lt-pdp-trust-mechanism-heading-{{ section.id }}"
          >
            {{- section.settings.heading | escape -}}
          </h2>
        {%- endif -%}
        {%- if section.settings.subline != blank -%}
          <p class="lt-pdp-trust-mechanism__description">{{ section.settings.subline | escape }}</p>
        {%- endif -%}
      </header>

      {%- if section.settings.mechanism_body != blank -%}
        <div class="lt-pdp-trust-mechanism__body rte">
          {{ section.settings.mechanism_body }}
        </div>
      {%- endif -%}
    </div>

    {%- if section.blocks.size > 0 -%}
      <div class="lt-pdp-trust-mechanism__trust">
        <div class="lt-pdp-trust-mechanism__grid" role="list">
          {%- for block in section.blocks -%}
            {%- case block.type -%}
              {%- when 'pillar' -%}
                <article class="lt-pdp-trust-mechanism__item" role="listitem" {{ block.shopify_attributes }}>
                  {%- if block.settings.title != blank -%}
                    <h3 class="lt-pdp-trust-mechanism__item-title">{{ block.settings.title | escape }}</h3>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <p class="lt-pdp-trust-mechanism__item-text">{{ block.settings.text | escape }}</p>
                  {%- endif -%}
                </article>
            {%- endcase -%}
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </section>
</div>

{% stylesheet %}
  .lt-pdp-trust-mechanism {
    /* design-governance.md §3 — spacing 8px base */
    --dg-space-2: 0.5rem;
    --dg-space-4: 1rem;
    --dg-space-5: 1.5rem;
    --dg-space-6: 2rem;
    --dg-space-7: 3rem;
    --dg-space-8: 4rem;
    --dg-space-9: 5rem;
    /* typography scale */
    --dg-text-h2: 1.75rem;
    --dg-text-h3: 1.5rem;
    --dg-text-body: 1rem;
    --dg-text-body-sm: 0.875rem;
    --dg-leading-heading: 1.15;
    --dg-leading-body: 1.4;
    --dg-leading-relaxed: 1.6;
    --dg-weight-bold: 700;
    --dg-header-max: 40rem;

    padding-block: var(--dg-space-9);
    color: var(--color-text-main);
    background: var(--color-background-main);
  }

  @media screen and (max-width: 749px) {
    .lt-pdp-trust-mechanism {
      padding-block: var(--dg-space-8);
    }
  }

  .lt-pdp-trust-mechanism__intro {
    max-width: var(--dg-header-max);
    margin-inline: auto;
  }

  .lt-pdp-trust-mechanism__section-header {
    margin-bottom: var(--dg-space-6);
    text-align: center;
  }

  .lt-pdp-trust-mechanism__title {
    margin: 0;
    font-family: var(--font-stack-headings-primary);
    font-size: var(--dg-text-h2);
    line-height: var(--dg-leading-heading);
    font-weight: var(--dg-weight-bold);
    color: var(--color-text-main);
  }

  .lt-pdp-trust-mechanism__description {
    margin: var(--dg-space-4) 0 0;
    font-family: var(--font-stack-body-primary);
    font-size: var(--dg-text-body);
    line-height: var(--dg-leading-body);
    font-weight: 400;
    color: var(--color-secondary-text-main);
  }

  .lt-pdp-trust-mechanism__body {
    font-family: var(--font-stack-body-primary);
    font-size: var(--dg-text-body);
    line-height: var(--dg-leading-relaxed);
    font-weight: 400;
    color: var(--color-text-main);
    text-align: start;
  }

  .lt-pdp-trust-mechanism__body p {
    margin: 0 0 var(--dg-space-4);
  }

  .lt-pdp-trust-mechanism__body p:last-child {
    margin-bottom: 0;
  }

  .lt-pdp-trust-mechanism__trust {
    margin-top: var(--dg-space-8);
    padding-top: var(--dg-space-7);
    border-top: 1px solid var(--color-borders-main);
  }

  .lt-pdp-trust-mechanism__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--dg-space-5);
    margin: 0;
    padding: 0;
    list-style: none;
  }

  @media screen and (min-width: 750px) and (max-width: 1024px) {
    .lt-pdp-trust-mechanism__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 1025px) {
    .lt-pdp-trust-mechanism__grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
  }

  .lt-pdp-trust-mechanism__item {
    margin: 0;
    padding: 0;
    border: 0;
    background: transparent;
  }

  .lt-pdp-trust-mechanism__item-title {
    margin: 0 0 var(--dg-space-2);
    font-family: var(--font-stack-headings-primary);
    font-size: var(--dg-text-h3);
    line-height: 1.25;
    font-weight: var(--dg-weight-bold);
    color: var(--color-text-main);
  }

  .lt-pdp-trust-mechanism__item-text {
    margin: 0;
    font-family: var(--font-stack-body-primary);
    font-size: var(--dg-text-body-sm);
    line-height: var(--dg-leading-relaxed);
    font-weight: 400;
    color: var(--color-secondary-text-main);
  }
{% endstylesheet %}

