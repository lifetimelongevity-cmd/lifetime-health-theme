{% comment %}
  LIFETIME — Approved Example: Team Grid Section (team-grid pattern)
  ──────────────────────────────────────────────────────────────────
  Produktiv-Implementierung: `sections/lt-about-team.liquid`
  CSS: `_examples/assets/section-team-grid.css`
       (produktiv: `assets/section-lt-about-team.css`)

  §12 Build Spec:
  - Surface:          --color-surface-secondary (warm)
  - Section label:    optional — weglassen, wenn die Headline den Kontext
                      trägt (§11 Subtraction)
  - Dominant element: Section-Headline (crs-heading-stack, headline_lg);
                      in der Karte der Name (--text-section, bold)
  - Heading size:     --text-h1 (Section) / --text-section (Card-Name)
  - Content pattern:  team-grid — card-info-Disziplin (weiße Karte,
                      --radius-md, Innenmaß --space-5) mit Foto oben,
                      grid-3 → grid-palm-1
  - CTA:              keiner
  - Removed:          Foto-Borders, Card-Links, Captions unter den Fotos
                      (Name + Rolle stehen im Meta-Block)
  - Quality move:     Foto läuft full-bleed bis an die Kartenkante
                      (overflow hidden) — Karte und Bild lesen sich als
                      ein Objekt; Name + Rolle sitzen als ruhige,
                      zentrierte Galerie-Caption darunter (nur zwei
                      Typo-Größen in der Karte: 20px Name, 12px Rolle)

  Heading-System: Section-Header IMMER über `section-heading-crs`
  (docs/section-heading-stack.md). Kein lokales Header-CSS.
  Card-Konsistenz: Karten-Optik (weiß, --radius-md, --shadow-sm)
  identisch zum benefits-/card-info-Pattern derselben Seite (§7).
{% endcomment %}

{{ 'section-team-grid.css' | asset_url | stylesheet_tag }}

<section class="lt-about-team">
  <div class="lt-about-team__container">

    {%- if section.settings.title != blank -%}
      {% render 'section-heading-crs',
        heading: section.settings.title,
        kicker: section.settings.kicker,
        align: 'left',
        headline_lg: true,
        heading_tag: 'h2',
        extra_class: 'lt-about-team__header'
      %}
    {%- endif -%}

    <ul class="lt-about-team__grid" role="list">
      {%- for block in section.blocks -%}
        <li class="lt-about-team__card" {{ block.shopify_attributes }}>

          <div class="lt-about-team__visual">
            {%- if block.settings.photo != blank -%}
              {{
                block.settings.photo
                | image_url: width: 800
                | image_tag:
                  loading: 'lazy',
                  class: 'lt-about-team__img',
                  alt: block.settings.name
              }}
            {%- else -%}
              <div class="lt-about-team__img-placeholder" aria-hidden="true">
                <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
                  <circle cx="12" cy="7" r="4"/>
                </svg>
              </div>
            {%- endif -%}
          </div>

          <div class="lt-about-team__meta">
            {%- if block.settings.name != blank -%}
              <h3 class="lt-about-team__name">{{ block.settings.name | escape }}</h3>
            {%- endif -%}
            {%- if block.settings.role != blank -%}
              <p class="lt-about-team__role">{{ block.settings.role | escape }}</p>
            {%- endif -%}
          </div>

        </li>
      {%- endfor -%}
    </ul>

  </div>
</section>

{% schema %}
{
  "name": "Team Grid",
  "tag": "section",
  "class": "lt-about-team-section",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker (micro label)",
      "info": "Optional. Leer lassen, wenn die Headline den Kontext trägt."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Heading",
      "default": "Management Team"
    }
  ],
  "blocks": [
    {
      "type": "member",
      "name": "Team-Mitglied",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Foto"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name",
          "default": "Vor- und Nachname"
        },
        {
          "type": "text",
          "id": "role",
          "label": "Rolle",
          "default": "Founder & CEO"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team Grid",
      "blocks": [
        { "type": "member" },
        { "type": "member" },
        { "type": "member" }
      ]
    }
  ]
}
{% endschema %}
