        "q-wer": {
          "type": "item",
          "settings": {
            "question": "Wer entscheidet über die Novel-Food-Zulassung?",
            "answer": "Die EU-Kommission gemeinsam mit den Mitgliedstaaten, nicht die EFSA. Die EFSA liefert nur die wissenschaftliche Sicherheitsbewertung, die Zulassung selbst ist ein Rechtsakt der Kommission."
          }
        },
        "q-dauer": {
          "type": "item",
          "settings": {
            "question": "Wie lange dauert ein Novel-Food-Verfahren?",
            "answer": "Es gibt keine feste Gesamtfrist. Die nominellen Verfahrenszeiten summieren sich auf rund anderthalb Jahre, in der Praxis dauert es oft länger, weil Rückfragen und Abstimmungen dazukommen."
          }
        },
        "q-unterschied": {
          "type": "item",
          "settings": {
            "question": "Was ist der Unterschied zwischen EFSA-Bewertung und Zulassung?",
            "answer": "Die EFSA-Bewertung prüft die wissenschaftliche Sicherheit eines Stoffs. Die Zulassung ist der rechtliche Durchführungsrechtsakt der EU-Kommission, der den Verkauf erst erlaubt."
          }
        },
        "q-unionsliste": {
          "type": "item",
          "settings": {
            "question": "Was ist die Unionsliste?",
            "answer": "Das offizielle EU-Verzeichnis zugelassener neuartiger Lebensmittel (Durchführungsverordnung (EU) 2017/2470). Für jeden Eintrag legt es die erlaubten Verwendungsbedingungen fest."
          }
        },
        "q-mehrere": {
          "type": "item",
          "settings": {
            "question": "Haben mehrere Firmen NMN-Anträge gestellt?",
            "answer": "Ja, für NMN liegen Anträge mehrerer Unternehmen vor, darunter der Antrag von EffePharm, zu dem die EFSA 2026 eine positive Sicherheitsbewertung abgegeben hat."
          }
        }
