      "blocks": {
        "faq_1": {
          "type": "item",
          "settings": {
            "question": "Was bedeutet Novel Food – ist NMN in Deutschland legal?",
            "answer": "NMN ist in der EU als Novel Food eingestuft — das bedeutet, es darf nicht als Nahrungsergänzungsmittel vermarktet werden. LIFETIME vertreibt NMN daher zu Forschungs- und Analysezwecken. Das Produkt ist legal erhältlich und unbedenklich. Die Einstufung betrifft nur die Vermarktungskategorie, nicht die Sicherheit des Stoffes."
          }
        },
        "faq_2": {
          "type": "item",
          "settings": {
            "question": "Wann spüre ich erste Ergebnisse?",
            "answer": "Die meisten Kunden berichten nach 2–4 Wochen von einem konstanteren Energieniveau. Maximale Effekte auf Stoffwechsel, Gefäßgesundheit und Zellreparatur entwickeln sich nach 3–4 Monaten kontinuierlicher Einnahme — NMN wirkt kumulativ."
          }
        },
        "faq_3": {
          "type": "item",
          "settings": {
            "question": "Wie nehme ich das Pulver ein?",
            "answer": "Morgens 1 Messlöffel (ca. 500 mg) in Wasser, Saft oder Smoothie einrühren – am besten vor oder zum Frühstück. Der Messlöffel liegt jedem Beutel bei. 30 g entsprechen ca. 60 Portionen und reichen etwa 2 Monate."
          }
        },
        "faq_4": {
          "type": "item",
          "settings": {
            "question": "Was ist Uthever® NMN – und warum ist das besser?",
            "answer": "Uthever® ist der weltweit meistverkaufte patentierte NMN-Rohstoff — klinisch untersucht, nach GMP hergestellt und auf >99% Reinheit standardisiert. Jede Charge kommt mit einem öffentlichen Certificate of Analysis. Das ist der Unterschied zu No-Name-NMN unbekannter Herkunft."
          }
        },
        "faq_5": {
          "type": "item",
          "settings": {
            "question": "Kann ich das Abo jederzeit kündigen oder pausieren?",
            "answer": "Ja — vollständig flexibel. Du kannst dein Abo jederzeit pausieren, anpassen oder kündigen. Direkt im Kundenkonto, ohne Angabe von Gründen, ohne Fristen, ohne Anruf."
          }
        },
        "faq_6": {
          "type": "item",
          "settings": {
            "question": "Wie lange reicht ein Beutel?",
            "answer": "Ein Beutel enthält 30 g NMN-Pulver mit ca. 60 Portionen à 500 mg (1 Messlöffel). Bei täglicher Einnahme reicht ein Beutel etwa 2 Monate – also 60 Tage Versorgung pro Bestellung."
          }
        },
        "faq_7": {
          "type": "item",
          "settings": {
            "question": "Wie sollte ich NMN lagern?",
            "answer": "Kühl, trocken und lichtgeschützt – kein Kühlschrank nötig. Das Pulver ist nach dem Öffnen luftdicht zu verschließen. Haltbarkeit: ca. 24 Monate ab Herstellung (Mindesthaltbarkeitsdatum auf der Rückseite)."
          }
        },
        "faq_8": {
          "type": "item",
          "settings": {
            "question": "Gilt die 30-Tage-Garantie auch für Abo-Bestellungen?",
            "answer": "Ja — die 30-Tage Geld-zurück-Garantie gilt für alle Bestellungen, einmalig und Abo. Schreib uns eine E-Mail — wir erstatten den Kaufpreis."
          }
        }
