        "custom_liquid_rj4Acb": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "{%- assign erf_list = product.metafields.custom.tag_kundenerfahrung.value -%}\n{%- if erf_list and erf_list.size > 0 -%}\n<section class=\"lt-experiences section\">\n  <div class=\"lt-experiences__inner\">\n    <div class=\"lt-experiences__header\">\n      <img \n        src=\"https://cdn.shopify.com/s/files/1/0621/2173/8340/files/speak-svgrepo-com.svg?v=1758015158\" \n        alt=\"Feedback Icon\" \n        width=\"18\" height=\"18\" \n        style=\"margin-right:6px;\">\n      <span class=\"toggle__title lt-experiences__title\">Kunden berichten von:</span>\n    </div>\n\n    <div class=\"lt-experiences__tags\">\n      {%- for item in erf_list -%}\n        {%- assign label = item | strip -%}\n        {%- if label != blank -%}\n          <span class=\"lt-tag-pill\">{{ label | escape }}</span>\n        {%- endif -%}\n      {%- endfor -%}\n    </div>\n  </div>\n</section>\n{%- endif -%}\n\n<style>\n  .lt-experiences {\n    margin: -0.5rem 0 1rem;   \n    border-radius: 10px;\n    padding: 4px 12px 12px;   \n    background: #FAFAFA;      \n  }\n\n  .lt-experiences__title {\n    font-size: 1rem;\n    font-weight: 600;\n  }\n\n  .lt-experiences__header {\n    display: flex;\n    align-items: center;\n    margin-bottom: .5rem;\n  }\n\n  .lt-experiences__tags {\n    display: flex;\n    flex-wrap: wrap;\n    gap: .4rem .6rem;\n  }\n\n  .lt-tag-pill {\n    display: inline-flex;\n    align-items: center;\n    justify-content: center;\n    padding: .28rem .55rem;\n    font-size: .8rem;\n    line-height: 1;\n    border: 1px solid #dcdfe3;\n    border-radius: 9999px;\n    background: #fff;\n    color: #4b5563;\n    text-decoration: none;\n    box-shadow: none !important;\n    text-shadow: none !important;\n    transition: border-color .15s ease, background-color .15s ease;\n    white-space: nowrap;\n  }\n\n  .lt-tag-pill:hover {\n    border-color: #9ca3af;\n    background: #f9fafb;\n  }\n\n  @media (min-width: 768px) {\n    .lt-experiences { display: none; }\n  }\n</style>"
          }
        },
