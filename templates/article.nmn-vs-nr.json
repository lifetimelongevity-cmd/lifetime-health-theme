        "q-besser": {
          "type": "item",
          "settings": {
            "question": "Ist NMN oder NR besser?",
            "answer": "Chemisch ist NMN die direkte NAD⁺-Vorstufe, NR wird im Körper zunächst zu NMN umgewandelt. Das erklärt, warum NMN das deutlich größere Forschungs- und Marktinteresse auf sich zieht. Ein im Menschen direkt belegter Wirkvorteil gegenüber NR ist damit aber nicht automatisch gezeigt."
          }
        },
        "q-dasselbe": {
          "type": "item",
          "settings": {
            "question": "Sind NMN und NR dasselbe?",
            "answer": "Nein. Beide sind NAD⁺-Vorstufen und eng verwandt, unterscheiden sich chemisch aber durch eine Phosphatgruppe: NMN trägt sie, NR nicht."
          }
        },
        "q-nr-eu": {
          "type": "item",
          "settings": {
            "question": "Ist NR in der EU zugelassen?",
            "answer": "Ja. Nicotinamid-Ribosid-Chlorid ist seit 2020 als Novel Food für Nahrungsergänzungsmittel zugelassen (Verordnung (EU) 2020/16), mit höchstens 300 mg pro Tag für Erwachsene. NMN ist dagegen noch nicht zugelassen."
          }
        },
        "q-kombi": {
          "type": "item",
          "settings": {
            "question": "Kann man NMN und NR kombinieren?",
            "answer": "Das ist eine Anwendungsfrage, die dieser Artikel nicht beantwortet. Da NMN in der EU nicht als Nahrungsergänzung zugelassen ist, ist das zunächst eine rechtliche Frage. Für gesundheitsbezogene Fragen ist ärztlicher Rat maßgeblich."
          }
        },
        "q-erforscht": {
          "type": "item",
          "settings": {
            "question": "Welche Vorstufe wird häufiger erforscht?",
            "answer": "Beide werden intensiv erforscht. NR hat bislang mehr und längere Humanstudien, NMN ist Gegenstand wachsender Forschung. Übersichtsarbeiten betonen, dass große Vergleichsstudien noch fehlen."
          }
        }
      },
