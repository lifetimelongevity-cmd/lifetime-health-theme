     width:100px;\n      height:14px;\n      background-image:url(\"data:image/svg+xml;utf8,<svg width='20' height='14' viewBox='0 0 14 13' xmlns='http://www.w3.org/2000/svg'><path d='m7 0 1.572 4.837h5.085l-4.114 2.99 1.572 4.836L7 9.673l-4.114 2.99 1.571-4.837-4.114-2.99h5.085L7 0Z' fill='{{ star_color }}'/></svg>\");\n      background-repeat:repeat-x;\n      background-size:20px 14px;\n    }\n  </style>\n\n  <div class=\"custom-rating-wrapper\" onclick=\"scrollToLastSection()\">\n    <div class=\"custom-rating-row\">\n      <span class=\"custom-stars\" aria-hidden=\"true\">\n        <span class=\"custom-stars-active\"></span>\n      </span>\n      <span class=\"text-size--medium\">{{ rating_text }} ({{ rating_count }})</span>\n    </div>\n  </div>\n\n  <script>\n    function scrollToLastSection() {\n      if (window.Shopify && Shopify.designMode) return;\n      const sections = document.querySelectorAll('[id^=\"shopify-section\"]');\n      if (sections.length) {\n        sections[sections.length - 1].scrollIntoView({ behavior: 'smooth' });\n      }\n    }\n  </script>\n{% endif %}"
