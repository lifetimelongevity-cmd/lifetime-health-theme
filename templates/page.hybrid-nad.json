    "custom_liquid_AM964K": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.refactor_words.custom_code.name",
      "settings": {
        "heading": "",
        "subheading": "",
        "section_heading_size": "text-size--regular",
        "section_heading_layout": "section-heading--left section-heading--one-row",
        "cta_label": "",
        "cta_url": "",
        "custom_liquid": "<section class=\"lt-riskfree\" role=\"region\" aria-label=\"Risikofrei testen\">\n  <div class=\"lt-riskfree__media\" aria-hidden=\"true\">\n    <img\n      src=\"https://cdn.shopify.com/s/files/1/0621/2173/8340/files/Money-Back_Guarantee_Website_Graphic_1.png?v=1762426057\"\n      alt=\"90-Tage-Geld-zurück-Garantie Siegel\"\n      loading=\"lazy\"\n      width=\"300\"\n      height=\"300\"\n    >\n  </div>\n\n  <div class=\"lt-riskfree__content\">\n    <h2 class=\"lt-riskfree__title h2\">Risikofrei testen</h2>\n    <span class=\"lt-riskfree__text\">90-Tage-Geld-zurück-Garantie. Nicht zufrieden? Du erhältst 100% des Kaufpreises zurück.</span>\n    {%- comment -%}\n      Optionaler Button – zum Aktivieren Kommentar entfernen.\n      <a href=\"/pages/order\" class=\"lt-riskfree__btn\" aria-label=\"Jetzt bestellen\">Jetzt bestellen</a>\n    {%- endcomment -%}\n  </div>\n\n  <style>\n    .lt-riskfree {\n      --lt-bg: #F2EFEC;  /* Hintergrund */\n      --lt-fg: #111;     /* Text */\n      --lt-accent: #111; /* Button/Icon */\n      --lt-gap: clamp(12px, 3vw, 20px);\n\n      box-sizing: border-box;\n      margin: 0 auto;\n      max-width: 1100px;\n      padding: clamp(14px, 3vw, 20px);\n      background: var(--lt-bg);\n      border: 0;\n      border-radius: 14px;\n      color: var(--lt-fg);\n\n      display: flex;\n      align-items: center;\n      gap: var(--lt-gap);\n      flex-wrap: nowrap; /* bleibt auch mobil nebeneinander */\n    }\n\n    .lt-riskfree__media {\n      flex: 0 0 auto;\n      width: clamp(64px, 18vw, 96px);\n      display: grid;\n      place-items: center;\n    }\n    .lt-riskfree__media img { width: 100%; height: auto; display: block; }\n\n    .lt-riskfree__content { flex: 1 1 auto; min-width: 0; }\n    .lt-riskfree__title  { margin: 0 0 .25em 0; }     /* Größe/Font kommt vom Theme */\n    .lt-riskfree__text   { display: inline-block; line-height: 1.55; }\n\n    .lt-riskfree__btn {\n      display: inline-block;\n      margin-top: .85em;\n      padding: 0 1.2em;\n      line-height: 2.8em;\n      border-radius: 999px;\n      text-decoration: none;\n      background: var(--lt-accent);\n      color: #fff;\n      border: 1.5px solid var(--lt-accent);\n      font-weight: 700;\n      transition: opacity .2s ease, transform .12s ease;\n      white-space: nowrap;\n    }\n    .lt-riskfree__btn:hover { opacity: .9; transform: translateY(-1px); }\n    .lt-riskfree__btn:active { transform: translateY(0); }\n  </style>\n</section>",
        "full_width": false,
        "remove_margin": false,
        "seo_h_tag": "h2"
      }
    },
