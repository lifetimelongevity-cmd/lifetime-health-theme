        },
        "text_LYUBkz": {
          "type": "text",
          "settings": {
            "text": "<p>FACHÄRZTIN FÜR ONKOLOGIE & HÄMATOLOGIE<br/><br/>Dr. med. Christina Limmroth bringt ihre langjährige Erfahrung als Onkologin sowie ihre Kompetenz in der indikationsspezifischen genetischen Beratung in die Arbeit bei LIFETIME ein. Sie unterstützt insbesondere bei der Interpretation genetischer Analysen und Auswertungen im Kontext von Tumorerkrankungen. </p><p>Dr. Limmroth ist Fachärztin für Innere Medizin, Hämatologie und internistische Onkologie und verfügt über umfangreiche Erfahrung in der personalisierten Medizin.</p>",
            "text_size": "regular"
          }
        }
