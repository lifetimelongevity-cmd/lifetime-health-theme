        "7c1b7dc8-bf0a-4d1d-9f52-4b6dac8e352c": {
          "type": "text",
          "settings": {
            "text": "<p>Wie sollte man NMN einnehmen, ist es ein sicherer Nährstoff und wie lagert man es am besten? In diesem Artikel gehen wir diesen Fragen auf den Grund.</p>",
            "text_size": "large"
          }
        }
      },
