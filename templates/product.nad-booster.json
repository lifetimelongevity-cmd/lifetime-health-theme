    "text_columns_images_4RqA7L": {
      "type": "text-columns-images",
      "blocks": {
        "image_rV3e8Q": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/benefits-of-nmn.jpg",
            "title": "NAD+ ist essenziell für die Zellfunktion",
            "caption": "NAD+ ist in jeder Zelle unseres Körpers. Es trägt entscheidend zur Energieproduktion bei, unterstützt die DNA-Reparatur und hilft bei der Regulierung von Zellsignalen. Man kann sich NAD+ als den Treibstoff für unsere Zellen vorstellen – es ermöglicht unseren Mitochondrien, Nahrung in Energie umzuwandeln.",
            "link": "",
            "open_in_new_window": false,
            "color_background_main": "rgba(0,0,0,0)",
            "color_text_main": "rgba(0,0,0,0)",
            "color_borders_main": "rgba(0,0,0,0)",
            "seo_h_tag": "h3"
          }
        },
        "image_hGXBBP": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/pexels-jason-deines-2993297-6258544.jpg",
            "title": "NMN ist der direkte Vorläufer von NAD+",
            "caption": "NMN wird von Zellen aufgenommen, erhöht die NAD+-Spiegel und unterstützt somit essenzielle Zellfunktionen. NMN ist für wissenschaftliche Studien besonders interessant, weil es den NAD+-Spiegel auf natürliche Weise wieder auffüllen kann.",
            "link": "",
            "open_in_new_window": false,
            "color_background_main": "rgba(0,0,0,0)",
            "color_text_main": "rgba(0,0,0,0)",
            "color_borders_main": "rgba(0,0,0,0)",
            "seo_h_tag": "h3"
          }
        },
        "image_7ynJPr": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/Black_and_White_Minimalist_Conference_Flyer_1.jpg",
            "title": "NAD+ sinkt im Alter",
            "caption": "Die NAD+-Spiegel sinken zwischen dem 40. und 60. Lebensjahr um bis zu 50 %. Dies verlangsamt den Energie-Stoffwechsel & verstärkt sichtbare Anzeichen des Alterns.",
            "link": "",
            "open_in_new_window": false,
            "color_background_main": "rgba(0,0,0,0)",
            "color_text_main": "rgba(0,0,0,0)",
            "color_borders_main": "rgba(0,0,0,0)",
            "seo_h_tag": "h3"
          }
        },
        "image_4Yhw8A": {
          "type": "image",
          "settings": {
            "image": "shopify://shop_images/sirtuine-visualisierung-nad.jpg",
            "title": "Aktivierung von Sirtuinen",
            "caption": "NMN und NAD+ sind wichtig für die Aktivierung von Sirtuinen, Enzymen, die Gene regulieren. Sirtuine benötigen NAD+ als Energiequelle, um optimal zu arbeiten. Mit sinkendem NAD+-Spiegel im Alter nimmt die Aktivität der Sirtuine ab, was ihre Funktion beeinflusst.",
            "link": "",
            "open_in_new_window": false,
            "color_background_main": "rgba(0,0,0,0)",
            "color_text_main": "rgba(0,0,0,0)",
            "color_borders_main": "rgba(0,0,0,0)",
            "seo_h_tag": "h3"
          }
        }
