    "info_tabs_rPYne6": {
      "type": "info-tabs",
      "blocks": {
        "tab_aR8Gzq": {
          "type": "tab",
          "settings": {
            "title": "Warum NAD⁺ so wichtig ist",
            "caption": "<p>NAD⁺ ist in nahezu jeder Zelle vorhanden und spielt eine Rolle in zentralen Energieprozessen. Mit sinkenden NAD⁺-Spiegeln im Alter ist eine Ergänzung für viele Menschen interessant.</p>",
            "image": "shopify://shop_images/kategorie-struktur.jpg",
            "icon": "star"
          }
        },
        "tab_NCzrwj": {
          "type": "tab",
          "settings": {
            "title": "Warum Liposome entscheidend sind",
            "caption": "<p>NAD⁺ ist von Natur aus ein großes Molekül, das die Zellmembran schwer passieren kann. In liposomaler Form wird es in winzige Fettbläschen verpackt – so kann es besser geschützt, transportiert und vom Körper aufgenommen werden.</p>",
            "image": "shopify://shop_images/kategorie-struktur.jpg",
            "icon": "star"
          }
        },
        "tab_bJj4fc": {
          "type": "tab",
          "settings": {
            "title": "Wissenschaftlich fundiert",
            "caption": "<p>NAD⁺ wird in Studien im Zusammenhang mit Energiehaushalt, DNA-Reparatur und gesunden Alterungsprozessen untersucht. Der Booster basiert auf diesen Erkenntnissen – vegan, glutenfrei und laborgeprüft.</p>",
            "image": "shopify://shop_images/kategorie-struktur.jpg",
            "icon": "star"
          }
        }
      },
