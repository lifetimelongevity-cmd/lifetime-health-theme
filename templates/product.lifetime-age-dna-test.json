          "settings": {
            "title": "Gehöralter",
            "text": "<p>Das Gehöralter gibt dir Einblicke in die Funktion deiner Ohren und kann Hinweise auf altersbedingte Veränderungen im Hörvermögen bieten.</p>"
          }
        },
        "ingredient_BpFGcp": {
          "type": "ingredient",
          "settings": {
