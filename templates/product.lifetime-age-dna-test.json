    "1216687b-21ed-405b-a029-234fc77aa804": {
      "type": "ss-product-ingredients-2",
      "blocks": {
        "ingredient_w6PP66": {
          "type": "ingredient",
          "settings": {
            "title": "Gesundheit",
            "text": "<p>Der Test bietet Einblicke in deine genetischen Veranlagungen, einschließlich Aspekte wie Koffein-Empfindlichkeit. Diese Informationen können dir helfen, fundierte Entscheidungen für deinen Lebensstil zu treffen.</p>"
          }
        },
        "ingredient_Q3hW4Y": {
          "type": "ingredient",
          "settings": {
            "title": "Ernährung",
            "text": "<p>Erfahre mehr über deine individuellen Ernährungspräferenzen, wie die Vorliebe für süße oder bittere Geschmäcker, und erhalte Einblicke in deinen Stoffwechsel und die Verarbeitung von Proteinen sowie Fetten.</p>"
          }
        },
        "ingredient_FA9VQK": {
          "type": "ingredient",
          "settings": {
            "title": "Bewegung",
            "text": "<p>Erhalte Einblicke in deine körperliche Veranlagung und Leistungsfähigkeit, einschließlich Faktoren wie anaerobe Schwelle, Reaktion auf Bewegung, Entzündungsneigung, Verletzungsrisiko und Aufbau von Muskelmasse sowie Muskelkraft.</p>"
          }
        },
        "ingredient_tKGG4D": {
          "type": "ingredient",
          "settings": {
            "title": "Vitamine",
            "text": "<p>Erhalte detaillierte Einblicke in die genetische Veranlagung deines Körpers zur Verarbeitung wichtiger Vitamine und Mineralien wie Arginin, BCAAs, Kalzium, Folsäure, Eisen, Magnesium, Omega-3, und den Vitaminen A, B12 und D.</p>"
          }
        },
        "ingredient_DigiJc": {
          "type": "ingredient",
          "settings": {
            "title": "Anti-Aging",
            "text": "<p>Erhalte Einblicke in genetische Veranlagungen, die mit Alterserscheinungen wie Rückenschmerzen, kognitiven Veränderungen, Fitness, Knochendichte, Hautalterung und den Auswirkungen von Stress in Verbindung stehen.</p>"
          }
        },
        "ingredient_YwEfAi": {
          "type": "ingredient",
          "settings": {
            "title": "Stress",
            "text": "<p>Erhalte Einblicke in deine genetische Veranlagung zur Stressresistenz, einschließlich der Reaktion auf Koffein, Bewältigungsstrategien und potenzielle Auswirkungen auf Gedächtnis, Blutdruck, Herzgesundheit und körperliche Reaktionen.</p>"
          }
        },
        "ingredient_EbMDJE": {
          "type": "ingredient",
          "settings": {
            "title": "Schlaf",
            "text": "<p>Erhalte Einblicke in die genetische Veranlagung zur Wechselwirkung zwischen Koffein und Schlafqualität, einschließlich Schlafmuster, potenziellen Schlafstörungen, idealer Schlafdauer und dem Zusammenhang zwischen Stress und Schlaf.</p>"
          }
        },
        "ingredient_GQ4Rk7": {
          "type": "ingredient",
          "settings": {
            "title": "Mentale Gesundheit",
            "text": "<p>Erhalte Einblicke in genetische Faktoren, die deine mentale Leistungsfähigkeit beeinflussen könnten, einschließlich Aufmerksamkeit, Konzentration, Reaktion auf Koffein, Gedächtnismanagement, nächtliche Produktivität und Arbeitsgewohnheiten.</p>"
          }
        },
        "ingredient_aAdewT": {
          "type": "ingredient",
          "settings": {
            "title": "Entzündungen",
            "text": "<p>Erhalte Einblicke in genetische Faktoren, die deine Immunreaktionen und Entzündungsanfälligkeit beeinflussen könnten, einschließlich Darmgesundheit, Vitamin-E-Verarbeitung und PTPN22-Variationen, um informierte Entscheidungen für deine Gesundheit zu treffen.</p>"
          }
        },
        "ingredient_KdAxJd": {
          "type": "ingredient",
          "settings": {
            "title": "Stoffwechsel",
            "text": "<p>Erhalte Einblicke in genetische Veranlagungen für Typ-2-Diabetes und AMPD1-Mangel, um informierte Entscheidungen für deinen Lebensstil und deine Ernährung zu treffen.</p>"
          }
        },
        "ingredient_QPR9FM": {
          "type": "ingredient",
          "settings": {
            "title": "Darm",
            "text": "<p>Erfahre, wie deine genetische Veranlagung die Reaktion deines Darms auf Koffein, Gluten und Stress beeinflussen könnte, um deine Darmgesundheit zu optimieren.</p>"
          }
        },
        "ingredient_gJbLqf": {
          "type": "ingredient",
          "settings": {
            "title": "Haut",
            "text": "<p>Erhalte Einblicke in genetische Veranlagungen, die deine Hautreaktionen beeinflussen, um deine Hautpflege gezielt anzupassen.</p>"
          }
        },
        "ingredient_6ktthw": {
          "type": "ingredient",
          "settings": {
            "title": "Augen",
            "text": "<p>Erfahre mehr über genetische Faktoren, die deine Augengesundheit beeinflussen könnten, um vorbeugende Maßnahmen zu unterstützen.</p>"
          }
        },
        "ingredient_gktMXh": {
          "type": "ingredient",
          "settings": {
            "title": "Verletzungsrisiko",
            "text": "<p>Erhalte Einblicke in genetische Veranlagungen, die das Verletzungsrisiko beeinflussen könnten, um präventive Maßnahmen und Rehabilitationsstrategien zu verbessern.</p>"
          }
        },
        "ingredient_w4Qh9t": {
          "type": "ingredient",
          "settings": {
            "title": "Muskeln",
            "text": "<p>Entdecke genetische Faktoren, die deine Muskelleistung beeinflussen, um deine Trainings- und Ernährungspläne zu optimieren.</p>"
          }
        },
        "ingredient_ExeUhG": {
          "type": "ingredient",
          "settings": {
            "title": "Muskuloskelettale",
            "text": "<p>Erhalte Einblicke in genetische Veranlagungen für muskuloskelettale Erkrankungen, um gezielte Präventionsstrategien zu entwickeln.</p>"
          }
        }
      },
