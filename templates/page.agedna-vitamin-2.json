    "rich_text_QEAxMn": {
      "type": "rich-text",
      "blocks": {
        "title_ixyLKE": {
          "type": "title",
          "settings": {
            "title": "Entdecke, wie du jugendlich bleiben kannst – auch in stressigen Zeiten!",
