    "f66fcf17-bb28-4561-8b47-855842b66b2f": {
      "type": "content-toggles",
      "blocks": {
        "text_MYMtCq": {
          "type": "text",
          "settings": {
            "title": "Woraus besteht das Cell Renewal Bundle?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Aus liposomalen NAD+, Spermidin und Fisetin – kombiniert, um Energiegrundlage, Reinigungs-/Erneuerungsroutinen der Zellen und ein ausgeglichenes Zell-Milieu gemeinsam zu adressieren</p>",
            "hide_block_if": false
          }
        },
        "text_KqA4hY": {
          "type": "text",
          "disabled": true,
          "settings": {
            "title": "Warum sollte ich ein Abo wählen?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Viele <strong>körperliche Prozesse</strong> brauchen <strong>Regelmäßigkeit</strong>, damit sie sich sinnvoll einpendeln. Das Abo stellt die <strong>kontinuierliche Versorgung ohne Lücken</strong> sicher – so bleibt deine Routine verlässlich; den Rhythmus kannst du bei Bedarf flexibel anpassen oder pausieren.</p>",
            "hide_block_if": false
          }
        },
        "text_mVCA69": {
          "type": "text",
          "settings": {
            "title": "Wie dosiere ich das Cell Renewal Bundle richtig?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Bitte <strong>genau nach Etikett</strong> der einzelnen Produkte. Empfohlene Tagesmengen <strong>nicht überschreiten</strong>. Bei Medikamenten, Schwangerschaft/Stillzeit oder Vorerkrankungen: vorher ärztlich abklären.</p>",
            "hide_block_if": false
          }
        },
        "text_KrENMc": {
          "type": "text",
          "settings": {
            "title": "Wie sollte ich das Cell Renewal Bundle einnehmen?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Täglich zur <strong>gleichen Tageszeit</strong>; mit einer <strong>Mahlzeit</strong> meist gut verträglich. Wenn mehrere Kapseln/Portionen vorgesehen sind, kannst du sie über den Tag <strong>aufteilen</strong> – <strong>Konstanz</strong> ist wichtiger als die Uhrzeit.</p>",
            "hide_block_if": false
          }
        },
        "2bc8cf89-27d4-416b-a00a-753aba5bb68a": {
          "type": "text",
          "settings": {
            "title": "Wie sollte das Cell Renewal Bundle gelagert werden?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p><strong>Kühl, trocken, lichtgeschützt</strong> lagern, nach Entnahme <strong>gut verschließen</strong>, <strong>außer Reichweite von Kindern</strong> aufbewahren.</p>",
            "hide_block_if": false
          }
        },
        "text_eaKLir": {
          "type": "text",
          "settings": {
            "title": "Wie lange ist das Cell Renewal Bundle haltbar?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Das <strong>MHD</strong> steht auf jeder Verpackung. Nach dem Öffnen sachgerecht lagern und innerhalb der empfohlenen Zeit verbrauchen.</p>",
            "hide_block_if": false
          }
        }
      },
