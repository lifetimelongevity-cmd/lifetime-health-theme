            "title": "Nährstoffe",
            "icon": "none"
          }
        },
        "custom_HNAAFA": {
          "type": "custom",
          "settings": {
            "liquid": "<style id=\"lt-bundle-styles\">\n  #lt-bundle .product-section { margin: 1.5rem 0; }\n  #lt-bundle h2, #lt-bundle h3{\n    font-size: 1.25rem;\n    line-height: 1.35;\n    margin: 0 0 .5rem 0;\n    display: flex;\n    align-items: center;\n    gap: .5rem;\n    flex-wrap: wrap;\n  }\n  #lt-bundle h4{ margin: 1rem 0 .5rem; }\n  #lt-bundle .lt-badge{\n    border: 1px solid #E5E7EB;\n    background: #F9FAFB;\n    color: #374151;\n    border-radius: 999px;\n    padding: .18rem .55rem;\n    font-size: .8rem;\n    line-height: 1;\n  }\n  #lt-bundle .nutrition-table{\n    width: 100% !important;\n    border-collapse: collapse !important;\n    table-layout: fixed !important;\n    margin-top: .6rem;\n    font-size: .95rem;\n    display: table !important;\n  }\n  #lt-bundle .nutrition-table thead{ display: table-header-group !important; }\n  #lt-bundle .nutrition-table tbody{ display: table-row-group !important; }\n  #lt-bundle .nutrition-table tr{ display: table-row !important; }\n  #lt-bundle .nutrition-table th,\n  #lt-bundle .nutrition-table td{\n    display: table-cell !important;\n    border: 1px solid #D1D5DB !important;\n    padding: .5rem .7rem !important;\n    text-align: left !important;\n    vertical-align: middle !important;\n    white-space: nowrap;\n  }\n  #lt-bundle .nutrition-table thead th{\n    background: #F9FAFB;\n    font-weight: 600;\n  }\n  #lt-bundle .note{\n    margin-top: .6rem;\n    font-size: .9rem;\n    color: #6B7280;\n    background: #F9FAFB;\n    border: 1px solid #E5E7EB;\n    border-radius: .35rem;\n    padding: .45rem .6rem;\n  }\n  #lt-bundle .lt-divider{\n    border: 0;\n    border-top: 1px solid #E5E7EB;\n    margin: 1.25rem 0;\n  }\n  .rte #lt-bundle table,\n  .product__description #lt-bundle table{ display: table !important; }\n</style>\n\n<div id=\"lt-bundle\">\n\n  <section id=\"nmn\" class=\"product-section\">\n    <h3>NMN (Nicotinamid-Mononukleotid) <span class=\"lt-badge\">Pulver</span></h3>\n    <table aria-label=\"Spezifikation NMN\" class=\"nutrition-table\">\n      <tbody>\n        <tr>\n          <td>Inhalt</td>\n          <td>30&nbsp;g</td>\n        </tr>\n        <tr>\n          <td>Reinheit</td>\n          <td>&gt;99&nbsp;%</td>\n        </tr>\n      </tbody>\n    </table>\n    <p class=\"note\">Nur für Forschungszwecke. Nicht zum Verzehr bestimmt.</p>\n  </section>\n\n  <hr class=\"lt-divider\">\n\n  <section id=\"spermidin\" class=\"product-section\">\n    <h3>Spermidin (Weizenkeim-Extrakt) <span class=\"lt-badge\">Kapseln</span></h3>\n    <table aria-label=\"Nährwerte Spermidin\" class=\"nutrition-table\">\n      <thead>\n        <tr>\n          <th>Nährstoff</th>\n          <th>Pro Kapsel</th>\n          <th>2 Kapseln</th>\n        </tr>\n      </thead>\n      <tbody>\n        <tr>\n          <td>Spermidin</td>\n          <td>5&nbsp;mg</td>\n          <td>10&nbsp;mg</td>\n        </tr>\n      </tbody>\n    </table>\n  </section>\n\n  <hr class=\"lt-divider\">\n\n  <section id=\"fisetin\" class=\"product-section\">\n    <h3>Fisetin (Cotinus coggygria) <span class=\"lt-badge\">Kapseln</span></h3>\n    <table aria-label=\"Nährwerte Fisetin\" class=\"nutrition-table\">\n      <tbody>\n        <tr>\n          <td>Fisetin</td>\n          <td>250&nbsp;mg (&gt;98&nbsp;% Reinheit)</td>\n        </tr>\n      </tbody>\n    </table>\n  </section>\n</div>"
