          "type": "tip",
          "settings": {
            "title": "Etabliere einen festen Schlafrhythmus",
            "body": "<p>Versuche, jeden Tag zur gleichen Zeit ins Bett zu gehen und aufzustehen. Ein stabiler Rhythmus unterstützt deinen Stoffwechsel und verbessert die Schlafqualität.</p>",
            "link_label": "Quelle anzeigen",
            "link_url": "https://doi.org/10.2337/dc19-0596"
