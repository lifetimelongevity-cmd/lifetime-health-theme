    "content_toggles_TJVd7e": {
      "type": "content-toggles",
      "blocks": {
        "text_CNmhNh": {
          "type": "text",
          "settings": {
            "title": "Lifestyle-Kombination (biologisches Alter: -4,5 Jahre)",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Die Studie analysierte <a href=\"https://doi.org/10.18632/aging.204602\" target=\"_blank\" title=\"https://doi.org/10.18632/aging.204602\">Auswirkungen eines 8-wöchigen Programms auf das biologische Alter bei Frauen, das Diät, Schlaf, Bewegung und Entspannung umfasste</a>.</p><p>Konkrete Intervention: Ernährungsplan mit Probiotika und Phytonährstoffen, 7 Stunden Schlaf, 5 Tage pro Woche 30 Minuten Sport bei 60-80% Belastung und zweimal täglich Atemübungen.</p>",
            "hide_block_if": false
          }
        },
        "text_CYhPqA": {
          "type": "text",
          "settings": {
            "title": "Bewegung & Sport (biologisches Alter: -1,75 Jahre)",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Die Studie untersuchte den <a href=\"https://doi.org/10.1111/acel.13828\" target=\"_blank\" title=\"https://doi.org/10.1111/acel.13828\">Zusammenhang zwischen körperlicher Aktivität und epigenetischem Altern</a> bei 3.567 Teilnehmern.</p><p>Konkrete Intervention: Maßnahmen umfassten tägliche Schritte (8.800) oder moderate bis intensive körperliche Aktivität (15 Stunden pro Woche).</p>",
            "hide_block_if": false
          }
        },
        "text_HDG8Qd": {
          "type": "text",
          "settings": {
            "title": "Schlaf (biologisches Alter: -2,5 Jahre)",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Diese Studie untersuchte den <a href=\"https://doi.org/10.1186/s13104-019-4633-1\" target=\"_blank\" title=\"https://doi.org/10.1186/s13104-019-4633-1\">Einfluss von Schlafdauer und -muster auf das epigenetische Altern</a>.</p><p>Konkrete Intervention: Teilnehmer mit mehr als 8h Schlaf und regelmäßigem Rhythmus alterten langsamer. Weniger als 6 Stunden Schlaf und unregelmäßige Muster erhöhten das biologische Alter (+ 3 Jahre).</p>",
            "hide_block_if": false
          }
        },
        "text_VhLbEL": {
          "type": "text",
          "settings": {
            "title": "Entspannungstraining (biologisches Alter: -4,7 Jahre)",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Die Studie untersuchte, ob <a href=\"https://doi.org/10.3390/ijerph16173074\" target=\"_blank\" title=\"https://doi.org/10.3390/ijerph16173074\">intensives Entspannungstraining das biologische Alter senken kann</a>.</p><p>Konkrete Intervention: Teilnehmer führten 60 Tage lang zweimal täglich 20-minütige Entspannungsübungen durch.</p>",
            "hide_block_if": false
          }
        },
        "text_MwCQaH": {
          "type": "text",
          "settings": {
            "title": "Vitamin D3-Ergänzung (biologisches Alter: -1,9 Jahre)",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Diese Studie untersuchte, ob <a href=\"https://doi.org/10.1093/gerona/gly223\" target=\"_blank\" title=\"https://doi.org/10.1093/gerona/gly223\">Vitamin-D3-Ergänzungen das epigenetische Altern bei übergewichtigen und adipösen Menschen verlangsamen kann</a>.</p><p>Konkrete Intervention: Teilnehmer nahmen täglich 4.000 IU (100 µg) Vitamin D3 ein.</p>",
            "hide_block_if": false
          }
        },
        "text_tbAwg9": {
          "type": "text",
          "settings": {
            "title": "Mittelmeer-Diät (biologisches Alter: -1,5 Jahre)",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p><a href=\"https://doi.org/10.1007/s11357-019-00149-0\" target=\"_blank\" title=\"https://doi.org/10.1007/s11357-019-00149-0\">Auswirkungen einer einjährigen Mittelmeerdiät auf epigenetische Altersmarker</a> wurden untersucht.</p><p>Konkrete Intervention: Die Diät umfasste pflanzliche Lebensmittel, gesunde Fette (Olivenöl), moderate Mengen an Fisch, Geflügel und Milchprodukten sowie wenig rotes Fleisch und verarbeitete Lebensmittel.</p>",
            "hide_block_if": false
          }
        }
      },
