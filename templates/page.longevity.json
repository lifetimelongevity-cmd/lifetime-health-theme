        },
        "tip_3": {
          "type": "tip",
          "settings": {
            "title": "Meide Bildschirme vor dem Schlafengehen",
            "body": "<p>Blaues Licht kann die Melatoninproduktion hemmen. Schalte elektronische Geräte mindestens 30 Minuten vor dem Schlafengehen aus.</p>",
            "link_label": "Quelle anzeigen",
            "link_url": "https://doi.org/10.3389/fphys.2022.943108"
          }
