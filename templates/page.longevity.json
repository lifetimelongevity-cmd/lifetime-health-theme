        },
        "tip_2": {
          "type": "tip",
          "settings": {
            "title": "Schlafe 7-9 Stunden pro Nacht",
            "body": "<p>Die meisten Erwachsenen profitieren von mindestens sieben Stunden Schlaf. Die individuelle ideale Dauer hängt von Alter, Alltag und Aktivitätsniveau ab.</p>",
            "link_label": "Quelle anzeigen",
            "link_url": "https://doi.org/10.5664/jcsm.4758"
