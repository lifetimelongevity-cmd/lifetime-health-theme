    "custom_liquid_dWWjEe": {
      "type": "custom-liquid",
      "name": "t:sections.refactor_words.custom_code.name",
      "settings": {
        "heading": "",
        "subheading": "",
        "section_heading_size": "text-size--regular",
        "section_heading_layout": "section-heading--left section-heading--one-row",
        "cta_label": "",
        "cta_url": "",
        "custom_liquid": "<style>\n  /* === CSS Custom Properties === */\n  .custom-partners {\n    --mint: #65C0B6;\n    --primary: #4A8C85;\n    --dark: #364F56;\n    --black: #0B0F12;\n    --bg-light: #FAFAFA;\n    --bg-warm: #F6F4F1;\n    --warm-accent: #C7A39B;\n    --text-muted: rgba(11, 15, 18, 0.6);\n\n    background: var(--black);\n    /* Padding reduziert, um die größere Logo-Höhe auszugleichen und die Section-Höhe beizubehalten */\n    padding: 12px 0;\n    overflow: hidden;\n    position: relative;\n  }\n\n  /* === Typography === */\n  .custom-partners__label {\n    font-family: 'Lato', 'Segoe UI', sans-serif;\n    font-size: 11px;\n    font-weight: 600;\n    text-transform: uppercase;\n    letter-spacing: 0.1em;\n    color: rgba(255, 255, 255, 0.4);\n    text-align: center;\n    /* Margin reduziert, um Platz für größere Logos zu schaffen */\n    margin-bottom: 40px;\n  }\n\n  /* === Ticker Track === */\n  .custom-partners__track-wrap {\n    position: relative;\n    display: flex;\n    width: 100%;\n  }\n\n  /* Verläufe an den Rändern für weiches Ein-/Ausblenden */\n  .custom-partners__track-wrap::before,\n  .custom-partners__track-wrap::after {\n    content: \"\";\n    position: absolute;\n    top: 0;\n    bottom: 0;\n    width: 60px;\n    z-index: 2;\n    pointer-events: none;\n  }\n\n  .custom-partners__track-wrap::before {\n    left: 0;\n    background: linear-gradient(to right, var(--black), transparent);\n  }\n\n  .custom-partners__track-wrap::after {\n    right: 0;\n    background: linear-gradient(to left, var(--black), transparent);\n  }\n\n  .custom-partners__track {\n    display: flex;\n    align-items: center;\n    width: max-content;\n    animation: customPartnersScroll 20s linear infinite;\n    will-change: transform;\n  }\n\n  .custom-partners__track:hover {\n    animation-play-state: paused;\n  }\n\n  @keyframes customPartnersScroll {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(calc(-100% / 3)); }\n  }\n\n  /* === Logo Items === */\n  .custom-partners__item {\n    flex-shrink: 0;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    padding: 0 40px;\n  }\n\n  .custom-partners__item img {\n    /* Logo-Höhe verdoppelt (vorher 22px) */\n    height: 44px;\n    width: auto;\n    object-fit: contain;\n    /* WICHTIG: filter: invert(1) wandelt die hochgeladenen dunklen Logos in weiße Logos um */\n    filter: invert(1) opacity(1);\n    transition: filter 0.3s ease, transform 0.3s ease;\n  }\n\n  .custom-partners__item:hover img {\n    filter: invert(1) opacity(1);\n    transform: scale(1.1);\n  }\n\n  /* === Desktop Adjustments === */\n  @media (min-width: 768px) {\n    .custom-partners { \n      /* Padding angepasst, um die Gesamthöhe der Section bei größeren Logos konstant zu halten */\n      padding: 30px 0; \n    }\n    .custom-partners__item { \n      padding: 0 60px; \n    }\n    .custom-partners__item img { \n      /* Logo-Höhe verdoppelt (vorher 28px) */\n      height: 56px; \n    }\n    .custom-partners__track-wrap::before,\n    .custom-partners__track-wrap::after {\n      width: 100px;\n    }\n  }\n</style>\n\n<section class=\"custom-partners\" aria-label=\"Unser Partnernetzwerk\">\n  <div class=\"custom-partners__label\">Unser Partnernetzwerk</div>\n  \n  <div class=\"custom-partners__track-wrap\">\n    <div class=\"custom-partners__track\" id=\"customPartnersTrack\">\n      \n      <!-- HINWEIS: Stelle sicher, dass die Bilder im Shopify Admin unter \"Inhalte -> Dateien\" hochgeladen sind -->\n      \n      <div class=\"custom-partners__item\">\n        <img src=\"{{ 'Group_40795.png' | file_url }}\" alt=\"Kliniken Köln\" loading=\"lazy\">\n      </div>\n      \n      <div class=\"custom-partners__item\">\n        <img src=\"{{ 'Group_40792_3a1522ab-6246-4c2c-ba85-3527428080c9.png' | file_url }}\" alt=\"illumina\" loading=\"lazy\">\n      </div>\n      \n      <div class=\"custom-partners__item\">\n        <img src=\"{{ 'Group_40793.png' | file_url }}\" alt=\"eurofins\" loading=\"lazy\">\n      </div>\n\n    </div>\n  </div>\n</section>\n\n<script>\n  (function() {\n    const track = document.getElementById('customPartnersTrack');\n    if (!track) return;\n    \n    // Speichere die originalen Logos\n    const originalItems = Array.from(track.children);\n    \n    // Klone die Logos zweimal für einen nahtlosen Loop auf allen Bildschirmgrößen.\n    // aria-hidden wird gesetzt, damit Screenreader die Logos nicht dreifach vorlesen.\n    \n    // Set 2 (Kopie 1)\n    originalItems.forEach(item => {\n      const clone = item.cloneNode(true);\n      clone.setAttribute('aria-hidden', 'true');\n      track.appendChild(clone);\n    });\n\n    // Set 3 (Kopie 2)\n    originalItems.forEach(item => {\n      const clone = item.cloneNode(true);\n      clone.setAttribute('aria-hidden', 'true');\n      track.appendChild(clone);\n    });\n  })();\n</script>",
        "full_width": true,
        "remove_margin": false,
        "seo_h_tag": "h2"
      }
    },
