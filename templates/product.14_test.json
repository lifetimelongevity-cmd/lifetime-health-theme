        "rev_t1": {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "Das Ergebnis hat mich wirklich überrascht. Mein biologisches Alter lag 6 Jahre unter meinem tatsächlichen Alter – das war der beste Motivationsboost, den ich mir vorstellen konnte.",
            "name": "Katrin B.",
