gin: 0 0 4px 0;\n  }\n\n  .custom-prod-header__category {\n    font-size: 13px;\n    font-weight: 400;\n    font-style: italic;\n    color: var(--text-light);\n    margin: 0 0 12px 0;\n    display: block;\n  }\n\n  /* === 2. Summary / Value Proposition === */\n  .custom-prod-header__summary {\n    font-size: 15px;\n    font-weight: 400;\n    color: var(--text-muted);\n    margin: 0 0 24px 0;\n  }\n\n  /* === 3. Preis-Bereich === */\n  .custom-prod-header__price-row {\n    display: flex;\n    align-items: center;\n    flex-wrap: wrap;\n    gap: 10px;\n    margin-bottom: 6px;\n  }\n\n  .custom-prod-header__price-current {\n    font-family: var(--font-heading);\n    font-size: clamp(24px, 5vw, 28px);\n    font-weight: 700;\n    color: var(--text-main);\n    letter-spacing: -0.02em;\n    line-height: 1.1;\n  }\n\n  .custom-prod-header__price-old {\n    font-size: 14px;\n    font-weight: 400;\n    color: var(--text-light);\n    text-decoration: line-through;\n  }\n\n  .custom-prod-header__badge {\n    background-color: var(--accent-teal-light);\n    color: var(--accent-teal);\n    font-size: 13px;\n    font-weight: 600;\n    padding: 4px 12px;\n    border-radius: 999px;\n    text-transform: uppercase;\n    letter-spacing: 0.05em;\n  }\n\n  .custom-prod-header__price-subtitle {\n    font-size: 13px;\n    font-weight: 600;\n    color: var(--accent-teal);\n    display: block;\n    margin: 0 0 0 0;\n  }\n</style>\n\n<section class=\"custom-prod-header\" aria-label=\"Produkt Header\">\n  <div class=\"custom-prod-header__container\">\n    \n    <!-- 1. Produktname (Dynamisch via Liquid mit Fallback) -->\n    <h1 class=\"custom-prod-header__title\">\n      {{ product.title | default: 'AGE & DNA-Test' }}\n    </h1>\n\n    <!-- Kategorie-Label (Statisch oder via Metafield, hier statisch als Fallback) -->\n    <span class=\"custom-prod-header__category\">\n      <!-- ANPASSEN: Kategorie Text -->\n      Epigenetische & genetische Laboranalyse\n    </span>\n\n    <!-- 2. Value Proposition / Summary -->\n    <p class=\"custom-prod-header__summary\">\n      <!-- ANPASSEN: Summary Text -->\n      Altert dein Körper schneller als du denkst? Finde es heraus – mit deinem biologischen Alter, 187 DNA-Reports und einem persönlichen KI Health Coach.\n    </p>\n\n    <!-- 3. Preis-Bereich (Dynamisch via Liquid) -->\n    <div class=\"custom-prod-header__price-row\">\n      \n      <!-- Aktueller Preis -->\n      <span class=\"custom-prod-header__price-current\">\n        {% if product != blank %}\n          {{ product.price | money }}\n        {% else %}\n          349,00 €\n        {% endif %}\n      </span>\n\n      <!-- Streichpreis & Spar-Badge (Nur anzeigen, wenn ein Vergleichspreis existiert) -->\n      {% if product.compare_at_price > product.price or product == blank %}\n        <span class=\"custom-prod-header__price-old\">\n          {% if product != blank %}\n            {{ product.compare_at_price | money }}\n          {% else %}\n            399,00 €\n          {% endif %}\n        </span>\n        \n        <span class=\"custom-prod-header__badge\">\n          {% if product != blank %}\n            {% assign savings = product.compare_at_price | minus: product.price %}\n            Spare {{ savings | money_without_trailing_zeros }}\n          {% else %}\n            Spare 50 €\n          {% endif %}\n        </span>\n      {% endif %}\n\n    </div>\n\n    <!-- Preis-Zusatzinfo -->\n    <span class=\"custom-prod-header__price-subtitle\">\n      <!-- ANPASSEN: Zusatzinfo unter dem Preis -->\n      Inkl. AI Health Coach + FaceScan\n    </span>\n\n  </div>\n</section>"
