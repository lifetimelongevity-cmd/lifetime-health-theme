            "custom_liquid": "<style>\n  /* === CSS Custom Properties === */\n  .custom-trust-wrapper {\n    /* Theme Colors */\n    --mint: #65C0B6;\n    --primary: #4A8C85;\n    --dark: #364F56;\n    --black: #0B0F12;\n    --bg-light: #FAFAFA;\n    --bg-warm: #F6F4F1;\n    --warm-accent: #C7A39B;\n    \n    /* Section Specific Colors */\n    --text-main: #1A1A1A;\n    --text-muted: #777777;\n    --accent-teal: #0A8A6A;\n    --bg-trust: #F7F7F7;\n    --border-color: #E5E5E5;\n    \n    /* Typography */\n    --font-heading: Helvetica, Arial, sans-serif;\n    --font-body: 'Lato', 'Segoe UI', sans-serif;\n\n    width: 100%;\n    margin-bottom: 24px;\n    display: flex;\n    flex-direction: column;\n    gap: 8px;\n  }\n\n  /* === Shipping Info Bar === */\n  .custom-shipping-bar {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n    background-color: var(--bg-trust);\n    border-radius: 8px;\n    padding: 12px 16px;\n    text-align: center;\n  }\n\n  /* Pulsierender Punkt */\n  @keyframes customPulseDot {\n    0% {\n      transform: scale(0.95);\n      box-shadow: 0 0 0 0 rgba(10, 138, 106, 0.7);\n    }\n    70% {\n      transform: scale(1);\n      box-shadow: 0 0 0 6px rgba(10, 138, 106, 0);\n    }\n    100% {\n      transform: scale(0.95);\n      box-shadow: 0 0 0 0 rgba(10, 138, 106, 0);\n    }\n  }\n\n  .custom-shipping-bar__dot {\n    width: 10px;\n    height: 10px;\n    background-color: var(--accent-teal);\n    border-radius: 50%;\n    margin-right: 12px;\n    flex-shrink: 0;\n    animation: customPulseDot 2s infinite;\n  }\n\n  .custom-shipping-bar__text {\n    font-family: var(--font-body);\n    font-size: 14px;\n    font-weight: 400;\n    color: var(--text-main);\n    line-height: 1.4;\n  }\n\n  .custom-shipping-bar__date {\n    font-family: var(--font-heading);\n    font-weight: 700;\n    color: var(--accent-teal);\n    letter-spacing: -0.01em;\n  }\n\n  /* === Trust Bar Layout === */\n  .custom-trust-bar__container {\n    display: grid;\n    grid-template-columns: repeat(3, 1fr);\n    background-color: var(--bg-trust);\n    border-radius: 8px;\n    padding: 14px 12px;\n  }\n\n  /* === Column Items === */\n  .custom-trust-bar__item {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    text-align: center;\n    position: relative;\n    padding: 0 6px;\n  }\n\n  /* Vertikale Trennlinien */\n  .custom-trust-bar__item:not(:last-child)::after {\n    content: '';\n    position: absolute;\n    right: 0;\n    top: 10%;\n    height: 80%;\n    width: 1px;\n    background-color: var(--border-color);\n  }\n\n  /* === Icons (Filigran & Modern) === */\n  .custom-trust-bar__icon {\n    width: 22px;\n    height: 22px;\n    color: var(--accent-teal);\n    margin-bottom: 8px;\n    display: flex;\n    align-items: center;\n    justify-content: center;\n  }\n\n  .custom-trust-bar__icon svg {\n    width: 100%;\n    height: 100%;\n    stroke-width: 1.25;\n    stroke: currentColor;\n    fill: none;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* === Typography === */\n  .custom-trust-bar__title {\n    font-family: var(--font-heading);\n    font-size: 13px;\n    font-weight: 400;\n    color: var(--text-main);\n    line-height: 1.3;\n    margin-bottom: 2px;\n    letter-spacing: -0.01em;\n  }\n\n  .custom-trust-bar__desc {\n    font-family: var(--font-body);\n    font-size: 12px;\n    font-weight: 400;\n    color: var(--text-muted);\n    line-height: 1.3;\n  }\n\n  /* === Responsive === */\n  @media (max-width: 767px) {\n    .custom-shipping-bar__text {\n      font-size: 13px;\n    }\n  }\n</style>\n\n<section class=\"custom-trust-wrapper\" aria-label=\"Versandinformationen und Vertrauenssignale\">\n  \n  <!-- Shipping Info -->\n  <div class=\"custom-shipping-bar\">\n    <div class=\"custom-shipping-bar__dot\" aria-hidden=\"true\"></div>\n    <span class=\"custom-shipping-bar__text\">\n      <!-- ANPASSEN: Text vor dem Datum -->\n      Versand bis: <span class=\"custom-shipping-bar__date js-custom-shipping-date\">wird berechnet...</span>\n    </span>\n  </div>\n\n  <!-- Trust Bar -->\n  <div class=\"custom-trust-bar__container\">\n    <!-- Spalte 1: DSGVO -->\n    <div class=\"custom-trust-bar__item\">\n      <div class=\"custom-trust-bar__icon\" aria-hidden=\"true\">\n        <svg viewBox=\"0 0 24 24\">\n          <path d=\"M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z\"></path>\n          <path d=\"M9 12l2 2 4-4\"></path>\n        </svg>\n      </div>\n      <strong class=\"custom-trust-bar__title\">DSGVO-konform</strong>\n      <span class=\"custom-trust-bar__desc\"></span>\n    </div>\n\n    <!-- Spalte 2: Labor/Science (DNA Icon) -->\n    <div class=\"custom-trust-bar__item\">\n      <div class=\"custom-trust-bar__icon\" aria-hidden=\"true\">\n        <svg viewBox=\"0 0 24 24\">\n          <path d=\"M15 2v2\"></path>\n          <path d=\"M9 2v2\"></path>\n          <path d=\"M15 20v2\"></path>\n          <path d=\"M9 20v2\"></path>\n          <path d=\"M15 4c0 4.418-6 3.582-6 8s6 3.582 6 8\"></path>\n          <path d=\"M9 4c0 4.418 6 3.582 6 8s-6 3.582-6 8\"></path>\n          <line x1=\"10\" y1=\"6\" x2=\"14\" y2=\"6\"></line>\n          <line x1=\"10\" y1=\"18\" x2=\"14\" y2=\"18\"></line>\n          <line x1=\"9\" y1=\"10\" x2=\"15\" y2=\"10\"></line>\n          <line x1=\"9\" y1=\"14\" x2=\"15\" y2=\"14\"></line>\n        </svg>\n      </div>\n      <strong class=\"custom-trust-bar__title\">Eurofins Laboranalyse</strong>\n      <span class=\"custom-trust-bar__desc\"></span>\n    </div>\n\n    <!-- Spalte 3: Laborversand (Erlenmeyerkolben Icon) -->\n    <div class=\"custom-trust-bar__item\">\n      <div class=\"custom-trust-bar__icon\" aria-hidden=\"true\">\n        <svg viewBox=\"0 0 24 24\">\n          <path d=\"M9 2v6.5L4.15 18a2 2 0 0 0 1.73 3h12.24a2 2 0 0 0 1.73-3L15 8.5V2\"></path>\n          <path d=\"M8 2h8\"></path>\n          <path d=\"M6 15h12\"></path>\n          <path d=\"M10 19v.01\"></path>\n          <path d=\"M13 18v.01\"></path>\n        </svg>\n      </div>\n      <strong class=\"custom-trust-bar__title\">Kostenfreier Laborversand</strong>\n      <span class=\"custom-trust-bar__desc\"></span>\n    </div>\n  </div>\n\n</section>\n\n<script>\n  (function(){\n    // JS wird genutzt, um Shopify-Caching-Probleme beim Datum zu umgehen\n    const dateSpan = document.querySelector('.js-custom-shipping-date');\n    if (!dateSpan) return;\n    \n    // Arrays für exakte deutsche Formatierung (unabhängig von Browser-Locales)\n    const days = ['So.', 'Mo.', 'Di.', 'Mi.', 'Do.', 'Fr.', 'Sa.'];\n    const months = ['Januar', 'Februar', 'März', 'April', 'Mai', 'Juni', 'Juli', 'August', 'September', 'Oktober', 'November', 'Dezember'];\n    \n    // Datum für morgen berechnen (+1 Tag)\n    const tomorrow = new Date();\n    tomorrow.setDate(tomorrow.getDate() + 1);\n    \n    // Formatierung zusammensetzen (z.B. \"Do., 5. März\")\n    const dayOfWeek = days[tomorrow.getDay()];\n    const dayOfMonth = tomorrow.getDate();\n    const month = months[tomorrow.getMonth()];\n    \n    dateSpan.textContent = `${dayOfWeek}, ${dayOfMonth}. ${month}`;\n  })();\n</script>"
