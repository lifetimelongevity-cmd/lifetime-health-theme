          "type": "candidate",
          "settings": {
            "candidate_description": "Du willst eine biologische Baseline, bevor du mit einem Longevity-Protokoll anfängst. Nicht nach Gefühl optimieren, sondern nach Daten."
          }
        },
        "candidate_2": {
          "type": "candidate",
          "settings": {
            "candidate_description": "Du nimmst bereits Supplements und willst wissen, welche genetisch zu dir passen — und welche du dir sparen kannst. Analysiert werden u. a. NMN, Kreatin, Omega-3 und Vitamin D."
          }
        },
        "candidate_3": {
          "type": "candidate",
          "settings": {
            "candidate_description": "Du hast das Gefühl, dass dein Körper anders altert als dein Pass vermuten lässt. In die eine oder andere Richtung. Du willst es wissen, nicht vermuten."
          }
        },
        "candidate_4": {
          "type": "candidate",
          "settings": {
            "candidate_description": "Du machst regelmäßig Blutbilder beim Hausarzt und willst die Ebene hinzufügen, die dein Arzt nicht misst: wie dein Lebensstil heute in deinen Zellen ankommt."
          }
        },
        "candidate_5": {
          "type": "candidate",
          "settings": {
            "candidate_description": "Du willst einen Gesundheitscheck, der in 6 Monaten wiederholbar ist. Kein einmaliger Schnappschuss, sondern ein Werkzeug, das Veränderung messbar macht."
          }
        },
