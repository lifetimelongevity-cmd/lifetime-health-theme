          }
        },
        "rev_t2": {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "Die DNA-Reports zu Schlaf, Ernährung und Sport sind unglaublich präzise. Ich wusste schon immer, dass Kohlenhydrate bei mir anders wirken – jetzt habe ich den Beweis.",
            "name": "Felix S.",
            "verified": true,
            "date": "Februar 2025"
          }
        },
        "rev_t3": {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "Einfachster Test, den ich je gemacht habe. Abstrich, einsenden, 4 Wochen warten, App öffnen – und dann eine Stunde lesen. Der AI Health Coach ist das Sahnehäubchen.",
            "name": "Laura M.",
            "verified": true,
            "date": "Januar 2025"
          }
        },
        "rev_t4": {
          "type": "review",
          "settings": {
            "rating": 4,
            "text": "Sehr detaillierte Auswertung, gut erklärt und ohne übertriebene Versprechen. Ich bin 61 und froh, endlich zu verstehen, warum bestimmte Diäten bei mir nie funktioniert haben.",
            "name": "Gerhard K.",
            "verified": true,
            "date": "Dezember 2024"
          }
        },
        "rev_t5": {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "Haben den Test als Paar gemacht. Die Unterschiede in unseren Ergebnissen waren faszinierend – und haben uns dazu gebracht, unsere gemeinsame Ernährung zu überdenken.",
            "name": "Sandra & Thomas W.",
            "verified": true,
            "date": "November 2024"
          }
        },
        "rev_t6": {
          "type": "review",
          "settings": {
            "rating": 5,
            "text": "Mein Arzt war beeindruckt, als ich die Ergebnisse mitgebracht habe. Die Tiefe der Analyse geht weit über das hinaus, was eine normale Blutuntersuchung liefert.",
            "name": "Dr. med. A. Hoffmann",
