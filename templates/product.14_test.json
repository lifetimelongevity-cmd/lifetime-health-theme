            "custom_liquid": "{% assign rating = product.metafields.loox.avg_rating | default: 0 | plus: 0 %}\n{% assign rating_count = product.metafields.loox.num_reviews | default: 0 | plus: 0 %}\n\n{% if rating_count > 0 and rating > 0 %}\n  {%- comment -%}Text: 1 Nachkommastelle + deutsches Komma{%- endcomment -%}\n  {% assign rating_text = rating | round: 1 | replace: '.', ',' %}\n\n  {%- comment -%}\n    Sterne: auf 0.0 / 0.5 / 1.0 runden, damit keine unsauberen Schnittkanten entstehen\n  {%- endcomment -%}\n  {% assign decimal = rating | modulo: 1 %}\n  {% assign rounded = rating | floor %}\n  {% if decimal >= 0.3 and decimal <= 0.7 %}\n    {% assign rounded = rounded | plus: 0.5 %}\n  {% elsif decimal > 0.7 %}\n    {% assign rounded = rounded | plus: 1 %}\n  {% endif %}\n  {% assign pct = rounded | times: 20 %}\n\n  {% assign star_color = '%23FFCC00' %}\n  {% assign bg_color = '%23E6E6E6' %}\n\n  <style>\n    .custom-rating-wrapper{\n      margin-top:-65px;\n      display:block;\n      text-decoration:none;\n      color:inherit;\n      cursor:pointer;\n    }\n    @media (max-width:767px){\n      .custom-rating-wrapper{ margin-top:-30px; }\n    }\n    .custom-rating-row{\n      display:flex;\n      align-items:center;\n      gap:.5rem;\n    }\n    .custom-stars{\n      position:relative;\n      display:inline-block;\n      width:100px;\n      height:14px;\n      background-image:url(\"data:image/svg+xml;utf8,<svg width='20' height='14' viewBox='0 0 14 13' xmlns='http://www.w3.org/2000/svg'><path d='m7 0 1.572 4.837h5.085l-4.114 2.99 1.572 4.836L7 9.673l-4.114 2.99 1.571-4.837-4.114-2.99h5.085L7 0Z' fill='{{ bg_color }}'/></svg>\");\n      background-repeat:repeat-x;\n      background-size:20px 14px;\n    }\n    .custom-stars-active{\n      position:absolute;\n      left:0; top:0;\n      height:14px;\n      width:{{ pct }}%;\n      overflow:hidden;\n    }\n    .custom-stars-active::before{\n      content:\"\";\n      position:absolute;\n      left:0; top:0;\n 