            "custom_liquid": "<style>\n  /* === CSS Custom Properties === */\n  .custom-benefit-list {\n    /* Farben */\n    --mint: #65C0B6;\n    --text-muted: #555555; \n\n    /* Basis-Styling */\n    width: 100%;\n    padding: 16px 0; \n    background-color: transparent;\n  }\n\n  /* === Container === */\n  .custom-benefit-list__container {\n    display: flex;\n    flex-direction: column;\n  }\n\n  /* === Liste === */\n  .custom-benefit-list__items {\n    list-style: none;\n    padding: 0;\n    margin: 0;\n    display: flex;\n    flex-direction: column;\n    gap: 12px; \n  }\n\n  /* === Listenpunkt === */\n  .custom-benefit-list__item {\n    display: flex;\n    align-items: center; /* Exakt vertikal zentriert */\n    gap: 12px;\n    opacity: 0;\n    animation: customBenefitFadeUp 0.5s ease forwards;\n    animation-play-state: paused;\n  }\n\n  /* Staggering der Animation */\n  .custom-benefit-list__item:nth-child(1) { animation-delay: 0.1s; }\n  .custom-benefit-list__item:nth-child(2) { animation-delay: 0.2s; }\n  .custom-benefit-list__item:nth-child(3) { animation-delay: 0.3s; }\n  .custom-benefit-list__item:nth-child(4) { animation-delay: 0.4s; }\n  .custom-benefit-list__item:nth-child(5) { animation-delay: 0.5s; }\n\n  .custom-benefit-list.is-visible .custom-benefit-list__item {\n    animation-play-state: running;\n  }\n\n  /* === Icon (Checkmark) === */\n  .custom-benefit-list__icon {\n    width: 18px; /* Exakt wie in der Referenz */\n    height: 18px;\n    border-radius: 50%;\n    background-color: #65C0B6; /* Gewünschte Akzentfarbe */\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    flex-shrink: 0;\n    color: #FFFFFF;\n  }\n\n  /* Häkchen minimal größer und weich abgerundet */\n  .custom-benefit-list__icon svg {\n    width: 15px; /* Minimal größer als vorher (füllt den 22px Kreis besser aus) */\n    height: 15px;\n    stroke-width: 2.5px;\n    stroke: currentColor;\n    fill: none;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* === Text === */\n  .custom-benefit-list__text {\n    font-family: 'Lato', 'Segoe UI', sans-serif;\n    font-weight: 400;\n    font-size: 15px; \n    line-height: 1.4;\n    color: var(--text-muted); \n    margin: 0;\n  }\n\n  /* === Keyframes === */\n  @keyframes customBenefitFadeUp {\n    from {\n      opacity: 0;\n      transform: translateY(10px);\n    }\n    to {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n</style>\n\n<section class=\"custom-benefit-list\" aria-label=\"Feature Benefits\">\n  <div class=\"custom-benefit-list__container\">\n    <ul class=\"custom-benefit-list__items\">\n      \n      <!-- Punkt 1 -->\n      <li class=\"custom-benefit-list__item\">\n        <div class=\"custom-benefit-list__icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\">\n            <polyline points=\"20 6 9 17 4 12\"></polyline>\n          </svg>\n        </div>\n        <span class=\"custom-benefit-list__text\">\n          187 personalisierte DNA-Reports zu Ernährung, Fitness & Gesundheit\n        </span>\n      </li>\n\n      <!-- Punkt 2 -->\n      <li class=\"custom-benefit-list__item\">\n        <div class=\"custom-benefit-list__icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\">\n            <polyline points=\"20 6 9 17 4 12\"></polyline>\n          </svg>\n        </div>\n        <span class=\"custom-benefit-list__text\">\n          Dein biologisches Alter – basierend auf epigenetischen Markern\n        </span>\n      </li>\n\n      <!-- Punkt 3 -->\n      <li class=\"custom-benefit-list__item\">\n        <div class=\"custom-benefit-list__icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\">\n            <polyline points=\"20 6 9 17 4 12\"></polyline>\n          </svg>\n        </div>\n        <span class=\"custom-benefit-list__text\">\n          Persönlicher KI Health Coach mit konkreten Empfehlungen\n        </span>\n      </li>\n\n      <!-- Punkt 4 -->\n      <li class=\"custom-benefit-list__item\">\n        <div class=\"custom-benefit-list__icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\">\n            <polyline points=\"20 6 9 17 4 12\"></polyline>\n          </svg>\n        </div>\n        <span class=\"custom-benefit-list__text\">\n          Einfache Speichelprobe für Zuhause – Laboranalyse bei Eurofins\n        </span>\n      </li>\n\n      <!-- Punkt 5 -->\n      <li class=\"custom-benefit-list__item\">\n        <div class=\"custom-benefit-list__icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\">\n            <polyline points=\"20 6 9 17 4 12\"></polyline>\n          </svg>\n        </div>\n        <span class=\"custom-benefit-list__text\">\n          Retest nach 6 Monaten zeigt deinen Fortschritt\n        </span>\n      </li>\n\n    </ul>\n  </div>\n</section>\n\n<script>\n  (function() {\n    const observer = new IntersectionObserver((entries) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          entry.target.classList.add('is-visible');\n          observer.unobserve(entry.target);\n        }\n      });\n    }, { \n      threshold: 0.1,\n      rootMargin: \"0px 0px -20px 0px\"\n    });\n\n    const section = document.querySelector('.custom-benefit-list');\n    if (section) {\n      observer.observe(section);\n    }\n  })();\n</script>"
