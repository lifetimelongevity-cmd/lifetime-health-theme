          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n  /* === CSS Custom Properties === */\n  .custom-feature-cards {\n    /* Farben */\n    --mint: #65C0B6;\n    --bg-card: #F7F7F7;\n    --text-muted: #444444;\n    --text-main: #1A1A1A;\n\n    /* Basis-Styling */\n    width: 100%;\n    padding: 16px 0; \n    background-color: transparent;\n  }\n\n  /* === Container === */\n  .custom-feature-cards__container {\n    display: flex;\n    flex-direction: column;\n  }\n\n  /* === Überschrift === */\n  .custom-feature-cards__title {\n    font-family: Helvetica, Arial, sans-serif;\n    font-weight: 700;\n    font-size: 18px;\n    color: #1A1A1A;\n    letter-spacing: -0.02em;\n    line-height: 1.2;\n    margin: 0 0 14px 0;\n  }\n\n  /* === Liste === */\n  .custom-feature-cards__items {\n    list-style: none;\n    padding: 0;\n    margin: 0;\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n  }\n\n  /* === Card (Listenpunkt) === */\n  .custom-feature-cards__item {\n    display: flex;\n    align-items: center;\n    background-color: var(--bg-card);\n    border-radius: 10px;\n    padding: 14px;\n    gap: 14px;\n    opacity: 0;\n    animation: customCardFadeUp 0.5s ease forwards;\n    animation-play-state: paused;\n  }\n\n  /* Staggering der Animation */\n  .custom-feature-cards__item:nth-child(1) { animation-delay: 0.1s; }\n  .custom-feature-cards__item:nth-child(2) { animation-delay: 0.2s; }\n  .custom-feature-cards__item:nth-child(3) { animation-delay: 0.3s; }\n  .custom-feature-cards__item:nth-child(4) { animation-delay: 0.4s; }\n  .custom-feature-cards__item:nth-child(5) { animation-delay: 0.5s; }\n\n  .custom-feature-cards.is-visible .custom-feature-cards__item {\n    animation-play-state: running;\n  }\n\n  /* === Icon Kreis === */\n  .custom-feature-cards__icon {\n    width: 28px;\n    height: 28px;\n    border-radius: 50%;\n    background-color: var(--mint);\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    flex-shrink: 0;\n    color: #FFFFFF;\n  }\n\n  .custom-feature-cards__icon svg {\n    width: 15px;\n    height: 15px;\n    stroke-width: 2px;\n    stroke: currentColor;\n    fill: none;\n    stroke-linecap: round;\n    stroke-linejoin: round;\n  }\n\n  /* === Text === */\n  .custom-feature-cards__text {\n    font-family: 'Lato', 'Segoe UI', sans-serif;\n    font-weight: 400;\n    font-size: 15px; \n    line-height: 1.4;\n    color: var(--text-muted); \n    margin: 0;\n  }\n\n  /* === Keyframes === */\n  @keyframes customCardFadeUp {\n    from {\n      opacity: 0;\n      transform: translateY(10px);\n    }\n    to {\n      opacity: 1;\n      transform: translateY(0);\n    }\n  }\n</style>\n\n<section class=\"custom-feature-cards\" aria-label=\"Feature Cards\">\n  <div class=\"custom-feature-cards__container\">\n    <h3 class=\"custom-feature-cards__title\">Das steckt in deinem Test</h3>\n    <ul class=\"custom-feature-cards__items\">\n      \n      <!-- Card 1: Dokument / Report -->\n      <li class=\"custom-feature-cards__item\">\n        <div class=\"custom-feature-cards__icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\">\n            <path d=\"M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z\"></path>\n            <polyline points=\"14 2 14 8 20 8\"></polyline>\n            <line x1=\"16\" y1=\"13\" x2=\"8\" y2=\"13\"></line>\n            <line x1=\"16\" y1=\"17\" x2=\"8\" y2=\"17\"></line>\n            <polyline points=\"10 9 9 9 8 9\"></polyline>\n          </svg>\n        </div>\n        <span class=\"custom-feature-cards__text\">\n          187 DNA-Reports zu Ernährung, Fitness & Gesundheit\n        </span>\n      </li>\n\n      <!-- Card 2: Uhr (Biologisches Alter) -->\n      <li class=\"custom-feature-cards__item\">\n        <div class=\"custom-feature-cards__icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\">\n            <circle cx=\"12\" cy=\"12\" r=\"10\"></circle>\n            <polyline points=\"12 6 12 12 16 14\"></polyline>\n          </svg>\n        </div>\n        <span class=\"custom-feature-cards__text\">\n          Dein biologisches Alter – basierend auf epigenetischen Markern\n        </span>\n      </li>\n\n      <!-- Card 3: Chat / Bot (KI Health Coach) -->\n      <li class=\"custom-feature-cards__item\">\n        <div class=\"custom-feature-cards__icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\">\n            <rect x=\"3\" y=\"3\" width=\"18\" height=\"14\" rx=\"2\"></rect>\n            <path d=\"M8 17v4l4-4\"></path>\n            <circle cx=\"9\" cy=\"9\" r=\"1\" fill=\"currentColor\" stroke=\"none\"></circle>\n            <circle cx=\"15\" cy=\"9\" r=\"1\" fill=\"currentColor\" stroke=\"none\"></circle>\n          </svg>\n        </div>\n        <span class=\"custom-feature-cards__text\">\n          Persönlicher KI Health Coach mit konkreten Empfehlungen\n        </span>\n      </li>\n\n      <!-- Card 4: Reagenzglas / Labor -->\n      <li class=\"custom-feature-cards__item\">\n        <div class=\"custom-feature-cards__icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\">\n            <path d=\"M9 2v6.5L4.15 18a2 2 0 0 0 1.73 3h12.24a2 2 0 0 0 1.73-3L15 8.5V2\"></path>\n            <path d=\"M8 2h8\"></path>\n            <path d=\"M6 15h12\"></path>\n          </svg>\n        </div>\n        <span class=\"custom-feature-cards__text\">\n          Einfache Speichelprobe für Zuhause – Laboranalyse bei Eurofins\n        </span>\n      </li>\n\n      <!-- Card 5: Trend-Pfeil / Chart (Fortschritt) -->\n      <li class=\"custom-feature-cards__item\">\n        <div class=\"custom-feature-cards__icon\" aria-hidden=\"true\">\n          <svg viewBox=\"0 0 24 24\">\n            <polyline points=\"22 7 13.5 15.5 8.5 10.5 2 17\"></polyline>\n            <polyline points=\"16 7 22 7 22 13\"></polyline>\n          </svg>\n        </div>\n        <span class=\"custom-feature-cards__text\">\n          Retest nach 6 Monaten zeigt deinen Fortschritt\n        </span>\n      </li>\n\n    </ul>\n  </div>\n</section>\n\n<script>\n  (function() {\n    const observer = new IntersectionObserver((entries) => {\n      entries.forEach(entry => {\n        if (entry.isIntersecting) {\n          entry.target.classList.add('is-visible');\n          observer.unobserve(entry.target);\n        }\n      });\n    }, { \n      threshold: 0.1,\n      rootMargin: \"0px 0px -20px 0px\"\n    });\n\n    const section = document.querySelector('.custom-feature-cards');\n    if (section) {\n      observer.observe(section);\n    }\n  })();\n</script>"
          }
        },
