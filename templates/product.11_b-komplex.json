    "rich_text_G6VgjN": {
      "type": "rich-text",
      "blocks": {
        "title_4DP8wn": {
          "type": "title",
          "settings": {
            "title": "Qualität, auf die du dich verlassen kannst",
            "title_size": "heading-size--regular",
            "seo_h_tag": "h2"
          }
        },
        "text_ReXXQh": {
          "type": "text",
          "settings": {
            "text": "<p>Unsere B-Vitamine sind sorgfältig ausgewählt und liegen in gut verwertbaren Formen vor – ohne künstliche Zusatzstoffe oder unnötige Füllstoffe. Produziert wird unter kontrollierten Bedingungen und nach höchsten Reinheitsstandards.</p><p>Jede Charge wird auf Qualität, Sicherheit und Wirkstoffgehalt geprüft – für maximale Verträglichkeit und eine verlässliche Wirkung im Alltag.</p>",
            "text_size": "regular"
          }
        }
      },
