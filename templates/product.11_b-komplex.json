    "f66fcf17-bb28-4561-8b47-855842b66b2f": {
      "type": "content-toggles",
      "blocks": {
        "2bc8cf89-27d4-416b-a00a-753aba5bb68a": {
          "type": "text",
          "settings": {
            "title": "Was ist Vitamin B-Komplex?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Vitamin B-Komplex besteht aus mehreren B-Vitaminen, die essenziell für Stoffwechsel, Nerven und Energieproduktion sind.</p>",
            "hide_block_if": false
          }
        },
        "template--16165087445092__f66fcf17-bb28-4561-8b47-855842b66b2f-text-1": {
          "type": "text",
          "settings": {
            "title": "Wie kann Vitamin B-Komplex meinen Körper unterstützen?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>B-Vitamine tragen zu einem normalen Energiestoffwechsel, einer gesunden Nervenfunktion und der Erhaltung von Haut, Haaren und Nägeln bei.</p>",
            "hide_block_if": false
          }
        },
        "template--16165087445092__f66fcf17-bb28-4561-8b47-855842b66b2f-text-2": {
          "type": "text",
          "settings": {
            "title": "Wann und wie sollte ich Vitamin B-Komplex einnehmen?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Am besten morgens mit einem Glas Wasser oder einer Mahlzeit, da B-Vitamine den Energiestoffwechsel anregen.</p>",
            "hide_block_if": false
          }
        },
        "text_eaKLir": {
          "type": "text",
          "settings": {
            "title": "Wie lange sollte ich Vitamin B-Komplex einnehmen?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Da der Körper B-Vitamine nicht speichert, empfiehlt sich eine regelmäßige Einnahme für eine optimale Versorgung.</p>",
            "hide_block_if": false
          }
        },
        "text_byhqec": {
          "type": "text",
          "settings": {
            "title": "Ist euer Vitamin B-Komplex vegan?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Ja, unser Produkt enthält rein pflanzliche Inhaltsstoffe und ist 100% vegan.</p>",
            "hide_block_if": false
          }
        },
        "text_XGDYpX": {
          "type": "text",
          "settings": {
            "title": "Gibt es Nebenwirkungen?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Bei der empfohlenen Dosierung sind keine Nebenwirkungen bekannt. Ein Überschuss wird vom Körper meist über den Urin ausgeschieden.</p>",
            "hide_block_if": false
          }
        },
        "text_9r99XP": {
          "type": "text",
          "settings": {
            "title": "Kann ich Vitamin B-Komplex mit anderen Nahrungsergänzungsmitteln kombinieren?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Ja, B-Vitamine lassen sich gut mit anderen Mikronährstoffen kombinieren. Achten Sie auf eine ausgewogene Dosierung.</p>",
            "hide_block_if": false
          }
        },
        "text_CTGRAe": {
          "type": "text",
          "settings": {
            "title": "Wie lange reicht eine Packung?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Eine Packung enthält <strong>60 Kapseln</strong> und reicht bei empfohlener Dosierung für <strong>60 Tage</strong>.</p>",
            "hide_block_if": false
          }
        }
      },
