        "custom_liquid_CwF4CD": {
          "type": "custom_liquid",
          "settings": {
            "custom_liquid": "<style>\n.tag {\n  display: inline-block;\n  padding: 8px 12px;\n  margin: 5px;\n  background-color: #ffffff; /* Hellgrauer Hintergrund */\n  color: #333;\n  border-radius: 20px; /* Abgerundete Ecken */\n  font-size: 14px;\n  font-weight: bold;\n  text-align: center;\n}\n</style>\n\n<div>\n  <span class=\"tag\">Methylierung</span>\n  <span class=\"tag\">Homocystein-Regulation </span>\n  <span class=\"tag\">Zellstabilität</span>\n  <span class=\"tag\">Energiestoffwechsel</span>\n</div>"
          }
        },
        "text_REgGaD": {
          "type": "text",
          "settings": {
            "text": "<p></p><ul><li>Bioaktives TMG (Betain)</li><li>Ideale Bioverfügbarkeit und höchste Qualität</li><li>TMG (Betain) ist die aktivierte Form von Cholin</li><li>Hochdosiert mit 1.000 mg pro Tag für 120 Tage</li></ul><p>TMG (Betain) ist ein natürlicher Methylgeber, der in der Forschung für seine Rolle bei der Förderung der Zellstabilität und Methylierungs-prozesse genutzt wird.</p><p>TMG (Betain) trägt zur Regulierung von Homocysteinspiegeln bei und unterstützt zentrale zelluläre Funktionen, die für den Stoffwechsel essenziell sind.</p>",
            "text_size": "large"
          }
        }
      },
