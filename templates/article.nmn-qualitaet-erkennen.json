        "q-hplc": {
          "type": "item",
          "settings": {
            "question": "Was bedeutet HPLC bei NMN?",
            "answer": "HPLC steht für Hochleistungsflüssigkeitschromatografie, ein Standard-Laborverfahren zur Messung der Reinheit. Es trennt die Bestandteile einer Probe auf und zeigt, wie hoch der NMN-Anteil ist."
          }
        },
        "q-coa": {
          "type": "item",
          "settings": {
            "question": "Sollte NMN ein CoA je Charge haben?",
            "answer": "Ja. Ein Analysezertifikat (CoA) je Charge belegt Reinheit und Schadstoffwerte für genau die Charge, die du erhältst. Ein allgemeines Musterzertifikat ist weniger aussagekräftig."
          }
        },
        "q-uthever": {
          "type": "item",
          "settings": {
            "question": "Was ist Uthever-NMN?",
            "answer": "Uthever ist ein Markenrohstoff für NMN, also NMN eines benannten Herstellers mit eigener Bezeichnung. Der Name macht Herkunft und Reinheitsprofil nachvollziehbar, ersetzt aber kein chargenbezogenes Laborzertifikat."
          }
        },
        "q-minderwertig": {
          "type": "item",
          "settings": {
            "question": "Woran erkenne ich minderwertiges NMN?",
            "answer": "An fehlenden Belegen: keine ausgewiesene Reinheit, kein chargenbezogenes CoA, kein Schadstofftest oder Qualitätsaussagen ohne Messwerte. Wo der Nachweis fehlt, bleibt die Qualität offen."
          }
        },
        "q-lagerung": {
          "type": "item",
          "settings": {
            "question": "Wie sollte NMN verpackt und gelagert sein?",
            "answer": "NMN sollte licht-, luft- und feuchtigkeitsgeschützt verpackt sein, zum Beispiel in einem wiederverschließbaren Beutel oder einem dichten Behälter. Kühl und trocken gelagert bleibt die Qualität am besten erhalten."
          }
        }
      },
