    "f66fcf17-bb28-4561-8b47-855842b66b2f": {
      "type": "content-toggles",
      "blocks": {
        "text_MYMtCq": {
          "type": "text",
          "settings": {
            "title": "Was ist TMG (Betain) und wofür wird es verwendet?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>TMG, auch als Trimethylglycin bekannt, ist eine natürliche Verbindung, die als Methyldonator im Körper wirkt. Es unterstützt die Methylierungsprozesse, die wichtig für die Genregulation und den Zellstoffwechsel sind. TMG wird häufig verwendet, um Homocystein-Spiegel auszugleichen und die allgemeine Zellgesundheit zu fördern.</p>",
            "hide_block_if": false
          }
        },
        "text_KqA4hY": {
          "type": "text",
          "settings": {
            "title": "Welche Lebensmittel enthalten TMG (Betain)?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>TMG kommt natürlicherweise in Lebensmitteln wie Zuckerrüben, Spinat und Weizen vor. </p>",
            "hide_block_if": false
          }
        },
        "text_mVCA69": {
          "type": "text",
          "settings": {
            "title": "Wie dosiere ich TMG (Betain) richtig?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Die empfohlene Tagesdosis von TMG (Betain) beträgt 2 Kapseln (= 1.000 mg).</p>",
            "hide_block_if": false
          }
        },
        "text_KrENMc": {
          "type": "text",
          "settings": {
            "title": "Wie sollte ich TMG (Betain) einnehmen?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>TMG (Betain) lässt sich einfach in Wasser, Saft oder andere Flüssigkeiten einrühren. </p><p>Es wird empfohlen, die Tagesdosis zu einer Mahlzeit einzunehmen, um die Aufnahme zu unterstützen und mögliche Magenbeschwerden zu vermeiden.</p>",
            "hide_block_if": false
          }
        },
        "2bc8cf89-27d4-416b-a00a-753aba5bb68a": {
          "type": "text",
          "settings": {
            "title": "Wie sollte TMG (Betain) gelagert werden?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Lagern Sie TMG (Betain) kühl, trocken und vor Licht geschützt. Es sollte luftdicht verschlossen und vor Feuchtigkeit geschützt werden. Beachten Sie das Mindesthaltbarkeitsdatum.</p>",
            "hide_block_if": false
          }
        },
        "text_eaKLir": {
          "type": "text",
          "settings": {
            "title": "Wie lange ist TMG (Betain) haltbar?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Auf der Rückseite jeder Verpackung, befindet sich das Mindesthaltbarkeitsdatum.</p>",
            "hide_block_if": false
          }
        }
      },
