    "ss_steps_12_5aedcd_wQzYRt": {
      "type": "ss-steps-12-5aedcd",
      "blocks": {
        "heading_4kQFb3": {
          "type": "heading",
          "settings": {
            "heading": "<h2>Was kannst du erwarten?</h2>",
            "heading_custom": false,
            "heading_font": "anton_n4",
            "heading_size": 48,
            "heading_size_mobile": 36,
            "heading_advanced": true,
            "heading_height": 110,
