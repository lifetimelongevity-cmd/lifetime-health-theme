            "heading_color": "#121212",
            "use_gradient": true,
            "gradient_start": "#fab1cd",
            "gradient_end": "#ea0f73"
          }
        },
        "text_C3hKWq": {
          "type": "text",
          "settings": {
            "text": "<p>Was Studienteilnehmer berichten. Ergebnisse aus placebokontrollierten Humanstudien mit NAD+ Vorstufen.</p>",
            "text_custom": false,
            "text_font": "poppins_n4",
            "text_size": 16,
            "text_size_mobile": 16,
            "text_advanced": false,
            "text_height": 150,
            "text_mt": 12,
            "text_mt_mobile": 12,
            "text_color": "#5c5959"
          }
        },
        "item_79MT66": {
          "type": "item",
          "settings": {
            "badge": "Nach 4 Wochen",
            "icon": "bolt",
            "heading": "<h3>Mehr Energie</h3>",
            "text": "<p>NAD⁺-Stoffwechsel: erste messbare Veränderungen. Viele berichten von einem konstanteren Energiegefühl im Alltag.</p>"
          }
        },
        "item_dwRyxA": {
          "type": "item",
          "settings": {
            "badge": "Nach 2 Monaten",
            "icon": "refresh_2",
            "heading": "<h3>Spürbar fitter</h3>",
            "text": "<p>Teilnehmer einer 60-Tage-Studie legten im 6-Minuten-Gehtest signifikant mehr Strecke zurück als Placebo. In einer Studie mit älteren Männern: verbesserte Gehgeschwindigkeit und Griffstärke. Biologisches Alter blieb stabil – in der Placebo-Gruppe stieg es weiter an.</p>"
          }
        },
        "item_Y9A74G": {
          "type": "item",
          "settings": {
            "badge": "Nach 3 Monaten",
            "icon": "heart",
            "heading": "<h3>Herz & Stoffwechsel</h3>",
            "text": "<p>Teilnehmerinnen zeigten verbesserte Insulinsensitivität im Skelettmuskel. Tendenz zu reduzierter arterieller Steifheit – ein etablierter Risikomarker für Herz-Kreislauf-Erkrankungen. In einer 12-Wochen-Studie: NAD+-Werte im Blut mehr als verdoppelt.</p>"
          }
        },
