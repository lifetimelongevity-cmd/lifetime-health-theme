        "item_4Y8MN7": {
          "type": "item",
          "settings": {
            "image": "shopify://shop_images/pexels-ecrin-59969312-7992688-sm.jpg",
            "heading": "<h3><strong>Monat 1: Besser verfügbare Energie</strong></h3>",
            "text": "<p>Steigt dein NAD⁺-Spiegel, können Zellen Energie effizienter bereitstellen – oft fühlt sich der Start in den Tag leichter an.</p>"
          }
        },
        "item_G7MD8b": {
          "type": "item",
          "settings": {
            "image": "shopify://shop_images/pexels-cottonbro-7232029_1.jpg",
            "heading": "<h3><strong>Monat 2: Weniger Energieeinbrüche</strong></h3>",
            "text": "<p>Stabilere NAD⁺-Werte unterstützen gleichmäßigere Energieprozesse – du bleibst über den Tag konstanter.</p>"
          }
        },
        "item_Jm8nNt": {
          "type": "item",
          "settings": {
            "image": "shopify://shop_images/pexels-roman-odintsov-6206151_1.jpg",
            "heading": "<h3><strong>Monat 3: Schnellere Erholung </strong></h3>",
            "text": "<p>Über Wochen hängen höhere NAD⁺-Spiegel mit Regenerationsprozessen zusammen – nach Belastung fühlst du dich eher wieder „frisch“.</p>"
          }
        },
        "item_bUBQA9": {
          "type": "item",
