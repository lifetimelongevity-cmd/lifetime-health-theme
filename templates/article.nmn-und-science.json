    "4f7cc3de-bfb4-435b-b17d-dd9b700a1255": {
      "type": "rich-text",
      "blocks": {
        "template--16212539834468__4f7cc3de-bfb4-435b-b17d-dd9b700a1255-text-1": {
          "type": "text",
          "settings": {
            "text": "<p><a href=\"https://www.lifetime-health.com\" title=\"https://www.lifetime-health.com\">Startseite</a> / <a href=\"/blogs/longevity-blog\" title=\"Longevity-Blog\">Longevity-Blog</a> / <a href=\"/pages/nmn\" title=\"NMN\">NMN</a></p>",
            "text_size": "regular"
          }
        },
        "template--16212539834468__4f7cc3de-bfb4-435b-b17d-dd9b700a1255-title-1": {
          "type": "title",
          "settings": {
            "title": "Die Wissenschaft hinter NMN: Aktuelle menschliche Studien",
            "title_size": "heading-size--regular",
            "seo_h_tag": "h1"
          }
        },
        "7c1b7dc8-bf0a-4d1d-9f52-4b6dac8e352c": {
          "type": "text",
          "settings": {
            "text": "<p>Nicotinamid-Mononukleotid (NMN) steht im Zentrum aktueller Anti-Aging-Forschung. Hier ist eine Übersicht aktueller Studien zu NMN.</p>",
            "text_size": "large"
          }
        },
        "text_6C7FQP": {
          "type": "text",
          "settings": {
            "text": "<h3></h3><ol><li><a href=\"https://www.sciencedirect.com/science/article/pii/S2405457723001249\" target=\"_blank\">Orale Verabreichung von NMN erhöhte die Plasmakonzentrationen</a> </li><li><a href=\"https://www.nature.com/articles/s41598-023-29787-3\" target=\"_blank\">NMN reduzierte die Steifheit der Blutgefäße</a> </li><li><a href=\"https://pubmed.ncbi.nlm.nih.gov/36740954/\" target=\"_blank\">NMN reduzierte signifikant den Cholesterinspiegel</a> </li><li><a href=\"https://pubmed.ncbi.nlm.nih.gov/36443648/\" target=\"_blank\">NMN erhöht Ausdauer und NAD+-Spiegel</a> </li><li><a href=\"https://pubmed.ncbi.nlm.nih.gov/36225528/\" target=\"_blank\">NMN milderte das Auftreten von Gebrechlichkeit</a> </li><li><a href=\"https://pubmed.ncbi.nlm.nih.gov/36482258/\" target=\"_blank\">NMN bei gesunden Erwachsenen sicher und gut verträglich</a> </li><li><a href=\"https://www.researchsquare.com/article/rs-1802944/v1\" target=\"_blank\">NMN reduzierte signifikant die Steifheit der Arterien</a> </li><li><a href=\"https://www.toukastress.jp/webj/article/2022/GS22-16.pdf\" target=\"_blank\">NMN verbesserte den Zucker- und Cholesterinstoffwechsel</a> </li><li><a href=\"https://www.researchgate.net/publication/360301476_ARTICLE_Chronic_nicotinamide_mononucleotide_supplementation_elevates_blood_nicotinamide_adenine_dinucleotide_levels_and_alters_muscle_function_in_healthy_older_men\" target=\"_blank\">NMN verbesserte die Gehgeschwindigkeit und Griffstärke</a> </li><li><a href=\"https://www.frontiersin.org/articles/10.3389/fragi.2022.851698/full\" target=\"_blank\">NMN erhöht die Ausdauer beim 6-Minuten-Gehen</a> </li><li><a href=\"https://pubmed.ncbi.nlm.nih.gov/33888596/\" target=\"_blank\">NMN verbesserte die Insulinempfindlichkeit</a> </li><li><a href=\"https://pubmed.ncbi.nlm.nih.gov/31685720/\" target=\"_blank\">NMN wurde bei gesunden Männern sicher und effektiv verstoffwechselt</a> </li><li><a href=\"https://pubmed.ncbi.nlm.nih.gov/35479740/\" target=\"_blank\">NMN hat die NAD+-Werte im Vollblut fast verdoppelt</a> </li><li><a href=\"https://pubmed.ncbi.nlm.nih.gov/35215405/\" target=\"_blank\">NMN verbesserte die Schlafqualität</a> </li><li><a href=\"https://pubmed.ncbi.nlm.nih.gov/35182418/\" target=\"_blank\">NMN verdoppelte den NAD+-Blutspiegel</a> </li><li><a href=\"https://pubmed.ncbi.nlm.nih.gov/34238308/\" target=\"_blank\">NMN erhöhte die aerobe Kapazität von Läufern</a> </li></ol>",
            "text_size": "regular"
          }
        }
      },
