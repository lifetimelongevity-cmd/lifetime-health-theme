      "blocks": {
        "nmn2_fq1": {
          "type": "item",
          "settings": {
            "show_shield": false,
            "question": "Was bedeutet Novel Food?",
            "answer": "<p>NMN ist in der EU als Novel Food eingestuft. Dieses Produkt wird daher nicht als Lebensmittel oder Nahrungsergänzungsmittel angeboten. Die Abgabe erfolgt ausschließlich zu Forschungs- und Analysezwecken.</p>"
          }
        },
        "nmn2_fq2": {
          "type": "item",
          "settings": {
            "question": "Wann spüre ich erste Ergebnisse?",
            "answer": "<p>Erste messbare Veränderungen berichten viele nach 4 Wochen. Maximale Effekte entwickeln sich nach 3–4 Monaten kontinuierlicher Einnahme.</p>"
          }
        },
        "nmn2_fq3": {
          "type": "item",
          "settings": {
            "question": "Wie nehme ich das Pulver ein?",
            "answer": "<p>Morgens 1 Messlöffel (ca. 500 mg) in Wasser, Saft oder Smoothie einrühren. Der Messlöffel liegt dem Beutel bei.</p>"
          }
        },
        "nmn2_fq4": {
          "type": "item",
          "settings": {
            "question": "Kann ich das Abo jederzeit kündigen?",
            "answer": "<p>Ja, das Abo ist jederzeit flexibel anpassbar, pausierbar oder kündbar — direkt in deinem Kundenkonto, ohne Angabe von Gründen.</p>"
          }
        },
        "nmn2_fq5": {
          "type": "item",
          "settings": {
            "question": "Was ist Uthever® NMN?",
            "answer": "<p>Uthever® ist ein patentierter Markenrohstoff — klinisch untersucht, nach GMP hergestellt, mit öffentlich einsehbarem COA.</p>"
          }
        },
        "nmn2_fq6": {
          "type": "item",
          "settings": {
            "question": "Ist NMN in Deutschland legal?",
            "answer": "<p>Ja. NMN ist legal erhältlich und wird von LIFETIME zu Forschungs- und Analysezwecken angeboten.</p>"
          }
        },
        "nmn2_fq7": {
          "type": "item",
          "settings": {
            "question": "Wie lange reicht ein Beutel?",
            "answer": "<p>30 g enthält ca. 60 Portionen à 500 mg (1 Messlöffel). Das entspricht ca. 60 Tagen Versorgung — also 2 Monate pro Beutel.</p>"
          }
        },
        "nmn2_fq8": {
          "type": "item",
          "settings": {
            "show_shield": true,
            "question": "Gilt die 90-Tage-Garantie auch für Abo-Bestellungen?",
            "answer": "<p>Ja. Die 90-Tage Geld-zurück-Garantie gilt für alle Bestellungen — einmalig und Abo. Einfach E-Mail an <a href=\"mailto:team@lifetime-health.de\">team@lifetime-health.de</a>.</p>"
          }
        }
      },
