    "faq": {
      "type": "crs-faq-accordion",
      "blocks": {
        "q-verboten": {
          "type": "item",
          "settings": {
            "question": "Ist NMN in Deutschland verboten?",
            "answer": "NMN ist nicht als „verboten\" im Sinne eines Straftatbestands eingestuft, aber es ist als Novel Food noch nicht zugelassen und darf daher nicht als Nahrungsergänzung in Verkehr gebracht werden."
          }
        },
        "q-bald": {
          "type": "item",
          "settings": {
            "question": "Wird NMN in der EU bald zugelassen?",
            "answer": "Die EFSA hat 2026 eine positive Sicherheitsbewertung abgegeben. Ob und wann die EU-Kommission die formale Zulassung erteilt, ist noch offen."
          }
        },
        "q-menge": {
          "type": "item",
          "settings": {
            "question": "Wie viel NMN gilt laut EFSA als sicher?",
            "answer": "Die EFSA nennt eine sichere Aufnahmemenge von bis zu 300 mg pro Tag für Erwachsene, ausgenommen Schwangere und Stillende."
          }
        },
        "q-usa": {
          "type": "item",
          "settings": {
            "question": "Darf ich NMN aus den USA nach Deutschland bestellen?",
            "answer": "Die US-Zulassung ändert die deutsche Rechtslage nicht. Ob ein Import zulässig ist, hängt vom EU-Recht ab, nicht von der FDA-Entscheidung."
          }
        },
        "q-nr": {
          "type": "item",
          "settings": {
            "question": "Was ist der Unterschied zwischen NMN und NR?",
            "answer": "NMN und NR (Nicotinamid-Ribosid) sind beides NAD⁺-Vorstufen, unterscheiden sich aber rechtlich und chemisch. Einen ausführlichen Vergleich findest du im Artikel „NMN vs. NR\"."
          }
        }
      },
