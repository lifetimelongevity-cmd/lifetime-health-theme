    "info_tabs_rPYne6": {
      "type": "info-tabs",
      "blocks": {
        "tab_bJj4fc": {
          "type": "tab",
          "settings": {
            "title": "Höchste Reinheit",
            "caption": "<p>Mit über 99% zertifizierter Reinheit gehört unser NMN zu den reinsten Produkten auf dem Markt. Zusätzlich wird sichergestellt, dass es keine Verunreinigungen in Form von Schwermetallen gibt.</p>",
            "image": "shopify://shop_images/product-8821411.png",
            "icon": "star"
          }
        },
        "tab_NCzrwj": {
          "type": "tab",
          "settings": {
            "title": "Wissenschaftliche Qualität",
            "caption": "<p>Unsere NMN-Produktion folgt strengsten Produktionsstandards inklusive GMP sowie HACCP. Besonderes Augenmerk wird auf höchste Stabilität und Bioverfügbarkeit gelegt. Aufgrund der hohen Qualität wird es in klinischen Studien eingesetzt, bleibt auch bei Raumtemperatur lange stabil und bietet konstant hohe Qualität.</p>",
            "image": "shopify://shop_images/Nicotinamid_Mononukleotid_99_Reinheit.png",
            "icon": "star"
          }
        },
        "tab_4p494L": {
          "type": "tab",
          "settings": {
            "title": "Unabhängig geprüft",
            "caption": "<p>Jede Charge unseres NMN wird zweifach geprüft: zuerst im Herstellungsprozess und dann in akkreditierten deutschen Laboren. Das zugehörige Certificate of Analysis (COA) bestätigt als unabhängiges Prüfzertifikat die Einhaltung aller Standards und listet Details zur Reinheit und Sicherheit.</p>",
            "image": "shopify://shop_images/Nicotinamid_Mononukleotid_99_Reinheit_1.png",
            "icon": "star"
          }
        }
      },
      "block_order": [
        "tab_bJj4fc",
