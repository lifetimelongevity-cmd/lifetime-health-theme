        "2bc8cf89-27d4-416b-a00a-753aba5bb68a": {
          "type": "text",
          "settings": {
            "title": "Wie sollte NMN gelagert werden?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Lagern Sie NMN kühl, trocken und vor Licht geschützt. Es sollte luftdicht verschlossen und vor Feuchtigkeit geschützt werden. Beachten Sie das Mindesthaltbarkeitsdatum.</p>",
            "hide_block_if": false
          }
        },
        "template--16165087445092__f66fcf17-bb28-4561-8b47-855842b66b2f-text-1": {
          "type": "text",
          "settings": {
            "title": "Ist NMN in der EU als Nahrungsergänzungsmittel zugelassen?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>NMN wird in der EU als “Novel Food” eingestuft und darf nicht als Nahrungsergänzungsmittel verkauft werden. Der Verkauf als Chemikalie ist erlaubt.</p>",
            "hide_block_if": false
          }
        },
        "template--16165087445092__f66fcf17-bb28-4561-8b47-855842b66b2f-text-2": {
          "type": "text",
          "settings": {
            "title": "Wie kann man die Menge von NMN abmessen?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Ein Messlöffel enthält ca. 500 mg NMN-Pulver.</p>",
            "hide_block_if": false
          }
        },
        "text_eaKLir": {
          "type": "text",
          "settings": {
            "title": "Wie lange ist NMN haltbar?",
            "subtitle": "",
            "icon": "no-icon",
            "button_label": "",
            "button_link": "",
            "body": "<p>Aufgrund der besonderen Stabilität unseres LIFETIME NMN, ist ein Beutel ungefähr 24 Monate haltbar. Auf der Rückseite jeder Verpackung, befindet sich das Mindesthaltbarkeitsdatum.</p>",
            "hide_block_if": false
          }
        }
