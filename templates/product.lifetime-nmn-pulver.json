            "custom_liquid": "<!-- Hinweisblock -->\n<script src=\"https://unpkg.com/@dotlottie/player-component@2.7.12/dist/dotlottie-player.mjs\" type=\"module\"></script>\n\n<style>\n  .lt-modal-overlay{\n    position:fixed; inset:0; background:rgba(0,0,0,.4);\n    display:none; z-index:9999;\n    /* Mobile-friendly: zentriert + Innenabstand fürs Scrollen */\n    display:none; \n  }\n  .lt-modal-overlay.is-open{ display:flex; align-items:flex-start; justify-content:center; padding:6vh 16px; }\n\n  .lt-modal{\n    box-sizing:border-box; background:#fff; color:inherit; font-family:inherit;\n    width:min(92vw,560px);\n    max-height:90vh;               /* <- macht das Popup auf Mobile scrollfähig */\n    overflow:auto;                 /* <- Scrollen innerhalb des Modals */\n    -webkit-overflow-scrolling:touch; /* iOS sanftes Scrollen */\n    padding:16px 18px; border-radius:12px; box-shadow:0 10px 30px rgba(0,0,0,.15);\n  }\n  .lt-modal header{ display:flex; align-items:center; justify-content:space-between; gap:.75rem; }\n  .lt-modal h3{ margin:0; font-size:1rem; font-weight:600; }\n  .lt-close{ appearance:none; border:0; background:transparent; cursor:pointer; font-size:1rem; line-height:1; padding:.25rem .5rem; }\n  .lt-body{ margin-top:.35rem; font-size:.95rem; line-height:1.5; }\n\n  /* Dezente Links im gleichen Grauton */\n  .lt-link{ color:inherit; text-decoration:underline; text-underline-offset:2px; cursor:pointer; }\n  .lt-link:visited{ color:inherit; }\n  .lt-link:hover,.lt-link:focus{ color:#444; outline:none; }\n</style>\n\n<div style=\"background:#FAFAFA; border-radius:10px; padding:12px; display:flex; flex-direction:column; gap:6px; margin-top:-1rem; margin-bottom:-7px; color:#666;\">\n  <div style=\"display:flex; align-items:center; font-size:0.85rem;\">\n    <dotlottie-player src=\"https://lottie.host/ac6ae8b6-6768-402f-adf4-7f81c0ae0d2f/bFbRiLHNdV.lottie\" background=\"transparent\" speed=\"1\" loop autoplay style=\"width:20px; height:20px; margin-right:6px;\"></dotlottie-player>\n    <span>Sofort lieferbar: In 1–3 Werktagen bei dir</span>\n  </div>\n  <div style=\"display:flex; align-items:center; font-size:0.85rem;\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0621/2173/8340/files/delivery-fast-svgrepo-com.svg?v=1757665322\" alt=\"\" width=\"20\" height=\"20\" style=\"margin-right:6px;\">\n    <span>Versandkostenfrei ab 100&nbsp;€</span>\n  </div>\n  <div style=\"display:flex; align-items:center; font-size:0.85rem;\">\n    <img src=\"https://cdn.shopify.com/s/files/1/0621/2173/8340/files/herz-garantie-90.svg?v=1761641733\" alt=\"\" width=\"20\" height=\"20\" style=\"margin-right:6px;\">\n    <span><a href=\"#\" class=\"lt-link\" id=\"lt-promise-open\" aria-haspopup=\"dialog\" aria-controls=\"lt-promise-modal\">90-Tage-Zufriedenheitsgarantie</a></span>\n  </div>\n</div>\n\n<!-- Modal -->\n<div class=\"lt-modal-overlay\" id=\"lt-promise-modal\" role=\"dialog\" aria-modal=\"true\" aria-labelledby=\"lt-promise-title\">\n  <div class=\"lt-modal\" role=\"document\">\n    <header>\n      <h3 id=\"lt-promise-title\">90-Tage-Zufriedenheitsgarantie</h3>\n      <button type=\"button\" class=\"lt-close\" id=\"lt-promise-close\" aria-label=\"Schließen\">✕</button>\n    </header>\n    <div class=\"lt-body\">\n      <p><strong>Risikofrei testen.</strong> 90 Tage Zeit, klare Schritte, transparente Erstattung.</p>\n      <ul style=\"margin:.25rem 0 0 1rem;\">\n        <li>Genug Zeit, um Routinen aufzubauen.</li>\n        <li>Fair & transparent – ohne Kleingedruckt-Gefühl.</li>\n        <li>Schnelle Abwicklung nach Wareneingang & Prüfung.</li>\n      </ul>\n\n      <p style=\"margin-top:.6rem;\"><strong>Kurz & knapp – so geht’s</strong></p>\n      <ul style=\"margin:.25rem 0 0 1rem;\">\n        <li>Per E-Mail mit Bestellnummer anzumelden.</li>\n        <li><strong>Foto der geöffneten Packung (Restmenge)</strong> mitschicken.</li>\n        <li>Rücksendung: 1 geöffnete Einheit + weitere identische Einheiten ungeöffnet/versiegelt.</li>\n        <li>Fristen: innerhalb 90 Tagen anmelden; 14 Tage Rücksendefrist nach RMA.</li>\n        <li>Erstattung: Kaufpreis nach Prüfung (ohne Versand-/Rücksendekosten).</li>\n      </ul>\n\n      <p style=\"margin-top:.6rem;\">\n        Details: <a class=\"lt-link\" href=\"https://lifetime-health.com/policies/refund-policy\" target=\"_blank\" rel=\"noopener\">Rückgabebedingungen</a>\n      </p>\n    </div>\n  </div>\n</div>\n\n<script>\n  (function(){\n    var openBtn=document.getElementById('lt-promise-open');\n    var modal=document.getElementById('lt-promise-modal');\n    var closeBtn=document.getElementById('lt-promise-close');\n    var prev=null;\n\n    if(!openBtn||!modal||!closeBtn) return;\n\n    function open(e){\n      if(e) e.preventDefault();\n      prev=document.activeElement;\n      modal.classList.add('is-open');\n      document.documentElement.style.overflow='hidden'; /* Hintergrund fixieren */\n      closeBtn.focus();\n    }\n    function close(){\n      modal.classList.remove('is-open');\n      document.documentElement.style.overflow=''; \n      if(prev) prev.focus();\n    }\n\n    openBtn.addEventListener('click',open);\n    closeBtn.addEventListener('click',close);\n    modal.addEventListener('click',function(e){ if(e.target===modal) close(); });\n    document.addEventListener('keydown',function(e){ if(modal.classList.contains('is-open')&&e.key==='Escape') close(); });\n  })();\n</script>"
          }
