    "custom_liquid_EaipWj": {
      "type": "custom-liquid",
      "disabled": true,
      "name": "t:sections.refactor_words.custom_code.name",
      "settings": {
        "heading": "",
        "subheading": "",
        "section_heading_size": "text-size--large",
        "section_heading_layout": "section-heading--left section-heading--two-rows",
        "cta_label": "",
        "cta_url": "",
        "custom_liquid": "<div style=\"display: flex; flex-wrap: wrap; gap: 12px;\">\n\n  <!-- 1. DNA-Schäden ↑ – ausgewählt -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #fff; border: 2px solid #2EC4B6; box-shadow: 0 0 0 4px rgba(46, 196, 182, 0.2);\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmark-dna_6946a143-5c8f-4dbe-945d-9e76c8ee59cb.png?v=1754563800\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    DNA-Schäden ↑\n  </div>\n\n  <!-- 2. Schutzkappen ↓ – ausgewählt -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #fff; border: 2px solid #2EC4B6; box-shadow: 0 0 0 4px rgba(46, 196, 182, 0.2);\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmark-telomere.png?v=1754563800\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    Schutzkappen ↓\n  </div>\n\n  <!-- 3. Genaktivität ↓↑ – ausgewählt -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #fff; border: 2px solid #2EC4B6; box-shadow: 0 0 0 4px rgba(46, 196, 182, 0.2);\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmark-epi.png?v=1754563799\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    Genaktivität ↓↑\n  </div>\n\n  <!-- 4. Proteinstruktur ↓ – neutral -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #f8f8f8; color: #999; border: 1px dashed #ddd;\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmark-proteostase.png?v=1754563799\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    Proteinstruktur ↓\n  </div>\n\n  <!-- 5. Mitochondrien ↓ – ausgewählt -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #fff; border: 2px solid #2EC4B6; box-shadow: 0 0 0 4px rgba(46, 196, 182, 0.2);\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmark-mitochondria.png?v=1754563799\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    Mitochondrien ↓\n  </div>\n\n  <!-- 6. Zombiezellen ↑ – ausgewählt -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #fff; border: 2px solid #2EC4B6; box-shadow: 0 0 0 4px rgba(46, 196, 182, 0.2);\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmark-seneszenz.png?v=1754563800\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    Zombiezellen ↑\n  </div>\n\n  <!-- 7. Stoffwechsel ↓ – neutral -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #f8f8f8; color: #999; border: 1px dashed #ddd;\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmark-nutrient.png?v=1754563800\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    Stoffwechsel ↓\n  </div>\n\n  <!-- 8. Zell-Recycling ↓ – neutral -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #f8f8f8; color: #999; border: 1px dashed #ddd;\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmark-autophagy.png?v=1754563799\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    Zell-Recycling ↓\n  </div>\n\n  <!-- 9. Dauerentzündung ↑ – neutral -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #f8f8f8; color: #999; border: 1px dashed #ddd;\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmark-inflammaging.png?v=1754563800\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    Dauerentzünd. ↑\n  </div>\n\n  <!-- 10. Zellkommunikation ↓ – neutral -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #f8f8f8; color: #999; border: 1px dashed #ddd;\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmark-communication.png?v=1754563800\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    Zellkommunik. ↓\n  </div>\n\n  <!-- 11. Stammzellen ↓ – neutral -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #f8f8f8; color: #999; border: 1px dashed #ddd;\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmark-stammzelle.png?v=1754563800\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    Stammzellen ↓\n  </div>\n\n  <!-- 12. Darmflora ↓ – neutral -->\n  <div style=\"display: flex; align-items: center; border-radius: 9999px; padding: 6px 12px; font-size: 14px; font-weight: 400; gap: 6px; background-color: #f8f8f8; color: #999; border: 1px dashed #ddd;\">\n    <img src=\"https://lifetime-health.com/cdn/shop/files/hallmarks-dysbiose.png?v=1754563800\" style=\"width: 18px; height: 18px;\" alt=\"\">\n    Darmflora ↓\n  </div>\n\n</div>\n<br><br><br>",
        "full_width": false,
        "remove_margin": false,
        "seo_h_tag": "h2"
      }
    },
    "ss_flip_cards_Ddijx6": {
      "type": "ss-flip-cards",
      "blocks": {
        "card_ETUXny": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/hallmark-dna_6946a143-5c8f-4dbe-945d-9e76c8ee59cb.png",
            "title": "DNA-Schäden ↑",
            "subtitle": "Genomische Instabilität nimmt zu (1|12)",
            "text": "<p>Mit der Zeit wird unsere DNA beschädigt – wie Tippfehler in einem Bauplan. Das kann Zellen aus dem Gleichgewicht bringen.</p>"
          }
        },
        "card_V4Rwt8": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/hallmark-telomere.png",
            "title": "Schutzkappen ↓",
            "subtitle": "Endkappen der Telomere verkürzen sich (2|12)",
            "text": "<p>Telomere – die Enden der Chromosomen – werden bei jeder Zellteilung kürzer. Irgendwann kann sich die Zelle nicht mehr teilen.</p>"
          }
        },
        "card_VRCaLR": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/hallmark-epi.png",
            "title": "Genaktivität ↓↑",
            "subtitle": "Veränderungen der Epigenetik (3|12)",
            "text": "<p>Die Regulation der Gene wird unpräzise. Gene werden zu oft oder zu selten aktiviert – das verändert die Zellfunktion.</p>"
          }
        },
        "card_pmxDpE": {
          "type": "card",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/hallmark-proteostase.png",
            "title": "Proteinstruktur ↓",
            "subtitle": "Verlust der zellulären Proteostase (4|12)",
            "text": "<p>Die Fähigkeit der Zelle, fehlerhafte Proteine zu erkennen und abzubauen, lässt nach. Es kommt zu Funktionsstörungen.</p>"
          }
        },
        "card_VPTjye": {
          "type": "card",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/hallmark-autophagy.png",
            "title": "Zell-Recycling ↓",
            "subtitle": "Beeinträchtigte Makroautophagie (5|12)",
            "text": "<p>Beschädigte Zellbestandteile – wie defekte Mitochondrien – werden nicht mehr abgebaut.</p>"
          }
        },
        "card_mxpqA7": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/hallmark-nutrient.png",
            "title": "Stoffwechsel ↓",
            "subtitle": "Nährstoffe werden falsch zugeordnet (6|12)",
            "text": "<p>Zellen erkennen nicht mehr zuverlässig, wann genug Energie vorhanden ist – die Stoffwechselsteuerung ist gestört.</p>"
          }
        },
        "card_wgr4a4": {
          "type": "card",
          "settings": {
            "image": "shopify://shop_images/hallmark-mitochondria.png",
            "title": "Mitochondrien ↓",
            "subtitle": "Energieproduktion der Zelle sinkt (7|12)",
            "text": "<p>Die Zellkraftwerke liefern weniger Energie und produzieren mehr schädliche Nebenprodukte – das belastet den ganzen Organismus.</p>"
          }
        },
        "card_xXkBj4": {
          "type": "card",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/hallmark-seneszenz.png",
            "title": "Zombiezellen ↑",
            "subtitle": "Alte Zellen senden schädliche Signale (8|12)",
            "text": "<p>Alte Zellen, die sich nicht mehr teilen, bleiben aktiv und senden schädliche Signale aus.</p>"
          }
        },
        "card_axxqgh": {
          "type": "card",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/hallmark-stammzelle.png",
            "title": "Stammzellen ↓",
            "subtitle": "Reparaturfähigkeiten des Körpers sinken (9|12)",
            "text": "<p>Die körpereigenen Reparaturmechanismen lassen nach – Gewebe regeneriert sich langsamer.</p>"
          }
        },
        "card_K8Ntri": {
          "type": "card",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/hallmark-communication.png",
            "title": "Zellkommunikation ↓",
            "subtitle": "Mehr falsche Signale zwischen Zellen (10|12)",
            "text": "<p>Zellen tauschen vermehrt entzündliche oder verwirrende Signale aus – gesunde Abläufe werden gestört.</p>"
          }
        },
        "card_yCqYa4": {
          "type": "card",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/hallmark-inflammaging.png",
            "title": "Dauerentzündung ↑",
            "subtitle": "Chronische Entzündung nehmen zu (11|12)",
            "text": "<p>Das Immunsystem ist dauerhaft aktiv – auch ohne akute Gefahr – und schädigt gesunde Strukturen.</p>"
          }
        },
        "card_yTKMk3": {
          "type": "card",
          "disabled": true,
          "settings": {
            "image": "shopify://shop_images/hallmarks-dysbiose.png",
            "title": "Darmflora ↓",
            "subtitle": "Dysbiose mit Verlust des Gleichgewichts (12|12)",
            "text": "<p>Wenn die Vielfalt und Balance der Darmbakterien gestört ist, kann das Entzündungen fördern und den gesamten Körper belasten.</p>"
          }
        }
