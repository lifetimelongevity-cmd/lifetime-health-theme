    "89dc6870-6fdb-4af5-92d4-814bdc454cd9": {
      "type": "ss-steps-5",
      "blocks": {
        "step_8C6rFV": {
          "type": "step",
          "settings": {
            "question": "Nach 4 Wochen ▸ Energielevel",
            "answer": "<p>Der NAD⁺-Spiegel steigt um bis zu 40 %. NAD⁺ ist essenziell für die Energieproduktion in den Mitochondrien, daher kann sich das Energielevel spürbar verbessern.</p><p></p><h6>DOI: 10.1126/science.abe9985<br/>DOI: 10.3389/fnut.2022.868640</h6>",
            "image": "shopify://shop_images/nad_level.png"
          }
        },
        "step_tQ3UPx": {
          "type": "step",
          "settings": {
            "question": "Nach 8 Wochen ▸ Muskelkraft",
            "answer": "<p>Muskelkraft und Glukosetoleranz verbessern sich – NMN unterstützt die Energieversorgung der Muskulatur über erhöhte NAD⁺-Spiegel.</p><p></p><h6>DOI: 10.1186/s12970-021-00442-4<br/>DOI: 10.1507/endocrj.EJ19-0313</h6>",
            "image": "shopify://shop_images/pexels-cottonbro-4761799.jpg"
          }
        },
        "step_t4pyjm": {
          "type": "step",
          "settings": {
            "question": "Nach 12 Wochen ▸ Leistung",
            "answer": "<p>Leistung und Stoffwechselfunktion steigen – NMN verbessert Griffkraft, Ausdauer und Insulinsensitivität bei älteren Erwachsenen.</p><p></p><h6>DOI: 10.1038/s41514-022-00084-z</h6>",
            "image": "shopify://shop_images/pexels-kgstudios-27289153.jpg"
          }
        },
        "step_Trxqwr": {
          "type": "step",
          "settings": {
            "question": "Nach 6 Monaten ▸ Altersmarker",
            "answer": "<p>Nach 6 Monaten zeigen erste Humanstudien eine Reduktion altersassoziierter Marker und eine stabilisierte mitochondriale Funktion – Hinweise auf eine Verlangsamung zellulärer Alterung.</p><p>↓ oxidativer Stress<br/>↓ inflammatorische Zytokine</p><p></p><h6>DOI: 10.1038/s41598-023-29787-3<br/>DOI: 10.1007/s11357-022-00705-1<br/>DOI: 10.1016/j.advnut.2023.08.008</h6>",
            "image": "shopify://shop_images/pexels-karolina-grabowska-8093227.jpg"
          }
        }
      },
      "block_order": [
        "step_8C6rFV",
