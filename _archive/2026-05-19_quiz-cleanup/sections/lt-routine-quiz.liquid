{% comment %}
  lt-routine-quiz
  ────────────────────────────────────────────────────────────
  Adaptives Quiz für /pages/meine-routine.

  Q1 (Routing) stellt 3 Bild-Karten. Die Auswahl entscheidet intern,
  welchen Pfad der Nutzer durchläuft — ohne sichtbare Weichenstellung:

    Karte 1 "Ich fühle den Unterschied" → Diagnostik, archetype = tired
    Karte 2 "Ich will verstehen"        → Diagnostik, archetype = measurer
    Karte 3 "Ich will loslegen"         → Supplement

  Diagnostik-Pfad  (Karten 1 + 2):
    Q2 Alter-Slider
    Q3 archetype-spezifische Folgefrage
    Q4 Was hast du bisher versucht?
    Q5 Intent (hot / cool)
    → Result: Archetype-Hypothesen + CTA zum AGE & DNA-Test

  Supplement-Pfad (Karte 3):
    Q2 Wo merkst du es am stärksten?   (Energie / Fokus / Schlaf / Langlebigkeit)
    → Result: Personalisiertes Bundle (primary + 2 secondaries)

  Advisor-Zeile (Prof. Limmroth) erscheint unter dem Quiz auf beiden Pfaden.
{% endcomment %}

{%- liquid
  assign p_energie_primary = all_products[section.settings.product_energie_primary]
  assign p_energie_sec1    = all_products[section.settings.product_energie_sec1]
  assign p_energie_sec2    = all_products[section.settings.product_energie_sec2]
  assign p_fokus_primary   = all_products[section.settings.product_fokus_primary]
  assign p_fokus_sec1      = all_products[section.settings.product_fokus_sec1]
  assign p_fokus_sec2      = all_products[section.settings.product_fokus_sec2]
  assign p_schlaf_primary  = all_products[section.settings.product_schlaf_primary]
  assign p_schlaf_sec1     = all_products[section.settings.product_schlaf_sec1]
  assign p_schlaf_sec2     = all_products[section.settings.product_schlaf_sec2]
  assign p_lang_primary    = all_products[section.settings.product_lang_primary]
  assign p_lang_sec1       = all_products[section.settings.product_lang_sec1]
  assign p_lang_sec2       = all_products[section.settings.product_lang_sec2]
-%}

{{ 'section-lt-longevity-quiz.css' | asset_url | stylesheet_tag }}

{% style %}
  /* Sticky-Header auf der Quiz-Seite unterdrücken — kein Overlap mit scroll-to-quiz */
  body.template-page-meine-routine .sticky-header,
  body.template-page-meine-routine .sticky-header.show {
    display: none !important;
  }

  #lt-routine-quiz-{{ section.id }} {
    --rq-bg: {{ section.settings.color_bg }};
    --rq-text: {{ section.settings.color_text }};
    --rq-accent: {{ section.settings.color_accent }};
    --rq-card: {{ section.settings.color_card_bg }};
    --rq-cta-bg: {{ section.settings.color_cta_bg }};
    --rq-cta-text: {{ section.settings.color_cta_text }};
    --rq-muted: {{ section.settings.color_text | color_modify: 'alpha', 0.62 }};
    --rq-border: {{ section.settings.color_text | color_modify: 'alpha', 0.12 }};
    --rq-accent-soft: {{ section.settings.color_accent | color_modify: 'alpha', 0.1 }};
    --rq-accent-border: {{ section.settings.color_accent | color_modify: 'alpha', 0.4 }};
    --rq-pad-top: {{ section.settings.padding_top }}px;
    --rq-pad-bottom: {{ section.settings.padding_bottom }}px;
    background: var(--rq-bg);
    color: var(--rq-text);
    padding: var(--rq-pad-top) var(--space-4) var(--rq-pad-bottom);
    font-family: var(--font-body);
  }

  #lt-routine-quiz-{{ section.id }} *,
  #lt-routine-quiz-{{ section.id }} *::before,
  #lt-routine-quiz-{{ section.id }} *::after { box-sizing: border-box; }

  #lt-routine-quiz-{{ section.id }} .rq-frame {
    width: 100%;
    max-width: 100%;
    margin: 0 auto;
    background: var(--rq-card);
    border-radius: var(--radius-lg);
    padding: var(--space-6) var(--space-5);
    min-height: clamp(580px, 68vh, 780px);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  @media (min-width: 750px) {
    #lt-routine-quiz-{{ section.id }} .rq-frame {
      padding: var(--space-7) var(--space-6);
      gap: var(--space-6);
    }
  }
  @media (min-width: 990px) {
    #lt-routine-quiz-{{ section.id }} .rq-frame {
      max-width: min(860px, 64rem);
      padding: var(--space-7);
    }
  }

  /* Progress — schlanke Zeile: Zurück (links) + Frage X von Y (rechts) */
  #lt-routine-quiz-{{ section.id }} .rq-progress {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    min-height: 24px;
  }
  /* Reserviert Platz auf Route-Screen, damit Q1→Q2 nicht springt */
  #lt-routine-quiz-{{ section.id }} .rq-progress[hidden] {
    display: flex;
    visibility: hidden;
  }
  /* Auf Result-Screens komplett kollabieren — kein Progress-Kontext mehr nötig */
  #lt-routine-quiz-{{ section.id }} .rq-progress.rq-progress--gone {
    display: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-back {
    appearance: none;
    border: 0;
    background: transparent;
    color: var(--rq-muted);
    font: inherit;
    font-size: var(--text-body-sm);
    cursor: pointer;
    padding: var(--space-1) var(--space-2);
    border-radius: var(--radius-sm);
    min-height: 32px;
    transition: color 180ms ease, background 180ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-back:hover,
  #lt-routine-quiz-{{ section.id }} .rq-back:focus-visible {
    color: var(--rq-text);
    background: var(--rq-accent-soft);
    outline: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-back[hidden] { display: none; }

  /* Screens */
  #lt-routine-quiz-{{ section.id }} .rq-screen {
    display: none;
    flex-direction: column;
    gap: var(--space-6);
    flex: 1;
  }
  #lt-routine-quiz-{{ section.id }} .rq-screen.is-active {
    display: flex;
    animation: rqFade 260ms var(--ease-smooth, ease);
  }
  @keyframes rqFade {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    #lt-routine-quiz-{{ section.id }} .rq-screen.is-active { animation: none; }
  }
  /* Platz für sticky Header beim In-View-Scrollen der Frage */
  #lt-routine-quiz-{{ section.id }} .rq-screen h2 {
    scroll-margin-top: 96px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-screen h2 {
    font-family: var(--font-heading);
    font-size: clamp(20px, 4.4vw, 24px);
    line-height: 1.25;
    font-weight: var(--weight-semibold);
    margin: 0;
    letter-spacing: -0.01em;
    outline: none;
    text-wrap: balance;
  }
  #lt-routine-quiz-{{ section.id }} .rq-kicker {
    font-size: var(--text-micro);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rq-muted);
    font-weight: var(--weight-medium);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-helper,
  #lt-routine-quiz-{{ section.id }} .rq-subhead {
    margin: 0;
    color: var(--rq-muted);
    font-size: var(--text-body-sm);
    line-height: var(--leading-body);
  }
  #lt-routine-quiz-{{ section.id }} fieldset {
    border: 0;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  #lt-routine-quiz-{{ section.id }} legend {
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  /* Image cards (Q1 routing + Q2 supplement focus) */
  #lt-routine-quiz-{{ section.id }} .rq-cards {
    display: grid;
    gap: var(--space-4);
    list-style: none;
    margin: 0;
    padding: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cards--route {
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card {
    flex-direction: row;
    align-items: stretch;
    min-height: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card__media {
    aspect-ratio: auto;
    flex: 0 0 33%;
    max-width: 140px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card__body {
    flex: 1 1 auto;
    justify-content: center;
    padding: var(--space-3) var(--space-4);
  }
  @media (min-width: 750px) {
    #lt-routine-quiz-{{ section.id }} .rq-cards--route {
      grid-template-columns: repeat(3, 1fr);
    }
    #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card {
      flex-direction: column;
    }
    #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card__media {
      aspect-ratio: 1 / 1;
      flex: initial;
      max-width: none;
    }
    #lt-routine-quiz-{{ section.id }} .rq-cards--route .rq-card__body {
      justify-content: flex-start;
      padding: var(--space-4) var(--space-4) var(--space-5);
    }
  }
  #lt-routine-quiz-{{ section.id }} .rq-cards--focus {
    grid-template-columns: repeat(2, 1fr);
  }
  @media (min-width: 750px) {
    #lt-routine-quiz-{{ section.id }} .rq-cards--focus {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  #lt-routine-quiz-{{ section.id }} .rq-card {
    appearance: none;
    border: 1px solid var(--rq-border);
    background: var(--rq-bg);
    color: inherit;
    font: inherit;
    text-align: left;
    padding: 0;
    border-radius: var(--radius-md);
    overflow: hidden;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    transition: border-color 200ms ease, transform 200ms ease, box-shadow 200ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card:hover,
  #lt-routine-quiz-{{ section.id }} .rq-card:focus-visible {
    border-color: var(--rq-accent-border);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md, 0 6px 18px rgba(0,0,0,.08));
    outline: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card.is-selected {
    border-color: var(--rq-accent);
    box-shadow: 0 0 0 2px var(--rq-accent-soft);
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__media {
    aspect-ratio: 1 / 1;
    background: var(--rq-accent-soft);
    overflow: hidden;
    position: relative;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__media--icon {
    display: grid;
    place-items: center;
    color: var(--rq-accent);
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__media--icon svg {
    width: 40%;
    height: 40%;
    stroke-width: 1.25;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__body {
    padding: var(--space-4) var(--space-4) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__label {
    font-family: var(--font-heading);
    font-size: var(--text-body);
    font-weight: var(--weight-semibold);
    line-height: 1.3;
    color: var(--rq-text);
    letter-spacing: -0.01em;
  }
  #lt-routine-quiz-{{ section.id }} .rq-card__sub {
    font-size: 13px;
    line-height: 1.4;
    color: var(--rq-muted);
  }

  /* Radio-style options (Q3 / Q4 / Q5) */
  #lt-routine-quiz-{{ section.id }} .rq-options {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border: 1px solid var(--rq-border);
    border-radius: var(--radius-md);
    background: var(--rq-bg);
    cursor: pointer;
    min-height: 48px;
    transition: border-color 180ms ease, background 180ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-option:hover {
    border-color: var(--rq-accent-border);
    background: var(--rq-accent-soft);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option input {
    position: absolute;
    opacity: 0;
    pointer-events: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-marker {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    border-radius: var(--radius-full);
    border: 2px solid var(--rq-border);
    margin-top: 2px;
    transition: border-color 160ms ease, background 160ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-option--checkbox .rq-marker {
    border-radius: var(--radius-sm);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option input:checked ~ .rq-marker {
    border-color: var(--rq-accent);
    background: var(--rq-accent);
    box-shadow: inset 0 0 0 3px var(--rq-card);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option--checkbox input:checked ~ .rq-marker {
    box-shadow: inset 0 0 0 2px var(--rq-card);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option:has(input:checked) {
    border-color: var(--rq-accent);
    background: var(--rq-accent-soft);
  }
  #lt-routine-quiz-{{ section.id }} .rq-option-label {
    font-size: 15px;
    line-height: 1.4;
    color: var(--rq-text);
  }

  /* Sliders (Q2 diagnostic) */
  #lt-routine-quiz-{{ section.id }} .rq-slider-group {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }
  #lt-routine-quiz-{{ section.id }} .rq-slider {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  #lt-routine-quiz-{{ section.id }} .rq-slider-label {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: var(--space-3);
    font-size: var(--text-body-sm);
    color: var(--rq-muted);
  }
  #lt-routine-quiz-{{ section.id }} .rq-slider-value {
    font-family: var(--font-heading);
    font-size: var(--text-h3);
    color: var(--rq-text);
    font-weight: var(--weight-semibold);
  }
  #lt-routine-quiz-{{ section.id }} input[type='range'] {
    -webkit-appearance: none;
    appearance: none;
    width: 100%;
    height: 6px;
    background: var(--rq-border);
    border-radius: var(--radius-full);
    outline: none;
  }
  #lt-routine-quiz-{{ section.id }} input[type='range']::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    background: var(--rq-accent);
    cursor: pointer;
    border: 3px solid var(--rq-card);
    box-shadow: var(--shadow-sm, 0 1px 3px rgba(0,0,0,.1));
  }
  #lt-routine-quiz-{{ section.id }} input[type='range']::-moz-range-thumb {
    width: 28px;
    height: 28px;
    border-radius: var(--radius-full);
    background: var(--rq-accent);
    cursor: pointer;
    border: 3px solid var(--rq-card);
  }
  /* Delta visualization — Q2 visual centerpiece (shared axis + big delta) */
  #lt-routine-quiz-{{ section.id }} .rq-delta {
    background: var(--rq-accent-soft);
    border-radius: var(--radius-md);
    padding: var(--space-4) var(--space-5);
    margin-bottom: var(--space-4);
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-3);
    flex-wrap: wrap;
    margin-bottom: var(--space-4);
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-big {
    font-family: var(--font-heading);
    font-weight: var(--weight-semibold);
    font-size: clamp(26px, 4vw, 32px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--rq-accent);
    font-variant-numeric: tabular-nums;
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-msg {
    font-size: var(--text-body-sm);
    line-height: var(--leading-body);
    color: var(--rq-text);
    flex: 1;
    min-width: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-bar {
    position: relative;
    height: 4px;
    background: var(--rq-border);
    border-radius: 2px;
    margin: 0 7px var(--space-3);
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-gap {
    position: absolute;
    top: 0;
    height: 4px;
    background: var(--rq-accent);
    opacity: 0.35;
    border-radius: 2px;
    transition: left 0.25s ease, width 0.25s ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-dot {
    position: absolute;
    top: 50%;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    transform: translate(-50%, -50%);
    background: #fff;
    border: 2px solid;
    transition: left 0.25s ease;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.08);
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-dot--chron {
    border-color: var(--rq-text);
    z-index: 2;
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-dot--felt {
    border-color: var(--rq-accent);
    z-index: 3;
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-dot--felt::after {
    content: "";
    position: absolute;
    inset: 2px;
    background: var(--rq-accent);
    border-radius: 50%;
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-legend {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 10px;
    color: var(--rq-muted);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-weight: var(--weight-semibold);
    padding: 0 7px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-legend .sw {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    margin-right: 6px;
    vertical-align: middle;
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-legend .sw--chron {
    background: #fff;
    border: 2px solid var(--rq-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-legend .sw--felt {
    background: var(--rq-accent);
    border: 2px solid var(--rq-accent);
  }
  #lt-routine-quiz-{{ section.id }} .rq-delta-legend-range {
    font-variant-numeric: tabular-nums;
    letter-spacing: 0.02em;
    text-transform: none;
    font-weight: var(--weight-medium);
  }

  /* CTAs */
  #lt-routine-quiz-{{ section.id }} .rq-cta-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-5);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta {
    appearance: none;
    border: 0;
    font: inherit;
    font-family: var(--font-body);
    font-weight: var(--weight-semibold);
    font-size: 15px;
    letter-spacing: 0.01em;
    min-height: 48px;
    padding: 14px 28px;
    border-radius: var(--radius-full);
    cursor: pointer;
    text-decoration: none;
    text-align: center;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    transition: background 180ms ease, transform 180ms ease, box-shadow 180ms ease, border-color 180ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta--primary {
    background: var(--rq-cta-bg);
    color: var(--rq-cta-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta--primary:hover,
  #lt-routine-quiz-{{ section.id }} .rq-cta--primary:focus-visible {
    transform: translateY(-1px);
    box-shadow: var(--shadow-md, 0 6px 16px rgba(0,0,0,.12));
    outline: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta--secondary {
    background: transparent;
    color: var(--rq-text);
    border: 1px solid var(--rq-border);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta--secondary:hover,
  #lt-routine-quiz-{{ section.id }} .rq-cta--secondary:focus-visible {
    border-color: var(--rq-text);
    outline: none;
  }

  /* Diagnostic result */
  #lt-routine-quiz-{{ section.id }} .rq-anchor {
    font-family: var(--font-heading);
    font-size: clamp(22px, 5vw, 28px);
    line-height: 1.2;
    font-weight: var(--weight-semibold);
    margin: 0;
    color: var(--rq-text);
    letter-spacing: -0.015em;
    outline: none;
    text-wrap: balance;
  }
  #lt-routine-quiz-{{ section.id }} .rq-empathy {
    margin: 0;
    color: var(--rq-text);
    font-size: var(--text-body);
    line-height: 1.5;
  }
  /* Supplement result bundle */
  #lt-routine-quiz-{{ section.id }} .rq-bundle {
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 1fr;
  }
  @media (min-width: 750px) {
    #lt-routine-quiz-{{ section.id }} .rq-bundle {
      grid-template-columns: 1.2fr 1fr 1fr;
      align-items: stretch;
    }
  }
  #lt-routine-quiz-{{ section.id }} .rq-product {
    background: var(--rq-bg);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    border: 1px solid var(--rq-border);
  }
  #lt-routine-quiz-{{ section.id }} .rq-product--primary {
    border-color: var(--rq-accent);
    box-shadow: 0 0 0 2px var(--rq-accent-soft);
  }
  #lt-routine-quiz-{{ section.id }} .rq-product__media {
    aspect-ratio: 1 / 1;
    background: var(--rq-accent-soft);
    border-radius: var(--radius-sm);
    overflow: hidden;
  }
  #lt-routine-quiz-{{ section.id }} .rq-product__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  #lt-routine-quiz-{{ section.id }} .rq-product__tag {
    font-size: var(--text-micro);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rq-accent);
    font-weight: var(--weight-semibold);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-product__title {
    font-family: var(--font-heading);
    font-size: var(--text-body);
    font-weight: var(--weight-semibold);
    margin: 0;
    line-height: 1.3;
  }
  #lt-routine-quiz-{{ section.id }} .rq-product__price {
    font-size: var(--text-body-sm);
    color: var(--rq-muted);
    margin: 0;
  }

  #lt-routine-quiz-{{ section.id }} .rq-sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* ═══════ Result — 4-Zonen-Layout ═══════ */
  #lt-routine-quiz-{{ section.id }} .rq-result.is-active {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
    text-align: left;
  }
  #lt-routine-quiz-{{ section.id }} .rq-zone {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  #lt-routine-quiz-{{ section.id }} .rq-zone + .rq-zone {
    padding-top: var(--space-6);
    border-top: 1px solid var(--rq-border);
  }

  /* Zone 0a — Bio-Age Headline-Number */
  #lt-routine-quiz-{{ section.id }} .rq-zone--bio-age {
    align-items: center;
    text-align: center;
    gap: var(--space-2);
  }
  #lt-routine-quiz-{{ section.id }} .rq-bio-label {
    font-size: var(--text-body-sm);
    line-height: 1.4;
    color: var(--rq-muted);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-bio-number {
    font-family: var(--font-heading, inherit);
    font-size: clamp(56px, 14vw, 96px);
    line-height: 1;
    font-weight: var(--weight-semibold);
    color: var(--rq-text);
    letter-spacing: -0.02em;
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-bio-context {
    font-size: var(--text-body-sm);
    line-height: 1.45;
    color: var(--rq-muted);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-bio-headline {
    font-size: clamp(20px, 4.6vw, 26px);
    line-height: 1.25;
    font-weight: var(--weight-semibold);
    color: var(--rq-text);
    text-wrap: balance;
    margin: var(--space-3) 0 0;
    max-width: 30ch;
  }

  /* Zone 0b — Empathy + Pain-Pill */
  #lt-routine-quiz-{{ section.id }} .rq-empathy-pain {
    display: inline-flex;
    align-self: flex-start;
    padding: 6px 12px;
    border-radius: 999px;
    background: var(--rq-accent-soft);
    border: 1px solid var(--rq-accent-border);
    font-size: var(--text-body-sm);
    color: var(--rq-text);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-empathy-line {
    font-size: clamp(16px, 3.6vw, 18px);
    line-height: 1.55;
    color: var(--rq-text);
    margin: 0;
    text-wrap: pretty;
  }

  /* Zone 0c — Impulse-CTA */
  #lt-routine-quiz-{{ section.id }} .rq-cta--impulse {
    align-self: stretch;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 14px 20px;
    border-radius: var(--radius-md);
    background: var(--rq-cta-bg);
    color: var(--rq-cta-text);
    font-weight: var(--weight-semibold);
    font-size: 16px;
    text-decoration: none;
    transition: transform 120ms ease, box-shadow 120ms ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta--impulse:hover {
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.14);
  }
  #lt-routine-quiz-{{ section.id }} .rq-impulse-microtrust {
    font-size: var(--text-body-sm);
    line-height: 1.4;
    color: var(--rq-muted);
    margin: 0;
    text-align: center;
  }

  /* Zone 0d — Honesty Disclaimer */
  #lt-routine-quiz-{{ section.id }} .rq-disclaimer {
    font-size: 13px;
    line-height: 1.5;
    color: var(--rq-muted);
    margin: 0;
    padding: var(--space-3) var(--space-4);
    border-left: 2px solid var(--rq-accent-border);
    background: var(--rq-accent-soft);
    border-radius: 0 var(--radius-sm, 8px) var(--radius-sm, 8px) 0;
  }

  /* Zone 0e — 3 Hebel */
  #lt-routine-quiz-{{ section.id }} .rq-hebels-kicker {
    font-size: var(--text-body-sm);
    line-height: 1.4;
    color: var(--rq-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-hebels-headline {
    font-size: clamp(20px, 4.4vw, 24px);
    line-height: 1.25;
    font-weight: var(--weight-semibold);
    color: var(--rq-text);
    margin: 0;
    text-wrap: balance;
  }
  #lt-routine-quiz-{{ section.id }} .rq-hebels-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-3);
  }
  @media (min-width: 750px) {
    #lt-routine-quiz-{{ section.id }} .rq-hebels-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  #lt-routine-quiz-{{ section.id }} .rq-hebel-card {
    display: flex;
    flex-direction: column;
    gap: 10px;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--rq-bg);
    border: 1px solid var(--rq-border);
  }
  #lt-routine-quiz-{{ section.id }} .rq-hebel-icon {
    font-size: 24px;
    line-height: 1;
  }
  #lt-routine-quiz-{{ section.id }} .rq-hebel-title {
    font-size: 16px;
    font-weight: var(--weight-semibold);
    line-height: 1.3;
    margin: 0;
    color: var(--rq-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-hebel-body {
    font-size: 14px;
    line-height: 1.5;
    color: var(--rq-text);
    opacity: 0.85;
    margin: 0;
  }

  /* Zone 0f — Bridge */
  #lt-routine-quiz-{{ section.id }} .rq-zone--bridge {
    background: var(--rq-bg);
    padding: var(--space-5);
    border-radius: var(--radius-md);
    border: 1px solid var(--rq-border);
  }
  #lt-routine-quiz-{{ section.id }} .rq-bridge-headline {
    font-size: clamp(18px, 4vw, 22px);
    line-height: 1.3;
    font-weight: var(--weight-semibold);
    color: var(--rq-text);
    margin: 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-bridge-body {
    font-size: 15px;
    line-height: 1.55;
    color: var(--rq-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-bridge-body p { margin: 0 0 var(--space-2); }
  #lt-routine-quiz-{{ section.id }} .rq-bridge-body p:last-child { margin-bottom: 0; }

  /* Zone 0g — Limmroth */
  #lt-routine-quiz-{{ section.id }} .rq-zone--limmroth {
    flex-direction: row;
    align-items: flex-start;
    gap: var(--space-4);
  }
  #lt-routine-quiz-{{ section.id }} .rq-limmroth-photo {
    flex: 0 0 80px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-limmroth-img {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }
  #lt-routine-quiz-{{ section.id }} .rq-limmroth-quote {
    margin: 0;
    flex: 1 1 auto;
  }
  #lt-routine-quiz-{{ section.id }} .rq-limmroth-quote p {
    font-size: 15px;
    line-height: 1.55;
    color: var(--rq-text);
    margin: 0 0 var(--space-2);
    font-style: italic;
  }
  #lt-routine-quiz-{{ section.id }} .rq-limmroth-quote cite {
    display: flex;
    flex-direction: column;
    gap: 2px;
    font-style: normal;
  }
  #lt-routine-quiz-{{ section.id }} .rq-limmroth-name {
    font-size: 14px;
    font-weight: var(--weight-semibold);
    color: var(--rq-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-limmroth-title {
    font-size: 13px;
    color: var(--rq-muted);
  }
  @media (max-width: 539px) {
    #lt-routine-quiz-{{ section.id }} .rq-zone--limmroth {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    #lt-routine-quiz-{{ section.id }} .rq-limmroth-quote cite {
      align-items: center;
    }
  }

  /* Zone 1 — Anchor */
  #lt-routine-quiz-{{ section.id }} .rq-anchor {
    font-size: clamp(22px, 5vw, 28px);
    line-height: 1.22;
    font-weight: var(--weight-semibold);
    color: var(--rq-text);
    margin: 0;
    text-wrap: balance;
  }
  #lt-routine-quiz-{{ section.id }} .rq-empathy {
    margin: 0;
    padding: var(--space-4);
    border-radius: var(--radius-md);
    background: var(--rq-accent-soft);
    font-size: 16px;
    line-height: 1.55;
    color: var(--rq-text);
  }

  /* Zone 2 — Focus grid */
  /* Anchor transition line */
  #lt-routine-quiz-{{ section.id }} .rq-anchor-transition {
    font-size: var(--text-body-sm);
    line-height: 1.4;
    color: var(--rq-muted);
    margin: var(--space-3) 0 0;
  }

  /* Zone 2 — Fokus-Grid 2×2, kompakter */
  #lt-routine-quiz-{{ section.id }} .rq-focus-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  #lt-routine-quiz-{{ section.id }} .rq-focus-card {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    background: var(--rq-accent-soft);
    border: 1px solid var(--rq-accent-border);
    color: var(--rq-text);
  }
  #lt-routine-quiz-{{ section.id }} .rq-focus-icon {
    width: 22px;
    height: 22px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--rq-accent);
  }
  #lt-routine-quiz-{{ section.id }} .rq-focus-icon svg {
    width: 100%;
    height: 100%;
  }
  #lt-routine-quiz-{{ section.id }} .rq-focus-title {
    font-size: 14px;
    font-weight: var(--weight-semibold);
    margin: 0;
    line-height: 1.25;
  }
  #lt-routine-quiz-{{ section.id }} .rq-focus-why {
    font-size: 12px;
    line-height: 1.4;
    color: var(--rq-muted);
    margin: 0;
  }

  /* Zone 3 — Ausklappbare Pill-Liste "Was ist noch im Test enthalten?" */
  #lt-routine-quiz-{{ section.id }} .rq-cat-details {
    /* kein zusätzlicher Border-Top — die Zonen-Trennung via .rq-zone + .rq-zone reicht */
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-legend {
    display: flex;
    align-items: center;
    gap: 8px;
    margin: var(--space-3) 0 0;
    font-size: 12px;
    color: var(--rq-muted);
    line-height: 1.4;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-legend-swatch {
    flex: 0 0 auto;
    width: 14px;
    height: 14px;
    border-radius: var(--radius-full);
    background: var(--rq-accent-soft);
    border: 1px solid var(--rq-accent-border);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-summary {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-3);
    cursor: pointer;
    list-style: none;
    color: var(--rq-text);
    padding: var(--space-2) 0;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-summary::-webkit-details-marker {
    display: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-summary-label {
    font-size: 14px;
    font-weight: var(--weight-semibold);
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-summary-label::before {
    content: '+';
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border: 1px solid var(--rq-border);
    border-radius: var(--radius-full);
    font-size: 14px;
    line-height: 1;
    color: var(--rq-muted);
    transition: transform 0.2s ease;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-details[open] .rq-cat-summary-label::before {
    content: '−';
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-summary-hint {
    font-size: 12px;
    color: var(--rq-muted);
    letter-spacing: 0.02em;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-details[open] {
    padding-bottom: var(--space-2);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-group {
    margin-top: var(--space-4);
  }
  #lt-routine-quiz-{{ section.id }} .rq-cat-group-label {
    font-size: 11px;
    font-weight: var(--weight-semibold);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--rq-muted);
    margin: 0 0 var(--space-2);
  }
  #lt-routine-quiz-{{ section.id }} .rq-pill-grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-pill {
    display: inline-flex;
    align-items: center;
    padding: 4px 10px;
    border-radius: var(--radius-full);
    background: var(--rq-bg);
    border: 1px solid var(--rq-border);
    font-size: 12px;
    color: var(--rq-text);
    line-height: 1.4;
  }
  #lt-routine-quiz-{{ section.id }} .rq-pill.is-focus {
    background: var(--rq-accent-soft);
    border-color: var(--rq-accent-border);
    color: var(--rq-text);
  }

  /* Zone 4 — CTA: Preis-Block, Primary, Secondary, Trust */
  #lt-routine-quiz-{{ section.id }} .rq-price {
    text-align: center;
    margin: 0 0 var(--space-3);
  }
  #lt-routine-quiz-{{ section.id }} .rq-price-line {
    font-family: var(--font-heading);
    font-size: clamp(26px, 4.4vw, 32px);
    font-weight: var(--weight-semibold);
    letter-spacing: -0.01em;
    color: var(--rq-text);
    line-height: 1;
    margin: 0 0 6px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-price-sub {
    font-size: 12px;
    color: var(--rq-muted);
    letter-spacing: 0.02em;
    line-height: 1.4;
  }
  #lt-routine-quiz-{{ section.id }} .rq-zone--cta .rq-cta-row {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-top: var(--space-2);
  }
  #lt-routine-quiz-{{ section.id }} .rq-zone--cta .rq-cta-row .rq-cta {
    width: 100%;
    text-align: center;
    justify-content: center;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta-secondary {
    text-align: center;
    margin: var(--space-3) 0 0;
    font-size: 13px;
    line-height: 1.5;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta-secondary a {
    color: var(--rq-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-cta-secondary a:hover {
    text-decoration-thickness: 2px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-trust-row {
    list-style: none;
    margin: var(--space-5) 0 0;
    padding: var(--space-4) 0 0;
    border-top: 1px solid var(--rq-border);
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-2) var(--space-4);
    font-size: 11px;
    color: var(--rq-muted);
    letter-spacing: 0.02em;
  }
  #lt-routine-quiz-{{ section.id }} .rq-trust-row li {
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  #lt-routine-quiz-{{ section.id }} .rq-trust-row li::before {
    content: '✓';
    color: var(--rq-accent);
    font-weight: var(--weight-semibold);
  }

  /* Reset-Button — leiser Text-Link unter dem Result */
  #lt-routine-quiz-{{ section.id }} .rq-reset {
    display: block;
    margin: var(--space-5) auto 0;
    padding: var(--space-2) var(--space-3);
    background: transparent;
    border: 0;
    font: inherit;
    font-size: 12px;
    color: var(--rq-muted);
    text-decoration: underline;
    text-underline-offset: 3px;
    cursor: pointer;
    letter-spacing: 0.02em;
  }
  #lt-routine-quiz-{{ section.id }} .rq-reset:hover {
    color: var(--rq-text);
  }

  /* Embedded supplement quiz — visuelle Konsistenz mit Routine-Quiz */
  #lt-routine-quiz-{{ section.id }} [data-supp-embed] .lt-quiz__header {
    display: none;
  }
  #lt-routine-quiz-{{ section.id }} .rq-embed-back {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    margin-bottom: var(--space-4);
    padding: 6px 10px;
    background: transparent;
    border: 0;
    color: var(--rq-muted);
    font-size: 13px;
    cursor: pointer;
  }
  #lt-routine-quiz-{{ section.id }} .rq-embed-back:hover {
    color: var(--rq-text);
  }

  /* Question counter in progress row */
  #lt-routine-quiz-{{ section.id }} .rq-progress-counter {
    margin: 0;
    font-size: 12px;
    color: var(--rq-muted);
    letter-spacing: 0.04em;
    font-variant-numeric: tabular-nums;
  }
  #lt-routine-quiz-{{ section.id }} .rq-progress-counter[hidden] { display: none; }
{% endstyle %}

<section id="lt-routine-quiz-{{ section.id }}" class="lt-routine-quiz" data-section-id="{{ section.id }}" data-section-type="lt-routine-quiz">
  <div class="rq-frame">

    {%- comment -%} Progress bar (hidden on route + result, shown during questions) {%- endcomment -%}
    <div class="rq-progress" data-progress hidden>
      <button type="button" class="rq-back" data-back hidden aria-label="Eine Frage zurück">← zurück</button>
      <p class="rq-progress-counter" data-progress-counter></p>
    </div>

    {%- comment -%} Q1 — Routing (3 Bild-Karten) {%- endcomment -%}
    <div class="rq-screen is-active" data-screen="route">
      <h2 tabindex="-1">Was bringt dich hierher?</h2>
      <ul class="rq-cards rq-cards--route" role="list">
        {%- for block in section.blocks -%}
          {%- if block.type == 'route_card' -%}
            <li {{ block.shopify_attributes }}>
              <button
                type="button"
                class="rq-card"
                data-route-card
                data-target-path="{{ block.settings.target_path }}"
                data-target-archetype="{{ block.settings.target_archetype }}"
              >
                <div class="rq-card__media">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 640 | image_tag:
                        loading: 'lazy',
                        alt: block.settings.image_alt,
                        widths: '320,480,640',
                        sizes: '(min-width: 750px) 32vw, 92vw' }}
                  {%- endif -%}
                </div>
                <div class="rq-card__body">
                  <span class="rq-card__label">{{ block.settings.label }}</span>
                  {%- if block.settings.sub != blank -%}
                    <span class="rq-card__sub">{{ block.settings.sub }}</span>
                  {%- endif -%}
                </div>
              </button>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    </div>

    {%- comment -%} ═══════ DIAGNOSTIK-PFAD ═══════ {%- endcomment -%}

    {%- comment -%} Q2 — Alter-Slider mit Delta-Visualization {%- endcomment -%}
    <div class="rq-screen" data-screen="diag_age">
      <h2 tabindex="-1">Wie alt bist du — und wie alt fühlst du dich?</h2>

      {%- comment -%} Delta visualization — shared axis + big delta number + dynamic message {%- endcomment -%}
      <div class="rq-delta">
        <div class="rq-delta-header">
          <div class="rq-delta-big" data-delta-big>&#8710; 0</div>
          <div class="rq-delta-msg" id="rq-delta-msg-{{ section.id }}" aria-live="polite" data-delta-msg>Pass-Alter und Gefühl auf einer Linie.</div>
        </div>
        <div class="rq-delta-bar">
          <div class="rq-delta-gap" data-delta-gap style="left:36.36%;width:0%"></div>
          <div class="rq-delta-dot rq-delta-dot--chron" data-delta-dot-chron style="left:36.36%"></div>
          <div class="rq-delta-dot rq-delta-dot--felt"  data-delta-dot-felt  style="left:36.36%"></div>
        </div>
