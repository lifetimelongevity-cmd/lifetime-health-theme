      lang_sec1:       { title: {{ p_lang_sec1.title       | default: '' | json }}, url: {{ p_lang_sec1.url       | default: '' | json }}, price: {{ p_lang_sec1.price       | money | default: '' | json }}, image: {{ p_lang_sec1.featured_image       | image_url: width: 400 | default: '' | json }} },
