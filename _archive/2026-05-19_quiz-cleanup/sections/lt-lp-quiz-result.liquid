{%- liquid
  assign cta_block = section.blocks | where: 'type', 'cta_block' | first
-%}

{% style %}
  #lt-lp-quiz-result-{{ section.id }} {
    --lt-lp-quiz-bg: {{ section.settings.color_bg }};
    --lt-lp-quiz-surface: {{ section.settings.color_card_bg }};
    --lt-lp-quiz-text: {{ section.settings.color_text }};
    --lt-lp-quiz-border: {{ section.settings.color_text | color_modify: 'alpha', 0.12 }};
    --lt-lp-quiz-muted: {{ section.settings.color_text | color_modify: 'alpha', 0.64 }};
    --lt-lp-quiz-accent: {{ section.settings.color_accent }};
    --lt-lp-quiz-accent-soft: {{ section.settings.color_accent | color_modify: 'alpha', 0.08 }};
    --lt-lp-quiz-accent-shadow: {{ section.settings.color_accent | color_modify: 'alpha', 0.12 }};
    --lt-lp-quiz-padding-top: {{ section.settings.padding_top }}px;
    --lt-lp-quiz-padding-bottom: {{ section.settings.padding_bottom }}px;
    --lt-lp-quiz-radius: 24px;
    --lt-lp-quiz-card-radius: 16px;
    --lt-lp-quiz-card-gap: 12px;
  }
{% endstyle %}

<section
  id="lt-lp-quiz-result-{{ section.id }}"
  class="lt-lp-quiz-result-section"
  data-active-goal=""
>
  <div class="lt-lp-quiz-result page-width">
    <div class="lt-lp-quiz-result__intro">
      <div class="lt-lp-quiz-result__placeholder" data-quiz-placeholder>
        {%- if section.settings.placeholder_kicker != blank -%}
          <p class="lt-lp-quiz-result__kicker">{{ section.settings.placeholder_kicker | escape }}</p>
        {%- endif -%}
        {%- if section.settings.placeholder_headline != blank -%}
          <h2 class="lt-lp-quiz-result__headline">{{ section.settings.placeholder_headline | escape }}</h2>
        {%- endif -%}
        {%- if section.settings.placeholder_body != blank -%}
          <p class="lt-lp-quiz-result__body">{{ section.settings.placeholder_body | escape }}</p>
        {%- endif -%}
      </div>

      {%- for block in section.blocks -%}
        {%- if block.type == 'goal_state' -%}
          <article
            class="lt-lp-quiz-result__state"
            data-goal-id="{{ block.settings.goal_id | escape }}"
            data-micro-texts-json="{{ block.settings.micro_texts_json | escape }}"
            hidden
            {{ block.shopify_attributes }}
          >
            {%- if block.settings.result_kicker != blank -%}
              <p class="lt-lp-quiz-result__kicker">{{ block.settings.result_kicker | escape }}</p>
            {%- endif -%}
            {%- if block.settings.result_headline != blank -%}
              <h2 class="lt-lp-quiz-result__headline">{{ block.settings.result_headline | escape }}</h2>
            {%- endif -%}
            {%- if block.settings.result_subline != blank -%}
              <p class="lt-lp-quiz-result__body">{{ block.settings.result_subline | escape }}</p>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <div class="lt-lp-quiz-result__matrix lt-lp-quiz-result__matrix--epigenetic">
      <p class="lt-lp-quiz-result__group-label">Epigenetik · 6 Bereiche</p>
      <div class="lt-lp-quiz-result__grid lt-lp-quiz-result__grid--3col">
        {%- for block in section.blocks -%}
          {%- if block.type == 'category_item' and block.settings.category_type == 'epigenetic' -%}
            <article
              class="lt-lp-quiz-result__card"
              data-category-title="{{ block.settings.title | strip | escape }}"
              data-category-type="{{ block.settings.category_type | escape }}"
              {{ block.shopify_attributes }}
            >
              <h3 class="lt-lp-quiz-result__card-title">{{ block.settings.title | escape }}</h3>
              <p class="lt-lp-quiz-result__card-micro" data-goal-micro hidden></p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    <div class="lt-lp-quiz-result__matrix lt-lp-quiz-result__matrix--dna">
      <p class="lt-lp-quiz-result__group-label">DNA · 16 Kategorien</p>
      <div class="lt-lp-quiz-result__grid lt-lp-quiz-result__grid--4col">
        {%- for block in section.blocks -%}
          {%- if block.type == 'category_item' and block.settings.category_type == 'dna' -%}
            <article
              class="lt-lp-quiz-result__card"
              data-category-title="{{ block.settings.title | strip | escape }}"
              data-category-type="{{ block.settings.category_type | escape }}"
              {{ block.shopify_attributes }}
            >
              <h3 class="lt-lp-quiz-result__card-title">{{ block.settings.title | escape }}</h3>
              <p class="lt-lp-quiz-result__card-micro" data-goal-micro hidden></p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>

    {%- if cta_block != blank -%}
      <div class="lt-lp-quiz-result__cta" {{ cta_block.shopify_attributes }}>
        <a
          href="{{ cta_block.settings.cta_url | default: '/products/lifetime-age-dna' }}"
          class="button button--solid button--move lt-lp-quiz-result__button"
        >
          {{ cta_block.settings.cta_label | default: 'Jetzt für 349€ bestellen →' | escape }}
        </a>
        {%- if cta_block.settings.cta_subline != blank -%}
          <p class="lt-lp-quiz-result__cta-subline">{{ cta_block.settings.cta_subline | escape }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<script>
  (function() {
    const section = document.getElementById('lt-lp-quiz-result-{{ section.id }}');
    if (!section) return;

    const placeholder = section.querySelector('[data-quiz-placeholder]');
    const states = Array.prototype.slice.call(section.querySelectorAll('[data-goal-id]'));
    const cards = Array.prototype.slice.call(section.querySelectorAll('[data-category-title]'));

    function normalizeValue(value) {
      return String(value || '').trim().toLowerCase();
    }

    function setGoal(goalId, shouldScroll) {
      const normalizedGoalId = normalizeValue(goalId);
      let activeState = null;

      states.forEach(function(state) {
        const isActive = normalizeValue(state.dataset.goalId) === normalizedGoalId;
        state.hidden = !isActive;
        if (isActive) activeState = state;
      });

      if (placeholder) {
        placeholder.hidden = Boolean(activeState);
      }

      let microMap = {};
      if (activeState) {
        try {
          microMap = JSON.parse(activeState.dataset.microTextsJson || '{}');
        } catch (err) {
          microMap = {};
        }
      }

      cards.forEach(function(card) {
        const title = card.dataset.categoryTitle;
        const microText = microMap[title];
        const microEl = card.querySelector('[data-goal-micro]');

        if (microText) {
          card.classList.add('is-highlighted');
          card.classList.remove('is-dimmed');
          if (microEl) {
            microEl.textContent = microText;
            microEl.hidden = false;
          }
        } else if (activeState) {
          card.classList.remove('is-highlighted');
          card.classList.add('is-dimmed');
          if (microEl) {
            microEl.textContent = '';
            microEl.hidden = true;
          }
        } else {
          card.classList.remove('is-highlighted');
          card.classList.remove('is-dimmed');
          if (microEl) {
            microEl.textContent = '';
            microEl.hidden = true;
          }
        }
      });

      section.dataset.activeGoal = activeState ? normalizedGoalId : '';

      if (shouldScroll) {
        section.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    }

    window.addEventListener('quiz-goal-selected', function(event) {
      if (!event.detail || !event.detail.goalId) return;
      setGoal(event.detail.goalId, Boolean(event.detail.shouldScroll));
    });

    setGoal('', false);
  })();
</script>

{% stylesheet %}
.lt-lp-quiz-result-section {
  background: var(--lt-lp-quiz-bg);
  color: var(--lt-lp-quiz-text);
}

.lt-lp-quiz-result {
  padding-top: var(--lt-lp-quiz-padding-top);
  padding-bottom: var(--lt-lp-quiz-padding-bottom);
}

.lt-lp-quiz-result__intro,
.lt-lp-quiz-result__matrix,
.lt-lp-quiz-result__cta {
  border-radius: var(--lt-lp-quiz-radius);
  background: var(--lt-lp-quiz-surface);
  border: 1px solid var(--lt-lp-quiz-border);
}

.lt-lp-quiz-result__intro {
  padding: 28px 24px;
}

.lt-lp-quiz-result__matrix,
.lt-lp-quiz-result__cta {
  margin-top: 20px;
}

.lt-lp-quiz-result__matrix {
  padding: 24px;
}

.lt-lp-quiz-result__placeholder,
.lt-lp-quiz-result__state {
  display: grid;
  gap: 14px;
}

.lt-lp-quiz-result__placeholder[hidden],
.lt-lp-quiz-result__state[hidden] {
  display: none;
}

.lt-lp-quiz-result__kicker,
.lt-lp-quiz-result__group-label {
  margin: 0;
  font-size: 0.78rem;
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--lt-lp-quiz-muted);
}

.lt-lp-quiz-result__headline,
.lt-lp-quiz-result__card-title {
  margin: 0;
  color: var(--lt-lp-quiz-text);
}

.lt-lp-quiz-result__headline {
  font-size: clamp(1.75rem, 4vw, 2.5rem);
  line-height: 1.04;
  letter-spacing: -0.04em;
}

.lt-lp-quiz-result__body,
.lt-lp-quiz-result__cta-subline {
  margin: 0;
  font-size: 1rem;
  line-height: 1.6;
  color: var(--lt-lp-quiz-muted);
}

.lt-lp-quiz-result__grid--3col,
.lt-lp-quiz-result__grid--4col {
  display: grid;
  gap: var(--lt-lp-quiz-card-gap);
  margin-top: 14px;
}

.lt-lp-quiz-result__grid--3col {
  grid-template-columns: repeat(3, minmax(0, 1fr));
}

.lt-lp-quiz-result__grid--4col {
  grid-template-columns: repeat(4, minmax(0, 1fr));
}

.lt-lp-quiz-result__card {
  background: var(--lt-lp-quiz-surface);
  border: 1px solid var(--lt-lp-quiz-border);
  border-radius: var(--lt-lp-quiz-card-radius);
  padding: 16px;
  min-height: 120px;
  transition: opacity 0.2s ease, border-color 0.2s ease, transform 0.2s ease, background 0.2s ease, box-shadow 0.2s ease;
}

.lt-lp-quiz-result__card.is-highlighted {
  border-color: var(--lt-lp-quiz-accent);
  background: var(--lt-lp-quiz-accent-soft);
  transform: translateY(-1px);
  box-shadow: 0 10px 28px var(--lt-lp-quiz-accent-shadow);
}

.lt-lp-quiz-result__card.is-dimmed {
  opacity: 0.5;
}

.lt-lp-quiz-result__card-title {
  font-size: 1rem;
  line-height: 1.25;
}

.lt-lp-quiz-result__card-micro {
  margin: 8px 0 0;
  font-size: 0.88rem;
  line-height: 1.45;
  color: var(--lt-lp-quiz-text);
}

.lt-lp-quiz-result__card-micro[hidden] {
  display: none;
}

.lt-lp-quiz-result__cta {
  padding: 24px;
  display: grid;
  gap: 12px;
  justify-items: start;
}

.lt-lp-quiz-result__button.button {
  border-radius: 999px;
}

@media screen and (max-width: 749px) {
  .lt-lp-quiz-result__grid--3col,
  .lt-lp-quiz-result__grid--4col {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
}

@media screen and (min-width: 750px) and (max-width: 989px) {
  .lt-lp-quiz-result__grid--4col {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media screen and (min-width: 750px) {
  .lt-lp-quiz-result__intro,
  .lt-lp-quiz-result__matrix,
  .lt-lp-quiz-result__cta {
    padding-left: 32px;
    padding-right: 32px;
  }

  .lt-lp-quiz-result__intro {
    padding-top: 32px;
    padding-bottom: 32px;
  }

  .lt-lp-quiz-result__matrix {
    padding-top: 28px;
    padding-bottom: 28px;
  }

  .lt-lp-quiz-result__cta {
    padding-top: 28px;
    padding-bottom: 28px;
  }
}
{% endstylesheet %}

