{% comment %}
  lt-lp-personalized-answer
  Surface: warm editorial answer block
  Dominant element: hero-card metric + personalized headline
  CTA: none
  Quality moves:
    - dark hero-card creates visual magnet on light bg
    - secondary question builds commitment without pressure
    - compact rest avoids scope overwhelm; expandable for curious readers
{% endcomment %}

{% style %}
  #lt-lp-personalized-answer-{{ section.id }} {
    --lt-lp-pa-bg: {{ section.settings.color_bg }};
    --lt-lp-pa-surface: {{ section.settings.color_surface }};
    --lt-lp-pa-text: {{ section.settings.color_text }};
    --lt-lp-pa-muted: {{ section.settings.color_text | color_modify: 'alpha', 0.64 }};
    --lt-lp-pa-border: {{ section.settings.color_text | color_modify: 'alpha', 0.12 }};
    --lt-lp-pa-accent: {{ section.settings.color_accent }};
    --lt-lp-pa-accent-soft: {{ section.settings.color_accent | color_modify: 'alpha', 0.08 }};
    --lt-lp-pa-hero-card-bg: {{ section.settings.hero_card_bg }};
    --lt-lp-pa-hero-card-text: {{ section.settings.hero_card_text }};
    --lt-lp-pa-hero-card-muted: {{ section.settings.hero_card_text | color_modify: 'alpha', 0.56 }};
    --lt-lp-pa-padding-top: {{ section.settings.padding_top }}px;
    --lt-lp-pa-padding-bottom: {{ section.settings.padding_bottom }}px;
  }
{% endstyle %}

<section id="lt-lp-personalized-answer-{{ section.id }}" class="lt-lp-pa" data-active-goal="">
  <div class="lt-lp-pa__inner page-width">
    <div class="lt-lp-pa__placeholder" data-pa-placeholder>
      <p class="lt-lp-pa__eyebrow">{{ section.settings.placeholder_eyebrow | escape }}</p>
      <h2 class="lt-lp-pa__headline">{{ section.settings.placeholder_headline | escape }}</h2>
      <p class="lt-lp-pa__body">{{ section.settings.placeholder_body | escape }}</p>
    </div>

    {%- for block in section.blocks -%}
      {%- if block.type == 'goal_answer' -%}
        <article
          class="lt-lp-pa__state"
          data-goal-id="{{ block.settings.goal_id | escape }}"
          data-highlighted-categories="{{ block.settings.highlighted_categories | escape }}"
          data-micro-texts="{{ block.settings.micro_texts_json | escape }}"
          data-hero-category="{{ block.settings.hero_category | escape }}"
          data-secondary-options="{{ block.settings.secondary_options_json | escape }}"
          data-confirmation-texts="{{ block.settings.confirmation_texts_json | escape }}"
          hidden
          {{ block.shopify_attributes }}
        >
          <p class="lt-lp-pa__eyebrow">Dein Fokus</p>
          <h2 class="lt-lp-pa__headline">{{ block.settings.result_headline | escape }}</h2>
          {%- if block.settings.result_subheadline != blank -%}
            <p class="lt-lp-pa__subheadline">{{ block.settings.result_subheadline | escape }}</p>
          {%- endif -%}

          {%- if block.settings.hero_category != blank -%}
            <div class="lt-lp-pa__hero-card" data-pa-hero-card>
              {%- if section.settings.hero_card_label != blank -%}
                <p class="lt-lp-pa__hero-card-kicker">{{ section.settings.hero_card_label | escape }}</p>
              {%- endif -%}
              <p class="lt-lp-pa__hero-card-title">{{ block.settings.hero_category | escape }}</p>
              {%- if block.settings.hero_category_subtitle != blank -%}
                <p class="lt-lp-pa__hero-card-sub">{{ block.settings.hero_category_subtitle | escape }}</p>
              {%- endif -%}
              <p class="lt-lp-pa__hero-card-micro" data-pa-hero-micro></p>
            </div>
          {%- endif -%}

          <div class="lt-lp-pa__checklist" data-pa-checklist></div>

          {%- if block.settings.secondary_question != blank -%}
            <div class="lt-lp-pa__secondary" data-pa-secondary>
              <p class="lt-lp-pa__secondary-question">{{ block.settings.secondary_question | escape }}</p>
              <div
                class="lt-lp-pa__secondary-options"
                role="group"
                aria-label="{{ block.settings.secondary_question | escape }}"
                data-pa-secondary-options
              ></div>
              <p class="lt-lp-pa__secondary-confirmation" data-pa-confirmation></p>
            </div>
          {%- endif -%}

          <div class="lt-lp-pa__rest">
            {%- if section.settings.rest_compact_text != blank -%}
              <p class="lt-lp-pa__rest-compact">{{ section.settings.rest_compact_text | escape }}</p>
              {%- if section.settings.rest_expand_label != blank -%}
                <button
                  class="lt-lp-pa__rest-expand-btn"
                  data-pa-expand-btn
                  data-expand-label="{{ section.settings.rest_expand_label | escape }}"
                  data-collapse-label="{{ section.settings.rest_collapse_label | escape }}"
                  type="button"
                  aria-expanded="false"
                >{{ section.settings.rest_expand_label | escape }}</button>
              {%- endif -%}
            {%- else -%}
              <p class="lt-lp-pa__rest-label">{{ section.settings.rest_categories_label | escape }}</p>
            {%- endif -%}
            <div class="lt-lp-pa__rest-clusters" data-pa-rest hidden></div>
          </div>

          {%- if section.settings.transition_cta_text != blank -%}
            <p class="lt-lp-pa__transition">{{ section.settings.transition_cta_text | escape }}</p>
          {%- endif -%}
        </article>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div hidden data-all-categories="{{ section.settings.all_categories_list | escape }}"></div>
  <div hidden data-category-clusters="{{ section.settings.category_clusters_json | escape }}"></div>
</section>

<script>
  (function() {
    var sectionId = '{{ section.id }}';

    function initPersonalizedAnswerSection() {
      var section = document.getElementById('lt-lp-personalized-answer-' + sectionId);
      if (!section || section.dataset.initialized === 'true') return;

      var placeholder = section.querySelector('[data-pa-placeholder]');
      var states = Array.prototype.slice.call(section.querySelectorAll('[data-goal-id]'));
      var allCategoriesEl = section.querySelector('[data-all-categories]');
      var categoryClustersEl = section.querySelector('[data-category-clusters]');
      var allCategories = (allCategoriesEl && allCategoriesEl.dataset ? allCategoriesEl.dataset.allCategories : '')
        .split(',')
        .map(function(item) { return item.trim(); })
        .filter(Boolean);

      function normalize(value) {
        return String(value || '').trim().toLowerCase();
      }

      function escapeHtml(value) {
        var div = document.createElement('div');
        div.textContent = value;
        return div.innerHTML;
      }

      function parseClusterConfig() {
        var parsed = {};
        try {
          parsed = JSON.parse(categoryClustersEl && categoryClustersEl.dataset ? categoryClustersEl.dataset.categoryClusters : '{}');
        } catch (error) {
          parsed = {};
        }
        return parsed;
      }

      function buildRestClusters(highlighted) {
        var clusterConfig = parseClusterConfig();
        var highlightedLookup = highlighted.map(normalize);
        var clusterEntries = [];
        var seen = {};

        Object.keys(clusterConfig).forEach(function(label) {
          var items = clusterConfig[label];
          if (!Array.isArray(items)) return;

          var filteredItems = items.filter(function(item) {
            var normalizedItem = normalize(item);
            if (!normalizedItem || highlightedLookup.indexOf(normalizedItem) !== -1) return false;
            seen[normalizedItem] = true;
            return true;
          });

          if (filteredItems.length > 0) {
            clusterEntries.push({ label: label, items: filteredItems });
          }
        });

        var uncategorized = allCategories.filter(function(item) {
          var normalizedItem = normalize(item);
          return normalizedItem && highlightedLookup.indexOf(normalizedItem) === -1 && !seen[normalizedItem];
        });

        if (uncategorized.length > 0) {
          clusterEntries.push({ label: 'Weitere Bereiche', items: uncategorized });
        }

        return clusterEntries;
      }

      function renderSecondaryQuestion(activeState) {
        var secondaryEl = activeState.querySelector('[data-pa-secondary]');
        if (!secondaryEl) return;

        var optionsEl = secondaryEl.querySelector('[data-pa-secondary-options]');
        var confirmationEl = secondaryEl.querySelector('[data-pa-confirmation]');

        var options = [];
        var confirmationTexts = {};

        try { options = JSON.parse(activeState.dataset.secondaryOptions || '[]'); } catch(e) { options = []; }
        try { confirmationTexts = JSON.parse(activeState.dataset.confirmationTexts || '{}'); } catch(e) { confirmationTexts = {}; }

        if (confirmationEl) {
          confirmationEl.textContent = '';
          confirmationEl.classList.remove('is-visible');
        }

        if (!optionsEl || !options.length) return;

        optionsEl.innerHTML = options.map(function(option) {
          return '<button type="button" class="lt-lp-pa__secondary-option" data-option="' + escapeHtml(option) + '" aria-pressed="false">' +
            '<span class="lt-lp-pa__secondary-option-marker" aria-hidden="true"></span>' +
            '<span class="lt-lp-pa__secondary-option-label">' + escapeHtml(option) + '</span>' +
          '</button>';
        }).join('');

        Array.prototype.slice.call(optionsEl.querySelectorAll('[data-option]')).forEach(function(btn) {
          btn.addEventListener('click', function() {
            Array.prototype.slice.call(optionsEl.querySelectorAll('[data-option]')).forEach(function(b) {
              b.classList.remove('is-active');
              b.setAttribute('aria-pressed', 'false');
            });
            btn.classList.add('is-active');
            btn.setAttribute('aria-pressed', 'true');

            var confirmation = confirmationTexts[btn.dataset.option] || '';
            if (confirmationEl) {
              confirmationEl.textContent = confirmation;
              confirmationEl.classList.toggle('is-visible', Boolean(confirmation));
            }
          });
        });
      }

      function initRestExpand(activeState) {
        var expandBtn = activeState.querySelector('[data-pa-expand-btn]');
        var restEl = activeState.querySelector('[data-pa-rest]');
        if (!expandBtn || !restEl) return;

        /* clone removes stale listeners from previous goal activations */
        var freshBtn = expandBtn.cloneNode(true);
        expandBtn.parentNode.replaceChild(freshBtn, expandBtn);

        freshBtn.setAttribute('aria-expanded', 'false');
        restEl.hidden = true;

        freshBtn.addEventListener('click', function() {
          var isExpanded = freshBtn.getAttribute('aria-expanded') === 'true';
          freshBtn.setAttribute('aria-expanded', isExpanded ? 'false' : 'true');
          restEl.hidden = isExpanded;
          freshBtn.textContent = isExpanded
            ? (freshBtn.dataset.expandLabel || '')
            : (freshBtn.dataset.collapseLabel || '');
        });
      }

      function setGoal(goalId, shouldScroll) {
        var normalizedGoalId = normalize(goalId);
        var activeState = null;

        states.forEach(function(state) {
          var isActive = normalize(state.dataset.goalId) === normalizedGoalId;
          state.hidden = !isActive;
          if (isActive) activeState = state;
        });

        if (placeholder) {
          placeholder.hidden = Boolean(activeState);
        }

        if (activeState) {
          var highlighted = (activeState.dataset.highlightedCategories || '')
            .split(',')
            .map(function(item) { return item.trim(); })
            .filter(Boolean);

          var microTexts = {};
          try { microTexts = JSON.parse(activeState.dataset.microTexts || '{}'); } catch (error) { microTexts = {}; }

          var heroCategory = (activeState.dataset.heroCategory || '').trim();

          /* fill hero card micro-text from micro_texts_json */
          var heroMicroEl = activeState.querySelector('[data-pa-hero-micro]');
          if (heroMicroEl) {
            heroMicroEl.textContent = (heroCategory && microTexts[heroCategory]) ? microTexts[heroCategory] : '';
          }

          /* checklist: skip hero category — it's already shown in the card */
          var checklistEl = activeState.querySelector('[data-pa-checklist]');
          if (checklistEl) {
            var checklistCategories = highlighted.filter(function(cat) {
              return normalize(cat) !== normalize(heroCategory);
            });

            checklistEl.innerHTML = checklistCategories.map(function(title) {
              var micro = microTexts[title] || '';
              return '<div class="lt-lp-pa__check-row">' +
                '<span class="lt-lp-pa__check-icon" aria-hidden="true">' +
                  '<svg viewBox="0 0 24 24" fill="none">' +
                    '<path d="M5 12l5 5 9-11" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>' +
                  '</svg>' +
                '</span>' +
                '<span class="lt-lp-pa__check-title">' + escapeHtml(title) + '</span>' +
                '<span class="lt-lp-pa__check-micro">' + escapeHtml(micro) + '</span>' +
              '</div>';
            }).join('');
          }

          /* secondary question */
          renderSecondaryQuestion(activeState);

          /* rest clusters + expand/collapse init */
          var restEl = activeState.querySelector('[data-pa-rest]');
          if (restEl) {
            var clusters = buildRestClusters(highlighted);
            restEl.innerHTML = clusters.map(function(cluster) {
              return '<div class="lt-lp-pa__rest-cluster">' +
                '<p class="lt-lp-pa__rest-cluster-title">' + escapeHtml(cluster.label) + '</p>' +
                '<p class="lt-lp-pa__rest-cluster-list">' + escapeHtml(cluster.items.join(' · ')) + '</p>' +
              '</div>';
            }).join('');
          }

          initRestExpand(activeState);
        }

        section.dataset.activeGoal = activeState ? normalizedGoalId : '';

        if (activeState && shouldScroll) {
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      }

      window.addEventListener('quiz-goal-selected', function(event) {
        if (!event.detail || !event.detail.goalId) return;
        setGoal(event.detail.goalId, Boolean(event.detail.shouldScroll));
      });

      setGoal('', false);
      section.dataset.initialized = 'true';
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initPersonalizedAnswerSection, { once: true });
    } else {
      initPersonalizedAnswerSection();
    }

    document.addEventListener('shopify:section:load', function(event) {
      if (event.target && event.target.id === 'shopify-section-' + sectionId) {
        initPersonalizedAnswerSection();
      }
    });
  })();
</script>

{% stylesheet %}
.lt-lp-pa {
  background: var(--lt-lp-pa-bg);
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__inner {
  padding-top: var(--lt-lp-pa-padding-top);
  padding-bottom: var(--lt-lp-pa-padding-bottom);
}

.lt-lp-pa__placeholder,
.lt-lp-pa__state {
  max-width: 64rem;
  margin-inline: auto;
  padding: var(--space-7);
  background: var(--lt-lp-pa-surface);
  border: 1px solid var(--lt-lp-pa-border);
  border-radius: var(--radius-lg);
}

.lt-lp-pa__placeholder[hidden],
.lt-lp-pa__state[hidden] {
  display: none;
}

.lt-lp-pa__eyebrow {
  margin: 0;
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-tight);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--lt-lp-pa-muted);
}

.lt-lp-pa__headline {
  margin: var(--space-3) 0 0;
  font-family: var(--font-heading);
  font-size: clamp(var(--text-h2), 4vw, var(--text-display));
  font-weight: var(--weight-bold);
  line-height: var(--leading-heading);
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__body,
.lt-lp-pa__subheadline {
  margin: var(--space-3) 0 0;
  font-family: var(--font-body);
  font-size: var(--text-body-lg);
  line-height: var(--leading-relaxed);
  color: var(--lt-lp-pa-muted);
}

/* ─── Hero card ─────────────────────────────────── */
.lt-lp-pa__hero-card {
  margin-top: var(--space-6);
  padding: var(--space-6);
  background: var(--lt-lp-pa-hero-card-bg);
  border-radius: var(--radius-lg);
}

.lt-lp-pa__hero-card-kicker {
  margin: 0;
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-tight);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--lt-lp-pa-accent);
}

.lt-lp-pa__hero-card-title {
  margin: var(--space-2) 0 0;
  font-family: var(--font-heading);
  font-size: var(--text-h2);
  font-weight: var(--weight-bold);
  line-height: var(--leading-heading);
  color: var(--lt-lp-pa-hero-card-text);
}

.lt-lp-pa__hero-card-sub {
  margin: var(--space-1) 0 0;
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  font-weight: var(--weight-medium);
  line-height: var(--leading-body);
  color: var(--lt-lp-pa-hero-card-muted);
}

.lt-lp-pa__hero-card-micro {
  margin: var(--space-4) 0 0;
  font-family: var(--font-body);
  font-size: var(--text-body);
  line-height: var(--leading-relaxed);
  color: var(--lt-lp-pa-hero-card-muted);
}

.lt-lp-pa__hero-card-micro:empty {
  display: none;
}

/* ─── Checklist ─────────────────────────────────── */
.lt-lp-pa__checklist {
  display: grid;
  gap: var(--space-2);
  margin-top: var(--space-6);
  padding-block: var(--space-5);
  border-top: 1px solid var(--lt-lp-pa-border);
  border-bottom: 1px solid var(--lt-lp-pa-border);
}

.lt-lp-pa__check-row {
  display: grid;
  grid-template-columns: calc(var(--space-6) - var(--space-2)) minmax(11rem, 24%) 1fr;
  gap: var(--space-4);
  align-items: baseline;
  padding-block: var(--space-2);
  font-size: var(--text-body);
  line-height: var(--leading-relaxed);
}

.lt-lp-pa__check-icon {
  display: inline-flex;
  width: calc(var(--space-6) - var(--space-2));
  height: calc(var(--space-6) - var(--space-2));
  align-items: center;
  justify-content: center;
  color: var(--lt-lp-pa-accent);
}

.lt-lp-pa__check-icon svg {
  width: 100%;
  height: 100%;
}

.lt-lp-pa__check-title {
  font-family: var(--font-body);
  font-size: var(--text-body);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-body);
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__check-micro {
  font-family: var(--font-body);
  font-size: var(--text-body);
  line-height: var(--leading-relaxed);
  color: var(--lt-lp-pa-muted);
}

/* ─── Secondary question ────────────────────────── */
.lt-lp-pa__secondary {
  margin-top: var(--space-6);
  padding-top: var(--space-5);
  border-top: 1px solid var(--lt-lp-pa-border);
}

.lt-lp-pa__secondary-question {
  margin: 0;
  font-family: var(--font-body);
  font-size: var(--text-body);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-body);
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__secondary-options {
  display: grid;
  gap: var(--space-2);
  margin-top: var(--space-3);
}

.lt-lp-pa__secondary-option {
  display: flex;
  align-items: center;
  gap: var(--space-4);
  width: 100%;
  min-height: 48px;
  padding: var(--space-3) var(--space-4);
  background: transparent;
  border: 1px solid var(--lt-lp-pa-border);
  border-radius: var(--radius-md);
  cursor: pointer;
  text-align: left;
  transition: border-color var(--ease-default), background var(--ease-default);
}

.lt-lp-pa__secondary-option-marker {
  flex-shrink: 0;
  width: var(--space-5);
  height: var(--space-5);
  border: 1px solid var(--lt-lp-pa-border);
  border-radius: 50%;
  transition: border-color var(--ease-default), background var(--ease-default), box-shadow var(--ease-default);
}

.lt-lp-pa__secondary-option-label {
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  font-weight: var(--weight-medium);
  line-height: var(--leading-body);
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__secondary-option:hover,
.lt-lp-pa__secondary-option:focus-visible {
  border-color: var(--lt-lp-pa-accent);
  outline: none;
}

.lt-lp-pa__secondary-option:hover .lt-lp-pa__secondary-option-marker,
.lt-lp-pa__secondary-option:focus-visible .lt-lp-pa__secondary-option-marker {
  border-color: var(--lt-lp-pa-accent);
}

.lt-lp-pa__secondary-option.is-active {
  border-color: var(--lt-lp-pa-accent);
  background: var(--lt-lp-pa-accent-soft);
}

.lt-lp-pa__secondary-option.is-active .lt-lp-pa__secondary-option-marker {
  border-color: var(--lt-lp-pa-accent);
  background: var(--lt-lp-pa-accent);
  box-shadow: inset 0 0 0 var(--space-1) var(--lt-lp-pa-surface);
}

.lt-lp-pa__secondary-confirmation {
  display: none;
  margin-top: var(--space-4);
  padding: var(--space-4);
  border-left: 2px solid var(--lt-lp-pa-accent);
  border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  background: var(--lt-lp-pa-accent-soft);
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  line-height: var(--leading-relaxed);
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__secondary-confirmation.is-visible {
  display: block;
}

/* ─── Rest / scope ──────────────────────────────── */
.lt-lp-pa__rest {
  margin-top: var(--space-5);
}

.lt-lp-pa__rest-compact {
  margin: 0;
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  line-height: var(--leading-relaxed);
  color: var(--lt-lp-pa-muted);
}

.lt-lp-pa__rest-expand-btn {
  display: inline-flex;
  align-items: center;
  margin-top: var(--space-2);
  padding: 0;
  background: none;
  border: none;
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  font-weight: var(--weight-medium);
  line-height: var(--leading-body);
  color: var(--lt-lp-pa-accent);
  cursor: pointer;
  text-decoration: underline;
  text-underline-offset: 2px;
}

.lt-lp-pa__rest-expand-btn:hover,
.lt-lp-pa__rest-expand-btn:focus-visible {
  opacity: 0.8;
  outline: none;
}

.lt-lp-pa__rest-label {
  margin: 0 0 var(--space-3);
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-body);
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__rest-clusters {
  display: grid;
  gap: var(--space-4);
  margin-top: var(--space-4);
}

.lt-lp-pa__rest-clusters[hidden] {
  display: none;
}

.lt-lp-pa__rest-cluster {
  min-width: 0;
}

.lt-lp-pa__rest-cluster-title {
  margin: 0 0 var(--space-2);
  font-family: var(--font-body);
  font-size: var(--text-micro);
  font-weight: var(--weight-semibold);
  line-height: var(--leading-tight);
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--lt-lp-pa-text);
}

.lt-lp-pa__rest-cluster-list {
  margin: 0;
  font-family: var(--font-body);
  font-size: var(--text-body-sm);
  line-height: var(--leading-relaxed);
  color: var(--lt-lp-pa-muted);
}

.lt-lp-pa__transition {
  margin: var(--space-7) 0 0;
  text-align: center;
  font-family: var(--font-body);
  font-size: var(--text-body);
  line-height: var(--leading-body);
  color: var(--lt-lp-pa-muted);
}

@media screen and (min-width: 990px) {
  .lt-lp-pa__rest-clusters {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
}

@media screen and (max-width: 749px) {
  .lt-lp-pa__placeholder,
  .lt-lp-pa__state {
    padding: var(--space-5);
  }

  .lt-lp-pa__body,
  .lt-lp-pa__subheadline {
    font-size: var(--text-body);
  }

  .lt-lp-pa__hero-card {
    padding: var(--space-5);
  }

  .lt-lp-pa__secondary-option {
    padding-inline: var(--space-3);
  }

  .lt-lp-pa__check-row {
    grid-template-columns: calc(var(--space-5) - var(--space-1)) 1fr;
    grid-template-areas:
      "icon title"
      ". micro";
    gap: var(--space-1) var(--space-3);
  }

  .lt-lp-pa__check-icon {
    grid-area: icon;
    width: calc(var(--space-5) - var(--space-1));
    height: calc(var(--space-5) - var(--space-1));
    align-self: start;
    margin-top: 2px; /* intentional: optical alignment with the first text baseline */
  }

  .lt-lp-pa__check-title {
    grid-area: title;
  }

  .lt-lp-pa__check-micro {
    grid-area: micro;
    font-size: var(--text-body-sm);
  }

  .lt-lp-pa__rest-clusters {
    gap: var(--space-3);
  }
}
{% endstylesheet %}

