{%- comment -%}
  LIFETIME — Quiz v2 Matrix-Komponente

  16 DNA-Kategorien (4×4-Grid) + 2 Epigenetik-Anker (immer aktiv).
  Aktivierung erfolgt via JS basierend auf den Antworten:
    - is-strong: aus Bedürfnis mit hoher Priorität
    - is-medium: aus Bedürfnis mit mittlerer Priorität
    - (kein Modifier): inaktiv, dezent grau

  Tooltip via title-Attribut (hover/long-press auf Touch).

  Reihenfolge folgt docs/lifetime-quiz-spec.md.
{%- endcomment -%}

<div class="lt-quiz-matrix" data-quiz-matrix>
  <p class="lt-quiz-matrix__title">
    Deine relevanten DNA-Bereiche
    <span class="lt-quiz-matrix__sub">leuchten auf, während du antwortest</span>
  </p>

  <div class="lt-quiz-matrix__grid">
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="gesunde-alterung"
      title="Marker, die zeigen, wie schnell deine Zellen altern.">
      Gesunde Alterung
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="supplements"
      title="Welche Nahrungsergänzungen genetisch zu dir passen.">
      Supplements
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="vitamine"
      title="Wie dein Körper Vitamine aufnimmt und verwertet.">
      Vitamine
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="sensitivitaeten"
      title="Laktose, Histamin, Koffein und andere Verträglichkeiten.">
      Sensitivitäten
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="stoffwechsel"
      title="Wie dein Körper Kohlenhydrate, Fette und Zucker verarbeitet.">
      Stoffwechsel
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="fitness"
      title="Kraft- oder Ausdauertyp — was dir genetisch leichter fällt.">
      Fitness
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="verletzung-regeneration"
      title="Sehnenstabilität, Regenerationszeit, Verletzungsrisiko.">
      Verletzung &amp; Regeneration
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="mental-health"
      title="Genetische Faktoren rund um Stimmung und Konzentration.">
      Mental Health
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="psychologisch"
      title="Belohnungsverarbeitung, Risikoneigung, mentale Resilienz.">
      Psychologisch
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="schlaf"
      title="Chronotyp, Koffein-Abbau, Faktoren für Schlafqualität.">
      Schlaf
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="stress"
      title="Wie dein Körper Stress verarbeitet und reguliert.">
      Stress
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="herz"
      title="Cholesterin, Blutdruck-Sensitivität, Herzkreislauf-Risiken.">
      Herz
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="atemwege"
      title="Lungenkapazität und Allergie-Disposition.">
      Atemwege
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="augen"
      title="Genetische Faktoren rund um Sehkraft und Sehalterung.">
      Augen
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="haare"
      title="Haarausfall-Disposition und Haarstruktur.">
      Haare
    </button>
    <button type="button" class="lt-quiz-matrix__tile" data-matrix-cat="niere"
      title="Filterfunktion und Salz-Sensitivität.">
      Niere
    </button>
  </div>

  <div class="lt-quiz-matrix__epi">
    <span class="lt-quiz-matrix__epi-label">Epigenetik</span>
    <button type="button" class="lt-quiz-matrix__tile lt-quiz-matrix__tile--epi" data-matrix-cat="bioalter"
      title="Dein biologisches Alter im Vergleich zum kalendarischen.">
      Biologisches Alter
    </button>
    <button type="button" class="lt-quiz-matrix__tile lt-quiz-matrix__tile--epi" data-matrix-cat="entzuendung"
      title="Marker für stille Entzündungsaktivität im Körper.">
      Entzündung
    </button>
  </div>
</div>
